    <!-- API Request Form View -->
    <record id="view_api_request_form" model="ir.ui.view">
        <field name="name">api.request.form</field>
        <field name="model">api.request</field>
        <field name="arch" type="xml">
            <form string="API Request">
                <header>
                    <button name="send_request" string="Send Request" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <!-- <div class="oe_title">
                        <h1><field name="name" placeholder="Request Name"/></h1>
                    </div> -->
                    <group>
                        <group>
                            <field name="url" placeholder="https://api.example.com/endpoint"/>
                            <field name="method"/>
                            <field name="content_type"/>
                        </group>
                        <group>
                            <field name="auth_type"/>
                            <field name="auth_username" attrs="{'invisible': [('auth_type', '!=', 'basic')], 'required': [('auth_type', '=', 'basic')]}"/>
                            <field name="auth_password" attrs="{'invisible': [('auth_type', '!=', 'basic')], 'required': [('auth_type', '=', 'basic')]}"/>
                            <field name="auth_token" attrs="{'invisible': [('auth_type', '!=', 'bearer')], 'required': [('auth_type', '=', 'bearer')]}"/>
                            <field name="auth_key_name" attrs="{'invisible': [('auth_type', '!=', 'api_key')], 'required': [('auth_type', '=', 'api_key')]}"/>
                            <field name="auth_key_value" attrs="{'invisible': [('auth_type', '!=', 'api_key')], 'required': [('auth_type', '=', 'api_key')]}"/>
                            <field name="auth_key_in" attrs="{'invisible': [('auth_type', '!=', 'api_key')], 'required': [('auth_type', '=', 'api_key')]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Response">
                            <group>
                                <field name="response_code"/>
                                <field name="response_time" widget="float_time"/>
                            </group>
                            <group>
                                <field name="response_headers" widget="ace" options="{'mode': 'json', 'readonly': True}"/>
                            </group>
                            <group>
                                <field name="response_body" widget="" options="{'mode': 'json', 'readonly': True}"/>
                            </group>
                        </page>
                        <page string="Request">
                            <group>
                                <field name="headers" widget="" options="{'mode': 'json'}" placeholder="{&#10;  &quot;Content-Type&quot;: &quot;application/json&quot;,&#10;  &quot;Accept&quot;: &quot;application/json&quot;&#10;}"/>
                            </group>
                            <group>
                                <field name="params" widget="" options="{'mode': 'json'}" placeholder="{&#10;  &quot;param1&quot;: &quot;value1&quot;,&#10;  &quot;param2&quot;: &quot;value2&quot;&#10;}"/>
                            </group> 
                            <group>
                                <field name="body" widget="" options="{'mode': 'json'}" placeholder="{&#10;  &quot;key&quot;: &quot;value&quot;&#10;}"/>
                            </group>
                            <group attrs="{'invisible': [('content_type', '!=', 'multipart/form-data')]}">
                                <field name="attachment_ids" widget="many2many_binary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Request History Form View -->
    <record id="view_api_request_history_form" model="ir.ui.view">
        <field name="name">api.request.history.form</field>
        <field name="model">api.request.history</field>
        <field name="arch" type="xml">
            <form string="API Request History">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date"/>
                            <field name="url"/>
                            <field name="method"/>
                            <field name="content_type"/>
                        </group>
                        <group>
                            <field name="response_code"/>
                            <field name="response_time" widget="float_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Response">
                            <group>
                                <field name="response_headers" widget="ace" options="{'mode': 'json', 'readonly': True}"/>
                            </group>
                            <group>
                                <field name="response_body" widget="" options="{'mode': 'json', 'readonly': True}"/>
                            </group>
                        </page>
                        <page string="Request">
                            <group>
                                <field name="headers" widget="ace" options="{'mode': 'json', 'readonly': True}"/>
                            </group>
                            <group>
                                <field name="params" widget="ace" options="{'mode': 'json', 'readonly': True}"/>
                            </group>
                            <group>
                                <field name="body" widget="ace" options="{'mode': 'json', 'readonly': True}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Request History Tree View -->
    <record id="view_api_request_history_tree" model="ir.ui.view">
        <field name="name">api.request.history.tree</field>
        <field name="model">api.request.history</field>
        <field name="arch" type="xml">
            <tree string="API Request History">
                <field name="create_date"/>
                <!-- <field name="request_id"/> -->
                <field name="method"/>
                <field name="url"/>
                <field name="response_code"/>
                <field name="response_time"/>
            </tree>
        </field>
    </record>

    <!-- API Request Search View -->
    <record id="view_api_request_search" model="ir.ui.view">
        <field name="name">api.request.search</field>
        <field name="model">api.request</field>
        <field name="arch" type="xml">
            <search string="Search API Requests">
                <!-- <field name="name"/> -->
                <field name="url"/>
                <field name="method"/>
                <group expand="0" string="Group By">
                    <filter string="Method" name="group_by_method" context="{'group_by': 'method'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- API Request History Search View -->
    <record id="view_api_request_history_search" model="ir.ui.view">
        <field name="name">api.request.history.search</field>
        <field name="model">api.request.history</field>
        <field name="arch" type="xml">
            <search string="Search API Request History">
                <!-- <field name="request_id"/> -->
                <field name="url"/>
                <field name="method"/>
                <field name="response_code"/>
                <group expand="0" string="Group By">
                    <!-- <filter string="Request" name="group_by_request" context="{'group_by': 'request_id'}"/> -->
                    <filter string="Method" name="group_by_method" context="{'group_by': 'method'}"/>
                    <filter string="Response Code" name="group_by_response_code" context="{'group_by': 'response_code'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>