<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ETL Dashboard View -->
    <record id="view_etl_dashboard_tree" model="ir.ui.view">
        <field name="name">etl.dashboard.tree</field>
        <field name="model">etl.dashboard</field>
        <field name="arch" type="xml">
            <tree string="ETL Dashboard" create="false" delete="false">
                <field name="name"/>
                <field name="category_id"/>
                <field name="frequency_id"/>
                <field name="last_sync_time"/>
                <field name="last_sync_status"/>
                <field name="total_records_synced"/>
                <field name="new_records"/>
                <field name="updated_records"/>
                <field name="avg_sync_time" widget="float_time"/>
                <field name="success_rate" widget="progressbar"/>
            </tree>
        </field>
    </record>
    
    <record id="view_etl_dashboard_search" model="ir.ui.view">
        <field name="name">etl.dashboard.search</field>
        <field name="model">etl.dashboard</field>
        <field name="arch" type="xml">
            <search string="Search Dashboard">
                <field name="name"/>
                <field name="category_id"/>
                <field name="frequency_id"/>
                <separator/>
                <filter string="Successful" name="status_success" domain="[('last_sync_status', '=', 'success')]"/>
                <filter string="Failed" name="status_failed" domain="[('last_sync_status', '=', 'failed')]"/>
                <filter string="Running" name="status_running" domain="[('last_sync_status', '=', 'running')]"/>
                <separator/>
                <filter string="Low Success Rate" name="low_success" domain="[('success_rate', '&lt;', 70)]"/>
                <filter string="High Sync Time" name="high_sync_time" domain="[('avg_sync_time', '&gt;', 10)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Frequency" name="group_frequency" context="{'group_by': 'frequency_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'last_sync_status'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <record id="view_etl_dashboard_form" model="ir.ui.view">
        <field name="name">etl.dashboard.form</field>
        <field name="model">etl.dashboard</field>
        <field name="arch" type="xml">
            <form string="ETL Dashboard" create="false" delete="false">
                <header>
                    <button name="action_run_sync" string="Run Sync" type="object" class="oe_highlight"/>
                    <button name="action_view_logs" string="View Logs" type="object"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="frequency_id"/>
                            <field name="last_sync_time"/>
                            <field name="last_sync_status"/>
                        </group>
                        <group>
                            <field name="total_records_synced"/>
                            <field name="new_records"/>
                            <field name="updated_records"/>
                            <field name="error_count"/>
                        </group>
                    </group>
                    <group string="Performance Metrics">
                        <group>
                            <field name="avg_sync_time" widget="float_time"/>
                            <field name="success_rate" widget="progressbar"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_etl_dashboard_graph" model="ir.ui.view">
        <field name="name">etl.dashboard.graph</field>
        <field name="model">etl.dashboard</field>
        <field name="arch" type="xml">
            <graph string="ETL Performance" type="bar">
                <field name="name"/>
                <field name="avg_sync_time" type="measure"/>
                <field name="success_rate" type="measure"/>
            </graph>
        </field>
    </record>
    
    <record id="view_etl_dashboard_pivot" model="ir.ui.view">
        <field name="name">etl.dashboard.pivot</field>
        <field name="model">etl.dashboard</field>
        <field name="arch" type="xml">
            <pivot string="ETL Statistics">
                <field name="category_id" type="row"/>
                <field name="name" type="row"/>
                <field name="total_records_synced" type="measure"/>
                <field name="new_records" type="measure"/>
                <field name="updated_records" type="measure"/>
                <field name="avg_sync_time" type="measure"/>
                <field name="success_rate" type="measure"/>
            </pivot>
        </field>
    </record>
    
    <record id="action_etl_dashboard" model="ir.actions.act_window">
        <field name="name">ETL Dashboard</field>
        <field name="res_model">etl.dashboard</field>
        <field name="view_mode">kanban,tree,form,graph,pivot</field>
        <field name="context">{'search_default_group_category': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No ETL tables defined yet
            </p>
            <p>
                This dashboard shows the performance and status of your ETL processes.
            </p>
        </field>
    </record>
    
    <!-- ETL Monitoring Views -->
    <record id="view_etl_monitoring_tree" model="ir.ui.view">
        <field name="name">etl.monitoring.tree</field>
        <field name="model">etl.monitoring</field>
        <field name="arch" type="xml">
            <tree string="ETL Monitoring">
                <field name="date"/>
                <field name="total_tables"/>
                <field name="synced_tables"/>
                <field name="failed_tables"/>
                <field name="pending_tables"/>
                <field name="total_records"/>
                <field name="success_rate" widget="progressbar"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    
    <record id="view_etl_monitoring_form" model="ir.ui.view">
        <field name="name">etl.monitoring.form</field>
        <field name="model">etl.monitoring</field>
        <field name="arch" type="xml">
            <form string="ETL Monitoring">
                <header>
                    <button name="action_refresh" string="Refresh Data" type="object" class="oe_highlight"
                            attrs="{'invisible': [('state', '!=', 'done')]}"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="total_tables"/>
                            <field name="synced_tables"/>
                            <field name="failed_tables"/>
                            <field name="pending_tables"/>
                        </group>
                        <group>
                            <field name="total_records"/>
                            <field name="new_records"/>
                            <field name="updated_records"/>
                            <field name="total_time" widget="float_time"/>
                            <field name="avg_time" widget="float_time"/>
                            <field name="success_rate" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <field name="detail_ids">
                                <tree>
                                    <field name="table_id"/>
                                    <field name="category_id"/>
                                    <field name="frequency_id"/>
                                    <field name="last_sync_time"/>
                                    <field name="last_sync_status"/>
                                    <field name="total_records"/>
                                    <field name="new_records"/>
                                    <field name="updated_records"/>
                                    <field name="sync_time" widget="float_time"/>
                                    <button name="action_view_table" string="View" type="object" icon="fa-eye"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_etl_monitoring_graph" model="ir.ui.view">
        <field name="name">etl.monitoring.graph</field>
        <field name="model">etl.monitoring</field>
        <field name="arch" type="xml">
            <graph string="ETL Monitoring Trend" type="line">
                <field name="date"/>
                <field name="total_records" type="measure"/>
                <field name="success_rate" type="measure"/>
            </graph>
        </field>
    </record>
    
    <record id="view_etl_monitoring_search" model="ir.ui.view">
        <field name="name">etl.monitoring.search</field>
        <field name="model">etl.monitoring</field>
        <field name="arch" type="xml">
            <search string="Search Monitoring">
                <field name="date"/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('date', '>=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" domain="[('date', '>=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Month" name="group_month" context="{'group_by': 'date:month'}"/>
                    <filter string="Week" name="group_week" context="{'group_by': 'date:week'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <record id="action_etl_monitoring" model="ir.actions.act_window">
        <field name="name">ETL Monitoring</field>
        <field name="res_model">etl.monitoring</field>
        <field name="view_mode">tree,form,graph</field>
        <field name="context">{'search_default_this_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No monitoring reports available
            </p>
            <p>
                Daily monitoring reports track the performance and success of your ETL processes.
            </p>
        </field>
    </record>
    
    <!-- ETL Monitoring Detail View -->
    <record id="view_etl_monitoring_detail_form" model="ir.ui.view">
        <field name="name">etl.monitoring.detail.form</field>
        <field name="model">etl.monitoring.detail</field>
        <field name="arch" type="xml">
            <form string="ETL Detail">
                <sheet>
                    <group>
                        <group>
                            <field name="table_id"/>
                            <field name="category_id"/>
                            <field name="frequency_id"/>
                            <field name="last_sync_time"/>
                            <field name="last_sync_status"/>
                        </group>
                        <group>
                            <field name="total_records"/>
                            <field name="new_records"/>
                            <field name="updated_records"/>
                            <field name="sync_time" widget="float_time"/>
                        </group>
                    </group>
                    <group string="Error Information" attrs="{'invisible': [('error_message', '=', False)]}">
                        <field name="error_message" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
              
    <!-- Scheduled Actions -->
    <record id="ir_cron_etl_daily_monitoring" model="ir.cron">
        <field name="name">ETL: Generate Daily Monitoring Report</field>
        <field name="model_id" ref="model_etl_monitoring"/>
        <field name="state">code</field>
        <field name="code">model.generate_daily_report()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
        <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).replace(hour=1, minute=30).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>
</odoo>
