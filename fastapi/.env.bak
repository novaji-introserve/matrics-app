POSTGRES_HOST=pgbouncer
# pgbouncer port for database connection
POSTGRES_PORT=5433
# Database credentials from docker-compose.yml
POSTGRES_DB=icomply_dev
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo16@2022
ODOO_BASE_URL=http://odoo16:8069
# Odoo database configuration
ODOO_DB=icomply_dev
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
RQ_QUEUE_NAME=alerts
RQ_SCHEDULER_POLL_INTERVAL_SECONDS=1
RQ_SCHEDULER_CRON=*/5 * * * *
RQ_SCHEDULER_JOB_ID=database-alert-email
ALERT_JOBS_SYNC_INTERVAL_SECONDS=60
ALERT_JOBS_FILE=config/alert_jobs.json
ALERT_QUERY_SQL=SELECT id,name,email FROM res_partner WHERE active = true LIMIT 10
ALERT_EMAIL_SUBJECT=Database alert records found
ALERT_QUERY_ENABLED=true
# Email configuration for sending alerts
ALERT_EMAIL_TO=jonathan.o@novajii.com
ALERT_EMAIL_LOGO_URL=https://novajii.com/storage/app/media/matrics.png
MAIL_SERVER=ssl0.ovh.net
MAIL_PORT=465
MAIL_USERNAME=alerts@novajii.com
MAIL_PASSWORD=Amore12345
MAIL_FROM=alerts@novajii.com
MAIL_FROM_NAME=Alert Manager
MAIL_STARTTLS=false
MAIL_SSL_TLS=true
MAIL_VALIDATE_CERTS=true
# Path to the CSV file containing training data for transaction classification
TRAINING_DATA_PATH=/app/custom/training-data/transaction_training_data.csv

