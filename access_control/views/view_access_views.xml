<odoo>
  <data>
  <!-- Tree view for access rules -->
  <record id="view_access_rule_tree" model="ir.ui.view">
    <field name="name">view.access.rule.tree</field>
    <field name="model">view.access.rule</field>
    <field name="arch" type="xml">
      <tree string="View Access Rules">
        <field name="name"/>
        <field name="model_id"/>
        <field name="action_ids" widget="many2many_tags"/>
        <field name="server_action_ids" widget="many2many_tags"/>
        <field name="menu_ids" widget="many2many_tags"/>
        <field name="active"/>
      </tree>
    </field>
  </record>

  <!-- Form view for access rules -->
  <record id="view_access_rule_form" model="ir.ui.view">
    <field name="name">view.access.rule.form</field>
    <field name="model">view.access.rule</field>
    <field name="arch" type="xml">
      <form string="View Access Rule">
        <sheet>
          <group>
            <field name="name"/>
            <field name="active"/>
          </group>
          <group>
            <field name="model_id" options="{'no_create': True}" />
            <field name="model_name" invisible="1"/>
          </group>
          <notebook>
            <page string="Window Actions">
              <group name="window_actions" string="Window Actions">
                <field name="action_ids" domain="[('res_model', '=', model_name)]" attrs="{'invisible': [('model_name', '=', False)]}" widget="many2many_tags" options="{'no_create': True}"/>
                <div class="text-muted" attrs="{'invisible': [('model_name', '=', False)]}">Leave empty to restrict access to all window actions of this model</div>
              </group>
            </page>

            <page string="Client Actions (Dashboards)">
              <group name="client_actions" string="Client Actions">
                <field name="client_action_ids" widget="many2many_tags" options="{'no_create': True}"/>
                <field name="client_action_id_numbers" invisible="1"/>
                <div class="text-muted">Select client actions (dashboards) to restrict</div>
              </group>
            </page>

            <!-- NEW: Server Actions page -->
            <page string="Server Actions">
              <group name="server_actions" string="Server Actions">
                <field name="server_action_ids" domain="[('model_name', '=', model_name)]" attrs="{'invisible': [('model_name', '=', False)]}" widget="many2many_tags" options="{'no_create': True}"/>
                <div class="text-muted" attrs="{'invisible': [('model_name', '=', False)]}">Select server actions to restrict (like "Open Customers" action)</div>
              </group>
            </page>

            <page string="Menu Restrictions">
              <group name="menu_restrictions" string="Restricted Menus">
                <field name="menu_ids" widget="many2many_tags" options="{'no_create': True}"/>
                <field name="menu_id_numbers" invisible="1"/>
                <div class="text-muted">Select specific menu items to restrict. Users must belong to allowed groups to access these menus.</div>
              </group>
            </page>

            <page string="Allowed Groups">
              <group name="allowed_groups" string="Allowed Groups">
                <field name="group_ids" widget="many2many_tags"/>
                <div class="text-muted">
                  <strong>Important:</strong> Users belonging to these groups will have access to all restricted items above.
                    For server actions, these groups will also be automatically set on the server action's built-in security.
                </div>
              </group>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>


 
  </data>
</odoo>