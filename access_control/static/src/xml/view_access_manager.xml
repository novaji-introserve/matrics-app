<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="view_access_control.ViewAccessManager" owl="1">
        <div class="o_view_access_manager h-100 d-flex flex-column">
            <div class="o_view_controller">
                <div class="o_cp_top">
                    <div class="o_cp_top_left">
                        <h1 class="o_page_title">View Access Control Manager</h1>
                    </div>
                </div>
            </div>

            <div class="o_content p-3 flex-grow-1 overflow-auto">
                <!-- Alert messages -->
                <div t-if="state.message" t-attf-class="alert alert-{{state.messageType}} alert-dismissible fade show" role="alert">
                    <span t-esc="state.message"/>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" t-on-click="() => state.message = ''"></button>
                </div>

                <!-- Create rule form -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Create Access Rule</h5>
                    </div>
                    <div class="card-body">
                        <form t-ref="form" class="row g-3">
                            <div class="col-md-6">
                                <label for="ruleName" class="form-label">Rule Name</label>
                                <input type="text" class="form-control" id="ruleName" t-att-value="state.ruleName" t-on-input="onNameChange" placeholder="Enter a descriptive name"/>
                            </div>
                            <div class="col-md-6">
                                <label for="modelSelect" class="form-label">Model</label>
                                <select class="form-select" id="modelSelect" t-on-change="onModelChange">
                                    <option value="">Select a Model</option>
                                    <t t-foreach="state.models" t-as="model" t-key="model.id">
                                        <option t-att-value="model.id" t-att-selected="state.selectedModel === model.id">
                                            <t t-esc="model.name"/>
 (                                            <t t-esc="model.model"/>
)
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="actionSelect" class="form-label">Actions</label>
                                <select class="form-select" id="actionSelect" multiple="multiple" size="5" t-on-change="onActionChange" t-att-disabled="!state.selectedModel">
                                    <t t-if="state.filteredActions.length === 0">
                                        <option value="" disabled="disabled">No actions available or select a model first</option>
                                    </t>
                                    <t t-else="" t-foreach="state.filteredActions" t-as="action" t-key="action.id">
                                        <option t-att-value="action.id" t-att-selected="state.selectedActions.includes(action.id)">
                                            <t t-esc="action.name"/>
                                        </option>
                                    </t>
                                </select>
                                <small class="form-text text-muted">Leave empty to apply to all actions of the model. Hold Ctrl/Cmd to select multiple.</small>
                            </div>
                            <div class="col-md-6">
                                <label for="groupSelect" class="form-label">Allowed Groups</label>
                                <select class="form-select" id="groupSelect" multiple="multiple" size="5" t-on-change="onGroupChange">
                                    <t t-foreach="state.groups" t-as="group" t-key="group.id">
                                        <option t-att-value="group.id" t-att-selected="state.selectedGroups.includes(group.id)">
                                            <t t-esc="group.name"/>
 (                                            <t t-esc="group.category"/>
)
                                        </option>
                                    </t>
                                </select>
                                <small class="form-text text-muted">Hold Ctrl/Cmd to select multiple groups.</small>
                            </div>
                            <div class="col-12">
                                <button type="button" class="btn btn-primary" t-on-click="createRule" t-att-disabled="state.loading">
                                    <i t-if="state.loading" class="fa fa-spinner fa-spin me-2"/>
                                    Create Rule
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Existing rules table -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Existing Rules</h5>
                    </div>
                    <div class="card-body">
                        <t t-if="state.rules.length === 0">
                            <div class="alert alert-info">No rules defined yet. Create your first rule above.</div>
                        </t>
                        <t t-else="">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Model</th>
                                            <th>Actions</th>
                                            <th>Allowed Groups</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.rules" t-as="rule" t-key="rule.id">
                                            <tr>
                                                <td>
                                                    <t t-esc="rule.name"/>
                                                </td>
                                                <td>
                                                    <t t-esc="getModelName(rule.model_id[0])"/>
                                                </td>
                                                <td>
                                                    <t t-esc="getActionNames(rule.action_ids)"/>
                                                </td>
                                                <td>
                                                    <t t-esc="getGroupNames(rule.group_ids)"/>
                                                </td>
                                                <td>
                                                    <span t-if="rule.active" class="badge bg-success">Active</span>
                                                    <span t-else="" class="badge bg-danger">Inactive</span>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-danger" t-on-click="() => this.deleteRule(rule.id)">
                                                        <i class="fa fa-trash"/>
 Delete
                                                    </button>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Loading overlay -->
                <div t-if="state.loading" class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center bg-white bg-opacity-75" style="z-index: 1050;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>