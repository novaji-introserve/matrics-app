<odoo>
    <data>
        <record id="view_report_form" model="ir.ui.view">
            <field name="name">report.form</field>
            <field name="model">res.regulatory.report</field>
            <field name="arch" type="xml">
                <form string="Regulatory Report">
                    <header>
                        <button name="action_process_report"
                            class="oe_highlight"
                            type="object"
                            string="Run Report" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe-edit-only" />
                            <h1>
                                <field name="name" placeholder="Enter report name" />
                            </h1>
                        </div>
                        <group>
                            <field name="template_id" />
                        </group>
                        <group>
                            <group>
                                <field name="date_from" />
                            </group>
                            <group>
                                <field name="date_to" />
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="run_mode" />
                            </group>
                            <group>
                                <field name="run_frequency" />
                            </group>
                        </group>
                        <notebook>
                            <page name="Report Runs" string="Report Runs">
                                <field name="run_ids">
                                    <tree create="false" edit="false" delete="true"
                                        context="{'default_report_id': id}">
                                        <field name="name" />
                                        <!--  <field name="processed_file" widget="binary"
                                        filename="processed_filename"/> -->
                                        <field name="processed_filename" />
                                        <field name="write_uid" />
                                        <field name="write_date" />
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" />
                        <field name="activity_ids" />
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>
        <record id="report_report_tree" model="ir.ui.view">
            <field name="name">res.regulatory.report.tree</field>
            <field name="model">res.regulatory.report</field>
            <field name="arch" type="xml">
                <tree string="Regulatory Report">
                    <field name="name" />
                    <field name="template_id" />
                    <field name="date_from" />
                    <field name="date_to" />
                    <field name="write_uid" />
                    <field name="write_date" />
                </tree>
            </field>
        </record>
        <record id="view_report_run_form" model="ir.ui.view">
            <field name="name">report.run.form</field>
            <field name="model">res.regulatory.report.run</field>
            <field name="arch" type="xml">
                <form string="Regulatory Report Run" readonly="1">
                    <header>
                        <button name="action_submit_report"
                            class="oe_highlight"
                            type="object"
                            string="Submit Report" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe-edit-only" />
                            <h1>
                                <field name="name" placeholder="Enter Report Name" />
                            </h1>
                        </div>
                        <notebook>
                            <page name="Download" string="Download">
                                <field name="processed_filename" invisible="1" />
                                <field name="processed_file" filename="processed_filename" />
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="report_report_run_tree" model="ir.ui.view">
            <field name="name">res.regulatory.report.run.tree</field>
            <field name="model">res.regulatory.report.run</field>
            <field name="arch" type="xml">
                <tree string="Regulatory Report Runs">
                    <field name="name" />
                    <field name="processed_file" widget="binary" filename="processed_filename" />
                    <field name="processed_filename" invisible="1" />
                    <field name="write_uid" />
                    <field name="write_date" />
                </tree>
            </field>
        </record>
        <record id="view_regulatory_report_search" model="ir.ui.view">
            <field name="name">Report Search</field>
            <field name="model">res.regulatory.report</field>
            <field name="priority" eval="10" />
            <field name="arch" type="xml">
                <search string="Search Template Items">
                    <field name="name" />
                    <field name="template_id" />
                    <separator />
                    <group expand="0" name="group_by" string="Group By">
                        <filter name="group_name" string="Name" domain="[]"
                            context="{'group_by' : 'name'}" />
                        <filter name="group_template" string="Template"
                            context="{'group_by': 'template_id'}" />
                    </group>
                </search>
            </field>
        </record>

    </data>
</odoo>