<odoo>
    <data>
        <record id="view_report_form" model="ir.ui.view">
            <field name="name">res.regulatory.report.form</field>
            <field name="model">res.regulatory.report</field>
            <field name="arch" type="xml">
                <form string="Regulatory Report">
                    <header>
                        <field name="latest_download_ready" invisible="1"/>
                        <button name="action_validate_query" type="object" string="Validate Query"/>
                        <button name="action_preview_report" type="object" string="Preview" class="oe_highlight"/>
                        <button name="action_queue_download" type="object" string="Queue Download"/>
                        <button
                            name="action_download_latest"
                            type="object"
                            string="Download Latest"
                            attrs="{'invisible': [('latest_download_ready', '=', False)]}"
                        />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="Transaction Summary"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="preview_row_count" readonly="1"/>
                                <field name="preview_truncated" readonly="1"/>
                            </group>
                            <group>
                                <field name="last_preview_at" readonly="1"/>
                                <field name="latest_run_state" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="SQL Query">
                                <field
                                    name="query_text"
                                    widget="ace"
                                    options="{'mode': 'pgsql'}"
                                    nolabel="1"
                                    placeholder="SELECT * FROM ..."
                                />
                            </page>
                            <page string="Preview">
                                <field name="preview_html" widget="html" nolabel="1" readonly="1"/>
                            </page>
                            <page string="Downloads">
                                <field name="run_ids" context="{'default_report_id': id}">
                                    <tree create="false" edit="false" delete="false">
                                        <field name="download_ready" invisible="1"/>
                                        <field name="name"/>
                                        <field name="state"/>
                                        <field name="row_count"/>
                                        <field name="requested_by"/>
                                        <field name="create_date"/>
                                        <button
                                            name="action_download_file"
                                            type="object"
                                            string="Download"
                                            icon="fa-download"
                                            attrs="{'invisible': [('download_ready', '=', False)]}"
                                        />
                                    </tree>
                                    <form string="Report Download">
                                        <header>
                                            <field name="download_ready" invisible="1"/>
                                            <button
                                                name="action_download_file"
                                                type="object"
                                                string="Download"
                                                class="oe_highlight"
                                                attrs="{'invisible': [('download_ready', '=', False)]}"
                                            />
                                            <field name="state" widget="statusbar" statusbar_visible="queued,running,done,failed"/>
                                        </header>
                                        <sheet>
                                            <group>
                                                <field name="name" readonly="1"/>
                                                <field name="requested_by" readonly="1"/>
                                                <field name="row_count" readonly="1"/>
                                                <field name="file_name" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="query_text" readonly="1"/>
                                                <field name="error_message" readonly="1" attrs="{'invisible': [('error_message', '=', False)]}"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="report_report_tree" model="ir.ui.view">
            <field name="name">res.regulatory.report.tree</field>
            <field name="model">res.regulatory.report</field>
            <field name="arch" type="xml">
                <tree string="Regulatory Reports">
                    <field name="name"/>
                    <field name="preview_row_count"/>
                    <field name="last_preview_at"/>
                    <field name="latest_run_state"/>
                    <field name="write_uid"/>
                    <field name="write_date"/>
                </tree>
            </field>
        </record>

        <record id="view_regulatory_report_search" model="ir.ui.view">
            <field name="name">res.regulatory.report.search</field>
            <field name="model">res.regulatory.report</field>
            <field name="arch" type="xml">
                <search string="Search Regulatory Reports">
                    <field name="name"/>
                    <field name="query_text"/>
                    <group expand="0" string="Group By">
                        <filter name="group_name" string="Name" context="{'group_by': 'name'}"/>
                        <filter name="group_creator" string="Created By" context="{'group_by': 'create_uid'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_report_run_tree" model="ir.ui.view">
            <field name="name">res.regulatory.report.run.tree</field>
            <field name="model">res.regulatory.report.run</field>
            <field name="arch" type="xml">
                <tree string="Regulatory Report Downloads" create="false" edit="false" delete="false">
                    <field name="download_ready" invisible="1"/>
                    <field name="name"/>
                    <field name="report_id"/>
                    <field name="state"/>
                    <field name="row_count"/>
                    <field name="requested_by"/>
                    <field name="create_date"/>
                    <button
                        name="action_download_file"
                        type="object"
                        string="Download"
                        icon="fa-download"
                        attrs="{'invisible': [('download_ready', '=', False)]}"
                    />
                </tree>
            </field>
        </record>

        <record id="view_report_run_form" model="ir.ui.view">
            <field name="name">res.regulatory.report.run.form</field>
            <field name="model">res.regulatory.report.run</field>
            <field name="arch" type="xml">
                <form string="Regulatory Report Download" create="false" edit="false" delete="false">
                    <header>
                        <field name="download_ready" invisible="1"/>
                        <button
                            name="action_download_file"
                            type="object"
                            string="Download"
                            class="oe_highlight"
                            attrs="{'invisible': [('download_ready', '=', False)]}"
                        />
                        <field name="state" widget="statusbar" statusbar_visible="queued,running,done,failed"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="report_id" readonly="1"/>
                            <field name="requested_by" readonly="1"/>
                            <field name="row_count" readonly="1"/>
                            <field name="file_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="query_text" readonly="1"/>
                            <field name="error_message" readonly="1" attrs="{'invisible': [('error_message', '=', False)]}"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
