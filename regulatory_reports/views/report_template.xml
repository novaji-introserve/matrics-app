<odoo>
  <data>
    <record id="view_regulatory_report_template_tree" model="ir.ui.view">
      <field name="name">regulatory.report.template.tree</field>
      <field name="model">res.regulatory.report.template</field>
      <field name="arch" type="xml">
        <tree string="Report Templates">
          <field name="name" />
          <field name="code" />
          <field name="entity_id" />
          <field name="report_type" />
          <field name="write_uid" />
          <field name="write_date" />
        </tree>
      </field>
    </record>
    <record id="view_regulatory_report_template_form" model="ir.ui.view">
      <field name="name">regulatory.report.template.form</field>
      <field name="model">res.regulatory.report.template</field>
      <field name="arch" type="xml">
        <form string="Report Template">
          <sheet>
            <div class="oe_title">
              <label for="name" class="oe-edit-only" />
              <h1>
                <field name="name" placeholder="Enter report template name" />
              </h1>
            </div>
            <group>
              <group>
                <field name="code" />
                <field name="entity_id" />
                
              </group>
              <group>
                <field name="report_type" />
                <field name="template_file_name" invisible="1" />
                <field name="template_file" filename="template_file_name" />
              </group>
            </group>
            <notebook>
              <page name="Report Items" string="Report Items">
                <field name="item_ids" domain="[('template_id','=',id)]"/>
              </page>
              <page name="narration" string="Narration">
                <field name="description" widget="html" />
              </page>
            </notebook>
          </sheet>
          <div class="oe_chatter">
            <field name="message_follower_ids" />
            <field name="activity_ids" />
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>

  </data>
</odoo>