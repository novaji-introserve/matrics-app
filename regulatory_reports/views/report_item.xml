<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_report_item_form" model="ir.ui.view">
            <field name="name">report.item.form</field>
            <field name="model">res.regulatory.report.item</field>
            <field name="arch" type="xml">

                <form string="Report Item">
                    <header>
                        <button name="validate_select_statement" string="Validate SQL Query" class="btn btn-primary" type="object" />
                        <field name="status" widget="statusbar" options="{'clickable':'1'}" />
                    </header>
                    <sheet>

                        <div class="oe_title">
                            <label for="name" class="oe-edit-only" />
                            <h1>
                                <field name="name" placeholder="Enter item name" />
                            </h1>
                        </div>
                        <group>
                            <field name="code" />
                            <field name="source" />
                            <field name="source_value" />
                        </group>
                        <notebook>
                            <page name="Description" string="Description">
                                <field name="description" widget="html" />
                            </page>
                            <page name="Source SQL" string="Source SQL">
                                <field name="source_sql" widget="ace" />
                            </page>
                        </notebook>

                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" />
                        <field name="activity_ids" />
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>

        <record id="view_report_item_tree" model="ir.ui.view">
            <field name="name">report.item.tree</field>
            <field name="model">res.regulatory.report.item</field>
            <field name="arch" type="xml">
                <tree string="Report Items">
                    <field name="name" />
                    <field name="code" />
                    <field name="source" />
                    <field name="status" />
                    <field name="write_uid" />
                    <field name="write_date" />
                </tree>
            </field>
        </record>

        <record id="action_regulatory_report_item" model="ir.actions.act_window">
            <field name="name">Report Items</field>
            <field name="res_model">res.regulatory.report.item</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>