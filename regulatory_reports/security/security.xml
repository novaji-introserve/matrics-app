<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_regulatory_report" model="res.groups">
        <field name="name">Regulatory Reporting</field>
        <field name="implied_ids"
            eval="[Command.link(ref('base.group_user'))]" />
        <field name="comment">Manage regulatory report</field>
        <field name="category_id" ref="compliance_management.module_category_compliance"/>
    </record>

    <record model="ir.rule" id="regulatory_report_owner_rule">
        <field name="name">Regulatory Report Owner</field>
        <field name="model_id" ref="model_res_regulatory_report" />
        <field name="groups" eval="[(4, ref('group_regulatory_report'))]" />
        <field name="domain_force">[('create_uid','=', user.id)]</field>
    </record>

    <record model="ir.rule" id="regulatory_report_manager_rule">
        <field name="name">Regulatory Report Manager</field>
        <field name="model_id" ref="model_res_regulatory_report" />
        <field name="groups"
            eval="[(4, ref('compliance_management.group_compliance_compliance_officer'))]" />
        <field name="domain_force">[(1,'=', 1)]</field>
    </record>

    <record model="ir.rule" id="regulatory_report_cco_rule">
        <field name="name">Regulatory Report CCO</field>
        <field name="model_id" ref="model_res_regulatory_report" />
        <field name="groups"
            eval="[(4, ref('compliance_management.group_compliance_chief_compliance_officer'))]" />
        <field name="domain_force">[(1,'=', 1)]</field>
    </record>

</odoo>