<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ════════════════════════════════════════════════════════════════
             CBN MONTHLY PRUDENTIAL RETURN — Cell Mappings
             Template: CBN-XLS-001
             File:     CBN_Monthly_Prudential_Return_Template.xlsx
             ════════════════════════════════════════════════════════════════ -->

        <!-- ── Header section ────────────────────────────────────────────── -->
        <record id="titem_cbn_period" model="res.regulatory.report.template.item">
            <field name="name">C5</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_reporting_period"/>
            <field name="description">Reporting period label (e.g. April 2026)</field>
        </record>

        <record id="titem_cbn_code" model="res.regulatory.report.template.item">
            <field name="name">C6</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_cbn_code"/>
            <field name="description">CBN institution code</field>
        </record>

        <record id="titem_cbn_prepared_by" model="res.regulatory.report.template.item">
            <field name="name">C7</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_prepared_by"/>
            <field name="description">Officer who prepared the return</field>
        </record>

        <record id="titem_cbn_date_submitted" model="res.regulatory.report.template.item">
            <field name="name">C8</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_date_submitted"/>
            <field name="description">Auto-generated submission date</field>
        </record>

        <!-- ── Section A — Balance Sheet (current month column = D) ──────── -->
        <record id="titem_cbn_total_assets" model="res.regulatory.report.template.item">
            <field name="name">D13</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_total_assets"/>
            <field name="description">Total assets — current month (₦ Millions)</field>
        </record>

        <record id="titem_cbn_total_loans" model="res.regulatory.report.template.item">
            <field name="name">D14</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_total_loans"/>
