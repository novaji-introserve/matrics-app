        </record>

        <record id="titem_cbn_total_borrowings" model="res.regulatory.report.template.item">
            <field name="name">D16</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_total_borrowings"/>
