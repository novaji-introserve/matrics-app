        </record>

        <record id="titem_cbn_interest_expense" model="res.regulatory.report.template.item">
            <field name="name">D27</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_interest_expense"/>
            <field name="description">Interest expense — current month (₦ Millions)</field>
        </record>

        <record id="titem_cbn_pat" model="res.regulatory.report.template.item">
            <field name="name">D33</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_summary"/>
            <field name="item_id" ref="item_profit_after_tax"/>
            <field name="description">Profit after tax — current month (₦ Millions)</field>
        </record>

        <!-- ── LargeTransactions sheet — multi-row from A3 downward ──────── -->
        <record id="titem_cbn_large_txn" model="res.regulatory.report.template.item">
            <field name="name">A3</field>
            <field name="template_id" ref="template_cbn_excel"/>
            <field name="worksheet_id" ref="worksheet_large_transactions"/>
            <field name="item_id" ref="item_large_transactions"/>
            <field name="description">Large transactions table — rows inserted from A3 downward. 7 columns: S/N, Ref, Customer, Account, Amount, Date, Branch.</field>
        </record>

    </data>
</odoo>
