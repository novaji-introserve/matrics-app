        <!-- ============================================================
             4. CUSTOMER BEHAVIORAL PROFILES
             One profile per demo customer.
             The m2 field is the Welford variance accumulator:
                 m2 = stddev² × (n − 1)
             Odoo computes stddev_amount automatically from m2 and
             transaction_count via the stored @api.depends field.

             Retail     → mean ₦18,500    / stddev ₦8,200    / 45 txns
             Individual → mean ₦185,000   / stddev ₦62,000   / 120 txns
             Corporate  → mean ₦3,800,000 / stddev ₦1,200,000 / 200 txns
             ============================================================ -->

        <record id="demo_profile_retail" model="res.aml.customer.profile">
            <field name="customer_id" ref="demo_aml_partner_retail"/>
            <field name="transaction_count">45</field>
            <field name="mean_amount">18500.00</field>
            <!-- m2 = 8200² × (45−1) = 67,240,000 × 44 = 2,958,560,000 -->
            <field name="m2" eval="8200**2 * 44"/>
            <!-- stddev_amount computed: sqrt(2,958,560,000 / 44) = 8,200 -->
            <field name="last_updated">2025-01-09 08:00:00</field>
        </record>

        <record id="demo_profile_individual" model="res.aml.customer.profile">
            <field name="customer_id" ref="demo_aml_partner_individual"/>
            <field name="transaction_count">120</field>
            <field name="mean_amount">185000.00</field>
            <!-- m2 = 62000² × (120−1) = 3,844,000,000 × 119 = 457,436,000,000 -->
            <field name="m2" eval="62000**2 * 119"/>
            <!-- stddev_amount computed: sqrt(457,436,000,000 / 119) = 62,000 -->
            <field name="last_updated">2025-01-10 08:00:00</field>
        </record>

        <record id="demo_profile_corporate" model="res.aml.customer.profile">
            <field name="customer_id" ref="demo_aml_partner_corporate"/>
            <field name="transaction_count">200</field>
            <field name="mean_amount">3800000.00</field>
            <!-- m2 = 1,200,000² × (200−1) = 1,440,000,000,000 × 199 = 286,560,000,000,000 -->
            <field name="m2" eval="1200000**2 * 199"/>
            <!-- stddev_amount computed: sqrt(286,560,000,000,000 / 199) = 1,200,000 -->
            <field name="last_updated">2025-01-12 08:00:00</field>
        </record>


        <!-- ============================================================
