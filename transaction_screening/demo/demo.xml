            <field name="name">VAL/DEMO/00003</field>
            <field name="transaction_id" ref="demo_txn_corporate_3"/>
            <field name="customer_id" ref="demo_aml_partner_corporate"/>
            <field name="window_hours">24</field>
            <field name="txn_count">19</field>
            <field name="total_amount">18500000.00</field>
            <field name="risk_score">100.00</field>
            <field name="state">escalated</field>
            <field name="created_at">2025-01-14 14:01:00</field>
            <field name="notes">Three payments totalling ₦14.45M within a single business day, all individually below the ₦5M CTR threshold. Combined with velocity breach (19 transactions, ₦18.5M volume). Escalated to CCO for STR decision. Account under enhanced monitoring.</field>
        </record>


        <!-- ============================================================
             6. STRUCTURING / SMURFING ALERTS
             Three alerts showing the pattern detection.
             Structuring means multiple sub-CTR transactions whose
             combined total approaches the CTR reporting threshold.
             ============================================================ -->

        <!--
            OPEN: Retail customer — 3 transactions in 72 hours totalling
            ₦4,910,000 (98.2% of the ₦5M CTR threshold). All sub-threshold.
        -->
        <record id="demo_structuring_alert_1" model="res.aml.structuring.alert">
            <field name="name">SAL/DEMO/00001</field>
            <field name="transaction_id" ref="demo_txn_retail_3"/>
            <field name="customer_id" ref="demo_aml_partner_retail"/>
            <field name="window_hours">72</field>
            <field name="txn_count">3</field>
            <field name="total_amount">4910000.00</field>
            <field name="ctr_threshold">5000000.00</field>
            <!-- risk_score = (4.91/5.0)*70 + (3/3)*30 = 68.74 + 30 = 98.74 -->
            <field name="risk_score">98.74</field>
            <field name="state">open</field>
            <field name="created_at">2025-01-12 11:06:00</field>
        </record>

        <!--
            FALSE POSITIVE: Individual — 4 sub-threshold transactions
            totalling ₦4.21M. Investigated and found legitimate.
        -->
        <record id="demo_structuring_alert_2" model="res.aml.structuring.alert">
            <field name="name">SAL/DEMO/00002</field>
            <field name="transaction_id" ref="demo_txn_individual_3"/>
            <field name="customer_id" ref="demo_aml_partner_individual"/>
            <field name="window_hours">72</field>
            <field name="txn_count">4</field>
            <field name="total_amount">4210000.00</field>
            <field name="ctr_threshold">5000000.00</field>
            <!-- risk_score = (4.21/5.0)*70 + (4/3)*30 = 58.94 + 40 = 98.94, capped at 100 -->
            <field name="risk_score">98.94</field>
            <field name="state">false_positive</field>
            <field name="created_at">2025-01-13 16:47:00</field>
            <field name="notes">Confirmed false positive. Customer was splitting a property purchase deposit across two accounts as instructed by their conveyancing solicitor. Sale agreement and solicitor letter sighted. Beneficiary accounts verified as legitimate law firm escrow accounts. Closed.</field>
        </record>

        <!--
            ESCALATED: Corporate — 3 payments of ₦4.8M, ₦4.9M and ₦4.75M
            in 5 hours, all to different beneficiaries, all just below ₦5M.
            Total ₦14.45M. Classic smurfing pattern.
        -->
        <record id="demo_structuring_alert_3" model="res.aml.structuring.alert">
            <field name="name">SAL/DEMO/00003</field>
            <field name="transaction_id" ref="demo_txn_corporate_3"/>
            <field name="customer_id" ref="demo_aml_partner_corporate"/>
            <field name="window_hours">72</field>
            <field name="txn_count">3</field>
            <field name="total_amount">14450000.00</field>
            <field name="ctr_threshold">5000000.00</field>
            <!-- risk_score = min(100, (14.45/5.0)*70 + (3/3)*30) = min(100, 202.3 + 30) = 100 -->
            <field name="risk_score">100.00</field>
            <field name="state">escalated</field>
            <field name="created_at">2025-01-14 14:02:00</field>
            <field name="notes">Classic structuring/smurfing: three payments of ₦4.8M, ₦4.9M and ₦4.75M to three different beneficiaries within 5 hours, each deliberately kept just below the ₦5M CTR threshold. Total ₦14.45M. STR filed with NFIU reference NFIU/STR/2025/0042. Account temporarily restricted pending investigation outcome.</field>
        </record>


        <!-- ============================================================
             7. ANOMALY ALERTS
             Four alerts showing different Z-score scenarios.

             Z-score interpretation:
               ±3.0 — threshold (just barely flagged)
               ±5.0 — strongly unusual
               ±10+ — extreme (almost certainly not accidental)
               negative — unusually SMALL transaction

             Risk score formula: min(100, (|Z| / 3.0) × 50)
               at Z=3.0  → score = 50
               at Z=6.0  → score = 100 (capped)
             ============================================================ -->

        <!--
            OPEN — MILD ANOMALY (Z = +3.20)
            Individual customer. Transaction ₦383,400 vs mean ₦185,000.
            Z = (383400 − 185000) / 62000 = 198400 / 62000 ≈ 3.2
            Just above the 3.0 threshold. Worth reviewing but may be legitimate.
        -->
        <record id="demo_anomaly_alert_1" model="res.aml.anomaly.alert">
            <field name="name">AAL/DEMO/00001</field>
            <field name="transaction_id" ref="demo_txn_individual_1"/>
            <field name="customer_id" ref="demo_aml_partner_individual"/>
            <field name="transaction_amount">383400.00</field>
            <field name="customer_mean">185000.00</field>
            <field name="customer_stddev">62000.00</field>
            <field name="zscore">3.20</field>
            <!-- risk_score = min(100, (3.2/3.0)*50) = min(100, 53.33) = 53.33 -->
            <field name="risk_score">53.33</field>
            <field name="state">open</field>
            <field name="created_at">2025-01-08 10:01:00</field>
        </record>

        <!--
            REVIEWED — STRONG ANOMALY (Z = +43.79)
            Individual customer. Transaction ₦2,900,000 vs mean ₦185,000.
            Z = (2900000 − 185000) / 62000 = 2715000 / 62000 ≈ 43.79
            Risk score capped at 100. Under investigation.
        -->
        <record id="demo_anomaly_alert_2" model="res.aml.anomaly.alert">
            <field name="name">AAL/DEMO/00002</field>
            <field name="transaction_id" ref="demo_txn_individual_3"/>
            <field name="customer_id" ref="demo_aml_partner_individual"/>
            <field name="transaction_amount">2900000.00</field>
            <field name="customer_mean">185000.00</field>
            <field name="customer_stddev">62000.00</field>
            <field name="zscore">43.79</field>
            <!-- risk_score = min(100, (43.79/3.0)*50) = min(100, 729.8) = 100 -->
            <field name="risk_score">100.00</field>
            <field name="state">reviewed</field>
            <field name="created_at">2025-01-13 16:46:00</field>
            <field name="notes">Transaction is 44 standard deviations above this customer's historical mean of ₦185,000. Customer verbally claims it is property sale proceeds. Case officer has requested: (1) Sale agreement, (2) Land title transfer, (3) Solicitor confirmation, (4) Buyer identity verification. Awaiting documents.</field>
        </record>

        <!--
            ESCALATED — EXTREME ANOMALY (Z = +589.21)
            Retail Tier-1 customer. Transaction ₦4,850,000 vs mean ₦18,500.
            Z = (4850000 − 18500) / 8200 = 4831500 / 8200 ≈ 589
            A Tier-1 customer with a lifetime mean of ₦18,500 depositing ₦4.85M
            in cash is almost certainly not normal behaviour.
        -->
        <record id="demo_anomaly_alert_3" model="res.aml.anomaly.alert">
            <field name="name">AAL/DEMO/00003</field>
            <field name="transaction_id" ref="demo_txn_retail_3"/>
            <field name="customer_id" ref="demo_aml_partner_retail"/>
            <field name="transaction_amount">4850000.00</field>
            <field name="customer_mean">18500.00</field>
            <field name="customer_stddev">8200.00</field>
            <field name="zscore">589.21</field>
            <field name="risk_score">100.00</field>
            <field name="state">escalated</field>
            <field name="created_at">2025-01-12 11:06:00</field>
            <field name="notes">Transaction is 589 standard deviations above this Tier-1 customer's lifetime mean of ₦18,500. In 45 prior transactions this customer has never exceeded ₦95,000. A ₦4.85M cash deposit is inexplicable from historical behaviour alone. Account restricted. STR filed. Escalated to CCO and MLRO for immediate review. Combined with velocity and structuring flags on same transaction — high-confidence suspicious activity.</field>
        </record>

        <!--
            CLOSED — NEGATIVE ANOMALY (Z = −3.15)
            Corporate customer. Transaction ₦14,800 vs mean ₦3,800,000.
            Z = (14800 − 3800000) / 1200000 = −3785200 / 1200000 ≈ −3.15
            This direction flags unusually SMALL transactions (mule account
            testing, unusual withdrawals, or simply petty cash).
            Investigated and confirmed legitimate.
        -->
        <record id="demo_anomaly_alert_4" model="res.aml.anomaly.alert">
            <field name="name">AAL/DEMO/00004</field>
            <field name="transaction_id" ref="demo_txn_corporate_1"/>
            <field name="customer_id" ref="demo_aml_partner_corporate"/>
            <field name="transaction_amount">14800.00</field>
            <field name="customer_mean">3800000.00</field>
            <field name="customer_stddev">1200000.00</field>
            <!-- Z is negative: amount is far BELOW the mean -->
            <field name="zscore">-3.15</field>
            <!-- risk_score = min(100, (|-3.15|/3.0)*50) = min(100, 52.5) = 52.5 -->
            <field name="risk_score">52.50</field>
