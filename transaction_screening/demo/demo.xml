        <!-- ============================================================
             2. AML CONFIGURATION
             One active record (read by detection engine at runtime).
             One inactive archived record for comparison/reference.
             The active config is the one returned by get_active_config().
             ============================================================ -->

        <!--
            ACTIVE — NFIU Standard 2025
            CTR threshold : ₦5,000,000
            Velocity      : 10 transactions or ₦10M in 24 hours
            Structuring   : 3+ sub-threshold txns totalling ≥80% of CTR in 72h
            Anomaly       : Z-score ≥ 3.0, requires 10 transactions of history
            Weights       : Velocity 30%, Structuring 40%, Anomaly 30%
        -->
        <record id="demo_aml_config_nfiu" model="res.aml.config">
            <field name="name">NFIU Standard Configuration 2025</field>
            <field name="active">True</field>
            <field name="currency_id" ref="base.NGN"/>
            <field name="ctr_threshold">5000000.00</field>
            <field name="velocity_window_hours">24</field>
            <field name="velocity_max_count">10</field>
            <field name="velocity_max_amount">10000000.00</field>
            <field name="structuring_window_hours">72</field>
            <field name="structuring_min_count">3</field>
            <field name="structuring_approach_pct">80.0</field>
            <field name="anomaly_zscore_threshold">3.0</field>
            <field name="anomaly_min_history">10</field>
            <field name="velocity_risk_weight">0.30</field>
            <field name="structuring_risk_weight">0.40</field>
            <field name="anomaly_risk_weight">0.30</field>
        </record>

        <!--
            ARCHIVED — Stricter thresholds (inactive, for reference only)
            CTR threshold : ₦3,000,000
            Velocity      : 5 transactions or ₦6M in 12 hours
            Structuring   : 2+ sub-threshold txns totalling ≥70% of CTR in 48h
            Anomaly       : Z-score ≥ 2.5, requires only 5 transactions of history
        -->
        <record id="demo_aml_config_strict" model="res.aml.config">
            <field name="name">Strict Config — Archived (Demo)</field>
            <field name="active">False</field>
            <field name="currency_id" ref="base.NGN"/>
            <field name="ctr_threshold">3000000.00</field>
            <field name="velocity_window_hours">12</field>
            <field name="velocity_max_count">5</field>
            <field name="velocity_max_amount">6000000.00</field>
            <field name="structuring_window_hours">48</field>
            <field name="structuring_min_count">2</field>
            <field name="structuring_approach_pct">70.0</field>
            <field name="anomaly_zscore_threshold">2.5</field>
            <field name="anomaly_min_history">5</field>
            <field name="velocity_risk_weight">0.30</field>
            <field name="structuring_risk_weight">0.40</field>
            <field name="anomaly_risk_weight">0.30</field>
        </record>


