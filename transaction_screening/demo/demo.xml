        <!-- ============================================================
             AML CONFIGURATION — one record per currency.
             CTR threshold is no longer stored here; it is always read
             from nfiu.currency.threshold by currency + customer type.
             These records control velocity, structuring window/count,
             anomaly z-score, dormant detection, and composite weights.
             ============================================================ -->

        <record id="aml_config_ngn" model="res.aml.config">
            <field name="name">AML Config — NGN</field>
            <field name="currency_id" ref="base.NGN"/>
            <field name="active">True</field>
            <!-- Velocity -->
            <field name="velocity_window_hours">24</field>
            <field name="velocity_max_count">10</field>
            <field name="velocity_max_amount">10000000.00</field>
            <!-- Structuring -->
            <field name="structuring_window_hours">72</field>
            <field name="structuring_min_count">3</field>
            <field name="structuring_approach_pct">80.0</field>
            <!-- Anomaly -->
            <field name="anomaly_zscore_threshold">3.0</field>
            <field name="anomaly_min_history">10</field>
            <!-- Dormant -->
            <field name="dormant_enabled">True</field>
            <field name="dormant_min_days">180</field>
            <!-- Weights (must sum to 1.0) -->
            <field name="velocity_risk_weight">0.30</field>
            <field name="structuring_risk_weight">0.35</field>
            <field name="anomaly_risk_weight">0.25</field>
            <field name="dormant_risk_weight">0.10</field>
        </record>

        <record id="aml_config_usd" model="res.aml.config">
            <field name="name">AML Config — USD</field>
