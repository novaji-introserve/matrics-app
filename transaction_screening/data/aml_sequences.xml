<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_aml_velocity_alert" model="ir.sequence">
            <field name="name">AML Velocity Alert</field>
            <field name="code">res.aml.velocity.alert</field>
            <field name="prefix">VAL/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False" />
        </record>
        <record id="seq_aml_structuring_alert" model="ir.sequence">
            <field name="name">AML Structuring Alert</field>
            <field name="code">res.aml.structuring.alert</field>
            <field name="prefix">SAL/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False" />
        </record>
        <record id="seq_aml_anomaly_alert" model="ir.sequence">
            <field name="name">AML Anomaly Alert</field>
            <field name="code">res.aml.anomaly.alert</field>
            <field name="prefix">AAL/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False" />
        </record>
        <record id="seq_aml_dormant_alert" model="ir.sequence">
            <field name="name">AML Dormant Account Alert</field>
            <field name="code">res.aml.dormant.alert</field>
            <field name="prefix">DAL/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False" />
        </record>

        <!-- Weekly cron to rebuild customer behavioral profiles from full history -->
        <record id="cron_rebuild_aml_profiles" model="ir.cron">
            <field name="name">AML: Rebuild Customer Behavioral Profiles</field>
            <field name="model_id" ref="model_res_aml_customer_profile" />
            <field name="state">code</field>
            <field name="code">model._cron_rebuild_profiles()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
