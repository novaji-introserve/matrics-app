<odoo>
    <data>
        <!-- Transaction Screening Rule Tree View -->
        <record id="transaction_view" model="ir.ui.view">
            <field name="name">transaction_tree</field>
            <field name="model">res.customer.transaction</field>
            <field name="inherit_id"
                ref="compliance_management.compliance_transaction_tree" />
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='likely_fraud']" position="after">
                    <field name="blocked" />
                </xpath>
            </field>
        </record>
        <record id="transaction_form" model="ir.ui.view">
            <field name="name">transaction_form</field>
            <field name="model">res.customer.transaction</field>
            <field name="inherit_id"
                ref="compliance_management.compliance_transaction_form" />
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_unblock" string="Release Transaction"
                        type="object" class="btn-warning"
                        attrs="{'invisible': [('blocked', '=', False)]}"
                        groups="compliance_management.group_compliance_compliance_officer"
                        confirm="Are you sure you want to release this transaction? This action cannot be reversed" />
                </xpath>
                <xpath expr="//notebook" position="before">
                    <div class="oe_title">
                        <label for="blocked" class="oe_edit_only" string="Blocked/On-Hold" />
                        <h1>
                            <field name="blocked" widget="boolean_toggle" readonly="1" />
                        </h1>
                    </div>
                </xpath>
            </field>
        </record>
        <record id="view_customer_trans_search" model="ir.ui.view">
            <field name="name">Customer Transaction Search</field>
            <field name="model">res.customer.transaction</field>
            <field name="inherit_id"
                ref="compliance_management.view_customer_trans_search" />
            <field name="priority">10</field>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='state_new']" position="before">
                    <filter string="Blocked/On-Hold" name="transaction_blocked"
                        domain="[('blocked', '=', True)]" />
                </xpath>
            </field>
        </record>
        <record id="action_view_blocked_transactions" model="ir.actions.server">
            <field name="name">Transactions On-Hold / Blocked</field>
            <field name="model_id" ref="model_res_customer_transaction" />
            <field name="type">ir.actions.server</field>
            <field name="state">code</field>
            <field name="code">action = model.action_view_blocked_transactions()</field>
        </record>
    </data>
</odoo>