                    <field name="transaction_id" />
                    <field name="transaction_amount" />
                    <field name="customer_mean" />
                    <field name="zscore" />
                    <field name="risk_score" widget="progressbar" options="{'editable': false}" />
                    <field name="state" widget="badge"
                        decoration-success="state == 'closed'"
                        decoration-warning="state in ('reviewed','escalated')"
                        decoration-danger="state == 'open'"
                        decoration-muted="state == 'false_positive'" />
                    <field name="created_at" />
