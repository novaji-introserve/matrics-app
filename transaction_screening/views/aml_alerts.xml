<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── Velocity Alerts ────────────────────────────────────────────── -->
        <record id="view_aml_velocity_alert_tree" model="ir.ui.view">
            <field name="name">res.aml.velocity.alert.tree</field>
            <field name="model">res.aml.velocity.alert</field>
            <field name="arch" type="xml">
                <tree string="Velocity Alerts" decoration-danger="state == 'escalated'" decoration-muted="state in ('closed','false_positive')">
                    <field name="name" />
                    <field name="customer_id" />
                    <field name="transaction_id" />
                    <field name="txn_count" />
                    <field name="total_amount" />
                    <field name="window_hours" />
                    <field name="risk_score" widget="progressbar" options="{'editable': false}" />
                    <field name="state" widget="badge"
                        decoration-success="state == 'closed'"
                        decoration-warning="state in ('reviewed','escalated')"
                        decoration-danger="state == 'open'"
                        decoration-muted="state == 'false_positive'" />
                    <field name="created_at" />
                </tree>
            </field>
        </record>

        <record id="view_aml_velocity_alert_form" model="ir.ui.view">
            <field name="name">res.aml.velocity.alert.form</field>
            <field name="model">res.aml.velocity.alert</field>
            <field name="arch" type="xml">
                <form string="Velocity Alert">
                    <header>
                        <field name="state" widget="statusbar"
                            statusbar_visible="open,reviewed,escalated,closed" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" />
                            <h1><field name="name" readonly="1" /></h1>
                        </div>
                        <group>
                            <group>
                                <field name="customer_id" />
                                <field name="transaction_id" />
                                <field name="created_at" />
                            </group>
                            <group>
                                <field name="window_hours" />
                                <field name="txn_count" />
                                <field name="total_amount" />
                                <field name="risk_score" />
                            </group>
                        </group>
                        <group string="Review Notes">
                            <field name="notes" nolabel="1" />
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" />
                        <field name="activity_ids" widget="mail_activity" />
                        <field name="message_ids" widget="mail_thread" />
                    </div>
                </form>
            </field>
        </record>

        <record id="view_aml_velocity_alert_search" model="ir.ui.view">
            <field name="name">res.aml.velocity.alert.search</field>
            <field name="model">res.aml.velocity.alert</field>
            <field name="arch" type="xml">
                <search>
                    <field name="customer_id" />
                    <field name="name" />
                    <filter string="Open" name="open" domain="[('state','=','open')]" />
                    <filter string="Escalated" name="escalated" domain="[('state','=','escalated')]" />
                    <separator />
                    <group expand="0" string="Group By">
                        <filter string="Customer" name="by_customer" context="{'group_by': 'customer_id'}" />
                        <filter string="State" name="by_state" context="{'group_by': 'state'}" />
                    </group>
                </search>
            </field>
        </record>

        <record id="action_aml_velocity_alerts" model="ir.actions.act_window">
            <field name="name">Velocity Alerts</field>
            <field name="res_model">res.aml.velocity.alert</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_aml_velocity_alert_search" />
            <field name="context">{'search_default_open': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No velocity alerts</p>
                <p>Alerts are raised when a customer exceeds the configured transaction count or volume within the velocity window.</p>
            </field>
        </record>

