            </field>
        </record>

        <record id="view_aml_dormant_alert_search" model="ir.ui.view">
            <field name="name">res.aml.dormant.alert.search</field>
            <field name="model">res.aml.dormant.alert</field>
            <field name="arch" type="xml">
                <search>
                    <field name="customer_id" />
                    <field name="name" />
                    <filter string="Open" name="open" domain="[('state','=','open')]" />
                    <filter string="Escalated" name="escalated" domain="[('state','=','escalated')]" />
                    <separator />
                    <group expand="0" string="Group By">
