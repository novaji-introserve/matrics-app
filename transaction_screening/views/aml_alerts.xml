            </field>
        </record>

        <record id="view_aml_anomaly_alert_search" model="ir.ui.view">
            <field name="name">res.aml.anomaly.alert.search</field>
            <field name="model">res.aml.anomaly.alert</field>
            <field name="arch" type="xml">
                <search>
                    <field name="customer_id" />
                    <field name="name" />
                    <filter string="Open" name="open" domain="[('state','=','open')]" />
                    <filter string="Escalated" name="escalated" domain="[('state','=','escalated')]" />
                    <separator />
                    <group expand="0" string="Group By">
                        <filter string="Customer" name="by_customer" context="{'group_by': 'customer_id'}" />
                        <filter string="State" name="by_state" context="{'group_by': 'state'}" />
                    </group>
                </search>
            </field>
        </record>

        <record id="action_aml_anomaly_alerts" model="ir.actions.act_window">
            <field name="name">Anomaly Alerts</field>
            <field name="res_model">res.aml.anomaly.alert</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_aml_anomaly_alert_search" />
            <field name="context">{'search_default_open': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No anomaly alerts</p>
                <p>Alerts are raised when a transaction amount deviates significantly (by Z-score) from the customer's historical baseline.</p>
            </field>
        </record>

        <!-- ── Dormant Account Alerts ─────────────────────────────────────── -->
        <record id="view_aml_dormant_alert_tree" model="ir.ui.view">
            <field name="name">res.aml.dormant.alert.tree</field>
            <field name="model">res.aml.dormant.alert</field>
            <field name="arch" type="xml">
                <tree string="Dormant Account Alerts" decoration-danger="state == 'escalated'" decoration-muted="state in ('closed','false_positive')">
                    <field name="name" />
                    <field name="customer_id" />
                    <field name="transaction_id" />
                    <field name="last_transaction_date" />
                    <field name="dormant_days" />
                    <field name="transaction_amount" />
                    <field name="risk_score" widget="progressbar" options="{'editable': false}" />
                    <field name="state" widget="badge"
                        decoration-success="state == 'closed'"
                        decoration-warning="state in ('reviewed','escalated')"
                        decoration-danger="state == 'open'"
                        decoration-muted="state == 'false_positive'" />
                    <field name="created_at" />
                </tree>
            </field>
        </record>

