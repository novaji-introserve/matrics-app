        <record id="action_aml_dormant_alerts" model="ir.actions.act_window">
            <field name="name">Dormant Account Alerts</field>
            <field name="res_model">res.aml.dormant.alert</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_aml_dormant_alert_search" />
            <field name="context">{'search_default_open': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No dormant account alerts</p>
                <p>Alerts are raised when a transaction occurs on an account that has been inactive beyond the configured dormancy threshold.</p>
            </field>
        </record>

        <!-- ── Menu items under Transaction Monitoring ───────────────────── -->
        <menuitem
            id="menu_aml_velocity_alerts"
            name="AML Velocity Alerts"
            action="action_aml_velocity_alerts"
            parent="compliance_management.menu_compliance_transaction_monitoring"
            groups="compliance_management.group_compliance_compliance_officer,compliance_management.group_compliance_transaction_monitoring_team"
            sequence="40" />

        <menuitem
            id="menu_aml_structuring_alerts"
            name="AML Structuring Alerts"
            action="action_aml_structuring_alerts"
            parent="compliance_management.menu_compliance_transaction_monitoring"
            groups="compliance_management.group_compliance_compliance_officer,compliance_management.group_compliance_transaction_monitoring_team"
            sequence="41" />

        <menuitem
            id="menu_aml_anomaly_alerts"
            name="AML Anomaly Alerts"
            action="action_aml_anomaly_alerts"
            parent="compliance_management.menu_compliance_transaction_monitoring"
            groups="compliance_management.group_compliance_compliance_officer,compliance_management.group_compliance_transaction_monitoring_team"
            sequence="42" />

        <menuitem
            id="menu_aml_dormant_alerts"
            name="AML Dormant Account Alerts"
            action="action_aml_dormant_alerts"
            parent="compliance_management.menu_compliance_transaction_monitoring"
            groups="compliance_management.group_compliance_compliance_officer,compliance_management.group_compliance_transaction_monitoring_team"
            sequence="43" />

        <!-- ── Transaction form: add AML tab ─────────────────────────────── -->
        <record id="transaction_form_aml" model="ir.ui.view">
            <field name="name">transaction_form_aml</field>
            <field name="model">res.customer.transaction</field>
            <field name="inherit_id" ref="compliance_management.compliance_transaction_form" />
            <field name="priority">25</field>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="AML Detection" name="aml_detection">
                        <group>
                            <group>
                                <field name="aml_risk_score" />
                                <field name="aml_flags" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Dormant Account Alerts">
                                <field name="aml_dormant_alert_ids" readonly="1">
                                    <tree>
                                        <field name="name" />
                                        <field name="last_transaction_date" />
                                        <field name="dormant_days" />
                                        <field name="transaction_amount" />
                                        <field name="risk_score" />
                                        <field name="state" />
                                        <field name="created_at" />
                                    </tree>
                                </field>
                            </page>
                            <page string="Velocity Alerts">
                                <field name="aml_velocity_alert_ids" readonly="1">
                                    <tree>
                                        <field name="name" />
                                        <field name="txn_count" />
                                        <field name="total_amount" />
                                        <field name="risk_score" />
                                        <field name="state" />
                                        <field name="created_at" />
                                    </tree>
                                </field>
                            </page>
                            <page string="Structuring Alerts">
                                <field name="aml_structuring_alert_ids" readonly="1">
                                    <tree>
                                        <field name="name" />
                                        <field name="txn_count" />
                                        <field name="total_amount" />
                                        <field name="ctr_threshold" />
                                        <field name="risk_score" />
                                        <field name="state" />
                                        <field name="created_at" />
                                    </tree>
                                </field>
                            </page>
                            <page string="Anomaly Alerts">
                                <field name="aml_anomaly_alert_ids" readonly="1">
                                    <tree>
                                        <field name="name" />
                                        <field name="transaction_amount" />
                                        <field name="customer_mean" />
                                        <field name="zscore" />
                                        <field name="risk_score" />
                                        <field name="state" />
                                        <field name="created_at" />
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
