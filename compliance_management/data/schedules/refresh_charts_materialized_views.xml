<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- cron jobs to stagger execution and use lower isolation level -->
        <record id="ir_cron_refresh_dashboard_chart_views" model="ir.cron">
            <field name="name">Refresh Dashboard Materialized Views</field>
            <field name="model_id" ref="model_res_materialized_views"/>
            <field name="state">code</field>
            <field name="code">model.run_all_materialized_views_cron_tasks(low_priority=True)</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            <!-- Add a small delay to avoid exact hourly overlap with cache cleaning -->
            <field name="nextcall" eval="(datetime.now() + timedelta(minutes=10)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

        <record id="ir_cron_refresh_dashboard_chart_payload_cache" model="ir.cron">
            <field name="name">Refresh Dashboard Chart Payload Cache</field>
            <field name="model_id" ref="model_res_dashboard_charts"/>
            <field name="state">code</field>
            <field name="code">model.refresh_dashboard_chart_payloads()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            <field name="nextcall" eval="(datetime.now() + timedelta(minutes=15)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>


        <record id="ir_cron_refresh_digital_mat_view" model="ir.cron">
            <field name="name">Refresh Digital Products Materialized View</field>
            <field name="model_id" ref="model_customer_digital_product_mat"/>
            <field name="state">code</field>
            <field name="code">model.refresh_view()</field>
            <field name="interval_number">3</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            </record>

        <record id="ir_cron_refresh_acct_tier_mat_view" model="ir.cron">
            <field name="name">Refresh Account Tier Materialized View</field>
            <field name="model_id" ref="model_account_tier_materialized"/>
            <field name="state">code</field>
            <field name="code">model.refresh_view()</field>
            <field name="interval_number">4</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            </record>
    </data>

    
</odoo>
