<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="ir_cron_update_list_metadata" model="ir.cron">
            <field name="name">Update Screening List Metadata</field>
            <field name="model_id" ref="model_res_partner_screening"/>
            <field name="state">code</field>
            <field name="code">model._update_list_metadata()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>  

        <record id="ir_cron_daily_screening" model="ir.cron">
            <field name="name">Daily Customer Screening</field>
            <field name="model_id" ref="model_res_partner_screening"/>
            <field name="state">code</field>
            <field name="code">model._cron_daily_screening(limit=5000)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>


        
    
    </data>
    

    

</odoo>
