<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="ir_cron_dashboard_snapshot_refresh" model="ir.cron">
            <field name="name">Refresh Dashboard Snapshots (5min)</field>
            <field name="model_id" ref="model_dashboard_snapshot"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh_all()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
