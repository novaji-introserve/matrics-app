<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduler for Automatic PEP List Update -->
        <record id="ir_cron_fetch_pep_data" model="ir.cron">
            <field name="name">Fetch Global PEP List and Sanctions Data</field>
            <field name="model_id" ref="model_res_pep"/>
            <field name="state">code</field>
            <field name="code">model.fetch_global_pep_list()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 03:00:00')"/>
        </record>
    </data>
</odoo>