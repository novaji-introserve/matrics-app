<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled Action for CSV Data Fetching -->
        <record id="ir_cron_fetch_pep_csv_data" model="ir.cron">
            <field name="name">Fetch PEP CSV Data</field>
            <field name="model_id" ref="model_pep_scraping_cron" />
            <field name="state">code</field>
            <field name="code">model.cron_fetch_pep_csv_data()</field>
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False" />
            <field name="active" eval="True" />
        </record>

        <!-- Scheduled Action for API Data Fetching -->
        <record id="ir_cron_fetch_pep_api_data" model="ir.cron">
            <field name="name">Fetch PEP API Data</field>
            <field name="model_id" ref="model_pep_scraping_cron" />
            <field name="state">code</field>
            <field name="code">model.cron_fetch_pep_api_data()</field>
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False" />
            <field name="active" eval="True" />
        </record>

        <!-- Scheduled Action for Job Cleanup -->
        <record id="ir_cron_cleanup_opensanctions_jobs" model="ir.cron">
            <field name="name">Clean up Old OpenSanctions Jobs</field>
            <field name="model_id" ref="model_opensanctions_job_queue" />
            <field name="state">code</field>
            <field name="code">model.clean_old_jobs(days=7)</field>
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False" />
            <field name="active" eval="True" />
        </record>

