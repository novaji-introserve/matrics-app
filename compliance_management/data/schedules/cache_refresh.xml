<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled job to refresh dashboard cache every 5 minutes -->
        <record id="ir_cron_refresh_dashboard_cache" model="ir.cron">
            <field name="name">Refresh Dashboard Cache</field>
            <field name="model_id" ref="model_compliance_dashboard_cache"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh_dashboard_cache()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
    </data>
</odoo>
