<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="ir_cron_run_risk_assessment" model="ir.cron">
            <field name="name">Run Risk Assessment</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.cron_run_risk_assessment()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="priority">5</field>
            <field name="active" eval="False"/>
        </record>

        <record id="ir_cron_generate_mv" model="ir.cron">
            <field name="name">Generated MV For Risk Analysis</field>
            <field name="model_id" ref="model_risk_analysis"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_views()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="priority">5</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_refresh_mv" model="ir.cron">
            <field name="name">Refresh MV For Risk Analysis</field>
            <field name="model_id" ref="model_risk_analysis"/>
            <field name="state">code</field>
            <field name="code">model.action_refresh_view()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="priority">5</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>