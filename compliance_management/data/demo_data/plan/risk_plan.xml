    <record id="risk_plan_watchlist" model="res.compliance.risk.assessment.plan">
        <field name="name">Customers on Watchlist</field>
        <field name="risk_score">7</field>
        <field name="code">cust_watchlist</field>
        <field name="sql_query">select risk_score from res_partner where id=%s and is_watchlist=true</field>
        <field name="priority">6</field>
        <field name="state">active</field>
        <field name="compute_score_from">static</field>
        <field name="narration">Customers on Watchlist are significantly high risk</field>
    </record>
    <record id="risk_plan_default" model="res.compliance.risk.assessment.plan">
        <field name="name">Default Risk Score</field>
        <field name="risk_score">3</field>
        <field name="code">default_plan</field>
        <field name="sql_query">select risk_rating from res_risk_assessment where is_default=true limit 1</field>
        <field name="priority">1</field>
        <field name="state">active</field>
        <field name="compute_score_from">static</field>
        <field name="narration">Default Plan for risk rating</field>
