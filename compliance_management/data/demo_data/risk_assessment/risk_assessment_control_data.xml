<record id="risk_control_fcra_permissible_purpose" model="risk.assessment.control">
    <field name="name">Permissible Purpose Verification</field>
    <field name="code">FCRA-CTRL-001</field>
    <field name="description">Verification process to ensure consumer reports are obtained only for permissible purposes under FCRA Section 604.</field>
    <field name="control_type">preventive</field>
    <field name="control_nature">semi_automated</field>
    <field name="is_fcra_relevant">True</field>
    <field name="priority">3</field>
    <field name="effectiveness_score">4</field>
    <field name="state">active</field>
</record>

