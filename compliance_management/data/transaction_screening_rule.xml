<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data noupdate="1">

        <!-- Rule 1: SQL — USD transactions above $1000 -->
        <record id="transaction_screening_rule_sample" model="res.transaction.screening.rule">
            <field name="name">USD Transactions Above $1000</field>
            <field name="code">usd_tran_above_1000</field>
            <field name="narration">High value dollar transactions are candidates for FIU reporting</field>
            <field name="risk_level">high</field>
            <field name="condition_select">sql</field>
            <field name="state">active</field>
            <field name="priority">1</field>
            <field name="transaction_flag">suspicious</field>
            <field name="sql_query"><![CDATA[
                SELECT name
                FROM res_customer_transaction t
                WHERE t.amount > 1000
                AND t.transaction_type IN ('C', 'D')
                AND t.currency = 'USD'
                AND t.id = #TRANSACTION_ID#
            ]]></field>
        </record>

        <!-- Rule 2: SQL — Same customer multiple large transactions within same day -->
        <record id="transaction_screening_rule_repeat_large" model="res.transaction.screening.rule">
            <field name="name">Repeated Large Transactions Same Day</field>
            <field name="code">repeat_large_same_day</field>
            <field name="narration">Customer performing 3 or more transactions above 500,000 in a single day. Possible structuring attempt.</field>
            <field name="risk_level">high</field>
            <field name="condition_select">sql</field>
            <field name="state">active</field>
            <field name="priority">2</field>
            <field name="transaction_flag">suspicious</field>
            <field name="likely_fraud">True</field>
            <field name="sql_query"><![CDATA[
                SELECT COUNT(*)
                FROM res_customer_transaction t
                WHERE t.customer_id = #CUSTOMER_ID#
                AND t.amount > 500000
                AND DATE(t.date_created) = (
                    SELECT DATE(date_created)
                    FROM res_customer_transaction
                    WHERE id = #TRANSACTION_ID#
                )
                AND t.id != #TRANSACTION_ID#
                HAVING COUNT(*) >= 2
            ]]></field>
        </record>

        <!-- Rule 3: Python — High risk customer with any transaction above 200k -->
        <record id="transaction_screening_rule_high_risk_customer" model="res.transaction.screening.rule">
            <field name="name">High Risk Customer Large Transaction</field>
            <field name="code">high_risk_cust_large_tran</field>
            <field name="narration">Any transaction above 200,000 from a customer rated high risk should be reviewed immediately.</field>
            <field name="risk_level">high</field>
            <field name="condition_select">python</field>
            <field name="state">active</field>
            <field name="priority">3</field>
            <field name="transaction_flag">suspicious</field>
            <field name="likely_fraud">True</field>
            <field name="condition_python"><![CDATA[
                # Flag if customer is high risk AND amount is above 200,000
                result = (
                    transaction.amount > 200000
                    and customer.risk_level == 'high'
                )
            ]]></field>
        </record>

        <!-- Rule 4: Python — Transaction just below reporting threshold (structuring indicator) -->
        <record id="transaction_screening_rule_below_threshold" model="res.transaction.screening.rule">
            <field name="name">Transaction Just Below Reporting Threshold</field>
            <field name="code">below_reporting_threshold</field>
            <field name="narration">
                Transactions deliberately kept just below the 1,000,000 reporting
                threshold are a strong indicator of structuring to avoid regulatory scrutiny.
            </field>
            <field name="risk_level">high</field>
            <field name="condition_select">python</field>
            <field name="state">active</field>
            <field name="priority">4</field>
            <field name="transaction_flag">suspicious</field>
            <field name="likely_fraud">True</field>
            <field name="condition_python"><![CDATA[
                # Reporting threshold is 1,000,000
                # Flag any transaction in the danger zone: 900,000 – 999,999
                THRESHOLD   = 1000000
                DANGER_ZONE = 900000

                result = DANGER_ZONE <= transaction.amount < THRESHOLD
            ]]></field>
        </record>

        <!-- Rule 5: Python — Any transaction between 10k and 100k -->
        <record id="transaction_screening_rule_mid_range" model="res.transaction.screening.rule">
            <field name="name">Mid-Range Transaction Review</field>
            <field name="code">mid_range_tran_review</field>
            <field name="narration">
                Any transaction between 10,000 and 100,000 should be reviewed.
                May indicate layering activity regardless of customer risk rating.
            </field>
            <field name="risk_level">low</field>
            <field name="condition_select">python</field>
            <field name="state">active</field>
            <field name="priority">5</field>
            <field name="transaction_flag">suspicious</field>
            <field name="likely_fraud">True</field>
            <field name="condition_python"><![CDATA[
                # Flag any transaction that falls between 10,000 and 100,000
                LOWER_BOUND = 10000
                UPPER_BOUND = 100000

                result = LOWER_BOUND <= transaction.amount <= UPPER_BOUND
            ]]></field>
        </record>

    </data>
</odoo>