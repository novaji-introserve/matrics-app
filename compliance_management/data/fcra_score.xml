<odoo>
    <data noupdate="1">
     <record id="inherent_score" model="res.fcra.score">
        <field name="name">Inherent Score</field>
        <field name="max_score">25</field>
        <field name="min_score">1</field>
    </record>
     <record id="control_effectiveness_score" model="res.fcra.score">
        <field name="name">Control Effectiveness</field>
        <field name="max_score">25</field>
        <field name="min_score">0</field>
    </record>
     <record id="residual_risk_score" model="res.fcra.score">
        <field name="name">Residual Risk</field>
        <field name="max_score">25</field>
        <field name="min_score">0</field>
    </record>
    </data>
</odoo>