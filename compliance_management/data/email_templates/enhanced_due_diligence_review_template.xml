<odoo>
    <data>
        <record id="enhanced_due_diligence_review_template" model="mail.template">
            <field name="name">EDD Review Notification</field>
            <field name="model_id" ref="model_res_partner_edd"/>
            <field name="subject">EEnhanced Due Diligence (EDD) Review Required</field>
            <field name="email_from"></field>
            <field name="email_to">{{ object.approving_officer_id.email_formatted }}</field>
            <field name="email_cc">${ctx.get('email_cc')}</field> 
            <!-- <field name="mail_server_id">1</field> -->
            <field name="auto_delete" eval="True"/>
            <field name="body_html">
                <![CDATA[
                <div style="max-width: 600px; margin: auto; font-family: Arial, sans-serif; border: 1px solid #ddd; padding: 20px; border-radius: 8px;">
                    <div style="text-align: center; padding-bottom: 20px;">
                      
                         <img src="/compliance_management/static/img/alt_bank_logo.png" alt="Company Logo" style="max-width: 150px; height: auto;"/>
                    </div>

                    <p>Dear <t t-out="ctx.get('officer_name')"></t>,</p> 
                    
                    <p>
                        Please be advised that an Enhanced Due Diligence (EDD) requires your attention.
                        Kindly review the document and approve.
                    </p>

                    <!-- Button -->
                    <p style="text-align: center; margin: 20px 0;">
                        <a href="${ctx.get('edd_url', '#')}"
                            style="background-color:#95536c;color:white;padding:10px 20px;text-decoration:none;border-radius:5px; display: inline-block;">
                            View Details
                        </a>
                    </p>

                    <p>Best Regards,</p>
                    <p><strong>The Compliance Team</strong></p>
                    <hr/>
                </div>
                ]]>
            </field>
        </record>
    </data>
</odoo>
