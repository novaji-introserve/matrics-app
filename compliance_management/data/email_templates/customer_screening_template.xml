<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Main Email Template -->
        <record id="email_template_screening_alert" model="mail.template">
            <field name="name">Sanction Screening Alert</field>
            <field name="model_id" ref="model_res_partner_screening_result"/>
            <field name="subject">Sanction Screening Alert: Potential Match Found!</field>
            <field name="email_from">${ctx.get('from_email', user.company_id.email or 'noreply@company.com')}</field>
            <field name="body_html" type="html">
                <div style="max-width: 600px; margin: auto; font-family: Arial, sans-serif; border: 1px solid #ddd; padding: 20px; border-radius: 8px;">

                    <div style="text-align: left; padding-bottom: 20px;">
                        
                        <img t-att-src="ctx.get('company_logo')" alt="Company Logo" style="max-width: 80px; height: auto;"/>

                    </div>

                    <p>Dear Compliance Officer, </p>

                    <p>A potential match has been found during customer sanction screening.</p>

                    <p style="line-height: 1.4;">
                        <strong >Date and Time Entry:</strong>
                        <t t-esc="ctx.get('datetime', '')"/>
                    </p>

                    <p style="line-height: 1.4;">
                        <strong>Customer Details:</strong>
                    </p>

                    <div>
                        <p>
                            <span style="border: 1px solid #ddd;">Customer Name:</span>
                            <t t-esc="ctx.get('name', 'N/A')"/>
                        </p>

                        <p>
                            <span style="border: 1px solid #ddd;">Customer ID:</span>
                            <t t-esc="ctx.get('customer_id', 'N/A')"/>
                        </p>
                        <p>
                            <span style="border: 1px solid #ddd;">BVN:</span>
                            <t t-esc="ctx.get('bvn', 'N/A')"/>
                        </p>
                        <p>
                            <span style="border: 1px solid #ddd;">Risk Score:</span>
                            <t t-esc="ctx.get('risk_score', 'N/A')"/>
                        </p>
                        <p>
                            <span style="border: 1px solid #ddd;">Risk Level:</span>
                            <t t-esc="str(ctx.get('risk_level', 'N/A')).upper()"/>
                        </p>
                    </div>

                    <p style="line-height: 1.4;">
                        <strong>Screening Results:</strong>
                    </p>

                    <ul style="list-style-type: decimal;">
                        <t t-foreach="ctx.get('results', [])" t-as="result">
                            <li style="margin-bottom: 8px; padding: 5px;">
                                <t t-if="result.get('list_type') == 'pep'">
                                    <span style="border: 1px solid #ddd;">Pep</span>
                                </t>
                                <t t-elif="result.get('list_type') == 'watchlist'">
                                    <span style="border: 1px solid #ddd;">Watchlist</span>
                                </t>
                                <t t-elif="result.get('list_type') == 'sanction'">
                                    <span style="border: 1px solid #ddd;">Sanction</span>
                                </t>
                                <t t-elif="result.get('list_type') == 'global_pep'">
                                    <span style="border: 1px solid #ddd;">Global Pep</span>
                                </t>
                                <t t-elif="result.get('list_type') == 'blacklist'">
                                    <span style="border: 1px solid #ddd;">Blacklist</span>
                                </t>
                                <t t-elif="result.get('list_type') == 'fep'">
                                    <span style="border: 1px solid #ddd;">Fep</span>
                                </t>
                                <t t-else="">
                                    <t t-esc="' '.join([word.capitalize() for word in str(result.get('list_type', '')).split('_')])"/>
                                </t>
                            </li>
                        </t>
                    </ul>

                    <p style="text-align: center; margin: 20px 0;">
                        <a t-att-href="ctx.get('record_url', '#')" style="background-color:#95536c;color:white;padding:10px 20px;text-decoration:none;border-radius:5px; display: inline-block;">
                            View Details
                        </a>
                    </p>

                    <p>Please review these matches and take appropriate action.</p>

                    <p>Best Regards,</p>
                    <p>
                        <strong>The Compliance Team</strong>
                    </p>
                    <hr/>

                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>

    </data>
</odoo>