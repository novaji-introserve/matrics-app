<odoo>
   

    <!--  KYC Limit -->

    <record id="res_partner_kyc_limit_1" model="res.partner.kyc.limit">
        <field name="name">Less Than Ngn 50000</field>
        <field name="code">less_than_ngn_50000</field>
        
    </record>


    <record id="res_partner_kyc_limit_2" model="res.partner.kyc.limit">
        <field name="name">Between 51000-500000</field>
        <field name="code">between_51000-500000</field>
    </record>


    <record id="res_partner_kyc_limit_3" model="res.partner.kyc.limit">
        <field name="name">Between 500000-1m</field>
        <field name="code">between_500000-1m</field>
    </record>


    <record id="res_partner_kyc_limit_4" model="res.partner.kyc.limit">
        <field name="name">Between 1m-5m</field>
        <field name="code">between_1m-5m</field>
    </record>


    <record id="res_partner_kyc_limit_5" model="res.partner.kyc.limit">
        <field name="name">Above 5m</field>
        <field name="code">above_5m</field>
    </record>
    <!--  Customer Tier -->

    <record id="res_partner_tier_1" model="res.partner.tier">
        <field name="name">Tier 1 - Individual</field>
        <field name="code">tier_1</field>
        <field name="risk_assessment" ref="res_risk_assessment_onboarding"/>
    </record>


    <record id="res_partner_tier_2" model="res.partner.tier">
        <field name="name">Tier 2 - Corporate</field>
        <field name="code">tier_2</field>
        <field name="risk_assessment" ref="res_risk_assessment_onboarding"/>
    </record>


    <record id="res_partner_tier_3" model="res.partner.tier">
        <field name="name">Tier 3 - Corporate</field>
        <field name="code">tier_3</field>
        <field name="risk_assessment" ref="res_risk_assessment_onboarding"/>
    </record>
   
</odoo>