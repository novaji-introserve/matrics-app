<odoo>
    <data noupdate="1">

        <record id="email_template_notify_officer_in_charge" model="mail.template">
            <field name="name">EDD Officer in Charge Notification</field>
            <field name="model_id" ref="compliance_management.model_res_partner_edd" />
            <field name="subject">EDD Request Submitted for Review</field>
            <field name="email_from">${object.user_id.email or ''}</field>
            <field name="email_to">${object.responsible_id.email or ''}</field>
            <field name="body_html">
                <![CDATA[
                    <p>Dear ${object.responsible_id.name},</p>
                    <p>The Enhanced Due Diligence (EDD) for the customer ${object.customer_id.name} has been submitted for your review.</p>
                    <p>Please take the necessary steps to initiate the review process.</p>
                    <p>Best Regards,</p>
                    <p>${object.user_id.name}</p>
                ]]>
            </field>
        </record>
    </data>
</odoo>
