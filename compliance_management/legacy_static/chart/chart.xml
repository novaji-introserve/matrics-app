<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl.ChartRender" owl="1">
        <div class="chart-container position-relative" style="width: 100%; height: 44vh;">
            <!-- Loading spinner overlay -->
            <div t-if="props.isLoading" class="position-absolute top-0 start-0 end-0 bottom-0 d-flex justify-content-center align-items-center bg-white bg-opacity-75" style="z-index: 10;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
            <canvas t-ref="compliance_chart" style="width: 100%; height: 100%; display: block; margin:auto" />
        </div>
    </t>
</templates>