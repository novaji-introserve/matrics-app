<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl.card" owl="1">
        <div t-on-click="() => props.onClick" class="px-4 pb-2 pt-1 box cursor-pointer shadow bg-white position-relative" t-attf-style="">

            <h2 class="my-3 fs-1">
                <t t-out="props.total" />
            </h2>

            <p class="text-muted text-capitalize fs-3">
                <t t-out="props.title" />
            </p>

            <div class="text-uppercase fw-bold text-center bg-dark text-white fs-6 position-absolute catbox">
                <p ><t t-out="props.scope.slice(0,2)" /></p>
            </div>


        </div>
    </t>
</templates>