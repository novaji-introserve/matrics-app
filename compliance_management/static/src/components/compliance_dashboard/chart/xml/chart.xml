<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
 <t t-name="owl.ChartRender" owl="1">
 <div class="chart-container position-relative" style="width: 100%; height: 18vh; min-height: 140px;">
   <!-- Library loading spinner overlay -->
   <div t-if="state.isLibraryLoading" class="position-absolute top-0 start-0 end-0 bottom-0 d-flex justify-content-center align-items-center bg-white bg-opacity-75" style="z-index: 10;">
     <div class="d-flex flex-column align-items-center">
       <div class="spinner-border text-primary mb-2" role="status">
         <span class="visually-hidden">Loading...</span>
       </div>
       <span>Loading chart library...</span>
     </div>
   </div>
   
   <!-- Chart initializing overlay -->
   <div t-if="state.isInitializing" class="position-absolute top-0 start-0 end-0 bottom-0 d-flex justify-content-center align-items-center bg-white bg-opacity-75" style="z-index: 10;">
     <div class="d-flex flex-column align-items-center">
       <div class="spinner-border text-primary mb-2" role="status">
         <span class="visually-hidden">Loading...</span>
       </div>
       <span>Initializing chart...</span>
     </div>
   </div>
   
   <!-- Loading animation progress -->
   <div t-if="state.isAnimating" class="position-absolute bottom-0 start-0 end-0 p-2 bg-white bg-opacity-75" style="z-index: 10;">
     <div class="d-flex flex-column">
       <div class="progress mb-1" style="height: 6px;">
         <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" 
              t-attf-style="width: {{(state.loadedElements / state.totalElements) * 100}}%" 
              t-attf-aria-valuenow="{{(state.loadedElements / state.totalElements) * 100}}" 
              aria-valuemin="0" aria-valuemax="100"></div>
       </div>
       <!-- <small class="text-muted text-end">
         <t t-out="state.loadedElements"/> of <t t-out="state.totalElements"/> items
         (<t t-out="Math.round((state.loadedElements / state.totalElements) * 100)"/>%)
       </small> -->
     </div>
   </div>
   
   <!-- Error message display -->
   <div t-if="state.error" class="position-absolute top-0 start-0 end-0 bottom-0 d-flex justify-content-center align-items-center bg-white bg-opacity-75" style="z-index: 10;">
     <div class="alert alert-danger" role="alert">
       <i class="fa fa-exclamation-triangle me-2"></i>
       <t t-out="state.error"/>
     </div>
   </div>
   
   <canvas t-ref="compliance_chart" style="width: 100%; height: 100%; display: block; margin:auto" />
 </div>
 </t>
</templates>
