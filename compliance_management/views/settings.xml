<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report on Settings -->
    <record id="compliance_settings_tree" model="ir.ui.view">
        <field name="name">res_compliance_settings_tree</field>
        <field name="model">res.compliance.settings</field>
        <field name="arch" type="xml">
            <tree string="Compliance Settings">
                <field name="name" string="Name" />
                <field name="code" />
                <field name="val" string="Value" />
            </tree>
        </field>
    </record>
    <!-- Customer Account Type Form -->
    <record id="compliance_settings_form" model="ir.ui.view">
        <field name="name">Compliance Settings</field>
        <field name="model">res.compliance.settings</field>
        <field name="arch" type="xml">
            <form class="o_form_document" delete="False">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group string="Details">
                        <group>
                            <field name="code" />
                        </group>
                        <group>
                            <field name="val" />
                        </group>
                    </group>
                    <notebook>
                        <page name="narration" string="Narration">
                            <field name="narration" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Account Type Action -->
    <record id="action_compliance_settings" model="ir.actions.act_window">
        <field name="name">Compliance Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.compliance.settings</field>
        <field name="view_id" ref="compliance_settings_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a Setting
            </p>
            <p>
                No data found
            </p>
        </field>
    </record>
    <menuitem
    id="menu_compliance_compliance_settings"
    action="action_compliance_settings"
    parent="menu_compliance_risk_settings"
    name="Settings"
    groups="group_compliance_compliance_risk_manager,group_compliance_compliance_officer"
    sequence="1100" />

</odoo>