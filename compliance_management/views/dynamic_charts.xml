<odoo>
    <data>
        <!-- Preserve the existing tree view with minimal changes -->
        <record model="ir.ui.view" id="res_charts_tree">
            <field name="name">res.dashboard.charts.tree</field>
            <field name="model">res.dashboard.charts</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="chart_type"/>
                    <field name="color_scheme"/>
                    <field name="last_execution_status" optional="show" widget="badge" 
                           decoration-success="last_execution_status == 'success'" 
                           decoration-danger="last_execution_status == 'error'"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>


        <record model="ir.ui.view" id="res_charts_form">
            <field name="name">res.dashboard.charts.form</field>
            <field name="model">res.dashboard.charts</field>
            <field name="arch" type="xml">
                <form string="Dynamic Chart">
                    <header>
                        <button name="action_test_query" string="Test Query" type="object" class="btn-primary"/>
                        <button name="action_refresh_materialized_view" string="Refresh View" type="object" 
                                class="btn-secondary" attrs="{'invisible': [('use_materialized_view', '=', False)]}"/>
                        <field name="state" widget="statusbar" options="{'clickable':'1'}" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Chart Name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="chart_type"/>
                                <field name="color_scheme"/>
                                <field name="branch_filter"/>
                                <field name="branch_field" attrs="{'invisible': [('branch_filter', '=', False)], 'required': [('branch_filter', '=', True)]}"/>
                                <field name="column"/>
                            </group>
                            <group>
                                <field name="x_axis_field"/>
                                <field name="y_axis_field"/>
                                <field name="date_field"/>
                                <field name="target_model_id" options="{'no_create': True}"/>
                                <field name="domain_field_id" options="{'no_create': True}" context="{'ir_model_id': target_model_id}"/>
                                <!-- Add new performance fields -->
                                <field name="use_materialized_view"/>
                                <field name="materialized_view_refresh_interval" 
                                       attrs="{'invisible': [('use_materialized_view', '=', False)]}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="SQL Query">
                                <field name="query" widget="ace" placeholder="SELECT column_1 as label, column_2 as value FROM table"/>
                                <group attrs="{'invisible': [('last_execution_time', '=', 0)]}">
                                    <field name="last_execution_time"/>
                                    <field name="last_execution_status" widget="badge" 
                                           decoration-success="last_execution_status == 'success'" 
                                           decoration-danger="last_execution_status == 'error'"/>
                                    <field name="materialized_view_last_refresh" 
                                           attrs="{'invisible': [('use_materialized_view', '=', False)]}"/>
                                </group>
                                <div class="mt-3 text-muted">
                                    <p>Enter a valid SQL query that returns at least two columns: one for labels (X-axis) and one for values (Y-axis).</p>
                                    <p>query requires date parameters, please specify a date field above for sorting.</p>
                                    <p class="text-danger">Note: Only SELECT queries are allowed. DDL and DML operations are prohibited.</p>
                                    <p>For complex queries, consider enabling the materialized view option for better performance.</p>
                                </div>
                                <div class="alert alert-danger" role="alert" attrs="{'invisible': [('last_error_message', '=', False)]}">
                                    <field name="last_error_message" readonly="1"/>
                                </div>
                            </page>
                            <page string="Description">
                                <field name="description" placeholder="Describe the purpose of this chart"/>
                            </page>
                            <page string="Advanced Settings" groups="base.group_system">
                                <group>
                                    <!-- <field name="is_complex_query" readonly="1"/> -->
                                    <field name="domain_filter"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="res_charts_action">
            <field name="name">Dashboard Charts</field>
            <field name="res_model">res.dashboard.charts</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first dynamic chart
                </p>
                <p>
                    Configure SQL queries to generate dynamic charts for your Odoo data.
                </p>
            </field>
        </record>
    </data>
</odoo>