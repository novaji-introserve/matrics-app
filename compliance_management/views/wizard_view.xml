<odoo>
    <data>
        <!-- edd_reject_wizard -->
        <record id="view_res_partner_edd_reject_wizard_form" model="ir.ui.view">
            <field name="name">res.partner.edd.reject.wizard.form</field>
            <field name="model">res.partner.edd.reject.wizard</field>
            <field name="arch" type="xml">
                <form string="Reason for Rejection">
                    <group>
                        <field name="edd_id" invisible="1"/>
                        <field name="reject_reason" placeholder="Reason for rejection"/>
                    </group>
                    <footer>
                        <button name="action_confirm_reject" type="object" string="Confirm" class="oe_highlight"/>
                        <button special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <act_window id="action_res_partner_edd_reject_wizard"
                    name="Reject EDD"
                    res_model="res.partner.edd.reject.wizard"
                    view_mode="form"
                    target="new"/>
    </data>
</odoo>