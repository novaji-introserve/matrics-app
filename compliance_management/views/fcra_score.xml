<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="fcra_score_tree" model="ir.ui.view">
    <field name="name">fcra.score.tree</field>
    <field name="model">res.fcra.score</field>
    <field name="arch" type="xml">
        <tree string="Risk Assessment Scores" create="false" delete="false">
             <field name="name" />
            <field name="max_score"/>
            <field name="min_score"/>
            
        </tree>
    </field>
</record>

<record id="fcra_score_form" model="ir.ui.view">
    <field name="name">fcra.score.form</field>
    <field name="model">res.fcra.score</field>
    <field name="arch" type="xml">
        <form string="Risk Assessment Score">
            <sheet>
                 <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                <group>
                    <group>
                        <field name="max_score"/>
                    </group>
                    <group>
                        <field name="min_score"/>
                    </group>
                    
                </group>
            </sheet>
             <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="activity_ids" widget="mail_activity"/>
                <field name="message_ids" widget="mail_thread"/>
            </div>
        </form>
    </field>
</record>

<record id="action_fcra_score_action" model="ir.actions.act_window">
    <field name="name">Risk Scores</field>
    <field name="res_model">res.fcra.score</field>
    <field name="view_mode">tree,form</field>
    <field name="help" type="html">
        <p class="oe_view_nocontent_create">
            Click to add a new Risk Score.
        </p>
    </field>
</record>

</odoo>