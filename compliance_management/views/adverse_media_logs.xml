<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_adverse_media_alert_tree" model="ir.ui.view">
        <field name="name">adverse.media.alert.tree</field>
        <field name="model">adverse.media.alert</field>
        <field name="arch" type="xml">
            <tree string="Adverse Media Alerts">
                <field name="partner_id"/>
                <field name="partner_category"/>
                <field name="name"/>
                <field name="risk_score_decoration" invisible="1"/>
                <field name="risk_score" decoration-danger="risk_score_decoration == 'danger'" decoration-warning="risk_score_decoration == 'warning'" decoration-success="risk_score_decoration == 'success'"/>
                <field name="status" widget="badge" decoration-danger="status=='new'" decoration-warning="status=='under_review'" decoration-success="status=='confirmed'" decoration-muted="status=='closed'"/>
                <field name="create_date" widget="date"/>
                <field name="source_date"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_adverse_media_alert_form" model="ir.ui.view">
        <field name="name">adverse.media.alert.form</field>
        <field name="model">adverse.media.alert</field>
        <field name="arch" type="xml">
            <form string="Adverse Media Alert">
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}" statusbar_visible="new,under_review,confirmed,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Alert Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <!-- <field name="media_id"/> -->
                            <field name="partner_id"/>
                            <field name="partner_category"/>
                            <field name="source_date" readonly="1"/>
                        </group>

                        <group>
                            <!-- <field name="risk_score" widget="percentage" readonly="1"/> -->
                            <field name="risk_score_decoration" invisible="1"/>
                            <field name="risk_score" widget="slider" step="1" min="1" max="9" readonly="1" decoration-danger="risk_score_decoration == 'danger'" decoration-warning="risk_score_decoration == 'warning'" decoration-success="risk_score_decoration == 'success'"/>
                            <!-- <field name="risk_score" decoration-danger="risk_score_decoration == 'danger'" decoration-warning="risk_score_decoration == 'warning'" decoration-success="risk_score_decoration == 'success'"/> -->

                            <field name="source_url" widget="url" readonly="1"/>
                        </group>



                    </group>

                    <group>
                        <field name="description" readonly="0"/>
                    </group>
                    <group>
                        <field name="content" readonly="0" string="Media content"/>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_adverse_media_alert_search" model="ir.ui.view">
        <field name="name">adverse.media.alert.search</field>
        <field name="model">adverse.media.alert</field>
        <field name="arch" type="xml">
            <search string="Search Adverse Media Alerts">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="description"/>
                <field name="content"/>
                <filter string="New Alerts" name="new_alerts" domain="[('status', '=', 'new')]"/>
                <filter string="Under Review" name="under_review" domain="[('status', '=', 'under_review')]"/>
                <filter string="Confirmed Risks" name="confirmed" domain="[('status', '=', 'confirmed')]"/>
                <filter string="Closed" name="closed" domain="[('status', '=', 'closed')]"/>
                <separator/>
                <filter string="High Risk" name="high_risk" domain="[('risk_score', '>=', 20)]"/>
                <filter string="Medium Risk" name="medium_risk" domain="[('risk_score', '>=', 19), ('risk_score', '&lt;', 19)]"/>
                <filter string="Low Risk" name="low_risk" domain="[('risk_score', '&lt;', 5)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    <filter string="Partner" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'partner_category'}"/>
                    <filter string="Publication Date" name="group_by_date" context="{'group_by': 'source_date'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>