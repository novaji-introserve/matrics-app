<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_pep_source_tree" model="ir.ui.view">
        <field name="name">pep.source.tree</field>
        <field name="model">pep.source</field>
        <field name="arch" type="xml">
            <tree string="PEP Sources">
                <field name="name" />
                <field name="domain" />
                <field name="source_type" />
                <!-- <field name="country_id" /> -->
                <field name="last_update" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_pep_source_form" model="ir.ui.view">
        <field name="name">pep.source.form</field>
        <field name="model">pep.source</field>
        <field name="arch" type="xml">
            <form string="PEP Source">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Source Name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="domain" />
                            <field name="source_type" />
                            <field name="country_id" />
                            <field name="frequency" />
                        </group>
                        <group>
                            <field name="active" />
                            <field name="last_update" readonly="1" />
                            <field name="is_free" />
                            <field name="api_key" password="True"
                                attrs="{'invisible': [('is_free', '=', True)]}" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_pep_source_search" model="ir.ui.view">
        <field name="name">pep.source.search</field>
        <field name="model">pep.source</field>
        <field name="arch" type="xml">
            <search string="Search PEP Sources">
                <field name="name" />
                <field name="domain" />
                <field name="source_type" />
                <field name="country_id" />
                <filter string="Active" name="active" domain="[('active','=',True)]" />
                <group expand="0" string="Group By">
                    <filter string="Source Type" name="groupby_type"
                        context="{'group_by': 'source_type'}" />
                    <filter string="Country" name="groupby_country"
                        context="{'group_by': 'country_id'}" />
                    <filter string="Frequency" name="groupby_frequency"
                        context="{'group_by': 'frequency'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pep_sources" model="ir.actions.act_window">
        <field name="name">PEP Sources</field>
        <field name="res_model">pep.source</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first PEP Source
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_pep_configurations" name="PEP Configurations"
        parent="menu_compliance_configuration"
        sequence="460" />
    <menuitem id="menu_pep_sources" name="PEP Sources" parent="menu_pep_configurations"
        action="action_pep_sources" sequence="10" />
    
</odoo>