        <field name="model_id" ref="model_res_customer_pep"/>
        <field name="binding_model_id" ref="model_res_customer_pep"/>
        <field name="state">code</field>
        <field name="code">action = records.action_mark_pep()</field>
    </record>

    <record id="action_view_customer_global_pep" model="ir.actions.server">
        <field name="name">Customers Matching Global PEP</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.action_view_global_pep_customer()</field>
    </record>

    <record id="action_view_likely_sanction_customer" model="ir.actions.server">
