<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Customer Tree -->
    <record id="compl_cust_tree_inherit_res_partner" model="ir.ui.view">
        <field name="name">model_res_partner_tree_inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='phone']" position="before">
                <field name="customer_id"/>
                <field name="branch_id"/>
                <field name="registration_date"/>
                <field name="tier_id" />
            </xpath>
        </field>
    </record>

    <record id="customer_actions_inherit_res_partner" model="ir.ui.view">
        <field name="name">res_partner_compliance_actions</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="priority">1600</field>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_initiate_edd" class="oe_highlight" type="object" string="Initiate EDD"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="This will trigger a request to carry out EDD on this customer. Are you sure?" />
                        <button name="action_add_pep" class="oe_highlight" type="object" string="Add to PEP List"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to PEP List. Are you sure?" />
                        <button name="action_add_fep" class="oe_highlight" type="object" string="Add to FEP List"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to FEP List. Are you sure?" />
                        <button name="action_blacklist" class="oe_highlight" type="object" string="Add to Blacklist"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to Blacklist. Are you sure?" />
                        <button name="action_watchlist" class="oe_highlight" type="object" string="Add to Watchlist"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to Watchlist. Are you sure?" />
                        <button name="action_conduct_risk_assessment" class="oe_highlight" type="object" string="Conduct Risk Assessment"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Conduct Risk Assessment. Are you sure?" />
                </header>
            </xpath>
        </field>
    </record>

    <!-- Add EDD Page to Customer Form -->
    <record id="customer_form_view_edd_page_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.edd.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="EDD Record" name="edd_record">
                    <field name="edd_ids" nolabel="1">
                        <tree string="EDD Record">
                            <field name="name"/>
                            <field name="status"/>
                            <field name="customer_id"/>
                            <field name="responsible_id"/>
                            <field name="user_id"/>
                            <field name="approved_by"/>
                            <field name="date_approved"/>
                            <field name="risk_score"/>
                            <field name="account_status"/>
                            <field name="documentation_status"/>
                        </tree>
                        <form string="EDD Record">
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name"/>
                                        <field name="status"/>
                                        <field name="customer_id"/>
                                        <field name="responsible_id"/>
                                        <field name="user_id"/>
                                        <field name="approved_by"/>
                                        <field name="date_approved"/>
                                        <field name="risk_score"/>
                                        <field name="account_status"/>
                                        <field name="documentation_status"/>
                                    </group>
                                    <group>
                                        <field name="is_foreigner"/>
                                        <field name="is_pep"/>
                                        <field name="id_expired"/>
                                        <field name="activity_level_matches_business"/>
                                        <field name="was_kyc_comprehensive"/>
                                        <field name="has_initiated_new_kyc"/>
                                        <field name="is_current_from_normal"/>
                                        <field name="does_business_support_volume"/>
                                        <field name="last_kyc_date"/>
                                    </group>
                                </group>
                                <notebook>
                                    <page string="Details">
                                        <group>
                                            <group string="Description">
                                                <field name="description" nolabel="1"/>
                                            </group>
                                            <group string="Visitation Observation">
                                                <field name="visitation_observation" nolabel="1"/>
                                            </group>
                                        </group>
                                        <group>
                                            <group string="KYC Information">
                                                <field name="overall_kyc_outcome" nolabel="1"/>
                                            </group>
                                        </group>
                                    </page>
                                    <page string="Transaction Information">
                                        <group>
                                            <group string="Cash Information">
                                                <field name="main_cash_purpose" nolabel="1"/>
                                            </group>
                                            <group string="Inflow Information">
                                                <field name="main_inflow_purpose" nolabel="1"/>
                                                <field name="main_fund_remitters" nolabel="1"/>
                                                <field name="inflow_sources" nolabel="1"/>
                                            </group>
                                        </group>
                                        <group>
                                            <group string="Additional Information">
                                                <field name="other_related_accounts" nolabel="1"/>
                                                <field name="occupation" nolabel="1"/>
                                            </group>
                                        </group>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

</odoo>