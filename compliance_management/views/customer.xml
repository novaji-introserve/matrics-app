<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="compl_cust_tree_inherit_res_partner" model="ir.ui.view">
        <field name="name">model_res_partner_tree_inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree" />
        <field name="arch" type="xml">
            <!-- Update the tree attributes instead of replacing the entire tree -->
            <xpath expr="//tree" position="attributes">
                <attribute name="create">false</attribute>
            </xpath>
 
            <!-- Replace the phone field with custom fields -->
            <xpath expr="//field[@name='phone']" position="before">
                <field name="customer_id" optional="show" />
                <field name="firstname" optional="show" />
                <field name="lastname" optional="show" />
                <field name="risk_score" widget="badge" decoration-info="1" on_change="1" />
                <field name="risk_level" 
                    widget="badge"
                    decoration-danger="risk_level == 'high'"
                    decoration-warning="risk_level == 'medium'"
                    decoration-success="risk_level =='low'"
                />
                <field name="branch_id" optional="hide" />
                <field name="registration_date" optional="hide"  />
                <field name="tier_id" optional="hide" />
            </xpath>

            <!-- Modify activity_ids field -->
            <xpath expr="//field[@name='activity_ids']" position="replace">
                <field name="activity_ids" invisible="1" widget="list_activity" />
            </xpath>

            <!-- Modify user_id field -->
            <xpath expr="//field[@name='user_id']" position="replace">
                <field name="user_id" optional="show" invisible="1" widget="many2one_avatar_user" domain="[('share', '=', False)]" />
            </xpath>

           

        </field>
    </record>


    <record id="customer_actions_inherit_res_partner" model="ir.ui.view">
        <field name="name">res_partner_compliance_actions</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="priority">1600</field>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_initiate_edd" class="oe_highlight" type="object"
                        string="Initiate EDD"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="This will trigger a request to carry out EDD on this customer. Are you sure?" />
                    <button name="action_add_pep" class="oe_highlight" type="object"
                        string="Add to PEP List"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to PEP List. Are you sure?"
                        attrs="{'invisible': [('is_pep', '=',True)]}" />
                    <button name="action_unmark_pep" class="oe_highlight" type="object"
                        string="Delist from Global PEP"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Unlink this customer from Global PEP list. Are you sure?"
                        attrs="{'invisible': [('global_pep', '=',False)]}" />
                    <button name="action_remove_pep" type="object"
                        string="Remove From PEP List"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Remove Customer from PEP List. Are you sure?"
                        attrs="{'invisible': [('is_pep', '!=',True)]}" />

                    <!-- <button name="action_add_fep" class="oe_highlight" type="object"
                        string="Add to FEP List"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to FEP List. Are you sure?"
                        attrs="{'invisible': [('is_fep', '=',True)]}" 
                        style="display: none;"
                        /> -->

                    <!-- <button name="action_remove_fep" type="object"
                        string="Remove from FEP List"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Remove from FEP List. Are you sure?"
                        attrs="{'invisible': [('is_fep', '!=',True)]}" 
                        /> -->

                    <button name="action_blacklist" class="oe_highlight" type="object"
                        string="Add to Blacklist"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to Blacklist. Are you sure?"
                        attrs="{'invisible': [('is_blacklist', '=',True)]}" />
                    <button name="action_remove_blacklist" type="object"
                        string="Remove from Blacklist"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Remove from Blacklist. Are you sure?"
                        attrs="{'invisible': [('is_blacklist', '!=',True)]}" />
                    <button name="action_watchlist" class="oe_highlight" type="object"
                        string="Add to Watchlist"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to Watchlist. Are you sure?"
                        attrs="{'invisible': [('is_watchlist', '=',True)]}" />
                    <button name="action_remove_watchlist" type="object"
                        string="Remove from Watchlist"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Remove from Watchlist. Are you sure?"
                        attrs="{'invisible': [('is_watchlist', '!=',True)]}" />
                    <button name="action_greylist" class="oe_highlight" type="object"
                        string="Add to Greylist"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Add Customer to Greylist. Are you sure?"
                        attrs="{'invisible': [('is_greylist', '=',True)]}" />
                    <button name="action_remove_greylist" type="object"
                        string="Remove from Greylist"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Remove from Greylist. Are you sure?"
                        attrs="{'invisible': [('is_greylist', '!=',True)]}" />
                    <button name="action_conduct_risk_assessment" class="oe_highlight" type="object"
                        string="Conduct Risk Assessment"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Conduct Risk Assessment. Are you sure?" />
                    <button name="action_compute_risk_score_with_plan" class="oe_highlight" type="object"
                        string="Compute Risk Score"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Compute Risk Score: Using your defined Risk Plan, the Customer risk score and level will be recomputed. This process cannot be reversed. Are you sure to proceed?" />
                    
                    <button name="scan_news_articles" class="oe_highlight" type="object"
                        string="Run Media Screening"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Run Media Screening: Are you sure?" />
                </header>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object" name="action_total_accounts" icon="fa-star">
                    <field name="total_accounts" widget="statinfo"/>
                </button>

                <!-- <button class="oe_stat_button" type="object" name="get_risk_level" icon="fa-thermometer-0">
                    <span>Risk 
                    <field string="Risk Level" name="risk_level" widget="badge" 
                    decoration-danger="risk_level in ('high')"
                    decoration-warning="risk_level in ('medium')"
                    decoration-success="risk_level in ('low')"/>
                    </span>                   
                </button> -->

                <button class="oe_stat_button"  icon="fa-thermometer-0">
                    <span>Risk
                        <field string="Risk Level" name="risk_level" widget="badge" 
                        decoration-danger="risk_level == 'high'" 
                        decoration-warning="risk_level == 'medium'" 
                        decoration-success="risk_level == 'low'"/>
                    </span>
                </button>

                <button class="oe_stat_button" type="object" name="get_risk_score" icon="fa-star">
                    <field string="Risk Score"  name="risk_score" widget="statinfo"/>
                </button>
            </xpath>
         
            <xpath expr="//field[@name='website']" position="replace">
                <field name="industry_id" invisible="0" />
                <!-- <attribute name="invisible">1</attribute> -->
            </xpath>

            <xpath expr="//field[@name='region_id']" position="replace">
                <field name="state_residence" invisible="0" />

            </xpath>

            <xpath expr="//field[@name='function']" position="replace">
                <field name="employment_status" invisible="0" />
                <field name="active" invisible="1" />
            </xpath>
          

            <xpath expr="//field[@name='mobile']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='company_reg_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
           

            <xpath expr="//form//field[@name='street2']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//form//field[@name='company_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//form//field[@name='company_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[@class='o_row']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
            <xpath expr="//span[@class='o_form_label o_td_label']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[@class='o_address_format']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[@class='o_address_format']" position="after">
                <field name="street" invisible="0" readonly="1"/>

            </xpath>
           

            <xpath expr="//field[@name='education_level_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide identification_type_id -->
            <xpath expr="//field[@name='identification_type_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide identification_number -->
            <xpath expr="//field[@name='identification_number']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide identification_expiry_date -->
            <xpath expr="//field[@name='identification_expiry_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>


            <!-- Readonly fields -->

            <xpath expr="//field[@name='middlename']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='othername']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='customer_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='branch_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <!--  -->

            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>


            <xpath expr="//field[@name='sector_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='phone']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='email']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='industry_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='title']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@id='individual']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>
    <record id="view_customer_search" model="ir.ui.view">
        <field name="name">Customer Search Custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="priority" eval="1000"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="replace">
                <search string="Search Customer">
                    <field name="name"
                       filter_domain="['|', '|', '|', '|', ('display_name', 'ilike', self), ('ref', 'ilike', self), ('email', 'ilike', self), ('vat', 'ilike', self), ('company_registry', 'ilike', self)]"/>
                    <field name="parent_id" domain="[('is_company', '=', True)]" operator="child_of"/>
                    <field name="email" filter_domain="[('email', 'ilike', self)]"/>
                    <field name="phone" filter_domain="['|', ('phone', 'ilike', self), ('mobile', 'ilike', self)]"/>
                    <field name="category_id" string="Tag" operator="child_of"/>
                    <field name="customer_id" filter_domain="[('customer_id', 'ilike', self)]"/>
                    <separator/>
                    <filter string="Customers" name="type_customer" domain="[('internal_category', '=', 'customer')]"/>
                    <filter string="Vendors" name="type_vendor" domain="[('internal_category', '=', 'vendor')]"/>
                    <filter string="Partners" name="type_partner" domain="[('internal_category', '=', 'partner')]"/>
                    <filter string="Respondents" name="type_respondent" domain="[('internal_category', '=', 'respondent')]"/>
                    <filter string="Correspondent" name="type_correspondent" domain="[('internal_category', '=', 'correspondent')]"/>
                    <separator/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group expand="0" name="group_by" string="Group By">
                        <filter name="group_branch" string="Branch" domain="[]" context="{'group_by' : 'branch_id'}" />
                        <filter name="group_tier" string="Tier" context="{'group_by': 'tier_id'}"/>
                        <filter name="group_risk_level" string="Risk Level" context="{'group_by': 'risk_level'}"/>
                        <filter name="group_internal_category" string="Category" context="{'group_by': 'internal_category'}"/>
                    </group>
                </search>
            </xpath>
        </field>
    </record>

    <!-- Inherit and modify the action_contacts -->
    <record id="contacts_action_contacts_inherit" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree,kanban,form,activity</field>
        <field name="search_view_id" ref="base.view_res_partner_filter"/>
        <field name="context">{'search_default_group_branch': 1}</field>
    </record>

    <!-- Override the menu item to use the new action -->
    <record id="contacts.res_partner_menu_contacts" model="ir.ui.menu">
        <field name="action" ref="contacts_action_contacts_inherit"/>
    </record>

    <!-- Disable create in tree view -->
    <record id="view_partner_tree_no_create" model="ir.ui.view">
        <field name="name">res.partner.tree.no.create</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <tree position="attributes">
                <attribute name="create">false</attribute>
            </tree>
        </field>
    </record>

    <!-- Disable create in kanban view -->
    <record id="view_partner_kanban_no_create" model="ir.ui.view">
        <field name="name">res.partner.kanban.no.create</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.res_partner_kanban_view"/>
        <field name="arch" type="xml">
            <kanban position="attributes">
                <attribute name="create">false</attribute>
            </kanban>
        </field>
    </record>

    <!-- Report on Settings -->
    <record id="compliance_pep_customers_tree" model="ir.ui.view">
        <field name="name">res_compliance_pep_customers_tree</field>
        <field name="model">res.customer.pep</field>
        <field name="arch" type="xml">
            <tree string="Customer matching PEP" create="False" delete="False">
                <field name="name" string="Name" />
                <field name="customer_id" />
                <field name="firstname" />
                <field name="lastname" />
                <field name="unique_identifier" />
                <field name="branch_id" />
                <field name="pep_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_customer_pep_search" model="ir.ui.view">
        <field name="name">Customer PEP Search Custom</field>
        <field name="model">res.customer.pep</field>
        <field name="priority" eval="1000"/>
        <field name="arch" type="xml">
            <search string="Search Customer PEP">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="firstname"/>
                <field name="lastname"/>
                <separator/>
                <filter string="Customers" name="type_customer" domain="[('internal_category', '=', 'customer')]"/>
                <filter string="Vendors" name="type_vendor" domain="[('internal_category', '=', 'vendor')]"/>
                <filter string="Partners" name="type_partner" domain="[('internal_category', '=', 'partner')]"/>
                <filter string="Respondents" name="type_respondent" domain="[('internal_category', '=', 'respondent')]"/>
                <filter string="Correspondent" name="type_correspondent" domain="[('internal_category', '=', 'correspondent')]"/>
                <separator/>
                <group expand="0" name="group_by" string="Group By">
                    <filter name="group_branch" string="Branch" domain="[]" context="{'group_by' : 'branch_id'}" />
                    <filter name="group_internal_category" string="Category" context="{'group_by': 'internal_category'}"/>
                </group>
            </search>
          
        </field>
    </record>

    <record model="ir.actions.server" id="action_mark_pep">
        <field name="name">Mark PEP</field>
        <field name="model_id" ref="model_res_customer_pep"/>
        <field name="binding_model_id" ref="model_res_customer_pep"/>
        <field name="state">code</field>
        <field name="code">action = records.action_mark_pep()</field>
    </record>

    <record id="action_view_customer_pep" model="ir.actions.server">
        <field name="name">Customers On PEP List</field>
        <field name="model_id" ref="model_res_customer_pep" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.action_view_customer_pep()</field>
    </record>

    <menuitem
        id="menu_compliance_customer_pep"
        action="action_view_customer_pep"
        parent="menu_compliance_customer_heading"
        name="Customers Matching PEPs"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="50" />

</odoo>