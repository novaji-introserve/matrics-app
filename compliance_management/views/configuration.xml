<odoo>
  <data>
     <!-- Account Types Report -->
    <record id="compliance_customer_account_type_tree" model="ir.ui.view">
        <field name="name">res_partner_account_type_tree</field>
        <field name="model">res.partner.account.type</field>
        <field name="arch" type="xml">
            <tree string="Account Types" delete="False">
                <field name="name" string="Name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>
     <!-- Customer Account Type Form -->
    <record id="compliance_customer_account_type_form" model="ir.ui.view">
        <field name="name">Account Types</field>
        <field name="model">res.partner.account.type</field>
        <field name="arch" type="xml">
            <form class="o_form_document" delete="False">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="code"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Account Type Action -->
   <record id="action_list_customer_account_type" model="ir.actions.act_window">
        <field name="name">Customer Account Type</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner.account.type</field>
        <field name="view_id" ref="compliance_customer_account_type_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a Customer Account Type
            </p>
            <p>
                No Account Type
            </p>
        </field>
    </record>
    
    <!-- Customer Sectors Report -->
    <record id="compliance_customer_sector_tree" model="ir.ui.view">
        <field name="name">res.partner.sector.tree</field>
        <field name="model">res.partner.sector</field>
        <field name="arch" type="xml">
            <tree string="Customer Sectors" delete="False">
                <field name="name" string="Name"/>
                <field name="code"/>
            </tree>
        </field>
    </record> 
    <!-- Customer Sectors Form -->
    <record id="compliance_customer_sector_form" model="ir.ui.view">
        <field name="name">Customer Sector</field>
        <field name="model">res.partner.sector</field>
        <field name="arch" type="xml">
            <form class="o_form_document" delete="False">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="code"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Customer Sectors Action -->
   <record id="action_list_customer_sector" model="ir.actions.act_window">
        <field name="name">Customer Sectors</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner.sector</field>
        <field name="view_id" ref="compliance_management.compliance_customer_sector_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a Customer Sector
            </p>
            <p>
                Customer are grouped by sector or industries
            </p>
        </field>
    </record>
     <!-- Menu Items -->    
    <menuitem
        id="menu_compliance_root"
        name="Compliance"
        groups="group_compliance_compliance_officer,base.group_user"
        web_icon="compliance_management,static/description/icons-compliance.png"
        sequence="75"/>
    <menuitem
        id="menu_compliance_configuration"
        name="Configuration" 
        groups="group_compliance_compliance_officer"
        parent="menu_compliance_root"
        sequence="100"/>
    <menuitem
        id="menu_compliance_account_type"
        action="action_list_customer_account_type"
        parent="menu_compliance_configuration" 
        name="Account Types"
        groups="group_compliance_compliance_officer" 
        sequence="10"/>
    <menuitem
        id="menu_compliance_sector"
        action="action_list_customer_sector"
        parent="menu_compliance_configuration" 
        name="Customer Sectors"
        groups="group_compliance_compliance_officer" 
        sequence="20"/>
  </data>
</odoo>