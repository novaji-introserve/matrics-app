                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="hr.menu_hr_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('compliance_management.group_compliance_chief_compliance_officer')])]"/>
        </record> 

      

        
        <!-- Digital Delivery Channel Views -->
        <record id="view_digital_delivery_channel_tree" model="ir.ui.view">
            <field name="name">digital.delivery.channel.tree</field>
            <field name="model">digital.delivery.channel</field>
            <field name="arch" type="xml">
                <tree string="Digital Delivery Channels">
                    <header>
                        <button name="action_create_dynamic_demo_subscriptions" type="object" string="Create Random Demo Data" class="btn btn-warning mr-2"  help="Creates random YES/NO subscriptions for all channels dynamically"/>
                    </header>
        
                
                    <field name="name"/>
                    <field name="code"/>
                    <field name="description"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <!-- Other required views... -->
        <record id="view_digital_delivery_channel_form" model="ir.ui.view">
            <field name="name">digital.delivery.channel.form</field>
            <field name="model">digital.delivery.channel</field>
            <field name="arch" type="xml">
                <form string="Digital Delivery Channel">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="description"/>
                            </group>
                            <group>
                                <field name="code"/>
                                <field name="status"/>
                            </group>
                        </group>
                       
                    </sheet>
                </form>
            </field>
        </record>
        
        


        <!-- Menu Items -->
