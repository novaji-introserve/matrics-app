<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <!-- Account Types Report -->
        <record id="compliance_customer_account_type_tree" model="ir.ui.view">
            <field name="name">res_partner_account_type_tree</field>
            <field name="model">res.partner.account.type</field>
            <field name="arch" type="xml">
                <tree string="Account Types" delete="False">
                    <field name="name" string="Name" />
                    <field name="code" />
                    <field name="risk_assessment" string="Risk Assessment" />
                </tree>
            </field>
        </record>
        <!-- Customer Account Type Form -->
        <record id="compliance_customer_account_type_form" model="ir.ui.view">
            <field name="name">Account Types</field>
            <field name="model">res.partner.account.type</field>
            <field name="arch" type="xml">
                <form class="o_form_document" delete="False">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" />
                            </h1>
                        </div>
                        <group>
                            <group string="Details">
                                <field name="code" />
                            </group>
                            <group string="Risk Assessment">
                                <field name="risk_assessment" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Customer Sectors Report -->
        <record id="compliance_customer_sector_tree" model="ir.ui.view">
            <field name="name">res.partner.sector.tree</field>
            <field name="model">res.partner.sector</field>
            <field name="arch" type="xml">
                <tree string="Customer Sectors" delete="False">
                    <field name="name" string="Name" />
                    <field name="code" />
                    <field name="risk_assessment" string="Risk Assessment" />
                </tree>
            </field>
        </record>
        <!-- Customer Sectors Form -->
        <record id="compliance_customer_sector_form" model="ir.ui.view">
            <field name="name">Customer Sector</field>
            <field name="model">res.partner.sector</field>
            <field name="arch" type="xml">
                <form class="o_form_document" delete="False">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" />
                            </h1>
                        </div>
                        <group>
                            <group string="Details">
                                <field name="code" />
                            </group>
                            <group string="Risk Assessment">
                                <field name="risk_assessment" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Account Products Tree View -->
        <record id="account_product_tree_view" model="ir.ui.view">
            <field name="name">res.partner.account.product.tree</field>
            <field name="model">res.partner.account.product</field>
            <field name="arch" type="xml">
                <tree string="Account Products" delete="False">
                    <field name="name" string="Name" />
                    <field name="code" string="Code" />
                    <field name="risk_assessment" string="Risk Assessment" />
                </tree>
            </field>
        </record>

        <!-- Account Products Form View -->
        <record id="account_product_form_view" model="ir.ui.view">
            <field name="name">res.partner.account.product.form</field>
            <field name="model">res.partner.account.product</field>
            <field name="arch" type="xml">
                <form class="o_form_document" delete="False">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group string="Details">

                            <group >
                                <field name="product_type" readonly="1" />
                                <field name="product_category" readonly="1" />
                            </group>

                            <group>
                                <field name="code" string="Product Code" readonly="1" />
                                <field name="description" readonly="1" />
                            </group>

                        </group>


                        <group string="Risk Assessment">
                            <field name="risk_assessment" readonly="1" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Education Levels Tree View -->
        <record id="education_level_tree_view" model="ir.ui.view">
            <field name="name">res.education.level.tree</field>
            <field name="model">res.education.level</field>
            <field name="arch" type="xml">
                <tree string="Education Levels" delete="False">
                    <field name="name" string="Education Level" />
                    <field name="code" string="Code" />
                    <field name="risk_assessment" string="Risk Assessment" />
                </tree>
            </field>
        </record>

        <!-- Education Levels Form View -->
        <record id="education_level_form_view" model="ir.ui.view">
            <field name="name">res.education.level.form</field>
            <field name="model">res.education.level</field>
            <field name="arch" type="xml">
                <form class="o_form_document" delete="False">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" />
                            </h1>
                        </div>
                        <group>
                            <group string="Details">
                                <field name="code" />
                            </group>
                            <group string="Risk Assessment">
                                <field name="risk_assessment" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>



        <!-- Customer Tiers Tree View -->
        <record id="customer_tier_tree_view" model="ir.ui.view">
            <field name="name">res.partner.tier.tree</field>
            <field name="model">res.partner.tier</field>
            <field name="arch" type="xml">
                <tree string="Customer Tiers" delete="False">
                    <field name="name" string="Name" />
                    <field name="code" string="Code" />
                    <field name="tier_level" string="Code" />
                    <field name="risk_assessment" string="Risk Assessment" />
                </tree>
            </field>
        </record>

        <!-- Customer Tiers Form View -->
        <record id="customer_tier_form_view" model="ir.ui.view">
            <field name="name">res.partner.tier.form</field>
            <field name="model">res.partner.tier</field>
            <field name="arch" type="xml">
                <form class="o_form_document" delete="False">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" />
                            </h1>
                        </div>
                        <group>
                            <group string="Details">
                                <field name="code" />
                                <field name="tier_level" />
                            </group>
                            <group string="Risk Assessment">
                                <field name="risk_assessment" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        

        <!-- Customer Regions Tree View -->
        <record id="customer_region_tree_view" model="ir.ui.view">
            <field name="name">res.partner.region.tree</field>
            <field name="model">res.partner.region</field>
            <field name="arch" type="xml">
                <tree string="Customer Regions">
                    <field name="name" string="Name" />
                    <field name="code" string="Code" />
                    <field name="risk_assessment" />
                    <field name="risk_rating" />
                    <field name="create_uid" />
                    <field name="create_date" />
                </tree>
            </field>
        </record>

        <!-- Customer Regions Form View -->
        <record id="customer_region_form_view" model="ir.ui.view">
            <field name="name">res.partner.region.form</field>
            <field name="model">res.partner.region</field>
            <field name="arch" type="xml">
                <form class="o_form_document">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" />
                            </h1>
                        </div>
                        <notebook>
                            <page name="name" string="Details">
                                <group>
                                    <group>
                                        <field name="code" />
                                    </group>
                                    <group>
                                        <field name="create_uid" />
                                    </group>
                                </group>
                                <group>
                                    <group>
                                        <field name="risk_assessment" />
                                    </group>
                                    <group>
                                        <field name="risk_rating" />
                                    </group>

                                </group>
                            </page>
                        </notebook>

                    </sheet>
                </form>
            </field>
        </record>

       

        <!-- Branch Tree View -->
        <record id="view_branch_tree" model="ir.ui.view">
            <field name="name">res.branch.tree</field>
            <field name="model">res.branch</field>
            <field name="arch" type="xml">
                <tree string="Branches" delete="False">
                    <field name="name" string="Branch Name" />
                    <field name="code" string="Branch Code" />
                    <field name="region_id" />
                    <field name="users" string="Users" />
                </tree>
            </field>
        </record>

        <!-- Branch Form View -->
        <record id="view_branch_form" model="ir.ui.view">
            <field name="name">res.branch.form</field>
            <field name="model">res.branch</field>
            <field name="arch" type="xml">
                <form class="o_form_document" delete="False">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" string="Branch" />
                            </h1>
                        </div>
                        <group>
                            <group string="Details">
                                <field name="code" string="Branch Code" />
                                <field name="region_id" />
                                <field name="users" widget="many2many_tags" string="Users" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>




        <!-- Risk Categories Tree View -->
        <record id="risk_category_tree_view" model="ir.ui.view">
            <field name="name">res.risk.category.tree</field>
            <field name="model">res.risk.category</field>
            <field name="arch" type="xml">
                <tree string="Risk Categories" delete="False">
                    <field name="name" string="Name" />
                    <field name="code" string="Code" />
                    <field name="user_id" string="User" />
                </tree>
            </field>
        </record>

        <!-- Risk Categories Form View -->
        <record id="risk_category_form_view" model="ir.ui.view">
            <field name="name">res.risk.category.form</field>
            <field name="model">res.risk.category</field>
            <field name="arch" type="xml">
