<odoo>
  <data>
    <record id="compliance_customer_sector_tree" model="ir.ui.view">
        <field name="name">res.partner.sector.tree</field>
        <field name="model">res.partner.sector</field>
        <field name="arch" type="xml">
            <tree string="Customer Sectors">
                <field name="name" string="Sector Name"/>
                <field name="code"/>
            </tree>
        </field>
    </record> 
   <record id="action_list_customer_sector" model="ir.actions.act_window">
        <field name="name">Customer Sectors</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner.sector</field>
        <field name="view_id" ref="compliance_management.compliance_customer_sector_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a Customer Sector
            </p>
            <p>
                Customer are grouped by sector or industries
            </p>
        </field>
    </record>
         
    <menuitem
        id="menu_compliance_root"
        name="Compliance"
        groups="group_compliance_compliance_officer,base.group_user"
        web_icon="compliance_management,static/description/icons-compliance.png"
        sequence="75"/>
    <menuitem
        id="menu_compliance_configuration"
        name="Configuration" 
        groups="group_compliance_compliance_officer"
        parent="menu_compliance_root"
        sequence="100"/>
    <menuitem
        id="menu_compliance_sector"
        action="action_list_customer_sector"
        parent="menu_compliance_configuration" 
        name="Customer Sectors"
        groups="group_compliance_compliance_officer" 
        sequence="0"/>
  </data>
</odoo>