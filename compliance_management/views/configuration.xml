            </field>
        </record>


        <!-- Risk Universe Tree View -->
        <record id="risk_universe_tree_view" model="ir.ui.view">
            <field name="name">res.risk.universe.tree</field>
            <field name="model">res.risk.universe</field>
            <field name="arch" type="xml">
                <tree string="Risk Universe" delete="False">
                    <field name="name" string="Name" />
                    <field name="code" string="Code" />
                    <field name="user_id" string="User" />
                </tree>
            </field>
        </record>

        <!-- Risk Universe Form View -->
        <record id="risk_universe_form_view" model="ir.ui.view">
            <field name="name">res.risk.universe.form</field>
            <field name="model">res.risk.universe</field>
            <field name="arch" type="xml">
                <form class="o_form_document" delete="False">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" />
                            </h1>
                        </div>
                        <group>
                            <group string="Details">
                                <field name="code" />
                                <field name="user_id" />
                                <field name="is_included_in_composite" widget="boolean_toggle"/>
                                <field name="weight_percentage" attrs="{'invisible': [('is_included_in_composite', '=', False)]}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

       

        <!-- Risk Subject Tree View -->
        <record id="risk_subject_tree_view" model="ir.ui.view">
            <field name="name">res.risk.subject.tree</field>
            <field name="model">res.risk.subject</field>
            <field name="arch" type="xml">
                <tree string="Risk Subject" delete="False">
                    <field name="name" string="Name" />
                    <field name="code" string="Code" />
                    <!-- <field name="universe_id" string="Risk Universe" /> -->
                </tree>
            </field>
        </record>

        <!-- Risk Subject Form View -->
        <record id="risk_subject_form_view" model="ir.ui.view">
