<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="transaction_screening_history_view_tree" model="ir.ui.view">
        <field name="name">transaction.screening.history.view.tree</field>
        <field name="model">res.transaction.screening.history</field>
        <field name="arch" type="xml">
            <tree string="Transaction Screening History" create="false" edit="false" delete="false">
                <field name="transaction_id" />
                <field name="customer_id" />
                <field name="account_id" />
                <field name="rule_id" />
                <field name="branch_id" />
                <field name="risk_level" widget="badge" decoration-danger="risk_level == 'high'"
                    decoration-warning="risk_level in ('medium')"
                    decoration-success="risk_level in ('low')" />
                <field name="create_date" />
                <field name="create_uid" />
            </tree>
        </field>
    </record>
    <record id="transaction_screening_history_view_form" model="ir.ui.view">
        <field name="name">transaction.screening.history.view.form</field>
        <field name="model">res.transaction.screening.history</field>
        <field name="arch" type="xml">
            <form edit="false" create="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <label for="rule_id" class="oe_edit_only" />
                        <h1>
                            <field name="rule_id" />
                        </h1>
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="transaction_id" />
                            <field name="customer_id" />
                            <field name="account_id" />

                        </group>
                        <group>
                            <field name="branch_id" />
                            <field name="risk_level" widget="badge"
                                decoration-danger="risk_level == 'high'"
                                decoration-warning="risk_level in ('medium')"
                                decoration-success="risk_level in ('low')" />
                            <field name="create_date" />
                            <field name="create_uid" />
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
    <record id="transaction_screening_history_view_search" model="ir.ui.view">
        <field name="name">transaction.screening.history.view.search</field>
        <field name="model">res.transaction.screening.history</field>
        <field name="arch" type="xml">
            <search string="Search Transaction Screening History">
                <field name="transaction_id" />
                <field name="customer_id" />
                <field name="rule_id" />
                <field name="risk_level" />
                <field name="branch_id" />
                <field name="create_date" />
                <separator />
                <filter string="High Risk" name="risk_level_high"
                    domain="[('risk_level', '=', 'high')]" />
                <filter string="Medium Risk" name="risk_level_medium"
                    domain="[('risk_level', '=', 'medium')]" />
                <filter string="Low Risk" name="risk_level_low"
                    domain="[('risk_level', '=', 'low')]" />
                <separator />
                <group expand="0" name="group_by" string="Group By">
                    <filter name="group_branch_id" string="Branch" domain="[]"
                        context="{'group_by' : 'branch_id'}" />
                    <filter name="group_rule_id" string="Rule" domain="[]"
                        context="{'group_by' : 'rule_id'}" />
                    <filter name="group_customer_id" string="Customer" domain="[]"
                        context="{'group_by' : 'customer_id'}" />
                    <filter name="group_transaction_id" string="Transaction"
                        context="{'group_by': 'transaction_id'}" />
                    <filter name="group_risk_level" string="Risk Level"
                        context="{'group_by': 'risk_level'}" />
                </group>
            </search>
        </field>
    </record>
    <record id="open_transaction_screening_history" model="ir.actions.server">
        <field name="name">Open Transaction Screening History</field>
        <field name="model_id" ref="model_res_transaction_screening_history" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_transaction_screening_history()</field>
    </record>

    <record id="customer_transaction_view_inherited_form" model="ir.ui.view">
        <field name="name">compliance.transaction.form.inherit</field>
        <field name="model">res.customer.transaction</field>
        <field name="inherit_id" ref="compliance_management.compliance_transaction_form" />
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object"
                    name="action_view_transaction_screening_rules"
                    icon="fa-exclamation-circle">
                    <field name="total_rules" string="Exceptions" widget="statinfo" />
                </button>
            </xpath>
        </field>
    </record>
</odoo>