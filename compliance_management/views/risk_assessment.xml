<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Risk Assesmsment Line -->
    <record id="compliance_customer_risk_assessment_line_form" model="ir.ui.view">
        <field name="name">Risk Assessment Line</field>
        <field name="model">res.risk.assessment.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet string="FCRA Risk Assessment Line">
                    <div class="oe_title" colspan="2">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="residual_risk_probability" string="% Residual Risk Probability" />
                        </group>
                        <group>
                            <field name="residual_risk_score" />
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="inherent_risk_score" widget="slider" step="1" min="1" max="25" />
                        </group>
                    </group>
                    <group>
                        <group colspan="2">
                            <field name="implication"/>
                        </group>
                    </group>
                    <group>
                        <group colspan="2">
                            <field name="existing_controls"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="control_effectiveness_score"  widget="slider" step="1" min="1" max="25"  />
                        </group>
                        <group>
                            <field name="residual_risk_impact"  widget="slider" step="1" min="1" max="25" />
                        </group>
                    </group>
                    <group>
                        <group colspan="2">
                            <field name="planned_mitigation" />
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="department_id" />
                        </group>
                        <group>
                            <field name="implementation_date" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Risk Assessment Report -->
    <record id="compliance_customer_risk_assessment_tree" model="ir.ui.view">
        <field name="name">res_customer_risk_assessment_tree</field>
        <field name="model">res.risk.assessment</field>
        <field name="arch" type="xml">
            <tree string="Risk Assessment">
                <field name="name" string="Name" />
                <field name="subject_id" />
                <field name="universe_id" />
                <field name="assessment_type_id" />
                <field name="type_id" />
                <field name="risk_rating" />
                <field name="create_uid" />
                <field name="create_date" />
            </tree>
        </field>
    </record>
    <!-- Risk Assessment Form -->
    <record id="compliance_customer_risk_assessment_form" model="ir.ui.view">
        <field name="name">Risk Assessment</field>
        <field name="model">res.risk.assessment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_update_risk_score" class="oe_highlight" type="object" string="Compute Risk Score"
                    groups="compliance_management.group_compliance_branch_compliance_officer" />  
                </header>
                <sheet string="Risk Assessment">
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_total_risk_lines" icon="fa-star">
                            <field string="Risk Rating" name="risk_rating" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="universe_id"/>
                        </group>
                        <group>
                            <field name="subject_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="assessment_type_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="type_id"/>
                        </group>
                    </group>
                    <group />
                    <group>
                        <separator />
                    </group>
                    <notebook colspan="4">
                        <page name='assessment_lines' string="FCRA Risk Assessment" autofocus="autofocus">
                            <field name="line_ids" string="Risk Assessment Lines">
                                <tree string="Risk Assessment Lines">
                                    <field name="name" string="Name" />
                                    <field name="category_id"/>
                                    <field name="residual_risk_probability"/>
                                    <field name="residual_risk_score"/>
                                </tree>
                            </field>
                        </page>
                        <page name='recommendation' string="Recommendation">
                            <field name="recommendation" placeholder="Recommendation..." />
                        </page>
                        <page name='internal_notes' string="Internal Notes">
                            <field name="narration" placeholder="Narration..." />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!-- Action -->
    <record id="action_list_risk_assessment" model="ir.actions.act_window">
        <field name="name">Risk Assessment</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.risk.assessment</field>
        <field name="view_id" ref="compliance_customer_risk_assessment_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add Institutional or Counter Party Risk Assessment
            </p>
            <p>
                No records yet
            </p>
        </field>
    </record>
    <!-- Menu -->
    <menuitem
        id="menu_compliance_risk"
        name="Risk"
        groups="group_compliance_compliance_risk_manager"
        parent="menu_compliance_root"
        sequence="30" />
    <menuitem id="menu_fcra_risk" name="FCRA Risk Assessment"
        parent="menu_compliance_risk" sequence="100"/>
    <menuitem
        id="menu_compliance_risk_assessment"
        action="action_list_risk_assessment"
        parent="menu_fcra_risk"
        name="Risk Assessment"
        groups="group_compliance_compliance_risk_manager,group_compliance_compliance_officer" 
        sequence="10" />
</odoo>