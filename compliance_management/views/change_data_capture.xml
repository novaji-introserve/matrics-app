<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_change_data_capture_tree" model="ir.ui.view">
        <field name="name">change.data.capture.tree</field>
        <field name="model">change.data.capture</field>
        <field name="arch" type="xml">
            <tree string="Change Data Capture Logs" create="false" delete="false">
                <field name="name"/>
                <field name="model"/>
                <field name="field_name"/>
                <field name="res_id"/>
                <field name="old_val"/>
                <field name="new_val"/>
            </tree>
        </field>
    </record>

    <record id="view_change_data_capture_form" model="ir.ui.view">
        <field name="name">change.data.capture.form</field>
        <field name="model">change.data.capture</field>
        <field name="arch" type="xml">
            <form string="Change Data Capture" create="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model"/>
                            <field name="res_id"/>
                            <field name="field_name"/>
                        </group>
                        <group>
                            <field name="updated_at"/>
                        </group>
                    </group>
                    <group>
                        <field name="old_val" widget="text" readonly="1"/>
                        <field name="new_val" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_change_data_capture" model="ir.actions.act_window">
        <field name="name">Change Data Capture</field>
        <field name="res_model">change.data.capture</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
