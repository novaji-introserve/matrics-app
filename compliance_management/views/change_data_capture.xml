<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_change_data_capture_tree" model="ir.ui.view">
        <field name="name">change.data.capture.tree</field>
        <field name="model">change.data.capture</field>
        <field name="arch" type="xml">
            <tree string="Change Data Capture Logs" create="false" edit="false" delete="false">
                <field name="name"/>
                <field name="model"/>
                <field name="field_name"/>
                 <field name="res_name"/>
                <field name="old_val"/>
                <field name="new_val"/>
                <field name="updated_at"/>
            </tree>
        </field>
    </record>

    <record id="view_change_data_capture_form" model="ir.ui.view">
        <field name="name">change.data.capture.form</field>
        <field name="model">change.data.capture</field>
        <field name="arch" type="xml">
            <form string="Change Data Capture" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model" readonly="1"/>
                            <field name="res_name" readonly="1"/>
                            <field name="field_name" readonly="1"/>
                            <field name="updated_at" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="old_val" widget="text" readonly="1"/>
                        <field name="new_val" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_change_data_capture_search" model="ir.ui.view">
        <field name="name">change.data.capture.search</field>
        <field name="model">change.data.capture</field>
        <field name="arch" type="xml">
            <search string="Search Change Data Capture">
                <filter
                    string="Updated Today"
                    name="updated_today"
                    domain="[('updated_at', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('updated_at', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"
                />
                <filter
                    string="Last 7 Days"
                    name="last_7_days"
                    domain="[('updated_at', '&gt;=', (context_today() - relativedelta(days=6)).strftime('%Y-%m-%d 00:00:00')), ('updated_at', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"
                />
                <filter
                    string="Last 1 Month"
                    name="last_1_month"
                    domain="[('updated_at', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-%d 00:00:00')), ('updated_at', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"
                />
                <group expand="0" string="Group By">
                    <filter string="Model" name="group_by_model" context="{'group_by': 'model'}"/>
                    <filter string="Updated At" name="group_by_updated_at" context="{'group_by': 'updated_at'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_change_data_capture" model="ir.actions.act_window">
        <field name="name">Change Data Capture</field>
        <field name="res_model">change.data.capture</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_change_data_capture_search"/>
        <field name="context">{'search_default_updated_today': 1, 'search_default_group_by_model': 1}</field>
    </record>
</odoo>
