<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Stats -->
    <record id="compliance_stats_form" model="ir.ui.view">
        <field name="name">Compliance Statistic</field>
        <field name="model">res.compliance.stat</field>
        <field name="arch" type="xml">
            <form >
                
                <header>
                    <!-- <button name="Validate_expression" class="oe_highlight" type="object"
                        string="Validate Expression"
                        groups="compliance_management.group_compliance_branch_compliance_officer" /> -->
                    <button name="refresh_materialized_view" string="Refresh View" type="object" 
        attrs="{'invisible': [('use_materialized_view', '=', False)]}" class="oe_highlight"/>
                </header>
                <sheet string="Compliance Statistic">
                    <div class="oe_title" colspan="2">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <div class="oe_title" colspan="2">
                        <label for="val" class="oe_edit_only" />
                        <h1>
                            <field name="val" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" />
                        </group>
                        <group>
                            <field name="scope" />
                        </group>
                        <group>
                        <field name="use_materialized_view"/>
                            <field name="materialized_view_refresh_interval" attrs="{'invisible': [('use_materialized_view', '=', False)]}"/>
                        </group>
                        <group>
                            <field name="materialized_view_last_refresh" attrs="{'invisible': [('use_materialized_view', '=', False)]}"/>
                        </group>
                    </group>
                    <notebook colspan="4">
                        <page name='sql_text' string="SQL Query" autofocus="autofocus">
                            <field name="sql_query" placeholder="Write SQL Query Here..." />
                        </page>
                        <page name='internal_notes' string="Internal Notes">
                            <field name="narration" placeholder="Narration..." />
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!-- Report-->
    <record id="compliance_stat_tree" model="ir.ui.view">
        <field name="name">res_compliance_stat_tree</field>
        <field name="model">res.compliance.stat</field>
        <field name="arch" type="xml">
            <tree string="Compliance Statistics">
                <field name="name" string="Name" />
                <field name="code" />
                <field name="scope" />
                <field name="val" widget="badge" decoration-info="1" />
                <field name="last_execution_status" optional="show" widget="badge" 
                           decoration-success="last_execution_status == 'success'" 
                           decoration-danger="last_execution_status == 'error'"/>
                <field name="create_date" />
                <field name="write_date" />
            </tree>
        </field>
    </record>
    <record id="compliance_stat_view_kanban" model="ir.ui.view">
        <field name="name">rec.compliance.stat.view.kanban</field>
        <field name="model">res.compliance.stat</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="scope">
                <field name="name" />
                <field name="val" />
                <field name="write_date" />
                <field name="scope" />
                <templates>
                    <t t-name="kanban-box">
                        <div class="d-flex mb-2" style="justify-content: space-between;">
                            <field name="name" class="fw-bolder fs-5" /><br/>
                            <field name="val" widget="badge" decoration-info="1"  />
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- Action -->
    <record id="action_list_compliance_stat" model="ir.actions.act_window">
        <field name="name">Compliance Statistics</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.compliance.stat</field>
        <field name="view_id" ref="compliance_stat_tree" />
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a Statitics
            </p>
            <p>
                No records yet
            </p>
        </field>
    </record>

    <!-- server -->
    <record id="action_stat_card_click" model="ir.actions.server">
    <field name="name">Stat Card Click</field>
    <field name="model_id" ref="model_res_compliance_stat"/>
    <field name="state">code</field>
    <field name="code">action = model.open_action()</field>
    </record>
    <!-- Menu -->
    <menuitem
        id="menu_compliance_stat"
        action="action_list_compliance_stat"
        parent="menu_compliance_risk_settings"
        name="Statistics"
        groups="group_compliance_compliance_risk_manager,group_compliance_compliance_officer"
        sequence="1000" />

</odoo>