<odoo>      
    <!-- Edd Tree View --> 
    <record id="edd_tree_view" model="ir.ui.view">
        <field name="name">res.partner.edd.tree</field>
        <field name="model">res.partner.edd</field>
        <field name="arch" type="xml">
            <tree string="Enhanced Due Diligence " delete="false">
           <!-- <tree string="Enhanced Due Diligence "> -->
                <field name="customer_id" />
                <field name="responsible_id" string="Responsible" />
                <field name="user_id" string="Initiated By" />
                <field name="risk_score" />
                <field name="approved_by" string="Approved By" />
                <field name="date_approved" />
                <field name="status"
                    decoration-info="status == 'draft'"
                    decoration-success="status == 'approved'"
                    decoration-warning="status == 'cancelled'"
                    decoration-danger="status == 'deleted'"
                    decoration-primary="status == 'completed'"
                    widget="badge" />
                <field name="last_kyc_date" />
                <field name="create_date" string="Created On" />
            </tree>
        </field>
    </record>
    
    <!-- Edd Form View -->
    <record id="edd_form_view" model="ir.ui.view">
        <field name="name">res.partner.edd.form</field>
        <field name="model">res.partner.edd</field>
        <field name="arch" type="xml">
            <form string="Manage Enhanced Due Diligence" delete="false">
                <header>
                    <button name="action_submit_for_review"
                            class="oe_highlight"
                            type="object"
                            string="Submit for Review"
                            groups="compliance_management.group_compliance_branch_compliance_officer"
                            attrs="{'invisible': ['|', ('status', '!=', 'draft'), ('is_current_user_responsible', '=', False)]}"/>

                    <button name="action_approve"
                            class="oe_highlight"
                            type="object"
                            string="Approve"
                            groups="compliance_management.group_compliance_branch_compliance_officer"
                            attrs="{'invisible': ['|', ('status', '!=', 'completed'), ('is_current_user_approving_officer', '=', False)]}" />

                    <button name="action_cancel"
                            class="oe_highlight"
                            type="object"
                            string="Cancel"
                            groups="compliance_management.group_compliance_branch_compliance_officer"
                            attrs="{'invisible': ['|', ('status', 'in', ['cancelled', 'approved', 'draft']), ('is_current_user_approving_officer', '=', False)]}" />

                    <button name="action_archive"
                            class="oe_highlight"
                            type="object"
                            string="Archive"
                            groups="compliance_management.group_compliance_branch_compliance_officer"
                            attrs="{'invisible': ['|', ('status', 'not in', ['cancelled', 'approved']), ('is_cco', '=', False)]}" />
                    
                    <button name="action_download_pdf"
                            string="Download Document"
                            type="object"
                            class="oe_highlight"
                            groups="compliance_management.group_compliance_branch_compliance_officer"
                            attrs="{'invisible': [('status', 'in', ['draft', 'cancelled', 'deleted','completed'])]}" />

                    <button name="action_send_back"
                            class="oe_highlight"
                            type="object"
                            string="Send Back"
                            groups="compliance_management.group_compliance_branch_compliance_officer"
                            attrs="{'invisible': ['|', ('status', 'in', ['draft', 'approved']), ('is_current_user_approving_officer', '=', False)]}" />

                   


                    <field name="status" widget="statusbar" statusbar_visible="draft,completed,approved,cancelled,deleted,archived"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name" attrs="{'readonly': ['|', ('is_cco', '=', False), ('status', 'in', ['approved','archived'])], 'required': [('is_cco', '=', True)]}"/>
                            <field name="is_cco" invisible="1"/>
                        </group>

                        <group>
                            <field name="customer_id" attrs="{'readonly': ['|', ('is_cco', '=', False), ('status', 'in', ['approved','archived'])], 'required': [('is_cco', '=', True)]}"/>
                        </group>

                        <group>
                            <field name="description" placeholder="Reason Initiated" attrs="{'readonly': ['|', ('is_cco', '=', False), ('status', 'in', ['approved','archived'])], 'required': [('is_cco', '=', True)]}"/>
                            <field name="status" invisible="1"/>
                        </group>
                           <group>
                            <field name="customer_type"  attrs="{'readonly': ['|', ('is_cco', '=', False), ('status', 'in', ['approved','archived'])], 'required': [('is_cco', '=', True)]}"/>
                            <field name="status" invisible="1"/>
                        </group>

                        <group>
                            <field name="approving_officer_id" attrs="{'readonly': ['|', ('is_cco', '=', False), ('status', 'in', ['approved','archived'])], 'required': [('is_cco', '=', True)]}"/>
                            <field name="is_current_user_approving_officer" invisible="1"/>
                            <field name = "approving_signature_filename" invisible="1"/>
                            <field name="approving_officer_signature"  
                            widge="image"
                            filename="approving_signature_filename"
                            attrs="{
                                    'readonly': ['|', ('is_current_user_approving_officer', '=', False), ('status', '!=', 'completed')],
                                    'required': ['&amp;', ('is_current_user_approving_officer', '=', True), ('status', '=', 'completed')],
                                    'invisible': [('status', '=', 'draft')]
                                }"/>
                        </group>

                        <group>
                            <field name="responsible_id" string="Officer in Charge" attrs="{'readonly': ['|', ('is_cco', '=', False), ('status', 'in', ['approved','archived'])], 'required': [('is_cco', '=', True)]}"/>
                            <field name="is_current_user_responsible" invisible="1"/>
                            <field name="responsible_signature_filename" invisible="1"/>
                            <field name="responsible_officer_signature"  
                            widge="image"
                            filename="responsible_signature_filename"
                            attrs="{
                                'readonly': ['|', ('is_current_user_responsible', '=', False), ('status', '!=', 'draft')],
                                'required': [('is_current_user_responsible', '=', True)]
                            }"/>

                            
                            <field name="is_current_user_responsible" invisible="1"/>
                        </group>

                        <group>
                            <field name="approved_by" attrs="{'invisible': [('status', 'in', ['draft', 'cancelled', 'deleted','completed'])]}" />

                        </group>
                        
                        <group>
                            <field name="date_approved" attrs="{'invisible': [('status', 'in', ['draft', 'cancelled', 'deleted','completed'])]}"/>
                            <field name="is_current_user_approver" invisible="1"/>
                            <field name="is_current_user_approving_officer" invisible="1"/>
                        </group>

                    </group>

                    <notebook>
                        <page string="Risk Assessment">
                            <group>
                                <group>
                                    <field name="risk_score" widget="slider" step="0.5" min="0.5" max="9" 
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="has_initiated_new_kyc" 
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="was_kyc_comprehensive" 
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="last_kyc_date" 
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="account_status" 
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="documentation_status" 
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Customer Assessment">
                            <group>
                                <group colspan="2">
                                        <field name="visitation_observation" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>

                                        <field name="overall_kyc_outcome" placeholder="overall kyc outcome" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                                  <group colspan="2">
                                        <field name="occupation" string="Occupation/Employment Profile" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    </group>
                             
                                   <group>
                                        <field name="is_current_from_normal" string="Is Current Inflow From Normal Business" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    </group>

                                    <group>
                                        <field name="does_business_support_volume" string="Does Nature of Business Support Volume and Velocity Of Inflows" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    </group>
                            </group>
                        </page>

                        <page string="Additional Information">
                            <group>
                                <group colspan="2">
                                    <field name="main_cash_purpose" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>

                                    <field name="main_inflow_purpose" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>

                                    <field name="main_fund_remitters" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>

                                    <field name="inflow_sources" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>

                                    <field name="other_related_accounts" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>

                                    <field name="supporting_document" widget="many2many_binary" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                            </group>
                        </page>

                    <page string="Due Diligence">
                        <!-- Corporate Customer Section -->
                        <group attrs="{'invisible': [('customer_type', '!=', 'corporate')]}">  
                            <group string="Corporate Profile Information" name="corporate_profile_info">
                                <field name="brief_customer_profile" 
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                <field name="nature_of_business"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                <field name="kycc_info"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                <field name="customer_address"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                            </group>
                            <group string="Company Registration and Legal Information" name="corporate_legal_info">
                                <field name="company_registration_number"
                                  attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                <field name="signatories_details"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                <field name="beneficial_owner_details"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                            </group>

                            <group string="Corporate Citizenship Info" name="corporate_citizenship_info">
                                <field name="dual_citizenship_info"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                <field name="citizenship_country_ids" widget="many2many_tags"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                            </group>
                        </group>

                        <group attrs="{'invisible': [('customer_type', '!=', 'corporate')]}">    
                            <group string="Corporate Financial Details" name="corporate_financial_details">
                                <field name="high_risk_industries"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                <field name="expected_monthly_income"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                <field name="estimated_net_worth"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>  
                            </group>

                            <group string="Corporate PEP Information" name="corporate_pep_info">
                                <field name="pep_association"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                
                                <field name="pep_relationship_details" 
                                    attrs="{'invisible': [('pep_association', '=', False)],
                                            'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate'), ('pep_association', '=', True)], 'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>

                                <field name="third_party_involvement"
                                    attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate')], 
                                            'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>

                                <field name="third_party_details" 
                                    attrs="{'invisible': [('third_party_involvement', '=', False)],
                                            'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'corporate'), ('third_party_involvement', '=', True)], 
                                            'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}" />

                                <field name="third_party_document" widget="many2many_binary" 
                                    attrs="{'invisible': [('third_party_involvement', '=', False)], 
                                            'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                            </group>
                        </group>
                        

                            <!-- Individual Customer Section -->
                        <group attrs="{'invisible': [('customer_type', '!=', 'individual')]}">
                                <group string="Individual Profile Information" name="individual_profile_info">
                                    <field name="brief_customer_profile"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="nature_of_business"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="employment_position"
                                         attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="employer_name"
                                         attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>

                                <group string="Residency Information" name="individual_residency_info">
                                    <field name="customer_address"
                                         attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="residency_status"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>                  
                                    
                                    <field name="applicable_country_ids" widget="many2many_tags"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                        </group>

                        <group attrs="{'invisible': [('customer_type', '!=', 'individual')]}">  
                                <group string="Individual Financial Details" name="individual_financial_details">
                                    <field name="expected_monthly_income"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="estimated_net_worth"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>           
                                </group>

                                <group string="Individual PEP Information" name="individual_pep_info">
                                    <field name="is_customer_pep"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="relationship_with_pep" 
                                        attrs="{'invisible': [('is_customer_pep', '=', False)],
                                                'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('customer_type', '=', 'individual'), ('is_customer_pep', '=', True)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}" />
                                </group>
                        </group>

                            <!-- Common Fields Section (applies to both Corporate and Individual) -->
                        <group>
                                <group string="Source of Funds/Wealth" name="financial_info">
                                    <field name="expected_source_of_funds"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="source_of_funds_document" widget="many2many_binary"
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="source_of_wealth"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="source_of_wealth_document" widget="many2many_binary"
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                                    
                                <group string="Transaction Details" name="transaction_details">
                                    <field name="inflow_purpose"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="inflow_document" widget="many2many_binary"
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="outflow_purpose"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                    
                                    <field name="outflow_document" widget="many2many_binary"
                                        attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>
                                </group>
                        </group>

                        <group>   
                                <group string="Media Publicity" name="media_info">
                                    <field name="has_negative_media"
                                        attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}"/>   
                                    
                                    <field name="negative_media_details" 
                                        attrs="{'invisible': [('has_negative_media', '=', False)],
                                                'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False), ('has_negative_media', '=', True)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}" />  
                                    
                                    <field name="negative_media_document" widget="many2many_binary"
                                        attrs="{'invisible': [('has_negative_media', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived', 'completed']), ('is_current_user_responsible', '=', False)]}" />
                                </group>

                                <group string="Cross-Border Transactions" name="cross_border_info">
