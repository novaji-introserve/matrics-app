<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="compliance_customer_account_tree" model="ir.ui.view">
        <field name="name">res_customer_account_tree</field>
        <field name="model">res.partner.account</field>
        <field name="arch" type="xml">
            <tree string="Account" create="false">
                <field name="name" string="Account Number" />
                <field name="account_name" optional="show"/>
                <field name="branch_id" optional="show"/>
                <!-- <field name="currency_id" optional="show"/> -->
                <!-- <field name="account_type_id" optional="show"/> -->
                <!-- <field name="product_id" optional="show"/> -->
                <field name="currency" readonly="1" />
                <field name="account_type" readonly="1" />
                <field name="account_position" readonly="1" />

                <field name="risk_score" optional="show"/>
                <field name="risk_level" widget="badge" decoration-danger="risk_level == 'high'" decoration-warning="risk_level in ('medium')" decoration-success="risk_level in ('low')" optional="show"/>
                <field name="account_tier" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'Active'" decoration-warning="state in ('Dormant', 'Flagged')" decoration-danger="state in ('Inactive', 'Closed')" optional="show"/>
                <field name="date_created" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="customer_account_view_form" model="ir.ui.view">
        <field name="name">customer.account.view.form</field>
        <field name="model">res.partner.account</field>
        <field name="arch" type="xml">
            <form readonly="1">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="Active,Inactive,Dormant,Flagged,Closed" clickable="True" />
                </header>
                <sheet string="Account">
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="get_risk_level" icon="fa-thermometer-0">
                            <span>Risk 
                                <field string="Risk Level" name="risk_level" widget="badge" decoration-danger="risk_level == 'high'" decoration-warning="risk_level in ('medium')" decoration-success="risk_level in ('low')"/>
                            </span>

                        </button>
                        <button class="oe_stat_button" type="object" name="get_risk_score" icon="fa-star">
                            <field string="Risk Score" name="risk_score" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="get_balance" icon="fa-money">
                            <field string="Balance" name="balance" widget="monetary" readonly="True" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <div class="row">
                        <div class="col col-md-auto">
                            <label for="account_name" string="Account Name" />
                            <div>
                                <field name="account_name" class="oe_inline" readonly="1" />
                                <field name="active" invisible="1"/>
                            </div>
                        </div>
                    </div>

                    <notebook>
                        <page name="details" string="Account Information">
                            <group>
                                <group>
                                    <field name="customer_id" readonly="1" />
                                    <field name="account_type" readonly="1" />
                                    <field name="account_position" readonly="1" />
                                    <field name="account_officer_id" readonly="1" />
                                    <field name="account_tier" readonly="1"/>
                                    <field name="uncleared_balance" readonly="1" />
                                    <field name="start_year_balance" readonly="1" />
                                    <field name="opening_date" readonly="1" />
                                </group>
                                <group>
                                    <field name="product_id" readonly="1" />
                                    <field name="currency" readonly="1" />
                                    <field name="category" readonly="1" />
                                    <field name="is_joint_account" readonly="1" />
                                    <field name="category_description" readonly="1" />
                                    <field name="branch_id" readonly="1" />
                                    <field name="risk_assessment" readonly="1" />
                                    <!-- <field name="date_created" readonly="1" /> -->
                                    <!-- <field name="closure_status" readonly="1" /> -->
                                    <!-- <field name="ledger_id" readonly="1" /> -->
                                </group>
                            </group>
                            <group>
                                <separator />
                            </group>
                        </page>
                        <page name="transaction_profile" string="Transaction Profile">
                            <group>

                                <group >
                                    <field name="last_transaction_date" readonly="1" />
                                    <field name="max_debit_daily" readonly="1" />
                                    <field name="overdraft_limit" readonly="1" />
                                </group>

                                <group>
                                    <field name="date_last_credit_customer" readonly="1" />
                                    <field name="amount_last_credit_customer" readonly="1" />
                                    <field name="date_last_debit_customer" readonly="1" />

                                </group>

                            </group>
                            <!-- <group>
                                <separator />
                            </group> -->
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
    <record id="view_customer_account_search" model="ir.ui.view">
        <field name="name">Customer Account Search</field>
        <field name="model">res.partner.account</field>
        <field name="priority" eval="10" />
        <field name="arch" type="xml">
            <search string="Search Account">
                <field name="name" />
                <field name="customer_id" />
                <field name="category"/>
                <field name="account_tier"/>

                <!-- Account Tier Filters -->
                <filter string="Tier 1" name="tier_1" domain="[('account_tier', '=', 'tier_1')]"/>
                <filter string="Tier 2" name="tier_2" domain="[('account_tier', '=', 'tier_2')]"/>
                <filter string="Tier 3" name="tier_3" domain="[('account_tier', '=', 'tier_3')]"/>

                <separator />
                <group expand="0" name="group_by" string="Group By">
                    <filter name="group_branch" string="Branch" domain="[]" context="{'group_by' : 'branch_id'}" />
                    <filter name="group_currency" string="Currency" context="{'group_by': 'currency_id'}" />
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}" />
                    <filter name="group_account_type" string="Account Type" context="{'group_by': 'account_type_id'}" />
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}" />
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category'}"/>

                </group>
            </search>
        </field>
    </record>
    <record id="open_accounts" model="ir.actions.server">
        <field name="name">Open Accounts</field>
        <field name="model_id" ref="model_res_partner_account" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_accounts()</field>
    </record>
    <menuitem id="menu_compliance_accounts" action="open_accounts" parent="menu_compliance_kyc" name="Accounts" groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer" sequence="20" />

</odoo>