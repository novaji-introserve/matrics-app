<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- High Risk Jurisdiction Views -->
    <record id="view_high_risk_jurisdiction_tree" model="ir.ui.view">
        <field name="name">res.high.risk.jurisdiction.tree</field>
        <field name="model">res.high.risk.jurisdiction</field>
        <field name="arch" type="xml">
            <tree string="High Risk Jurisdictions" decoration-danger="risk_level=='extreme'" decoration-warning="risk_level=='high'" decoration-info="risk_level=='medium'" decoration-success="risk_level=='low'">
                <field name="name"/>
                <field name="country_code"/>
                <field name="risk_score"/>
                <field name="risk_level"/>
                <field name="last_updated"/>
            </tree>
        </field>
    </record>

    <record id="view_high_risk_jurisdiction_form" model="ir.ui.view">
        <field name="name">res.high.risk.jurisdiction.form</field>
        <field name="model">res.high.risk.jurisdiction</field>
        <field name="arch" type="xml">
            <form string="High Risk Jurisdiction">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Country/Region Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="country_code"/>
                            <field name="risk_score" widget="percentage"/>
                            <field name="risk_level"/>
                        </group>
                        <group>
                            <field name="last_updated"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Risk Factors">
                            <field name="factors" widget="html"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_high_risk_jurisdiction_search" model="ir.ui.view">
        <field name="name">res.high.risk.jurisdiction.search</field>
        <field name="model">res.high.risk.jurisdiction</field>
        <field name="arch" type="xml">
            <search string="Search High Risk Jurisdictions">
                <field name="name"/>
                <field name="country_code"/>
                <filter string="High Risk" name="high_risk" domain="[('risk_level', 'in', ['high', 'extreme'])]"/>
                <filter string="Medium Risk" name="medium_risk" domain="[('risk_level', '=', 'medium')]"/>
                <filter string="Low Risk" name="low_risk" domain="[('risk_level', '=', 'low')]"/>
                <group expand="0" string="Group By">
                    <filter string="Risk Level" name="group_by_risk_level" context="{'group_by': 'risk_level'}"/>
                </group>
            </search>
        </field>
    </record>

 

   
    

