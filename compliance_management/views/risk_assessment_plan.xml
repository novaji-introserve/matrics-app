<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Risk Analysis Report -->
    <record id="compliance_risk_assessment_plan_tree" model="ir.ui.view">
        <field name="name">compliance_risk_assessment_plan_tree</field>
        <field name="model">res.compliance.risk.assessment.plan</field>
        <field name="arch" type="xml">
            <tree string="Customer Risk Analysis">
                <field name="name" />
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-warning="state == 'inactive'" />
                <field name="priority" />
                 <field name="compute_score_from" />
                <field name="risk_assessment" />
                <field name="risk_assessment_score" />
                <field name="risk_score" string="Static Risk Score" />
                <field name="create_uid" />
                <field name="create_date" />
            </tree>
        </field>
    </record>
    <record id="compliance_risk_assessment_plan_search" model="ir.ui.view">
        <field name="name">compliance_risk_assessment_plan_search</field>
        <field name="model">res.compliance.risk.assessment.plan</field>
        <field name="arch" type="xml">
            <search string="Customer Risk Analysis">
                <field name="name" />
                <field name="code" />
                <field name="risk_assessment" />
                <filter string="Active" name="filter_state_active" domain="[('state', '=', 'active')]" />
                <filter string="Inactive" name="filter_state_inactive" domain="[('state', '=', 'inactive')]" />
                <separator />
                <group expand="0" string="Group By">
                    <filter string="Internal Category" name="group_internal_category" context="{'group_by': 'internal_category'}" />
                    <filter string="Risk Universe" name="group_universe_id" context="{'group_by': 'universe_id'}" />
                    <filter string="Risk Subject" name="group_subject_id" context="{'group_by': 'subject_id'}" />
                    <filter string="Risk Type" name="group_type_id" context="{'group_by': 'type_id'}" />
                    <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                </group>
            </search>
        </field>
    </record>
    <!-- Risk Assessment Form -->
    <record id="compliance_risk_assessment_plan_form" model="ir.ui.view">
        <field name="name">Customer Risk Analysis</field>
        <field name="model">res.compliance.risk.assessment.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" class="oe_highlight" type="object"
                        string="Activate Plan"
                        groups="compliance_management.group_compliance_compliance_risk_manager"
                        confirm="Activate this Plan. Are you sure?"
                        attrs="{'invisible': [('state', 'not in',['draft','inactive'])]}" />
                    <button name="action_deactivate" type="object" string="Deactivate Plan"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Deactivate this Plan. Are you sure?"
                        attrs="{'invisible': [('state','not in',['active','draft'])]}" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,inactive"
                        clickable="True" />
                </header>
                <sheet string="Risk Analysis">

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="risk_assessment" nocreate="True" noedit="True" />
                            <field name="risk_score" widget="slider" step="1" min="1" max="eval()" />
                        </group>
                        <group>
                            <field name="compute_score_from" />
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="code" />
                        </group>
                        <group>
                            <field name="priority" />
                        </group>
                        <group>
                            <field name="use_composite_calculation" widget="boolean_toggle" />
                        </group>

                        <group
                            attrs="{'required': [('use_composite_calculation', '=', True)], 'invisible': [('use_composite_calculation', '=', False)]}">
                            <field name="universe_id"
                                attrs="{'required': [('use_composite_calculation', '=', True)], 'invisible': [('use_composite_calculation', '=', False)]}" />
                        </group>
                    </group>
                    <notebook colspan="4">
                        <page name='plan_query' string="Plan SQL Query" autofocus="autofocus">
                            <field name="sql_query"
                                placeholder="SQL Query returning a single value..." widget="ace" />
                            <div class="alert alert-info" role="alert" name="sql_tips"> Customer ID
                                will be replaced with the %s placeholder value and used to evaluate
                                for each customer. The query result will be returned as the risk
                                score<br /> Example SQL Query to give all customers without BVN a
                                risk score: <br />
                <code>SELECT 17 FROM res_partner WHERE id = %s AND bvn IS NULL</code>
                            </div>
                        </page>
                        <page name='condition_python' string="Rule Python Code">
                            <field name="condition_python"  widget="ace"/>
                            <div class="alert alert-info" role="alert" name="test_warning"> You can
                                use the following variables in the Python code:
                                <br /> # customer: object containing the customer
                                <br /> # branch: object containing the branch<br />
                                # env: environment object<br />
                                #----------------------<br /> # Note: returned value have to be set
                                in the variable 'result'<br /> result = 100 if customer.is_pep == True else 1<br />
                            </div>
                        </page>
                        <page name='internal_notes' string="Internal Notes">
                            <field name="narration" placeholder="Narration..." />
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

</odoo>
