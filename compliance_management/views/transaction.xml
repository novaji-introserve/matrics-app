<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="compliance_transaction_tree" model="ir.ui.view">
        <field name="name">res_cust_transaction_tree</field>
        <field name="model">res.customer.transaction</field>
        <field name="arch" type="xml">
            <tree string="Transactions">
                <field name="name" string="Reference Number" />
                <field name="account_id" />
                <field name="branch_id" />
                <field name="currency_id" />
                <field name="amount" />
                <field name="tran_type" />
                <field name="rule_id" />
                <field name="risk_level" widget="badge" decoration-danger="risk_level == 'high'"
                    decoration-warning="risk_level in ('medium')"
                    decoration-success="risk_level in ('lowel')" />
                <field name="date_created" />
            </tree>
        </field>
    </record>
    <!-- Risk Assessment Form -->
    <record id="compliance_transaction_form" model="ir.ui.view">
        <field name="name">Transaction Form</field>
        <field name="model">res.customer.transaction</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_screen" class="oe_highlight" type="object"
                        string="Run Transaction Screening"
                        groups="compliance_management.group_compliance_compliance_risk_manager"
                        confirm="Run screening rules. All transaction screening rulles will be applied. The first exception found will flagged. Are you sure?" />
                </header>
                <sheet string="Transaction">
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="get_risk_level"
                            icon="fa-thermometer-0">
                            <span>Risk <field string="Risk Level" name="risk_level" widget="badge"
                                    decoration-danger="risk_level == 'high'"
                                    decoration-warning="risk_level in ('medium')"
                                    decoration-success="risk_level in ('lowel')" />
                            </span>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <div class="oe_title">
                        <label for="amount" class="oe_edit_only" />
                        <h1>
                            <field name="amount" readonly="1" />
                        </h1>
                    </div>

                    <notebook colspan="4">
                        <page name='details' string="Transaction Details" autofocus="autofocus">
                            <group>
                                <group>
                                    <field name="customer_id" readonly="1" />
                                    <field name="account_id" readonly="1" />
                                </group>
                                <group>
                                    <field name="currency_id" readonly="1" />
                                    <field name="branch_id" readonly="1" />
                                    <field name="rule_id" readonly="1" />
                                </group>
                                <group>
                                    <field name="tran_type" readonly="1" />
                                    <field name="date_created" string="Transaction Date"
                                        readonly="1" />
                                </group>
                            </group>
                        </page>
                        <page name='internal_notes' string="Narration">
                            <field name="narration" readonly="1" />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
    <record id="view_customer_trans_search" model="ir.ui.view">
        <field name="name">Customer Transaction Search</field>
        <field name="model">res.customer.transaction</field>
        <field name="priority" eval="10" />
        <field name="arch" type="xml">
            <search string="Search Transaction">
                <field name="name" />
                <field name="customer_id" />
                <separator />
                <group expand="0" name="group_by" string="Group By">
                    <filter name="group_branch" string="Branch" domain="[]"
                        context="{'group_by' : 'branch_id'}" />
                    <filter name="group_currency" string="Currency"
                        context="{'group_by': 'currency_id'}" />
                    <filter name="group_tran_type" string="Transaction Type"
                        context="{'group_by': 'tran_type'}" />
                </group>
            </search>
        </field>
    </record>
    <record id="open_transactions" model="ir.actions.server">
        <field name="name">Open Transactions</field>
        <field name="model_id" ref="model_res_customer_transaction" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_transactions()</field>
    </record>
    <menuitem
        id="menu_compliance_transaction_monitoring"
        parent="menu_compliance_kyc"
        name="Transaction Monitoring"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="30" />
    <menuitem
        id="menu_compliance_transactions"
        action="open_transactions"
        parent="menu_compliance_transaction_monitoring"
        name="Transactions"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="10" />

</odoo>