<odoo>
    <data>
        <!-- Action for PEP -->
        <record id="action_res_pep" model="ir.actions.act_window">
            <field name="name">PEP List</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[('is_pep', '=', True)]</field>
        </record>

        <!-- Action for FEP -->
        <record id="action_res_partner_fep" model="ir.actions.act_window">
            <field name="name">FEP List</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[('is_fep', '=', True)]</field>
        </record>
        <!-- Actions for Blacklist-->
        <record id="action_res_partner_blacklist" model="ir.actions.act_window">
            <field name="name">Black List</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[('is_blacklist', '=', True)]</field>
        </record>

        <record id="action_res_partner_watchlist" model="ir.actions.act_window">
            <field name="name">Watchlist</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[('is_watchlist', '=', True)]</field>
        </record>

        <!-- Actions for Greylist-->
        <record id="action_res_partner_greylist" model="ir.actions.act_window">
            <field name="name">Grey List</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[('is_greylist', '=', True)]</field>
        </record>

        <!-- Form Views for Global PEP -->
        <!-- Views for Global PEP List-->
        <record id="view_res_global_pep_tree" model="ir.ui.view">
            <field name="name">res.pep.tree</field>
            <field name="model">res.pep</field>
            <field name="arch" type="xml">
                <tree string="Global PEP List">
                    <field name="unique_identifier" />
                    <field name="name" />
                    <field name="surname" />
                    <field name="first_name" />
                    <field name="title" />
                    <field name="status" />
                    <field name="pep_classification" />
                    <field name="present_position" />
                    <field name="createdon" />
                    <field name="lastmodifiedon" />
                </tree>
            </field>
        </record>
        <record id="view_res_global_pep_form" model="ir.ui.view">
            <field name="name">res.pep.form</field>
            <field name="model">res.pep</field>
            <field name="arch" type="xml">
                <form string="Global PEP List">
                    <header>
                    
                        <button name="action_find_person" class="oe_highlight" type="object"
                            string="Find Biography"
                            groups="compliance_management.group_compliance_compliance_risk_manager" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" placeholder="Name" />
                            </h1>
                        </div>
                        <div class="oe_title">
                            <label for="unique_identifier" class="oe_edit_only" />
                            <h1>
                                <field name="unique_identifier" placeholder="Name" />
                            </h1>
                        </div>
                        <group>
                            <group string="Personal Information">
                                <field name="surname" />
                                <field name="first_name" />
                                <field name="middle_name" />
                                <field name="title" />
                                <field name="aka" />
                                <field name="sex" />
                                <field name="date_of_birth" />
                                <field name="age" />
                                <field name="email" />
                                <field name="place_of_birth" />
                                <field name="state_of_origin" />
                            </group>
                            <group>
                                <field name="citizenship" />
                                <field name="present_position" />
                                <field name="previous_position" />
                                <field name="pep_classification" />
                                <field name="profession" />
                                <field name="status" />
                                <field name="business_interest" />
                            </group>
                        </group>

                        <notebook>
                            <page name="info" string="Biography">
                                <field name="narration" />
                            </page>
                            <page name="family" string="Family and Contacts">
                                <group>
                                    <group string="Contact Information">
                                        <field name="official_address" />
                                        <field name="residential_address" />
                                    </group>
                                    <group string="Family Information">
                                        <field name="spouse" />
                                        <field name="children" />
                                        <field name="sibling" />
                                        <field name="parents" />
                                        <field name="mothers_maden_name" />
                                    </group>
                                </group>
                            </page>
                            <page name="education" string="Education">
                                <field name="education" />
                            </page>
                            <page name="career" string="Career">
                                <field name="career_history" />
                            </page>
                            <page string="Associates">
                                <group>
                                    <field name="associates__business_political_social_" />
                                    <field name="associate_business_politics" />
                                    <field name="bankers" />
                                    <field name="account_details" />

                                </group>
                            </page>
                            <page string="Reports &amp; Remarks">
                                <group>
                                    <field name="press_report" />
                                    <field name="date_report" />
                                    <field name="remarks" />
                                    <field name="additional_info" />
                                </group>
                            </page>
                            <page string="Audit Information">
                                <group>
                                    <field name="createdby" />
                                    <field name="createdon" />
                                    <field name="createdbyemail" />
                                    <field name="lastmodifiedby" />
                                    <field name="lastmodifiedon" />
                                    <field name="lastmodifiedbyemail" />
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" />
                        <field name="activity_ids" />
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>

        <record id="view_global_pep_search" model="ir.ui.view">
            <field name="name">Global PEP Search</field>
            <field name="model">res.pep</field>
            <field name="priority" eval="10" />
            <field name="arch" type="xml">
                <search string="Search PEP">
                    <field name="first_name" />
                    <field name="surname" />
                </search>
            </field>
        </record>


        <!--  Action For Global PEP-->
        <record id="action_res_global_pep" model="ir.actions.act_window">
            <field name="name">Global PEP List</field>
            <field name="res_model">res.pep</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_res_global_pep_tree" />
        </record>


        <!-- Menu Items -->

        <menuitem
            id="menu_sanction_screening_root"
            name="Sanction screening"
            groups="group_compliance_compliance_officer"
            parent="menu_compliance_root"
            sequence="150" />

        <menuitem
            id="menu_is_pep"
            action="action_res_pep"
            parent="menu_sanction_screening_root"
            name="PEP List"
            groups="group_compliance_compliance_officer"
            sequence="10" />

        <menuitem
            id="menu_is_fep"
            action="action_res_partner_fep"
            parent="menu_sanction_screening_root"
            name="FEP List"
            groups="group_compliance_compliance_officer"
            sequence="20" />

        <menuitem
            id="menu_watchlist"
            action="action_res_partner_watchlist"
            parent="menu_sanction_screening_root"
            name="Watchlist"
            groups="group_compliance_compliance_officer"
            sequence="30" />

        <menuitem
            id="menu_blacklist"
            action="action_res_partner_blacklist"
            parent="menu_sanction_screening_root"
            name="Blacklist"
            groups="group_compliance_compliance_officer"
            sequence="40" />

        <menuitem
            id="menu_global_pep_list"
            action="action_res_global_pep"
            parent="menu_sanction_screening_root"
            name="Global PEP List"
            groups="group_compliance_compliance_officer"
            sequence="50" />
        
        <menuitem
            id="menu_greylist"
            action="action_res_partner_greylist"
            parent="menu_sanction_screening_root"
            name="Greylist"
            groups="group_compliance_compliance_officer"
            sequence="60" />
        

    </data>
</odoo>