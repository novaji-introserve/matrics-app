<odoo>
    <record id="contacts.action_contacts" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form,activity</field>
        <field name="search_view_id" ref="base.view_res_partner_filter" />
        <field name="context">{'default_is_company': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Customer
            </p>
            <p>
                Track all activities related to your customers
            </p>
        </field>
    </record>

    <record model="ir.ui.view" id="partner_inherit_form_view">
        <field name="name">compliance.customer.form.view</field>
        <field name="model">res.partner</field>
        <field name="priority">1500</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="sector_id"/>
                <field name="region_id"/>
                <field name="registration_date" />
                <field name="company_reg_date" />
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="internal_category"/>
            </xpath>
            <xpath expr="//page[@name='contact_addresses']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <xpath expr="//page[@name='contact_addresses']" position="before">
                <page name='compliance' string="Personal Information" autofocus="autofocus">
                    <group>
                        <group string="Personal Information" name="personal" priority="1">
                            <field name="firstname" />
                            <field name="lastname" />
                            <field name="middlename" />
                            <field name="othername" />
                            <field name="dob" />
                            <field name="education_level_id" />
                            <field name="sex_id" />
                            <field name="town" />
                            <field name="internal_category" invisible="1" />
                        </group>
                        <group string="Identification" name="identification">
                            <field name="customer_id" />
                            <field name="branch_id" />
                            <field name="account_officer_id" />
                            <field name="bvn" />
                            <field name="identification_type_id" />
                            <field name="identification_number" />
                            <field name="identification_expiry_date" />
                        </group>
                    </group>
                </page>
            </xpath>

            <xpath expr="//page[@name='contact_addresses']" position="before">
                <page name='risk_assessment' string="Risk Assessment">
                    <field name="risk_assessment_ids"
                        view_ref="compliance_customer_risk_assessment_tree"
                        context="{'default_partner_id': active_id}" />
                </page>
                <page name="due_diligence" string="Due Diligence" attrs="{'invisible' : [('internal_category', '!=', 'vendor')]}" >
                    <group>
                        <group>
                            <field name="anti_bribery" filename="anti_bribery_file_name"/>
                            <field name="anti_bribery_file_name" invisible="1"/>
                            <field name="whistle_blowing" filename="whistle_blowing_file_name"/>
                            <field name="whistle_blowing_file_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="data_protection" filename="data_protection_file_name"/>
                            <field name="data_protection_file_name" invisible="1"/>
                            <field name="anti_money_laundering" filename="anti_money_laundering_file_name" />
                            <field name="anti_money_laundering_file_name" invisible="1"/>
                        </group>
                    </group>
                   
                </page>
                <page name='sanction_screening' string="Sanction Screening">
                    <group name="sanction" string="Sanction Screening">
                        <field name="is_pep" attrs="{'readonly': True}" />
                        <field name="is_fep" attrs="{'readonly': True}" />
                        <field name="is_blacklist" attrs="{'readonly': True}" />
                        <field name="is_watchlist" attrs="{'readonly': True}" />
                        <field name="global_pep" attrs="{'readonly': True}" />
                    </group>
                </page>
                
            </xpath>

            <!-- Add EDD Page to Customer Form -->
            <xpath expr="//page[@name='contact_addresses']" position="before">
                <!-- <notebook position="inside"> -->
                <page string="Enhanced Due Diligence" name="edd_record">
                    <field name="edd_ids" nolabel="1">
                        <tree string="EDD Record">
                            <field name="name" />
                            <field name="status" />
                            <field name="customer_id" />
                            <field name="responsible_id" />
                            <field name="user_id" />
                            <field name="approved_by" />
                            <field name="date_approved" />
                            <field name="risk_score" />
                            <field name="account_status" />
                            <field name="documentation_status" />
                        </tree>
                        <form string="EDD Record">
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name" />
                                        <field name="status" />
                                        <field name="customer_id" />
                                        <field name="responsible_id" />
                                        <field name="user_id" />
                                        <field name="approved_by" />
                                        <field name="date_approved" />
                                        <field name="risk_score" />
                                        <field name="account_status" />
                                        <field name="documentation_status" />
                                    </group>
                                    <group>
                                        <field name="is_foreigner" />
                                        <field name="is_pep" />
                                        <field name="id_expired" />
                                        <field name="activity_level_matches_business" />
                                        <field name="was_kyc_comprehensive" />
                                        <field name="has_initiated_new_kyc" />
                                        <field name="is_current_from_normal" />
                                        <field name="does_business_support_volume" />
                                        <field name="last_kyc_date" />
                                    </group>
                                </group>
                                <notebook>
                                    <page string="Details">
                                        <group>
                                            <group string="Description">
                                                <field name="description" nolabel="1" />
                                            </group>
                                            <group string="Visitation Observation">
                                                <field name="visitation_observation" nolabel="1" />
                                            </group>
                                        </group>
                                        <group>
                                            <group string="KYC Information">
                                                <field name="overall_kyc_outcome" nolabel="1" />
                                            </group>
                                        </group>
                                    </page>
                                    <page string="Transaction Information">
                                        <group>
                                            <group string="Cash Information">
                                                <field name="main_cash_purpose" nolabel="1" />
                                            </group>
                                            <group string="Inflow Information">
                                                <field name="main_inflow_purpose" nolabel="1" />
                                                <field name="main_fund_remitters" nolabel="1" />
                                                <field name="inflow_sources" nolabel="1" />
                                            </group>
                                        </group>
                                        <group>
                                            <group string="Additional Information">
                                                <field name="other_related_accounts" nolabel="1" />
                                                <field name="occupation" nolabel="1" />
                                            </group>
                                        </group>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </page>
                <!-- </notebook> -->
            </xpath>

        </field>
    </record>

    <!-- Edd Tree View -->
    <record id="edd_tree_view" model="ir.ui.view">
        <field name="name">res.partner.edd.tree</field>
        <field name="model">res.partner.edd</field>
        <field name="arch" type="xml">
            <!-- <tree string="Enhanced Due Diligence " delete="false"> -->
           <tree string="Enhanced Due Diligence ">
                <field name="customer_id" />
                <field name="responsible_id" string="Responsible" />
                <field name="user_id" string="Initiated By" />
                <field name="risk_score" />
                <field name="approved_by" string="Approved By" />
                <field name="date_approved" />
                <field name="status"
                    decoration-info="status == 'draft'"
                    decoration-success="status == 'approved'"
                    decoration-warning="status == 'cancelled'"
                    decoration-danger="status == 'deleted'"
                    decoration-primary="status == 'completed'"
                    widget="badge" />
                <field name="last_kyc_date" />
                <field name="create_date" string="Created On" />
            </tree>
        </field>
    </record>


    <!-- Edd Form View -->
    <record id="edd_form_view" model="ir.ui.view">
        <field name="name">res.partner.edd.form</field>
        <field name="model">res.partner.edd</field>
        <field name="arch" type="xml">
            <form string="Manage Enhanced Due Diligence" delete="false">
                <header>

                    <button
                        name="action_submit_for_review"
                        class="oe_highlight"
                        type="object"
                        string="Submit for Review"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        attrs="{'invisible': ['|', ('status', '!=', 'draft'), ('is_current_user_responsible', '=', False)]}" />

                    <button name="action_approve"
                        class="oe_highlight"
                        type="object"
                        string="Approve"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        attrs="{'invisible': [ '|', ('status', '!=', 'completed'), ('is_current_user_approving_officer', '=', False)]}"
                    />

                    <button name="action_cancel"
                        class="oe_highlight"
                        type="object"
                        string="Cancel"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        attrs="{'invisible': ['|', ('status', 'in', ['cancelled', 'approved', 'draft']), ('is_current_user_approving_officer', '=', False)]}"
                    />

                    <button name="action_archive"
                        class="oe_highlight"
                        type="object"
                        string="Archive"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        attrs="{'invisible': [('status', 'not in', ('cancelled'))]}"
                    />

                    <button name="action_send_back"
                        class="oe_highlight"
                        type="object"
                        string="Send Back"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        attrs="{'invisible': ['|', ('status', '=', 'draft'), ('is_current_user_approving_officer', '=', False), ('status', '!=', 'archived'),]}"
                    />

                    <field name="status" widget="statusbar"
                        statusbar_visible="draft,completed,approved,cancelled,deleted,archived" />
                </header>

                <sheet>
                    <group>
                        <group colspan="2">
                            <field name="name" />
                        </group>
                        <group colspan="2">
                            <field name="description" placeholder="Reason Initiated" />
                        </group>
                        <group colspan="2">
                            <field name="customer_id" />
                        </group>
                        <group>
                            <field name="approving_officer_id" />
                             <field name="is_current_user_approving_officer" invisible="1"/>
                         </group>
                        <group>
                            <field name="responsible_id" string="Officer in Charge" />
                            <field name="is_current_user_responsible" invisible="1" />
                        </group>
                        <!-- <group>
                            <field name="status" />
                            <field name="user_id" string="Initiated By" />
                        </group> -->
                        <group>
                            <field name="approved_by" />
                            <field name="is_current_user_approver" invisible="1" />
                        </group>
                        <group>
                            <field name="date_approved" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Complete Enhanced Due Diligence">
                            <group>
                                <group>
                                    <field name="risk_score" widget="slider"
                                           step="0.5" min="0.5" max="25" />
                                    <field name="has_initiated_new_kyc" />
                                </group>
                                <group>
                                    <field name="was_kyc_comprehensive" />
                                    <field name="last_kyc_date" />
                                </group>
                                <group>
                                    <field name="account_status" />
                                </group>
                                <group>
                                    <field name="documentation_status" />
                                </group>
                            </group>
                            <separator string="" />
                            <group string="Customer Assessment">
                                <group colspan="2">
                                    <field name="visitation_observation" />
                                </group>
                                <group colspan="2">
                                    <field name="overall_kyc_outcome"
                                        placeholder="overall kyc outcome" />
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="is_foreigner" string="Is Customer a Foreigner?" />
                                    <field name="is_pep" string="Is Customer a PEP?" />
                                </group>
                                <group>
                                    <field name="id_expired" string="Customer ID still valid" />
                                    <field name="activity_level_matches_business"
                                        string="Does Activity Level Reflect Customer's Business" />
                                </group>
                            </group>
                            <separator string="" />
                            <group string="Additional Information">
                                <group colspan="2">
                                    <field name="main_cash_purpose" />
                                </group>
                                <group colspan="2">
                                    <field name="main_inflow_purpose" />
                                </group>
                                <group colspan="2">
                                    <field name="main_fund_remitters" />
                                </group>
                                <group colspan="2">
                                    <field name="inflow_sources" />
                                </group>
                                <group colspan="2">
                                    <field name="other_related_accounts" />
                                </group>
                            </group>
                            <group>
                                <group colspan="2">
                                    <field name="occupation" string="Occupation/Employment Profile" />
                                </group>
                                <group>
                                    <field name="is_current_from_normal"
                                        string="Is Current Inflow From Normal Business" />
                                </group>
                                <group>
                                    <field name="does_business_support_volume"
                                        string="Does Nature of Business Support Volume and Velocity Of Inflows" />
                                </group>
                                <group colspan="2">
                                   <field name="supporting_document" widget="many2many_binary"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_res_partner_edd" model="ir.actions.act_window">
        <field name="name">Enhanced Due Diligence</field>
        <field name="res_model">res.partner.edd</field>
        <field name="view_id" ref="edd_tree_view" />
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Conduct EDD for a Customer
            </p>
            <p>
                Customer Enhanced Due Diligence is conducted here
            </p>
        </field>
    </record>

    <record id="open_customers" model="ir.actions.server">
        <field name="name">Open Customers</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_customers()</field>
    </record>
    <record id="open_vendors" model="ir.actions.server">
        <field name="name">Open Vendors</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_vendors()</field>
    </record>
    <record id="open_partners" model="ir.actions.server">
        <field name="name">Open Partners</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_partners()</field>
    </record>
    <record id="open_respondents" model="ir.actions.server">
        <field name="name">Open Respondents</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_respondents()</field>
    </record>
    <record id="open_correspondents" model="ir.actions.server">
        <field name="name">Open Correspondents</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_correspondents()</field>
    </record>

    <menuitem id="base.menu_board_root" name="Dashboards" sequence="260"
        web_icon="compliance_management,static/description/icon-dashboard.png"
        groups="base.group_user" />
    <menuitem
        id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root"
        name="Dashboards"
        action="spreadsheet_dashboard.ir_actions_dashboard_action"
        web_icon="compliance_management,static/description/icon-dashboard.png"
        sequence="37" />
    <menuitem name="Customers"
        id="contacts.menu_contacts"
        sequence="20"
        web_icon="compliance_management,static/description/icons-contact.png"
        groups="base.group_system" />
    <menuitem id="contacts.res_partner_menu_contacts"
        name="Customers"
        action="contacts.action_contacts"
        groups="base.group_system"
        parent="contacts.menu_contacts"
        sequence="2" />
    <menuitem
        id="hr.menu_hr_root"
        name="Employees"
        groups="hr.group_hr_manager,hr.group_hr_user"
        web_icon="compliance_management,static/description/icon-employee.png"
        sequence="75" />
    <menuitem
        id="mail.menu_root_discuss"
        name="Messaging"
        action="mail.action_discuss"
        web_icon="compliance_management,static/description/icon-chat.png"
        groups="base.group_user"
        sequence="1" />
    <menuitem
        id="menu_compliance_dd"
        name="Due Diligence"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        parent="menu_compliance_root"
        sequence="5" />
    <menuitem
        id="menu_compliance_kyc"
        name="KYC"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        parent="menu_compliance_root"
        sequence="10" />
    <menuitem
        id="menu_compliance_customer"
        action="open_customers"
        parent="menu_compliance_kyc"
        name="Customers"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="10" />
    <menuitem
        id="menu_compliance_customer_dd"
        action="open_customers"
        parent="menu_compliance_dd"
        name="Customers"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="10" />
    <menuitem
        id="menu_compliance_vendor_dd"
        action="open_vendors"
        parent="menu_compliance_dd"
        name="Vendors"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="20" />
    <menuitem
        id="menu_compliance_paerner_dd"
        action="open_partners"
        parent="menu_compliance_dd"
        name="Partners"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="30" />
    <menuitem
        id="menu_compliance_respondents_dd"
        action="open_respondents"
        parent="menu_compliance_dd"
        name="Respondents"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="40" />
    <menuitem
        id="menu_compliance_correspondents_dd"
        action="open_correspondents"
        parent="menu_compliance_dd"
        name="Correspondents"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="50" />
    <menuitem id="menu_compliance_enhanced_due_deligence"
        action="action_res_partner_edd"
        parent="menu_compliance_kyc"
        name="Enhanced Due Diligence"
        groups="group_compliance_compliance_officer,group_compliance_branch_compliance_officer"
        sequence="20" />

</odoo>