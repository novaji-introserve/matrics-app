    <record id="open_respondents" model="ir.actions.server">
        <field name="name">Open Respondents</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_respondents()</field>
    </record>
    <record id="open_correspondents" model="ir.actions.server">
        <field name="name">Open Correspondents</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_correspondents()</field>
    </record>

