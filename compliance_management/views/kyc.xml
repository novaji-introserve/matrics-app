<odoo>
    <record id="risk_plan_line_ids_view_tree" model="ir.ui.view">
        <field name="name">risk_plan_line_ids.view.tree</field>
        <field name="model">res.partner.risk.plan.line</field>
        <field name="arch" type="xml">
            <tree string="Risk Analysis Lines" create="False" edit="False" delete="False">
                <field name="plan_line_id" />
                <field name="risk_score" />
                <!-- <field name="create_date" /> -->
            </tree>
        </field>
    </record>


    <record model="ir.ui.view" id="partner_inherit_form_view">
        <field name="name">compliance.customer.form.view</field>
        <field name="model">res.partner</field>
        <field name="priority">1500</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="sector_id"/>
                <field name="region_id"/>
                <field name="registration_date" />
                <field name="company_reg_date" />
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="internal_category"/>
            </xpath>
            <xpath expr="//page[@name='contact_addresses']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <xpath expr="//page[@name='contact_addresses']" position="before">
                <page name='compliance' string="Personal Information" autofocus="autofocus">
                    <group>
                        <group string="Personal Information" name="personal" priority="1">
                            <field name="firstname" />
                            <field name="lastname" />
                            <field name="middlename" />
                            <field name="othername" />
                            <field name="dob" />
                            <field name="education_level_id" />
                            <field name="gender" invisible="1" />
                            <field name="formatted_gender" />
                            <field name="town" />
                            <field name="internal_category" invisible="1" />
                        </group>
                        <group string="Identification" name="identification">
                            <field name="customer_id" />
                            <field name="branch_id" />
                            <field name="account_officer_id" />
                            <field name="bvn" />
                            <field name="nin" />
                            <field name="identification_type_id" />
                            <field name="identification_number" />
                            <field name="identification_expiry_date" />
                        </group>
                    </group>
                </page>
            </xpath>

            <xpath expr="//page[@name='contact_addresses']" position="before">
                <page name='accounts' string="Accounts">
                    <field name="account_ids" context="{'default_customer_id': active_id}" />
                </page>


                <page name="digital_products" string="Customer Channels">
                    <!-- Simplified view without problematic fields -->

                    <field name="channel_subscription_ids" context="{'default_customer_id': customer_id}" domain="[]">
                        <tree editable="bottom" create="false" delete="false">
                            <field name="channel_id"/>
                            <field name="value"/>
                        </tree>
                    </field>
                </page>


                <page name="risk_composite" string="Risk Composite" attrs="{'invisible': [('composite_risk_score', '&lt;=', 0)]}">
                    
                    <separator string="COMPOSITE RISK SCORE" class="mt16"/>
                    <p>
                        <field name="composite_risk_score" class="oe_inline" readonly="1" nolabel="1"/>
                    </p>

                    <separator string="UNIVERSE RISK WEIGHTS" class="mt16"/>
                    <field name="universe_weight_ids" readonly="1" context="{'tree_view_ref': 'view_partner_risk_universe_weight_tree'}">
                        <tree editable="bottom" create="false" delete="false">
                            <field name="name"/>
                            <field name="subject_id"/>
                            <field name="weight_percentage" sum="Total %"/>
                            <field name="universe_score" string="Risk score"/>
                            <!-- <field name="weighted_score" sum="Total Weighted"/> -->
                            <!-- <field name="assigned_score"/> -->
                        </tree>
                    </field>
                </page>


                <page name='plans' string="Risk Analysis">
                    <field name="risk_plan_line_ids" context="{'default_partner_id': active_id}" />
                </page>
                <page name='risk_assessment' string="Risk Assessment">
                    <field name="risk_assessment_ids" view_ref="compliance_customer_risk_assessment_tree" context="{'default_partner_id': active_id}" />
                </page>
                <page name="due_diligence" string="Due Diligence" attrs="{'invisible' : [('internal_category', '!=', 'vendor')]}">
                    <group>
                        <group>
                            <field name="anti_bribery" filename="anti_bribery_file_name"/>
                            <field name="anti_bribery_file_name" invisible="1"/>
                            <field name="whistle_blowing" filename="whistle_blowing_file_name"/>
                            <field name="whistle_blowing_file_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="data_protection" filename="data_protection_file_name"/>
                            <field name="data_protection_file_name" invisible="1"/>
                            <field name="anti_money_laundering" filename="anti_money_laundering_file_name" />
                            <field name="anti_money_laundering_file_name" invisible="1"/>
                        </group>
                    </group>

                </page>
                <page name='sanction_screening' string="Sanction Screening">
                    <group>
                        <group name="pep" string="PEP Screening">
                            <field name="is_pep" attrs="{'readonly': True}" />
                            <field name="global_pep" attrs="{'readonly': True}" />
                            <field name="global_pep_id" attrs="{'readonly': True}" />
                        </group>
                        <group name="other" string="Others">
                            <field name="is_fep" attrs="{'readonly': True}" />
                            <field name="is_blacklist" attrs="{'readonly': True}" />
                            <field name="is_watchlist" attrs="{'readonly': True}" />
                            <field name="likely_sanction" attrs="{'readonly': True}" />
                            <field name="is_greylist" attrs="{'readonly': True}" />
                        </group>
                    </group>
                </page>

            </xpath>

            <!-- Add EDD Page to Customer Form -->
            <xpath expr="//page[@name='contact_addresses']" position="before">


                <!-- <notebook position="inside"> -->
                <page string="Enhanced Due Diligence" name="edd_record">
                    <field name="edd_ids" nolabel="1">
                        <tree string="EDD Record" delete="False" create="False" edit="False">
                            <field name="name" />
                            <field name="status" />
                            <field name="customer_id" />
                            <field name="responsible_id" />
                            <field name="user_id" />
                            <field name="approved_by" />
                            <field name="date_approved" />
                            <field name="risk_score" />
                            <field name="account_status" />
                            <field name="documentation_status" />
                        </tree>
                        <form string="EDD Record">
                            <header>
                                <button name="action_submit_for_review" class="oe_highlight" type="object" string="Submit for Review" groups="compliance_management.group_compliance_branch_compliance_officer" attrs="{'invisible': ['|', ('status', '!=', 'draft'), '|', ('is_current_user_responsible', '=', False), ('is_cco', '=', False)]}" />

                                <button name="action_approve" class="oe_highlight" type="object" string="Approve" groups="compliance_management.group_compliance_branch_compliance_officer" attrs="{'invisible': ['|', ('status', '!=', 'completed'), ('is_current_user_approving_officer', '=', False)]}" />

                                <button name="action_cancel" class="oe_highlight" type="object" string="Cancel" groups="compliance_management.group_compliance_branch_compliance_officer" attrs="{'invisible': ['|', ('status', 'in', ['cancelled', 'approved', 'draft']), ('is_current_user_approving_officer', '=', False)]}" />

                                <button name="action_archive" class="oe_highlight" type="object" string="Archive" groups="compliance_management.group_compliance_branch_compliance_officer" attrs="{'invisible': ['|', ('status', 'not in', ['cancelled', 'approved']), ('is_cco', '=', False)]}" />

                                <button name="action_send_back" class="oe_highlight" type="object" string="Send Back" groups="compliance_management.group_compliance_branch_compliance_officer" attrs="{'invisible': ['|', ('status', 'in', ['draft', 'approved']), ('is_current_user_approving_officer', '=', False)]}" />


                                <field name="status" widget="statusbar" statusbar_visible="draft,completed,approved,cancelled,deleted,archived"/>
                            </header>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name" />
                                        <!-- <field name="status" /> -->
                                        <field name="customer_id" readonly="1"/>
                                        <field name="responsible_id" />
                                        <field name="user_id" />

                                        <field name="is_cco" invisible="1"/>
                                        <field name="status" invisible="1"/>
                                        <field name="is_current_user_responsible" invisible="1"/>
                                        <field name="is_current_user_approver" invisible="1"/>
                                        <field name="is_current_user_approving_officer" invisible="1"/>
                                        <field name="risk_score" widget="numeric_step" options="{'step': 0.25, 'min': 0.5, 'max': 25}" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'cancelled', 'deleted', 'archived', 'completed']), '|',
                                                     '&amp;', ('is_current_user_responsible', '=', True), ('status', '=', 'completed'),'&amp;', ('is_current_user_responsible', '=', False), ('status', '=', 'draft'), ('is_cco', '=', False)],
                                                     'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)]}" />




                                    </group>
                                    <group>
                                        <field name="account_status" />
                                        <field name="documentation_status" />
                                        <field name="last_kyc_date" />
                                        <field name="approved_by" />
                                        <field name="date_approved" />


                                    </group>
                                </group>
                                <notebook>
                                    <page string="Details">
                                        <group>
                                            <field name="description" />
                                            <field name="visitation_observation" />
                                            <field name="overall_kyc_outcome" />

                                        </group>

                                    </page>
                                    <page string="Transaction Information">
                                        <group>
                                            <group string="Cash Information">
                                                <field name="main_cash_purpose" />
                                            </group>
                                            <group string="Inflow Information">
                                                <field name="main_inflow_purpose" />
                                                <field name="main_fund_remitters" />
                                                <field name="inflow_sources" />
                                            </group>
                                        </group>
                                        <group>
                                            <group string="Additional Information">
                                                <field name="other_related_accounts" />
                                                <field name="occupation" />
                                            </group>
                                        </group>
                                    </page>

                                    <page string="Customer Assessment">

                                        <group>

                                            <group >

                                                <field name="is_foreigner" />
                                                <field name="is_pep" />
                                                <field name="id_expired" />
                                                <field name="was_kyc_comprehensive" />
                                            </group>

                                            <group >

                                                <field name="has_initiated_new_kyc" />
                                                <field name="is_current_from_normal" />
                                                <field name="activity_level_matches_business" />
                                                <field name="does_business_support_volume" />

                                            </group>
                                        </group>


                                    </page>

                                    <page string="Supporting Document(s)">
                                        <group >,
                                            <field name="supporting_document" widget="many2many_binary" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'cancelled', 'deleted', 'archived', 'completed']), '|',
                                                     '&amp;', ('is_current_user_responsible', '=', True), ('status', '=', 'completed'),'&amp;', ('is_current_user_responsible', '=', False), ('status', '=', 'draft'), ('is_cco', '=', False)],
                                                  'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_cco', '=', False)]}" />


                                        </group>

                                    </page>

                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </page>

            </xpath>

        </field>
    </record>

    <record id="open_customers" model="ir.actions.server">
        <field name="name">Open Customers</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_customers()</field>
    </record>
    <record id="open_vendors" model="ir.actions.server">
        <field name="name">Open Vendors</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_vendors()</field>
    </record>
    <record id="open_partners" model="ir.actions.server">
        <field name="name">Open Partners</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_partners()</field>
    </record>
    <record id="open_respondents" model="ir.actions.server">
        <field name="name">Open Respondents</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_respondents()</field>
    </record>
    <record id="open_correspondents" model="ir.actions.server">
        <field name="name">Open Correspondents</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = model.open_correspondents()</field>
    </record>

</odoo>