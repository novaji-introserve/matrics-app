<odoo>
    <data noupdate="1">
        <!-- Template for New EDD Assigned -->
        <record id="email_template_new_edd_assigned" model="mail.template">
            <field name="name">New EDD Assigned</field>
            <field name="email_from">${(user.email or '')|safe}</field>
            <field name="subject">New EDD Assigned</field>
            <field name="model_id" ref="compliance_management.model_res_partner_edd"/>
            <field name="auto_delete" eval="True"/>
            <field name="body_html">
                <![CDATA[
                <div style="font-family: Arial, sans-serif;">
                    <h1>New EDD Assigned</h1>
                    <p>Dear ${object.responsible_user_id.name},</p>
                    <p>An EDD has been assigned for you to conduct.</p>
                    <p>Best regards,<br>Your Company Name</p>
                </div>
                ]]>
            </field>
        </record>

        <!-- Template for EDD Submitted for Review -->
        <record id="email_template_edd_submitted_for_review" model="mail.template">
            <field name="name">EDD Submitted for Review</field>
            <field name="email_from">${(user.email or '')|safe}</field>
            <field name="subject">EDD Submitted for Review</field>
            <field name="model_id" ref="compliance_management.model_res_partner_edd"/>
            <field name="auto_delete" eval="True"/>
            <field name="body_html">
                <![CDATA[
                <div style="font-family: Arial, sans-serif;">
                    <h1>EDD Submitted for Review</h1>
                    <p>Dear ${object.approving_officer_id.name},</p>
                    <p>An EDD has been submitted for you to review.</p>
                    <p>Best regards,<br>Your Company Name</p>
                </div>
                ]]>
            </field>
        </record>
    </data>
</odoo>
