<odoo noupdate="1">
    <record id="rule_manage_compliance_groups" model="ir.rule">
        <field name="name">Manage Compliance Groups</field>
        <field name="model_id" ref="model_res_groups" />
        <field name="domain_force">['|', '|', '|', '|', ('id', '=',
            ref('compliance_management.group_compliance_branch_compliance_officer')), ('id', '=',
            ref('compliance_management.group_compliance_branch_control_officer')), ('id', '=',
            ref('compliance_management.group_compliance_compliance_officer')), ('id', '=',
            ref('compliance_management.group_compliance_compliance_risk_manager')), ('id', '=',
            ref('compliance_management.group_compliance_chief_compliance_officer'))]</field>
        <field name="groups" eval="[(4, ref('compliance_management.group_compliance_group_manager'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
    </record>
</odoo>