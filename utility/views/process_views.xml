<!-- views/process_views.xml -->
<odoo>
    <record id="view_process_tree" model="ir.ui.view">
        <field name="name">process.tree</field>
        <field name="model">process</field>
        <field name="arch" type="xml">
            <tree
               
            >
                <field name="name" />
                <field name="category_id" />
                <field name="sla_severity_id"
                    decoration-danger="severity_level == 'Critical'"
                    decoration-warning="severity_level == 'Medium'"
                    decoration-muted="severity_level == 'Low'" />
            </tree>

        </field>
    </record>

    <record id="view_process_form" model="ir.ui.view">
        <field name="name">process.form</field>
        <field name="model">process</field>
        <field name="arch" type="xml">
            <form string="Process">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="category_id" widget="many2one" />
                        <field name="sla_severity_id" widget="many2one" />
                        <field name="description" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Rulebook Search View -->
    <record id="view_process_search" model="ir.ui.view">
        <field name="name">process.search</field>
        <field name="model">process</field>
        <field name="arch" type="xml">
            <search>
                <searchpanel>
                    <field name="sla_severity_id" icon="fa-thermometer-half" enable_counters="1"
                        options='{"counters": true}' string="Severity" />
                    <field name="category_id" icon="fa-building" enable_counters="1"
                        options='{"counters": true}' string="Process Category" />
                </searchpanel>
                <!-- Standard search fields -->
                <field name="name" string="Title" />
                <field name="description" string="Description" />
                <field name="sla_severity_id" string="Description" />
            </search>
        </field>
    </record>
</odoo>