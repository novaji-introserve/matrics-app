<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron Job for Setting Cases to Overdue -->
    <record id="ir_cron_check_overdue_cases" model="ir.cron">
        <field name="name">Case Management: Check for Overdue Cases</field>
        <field name="model_id" ref="model_case_manager"/>
        <field name="state">code</field>
        <field name="code">model._check_overdue_cases()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
    </record>

    <!-- Cron Job for Archiving Old Closed Cases -->
    <record id="ir_cron_archive_old_closed_cases" model="ir.cron">
        <field name="name">Case Management: Archive Old Closed Cases</field>
        <field name="model_id" ref="model_case_manager"/>
        <field name="state">code</field>
        <field name="code">model._archive_old_closed_cases()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
    </record>
</odoo>