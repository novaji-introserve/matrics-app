                    </td>
                </tr>

                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold; width: 35%;">Case reference:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('case_ref')"/>
                    </td>
                </tr>


                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Case Severity:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('case_rating')"/>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Risk Score:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('case_score')"/>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Department:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('department_id')"/>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Case Status:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('case_tatus')"/>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Exception Category:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('process_category')"/>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Exception Process:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('process')"/>
                    </td>
                </tr>

                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Recommended Action:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('case_action')"/>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Response Details:</td>
                    <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;">
                        <t t-esc="ctx.get('response')"/>
                    </td>
                </tr>
            </table>


            <div style="margin-top: 20px;">

                <h3 style="color: #000000; margin-bottom: 10px;">
                    <b>Required Action</b>
                </h3>
                <p style="margin: 0 0 10px 0;">
                    <i>Please review and ensure compliance.</i>
                </p>
                <p style="margin: 0;">
                    <i>Please ensure 100% review of this exception.</i>
                </p>
            </div>

            <div style="margin-top: 25px; text-align: left;">
                <a t-att-href="ctx.get('record_url', '#')" style="background-color: #000000; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px; display: inline-block;">Review</a>
            </div>

        </div>

        <div style="padding: 10px 15px; background-color: #FFFFFF; font-size: 12px; color: rgb(114, 98, 6); text-align: left; border-top: 1px solid #DDDDDD;">
            <p>This is an automated notification from your Case Management System. Please do not reply directly to this email.</p>
        </div>
    </div>
</field>
</record>

<!-- Case Closure Alert Email Template -->
