<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- Main Case Manager Action -->
    <record id="action_case_manager" model="ir.actions.act_window">
        <field name="name">All Cases</field>
        <field name="res_model">case.manager</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
        '|', '|',
        ('create_uid', '=', uid),
        ('officer_responsible', '=', uid),
        ('supervisors', 'in', [uid])
    ]</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first case
            </p>
            <p>
                Cases help you track and manage exceptions or issues that require attention.
            </p>
        </field>
    </record>


    <!-- Action for Create New Case - Using Dialog -->
    <record id="action_create_case" model="ir.actions.act_window">
        <field name="name">Create Case</field>
        <field name="res_model">case.manager</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>        <!-- This opens in a dialog -->
        <field name="context">{'default_case_status': 'open'}</field>
        <field name="view_id" ref="view_case_manager_form"/>
    </record>

    <!-- Action for Open Cases -->
    <record id="action_open_cases" model="ir.actions.act_window">
        <field name="name">Open Cases</field>
        <field name="res_model">case.manager</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
        '&amp;',
        ('case_status', '=', 'open'),
        '|', '|',
        ('create_uid', '=', uid),
        ('officer_responsible', '=', uid),
        ('supervisors', 'in', [uid])
               ]
        </field>
        <field name="context">{'search_default_open_cases': 1}</field>
    </record>

    <!-- Action for Closed Cases -->
    <record id="action_closed_cases" model="ir.actions.act_window">
        <field name="name">Closed Cases</field>
        <field name="res_model">case.manager</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            '&amp;',
            ('case_status', '=', 'closed'),
            '|', '|',
            ('create_uid', '=', uid),
            ('officer_responsible', '=', uid),
            ('supervisors', 'in', [uid])
        ]
        </field>
        <field name="context">{'search_default_closed_cases': 1}</field>
    </record>

    <!-- Action for Overdue Cases -->
    <record id="action_overdue_cases" model="ir.actions.act_window">
        <field name="name">Overdue Cases</field>
        <field name="res_model">case.manager</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            '&amp;',
            ('case_status', '=', 'overdue'),
            '|', '|',
            ('create_uid', '=', uid),
            ('officer_responsible', '=', uid),
            ('supervisors', 'in', [uid])
        ]</field>

        <field name="context">{'search_default_overdue_cases': 1}</field>
    </record>

    <record id="action_archived_cases" model="ir.actions.act_window">
        <field name="name">Archived Cases</field>
        <field name="res_model">case.manager</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            '&amp;',
            ('active', '=', False),
            '&amp;',
            ('case_status', '=', 'archived'),
            '|', '|',
            ('create_uid', '=', uid),
            ('officer_responsible', '=', uid),
            ('supervisors', 'in', [uid])
        ]</field>
        <field name="context">{'search_default_archived_cases': 1, 'active_test': False}</field>
    </record>

    <!-- Action for My Cases -->
    <record id="action_my_cases" model="ir.actions.act_window">
        <field name="name">Assigned To Me</field>
        <field name="res_model">case.manager</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('officer_responsible', '=', uid)]</field>
        <field name="context">{'search_default_my_cases': 1}</field>
    </record>

    <!-- Action for Cases Created By Me -->
    <record id="action_cases_created_by_me" model="ir.actions.act_window">
        <field name="name">Created By Me</field>
        <field name="res_model">case.manager</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('create_uid', '=', uid)]</field>
        <field name="context">{'search_default_created_by_me': 1}</field>
    </record>
    

    <record id="action_owl_case_dashboard" model="ir.actions.client">
        <field name="name">Case Dashboard</field>
        <field name="tag">owl_case_dashboard</field>
    </record>

    <!-- Actions -->
    <record id="action_exception_category" model="ir.actions.act_window">
        <field name="name">Exception Categories</field>
        <field name="res_model">exception.category.</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first exception category
            </p>
            <p>
                Exception categories help organize and classify different types of cases.
            </p>
        </field>
    </record>

    <record id="action_exception_process" model="ir.actions.act_window">
        <field name="name">Exception Processes</field>
        <field name="res_model">exception.process.</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first exception process
            </p>
            <p>
                Exception processes define specific processes within each category.
            </p>
        </field>
    </record>

    <record id="action_case_settings" model="ir.actions.act_window">
        <field name="name">Case Settings</field>
        <field name="res_model">case.settings</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a Setting
            </p>
            <p>
                No data found
            </p>
        </field>
    </record>

    <record id="action_case_alert_history" model="ir.actions.act_window">
        <field name="name">Case Alerts</field>
        <field name="res_model">alert.history</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_in_emails_', '=', True), ('source', '=', 'Case Manager')]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No case alerts found
            </p>
            <p>
                Case alerts will appear here when you are included in case notifications.
            </p>
        </field>
    </record>

    <!-- Main Menu -->
    <menuitem id="menu_case_management_root" name="Cases" web_icon="case_management_v2,static/description/icon.png" sequence="10"/>

    <!-- Case Menu -->
    <menuitem id="menu_case_management" name="Cases" parent="menu_case_management_root" sequence="10"/>

    <!-- Create Case Menu -->
    <menuitem id="menu_create_case" name="Create Case" parent="menu_case_management" action="action_create_case" sequence="10"/>

    <!-- All Cases Menu -->
    <menuitem id="menu_all_cases" name="All Cases" parent="menu_case_management" action="action_case_manager" sequence="50"/>

    <!-- My Cases Menu -->
    <menuitem id="menu_my_cases" name="Assigned To Me" parent="menu_case_management" action="action_my_cases" sequence="35"/>

    <!-- Cases Created By Me Menu -->
    <menuitem id="menu_cases_created_by_me" name="Created By Me" parent="menu_case_management" action="action_cases_created_by_me" sequence="40"/>

    <!-- Open Cases Menu -->
    <menuitem id="menu_open_cases" name="Open Cases" parent="menu_case_management" action="action_open_cases" sequence="10"/>

    <!-- Closed Cases Menu -->
    <menuitem id="menu_closed_cases" name="Closed Cases" parent="menu_case_management" action="action_closed_cases" sequence="20"/>

    <!-- Overdue Cases Menu -->
    <menuitem id="menu_overdue_cases" name="Overdue Cases" parent="menu_case_management" action="action_overdue_cases" sequence="30"/>

    <!-- Archived Cases Menu -->
    <menuitem id="menu_archived_cases" name="Archived Cases" parent="menu_case_management" action="action_archived_cases" sequence="31"/>

    <menuitem id="menu_case_my_alerts" name="My Alerts" parent="menu_case_management" action="action_case_alert_history" sequence="51" />


   
    <!-- Add to menu - adjust parent menu as needed -->
    <menuitem id="menu_case_dashboard_" name="Dashboard" parent="case_management_v2.menu_case_management_root" action="action_owl_case_dashboard" sequence="6" />

    <!-- Configuration Menu -->
    <menuitem id="menu_case_configuration" name="Configuration" parent="menu_case_management_root" sequence="100"/>

    <!-- Exception Category Menu -->
    <menuitem id="menu_exception_category" name="Exception Categories" parent="menu_case_configuration" action="action_exception_category" sequence="10"/>

    <!-- Exception Process Menu -->
    <menuitem id="menu_exception_process" name="Exception Processes" parent="menu_case_configuration" action="action_exception_process" sequence="20"/>

    <menuitem id="menu_case_settings_" action="action_case_settings" parent="menu_case_configuration" name="Settings" sequence="30" />





</odoo>
