<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="rule_case_manager_personal" model="ir.rule">
        <field name="name">Case Manager: Personal Cases</field>
        <field name="model_id" ref="model_case_manager"/>
        <field name="domain_force">[
            '|', '|',
            ('create_uid', '=', user.id),
            ('officer_responsible', '=', user.id),
            ('supervisors', 'in', [user.id])
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
