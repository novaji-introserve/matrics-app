<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="owl.KpiCard" owl="1">
        <div class="col-lg-3 m-0 p-0">
            <div class="shadow-sm border m-2 p-4 bg-white text-center cursor-pointer" t-on-click="()=>props.onClick()">
                <div class="h1 fw-bold text-dark" style="font-size: 20px"><span t-esc="props.value"/></div>
                <div class="h6 text-muted"><span t-esc="props.name"/></div>
            </div>
        </div>
    </t>
</templates>

