<odoo>
    <!-- Tree View for Open Cases - Allow opening (reading) for everyone -->
    <record id="view_open_cases_tree" model="ir.ui.view">
        <field name="name">open.cases.tree</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="name"/>
                <field name="transaction_reference"/>
                <field name="title" string="Severity" readonly="1" />
                <field name="created_at" string="Case Creation Date"/>
                <field name="user_id" string="Created By"/>
                <field name="staff_id" string="Staff Responsible"/>
                <field name="data_source" readonly="1"/>
                <field name="cases_action" string="Recommended Action" readonly="1"/>
                <field name="team_id"/>
                <field name="status_html" widget="html"/>
                <field name="severity_level" invisible="1"/>
                <field name="has_responses" invisible="1"/>
                <field name="is_creator" invisible="1"/>
                <field name="is_assigned_staff" invisible="1"/>
                <field name="is_supervisor" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View for Cases with Proper Access Control -->
    <record id="view_case_form_staff_only" model="ir.ui.view">
        <field name="name">case.form.staff.only</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <form string="Case" create="false" delete="false">
                <header>
                    <!-- Close button only for creator and only if there are responses -->
                    <button name="action_close_case" 
                            string="Close Case" 
                            type="object" 
                            class="btn-primary" 
                            attrs="{'invisible': ['|', '|', ('is_creator', '=', False), ('has_responses', '=', False), ('is_supervisor', '=', True)]}"/>
                    <field name="status_id" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <field name="is_supervisor" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="created_at" readonly="1" invisible="1"/>
                            <field name="created_at_formatted_datetime" widget="text"/>
                            <field name="event_date" readonly="1" invisible="1"/>
                            <field name="event_date_formatted_datetime" widget="text"/>
                            <field name="branch_id" readonly="1"/>
                            <field name="team_id" readonly="1"/>
                            <field name="transaction_reference" readonly="1"/>
                            <field name="data_source" readonly="1"/>
                            <field name="cases_action" readonly="1"/>

                            <!-- <field name="response_text" widget="text" attrs="{'readonly': ['|', ('is_assigned_staff', '=', False), ('is_supervisor', '=', True)]}" /> -->
                            <!-- <field name="response_text" widget="text"
                                attrs="{'readonly': ['|', ('is_assigned_staff', '=', False), ('is_supervisor', '=', True)]}"/>
                            <button name="action_add_response"
                                    string="Add Response"
                                    type="object"
                                    class="btn-primary"
                                    attrs="{'invisible': ['|', ('is_assigned_staff', '=', False), ('is_supervisor', '=', True)]}"/> -->



                            <!-- <field name="response_ids" string="Response" nolabel="1">
                                <tree editable="bottom">
                                    <field name="response"/>
                                </tree>
                            </field> -->
                            <!-- <field name="response" string="Response" attrs="{'readonly': ['|', ('is_assigned_staff', '=', False), ('is_supervisor', '=', True)]}" nolabel="1"/>
                                -->
                               
                                <!-- <form>
                                    <page>
                                        <field name="response"/>
                                    </page>
                                </form>
                            </field>
                         -->
                        </group>
                        <group>
                            <field name="staff_id" string="Staff Responsible" readonly="1"/>
                            <field name="supervisor_one_id" readonly="1"/>
                            <!-- Show supervisor_two only for medium or high severity -->
                            <field name="supervisor_two_id" readonly="1" 
                                   attrs="{'invisible': [('severity_level', '=', 'low')]}" groups="base.group_user" widget="no_label"/>
                            
                            <!-- Show supervisor_three only for high severity -->
                            <field name="supervisor_three_id" readonly="1"
                                    attrs="{'invisible': ['|', ('severity_level', '=', 'low'), ('severity_level', '=', 'medium')]}" groups="base.group_user" widget="no_label"/>

                            <field name="is_supervisor" invisible="1"/>
                            
                            <field name="user_id" readonly="1"/>
                            <field name="severity_level" invisible="1"/>
                            <field name="is_creator" invisible="1"/>
                            <field name="is_assigned_staff" invisible="1"/>
                            <field name="has_responses" invisible="1"/>
                            <field name="process_category_id" string="Process Category"/>
                            <field name="process_id" string="Process"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="cases_description" readonly="1"/>
                                <field name="further_description" readonly="1"/>
                            </group>
                        </page>
                        <page string="Responses" attrs="{'invisible': []}">
                            <!-- Responses writable only for assigned staff and not supervisors -->
                            <field name="response_ids" attrs="{'readonly': ['|', ('is_assigned_staff', '=', False), ('is_supervisor', '=', True)]}" nolabel="1">
                                <tree editable="bottom">
                                    <field name="create_date" readonly="1"/>
                                    <field name="create_uid" readonly="1"/>
                                    <field name="response" readonly="1"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="response"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Attachments" attrs="{'invisible': [('is_supervisor', '=', True)]}">
                            <field name="attachment_ids" widget="many2many_binary" attrs="{'readonly': [('is_supervisor', '=', True)]}" />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <!-- <field name="activity_ids" widget="mail_activity"/> -->
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action for Open Cases -->
    <record id="case_action" model="ir.actions.act_window">
        <field name="name">Open Cases</field>
        <field name="res_model">case</field>
        <field name="view_mode">tree,form</field>
        <!-- <field name="domain">[('status_id.name', '=', 'open'), ('id', 'in', context.get('accessible_cases', []))]</field> -->
        <!-- <field name="domain">[('status_id.name', '=', 'open')]</field> -->
        <field name="domain">['|', '|', '|', 
                         ('status_id.name', '=', 'open'),
                         ('supervisor_one_id', '=', uid),
                         ('supervisor_two_id', '=', uid),
                         ('supervisor_three_id', '=', uid)]</field>
        <field name="view_ids" eval="[(5, 0, 0), 
                                      (0, 0, {'view_mode': 'tree', 'view_id': ref('view_open_cases_tree')}),
                                      (0, 0, {'view_mode': 'form', 'view_id': ref('view_case_form_staff_only')})]"/>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No open cases found
            </p>
            <p>
                All current open cases will appear here.
            </p>
        </field>
    </record>

    <record id="case_rule_supervisor" model="ir.rule">
        <field name="name">Case: supervisors see their cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="domain_force">[
        ('status_id.name', '=', 'open'),
        '|', '|',
            ('supervisor_one_id', '=', user.id),
            ('supervisor_two_id', '=', user.id),
            ('supervisor_three_id', '=', user.id)
    ]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Server Action for Open Cases -->
    <record id="action_open_cases_custom" model="ir.actions.server">
        <field name="name">Open Cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_cases()</field>
    </record>

    
</odoo>