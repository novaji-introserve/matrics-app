<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for the Wizard -->
    <record id="view_wizard_load_exception_data_form" model="ir.ui.view">
        <field name="name">wizard.load.exception.data.form</field>
        <field name="model">wizard.load.exception.data</field>
        <field name="arch" type="xml">
            <form string="Load Exception Data">
                <group>
                    <p>This will load exception process types and processes from CSV files.</p>
                </group>
                <footer>
                    <button name="action_load_data" string="Load Data" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the Wizard -->
    <record id="action_wizard_load_exception_data" model="ir.actions.act_window">
        <field name="name">Load Exception Data</field>
        <field name="res_model">wizard.load.exception.data</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu item under Settings/Technical -->
    <menuitem id="menu_wizard_load_exception_data"
              name="Load Exception Data"
              action="action_wizard_load_exception_data"
              parent="base.menu_custom"
              sequence="100"
              groups="base.group_system"/>
</odoo>