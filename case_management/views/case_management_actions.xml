<odoo>
    <!-- Action for Open Cases -->
    <record id="action_open_cases" model="ir.actions.act_window">
        <field name="name">Open Cases</field>
        <field name="res_model">case.management</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('status_id','=','open')]</field>
    </record>

    <!-- Action for Closed Cases -->
    <record id="action_closed_cases" model="ir.actions.act_window">
        <field name="name">Closed Cases</field>
        <field name="res_model">case.management</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('status_id','=','closed')]</field>
    </record>

    <!-- Action for Overdue Cases -->
    <record id="action_overdue_cases" model="ir.actions.act_window">
        <field name="name">Overdue Cases</field>
        <field name="res_model">case.management</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('event_date','lt',datetime.now())]</field>
    </record>

    <!-- Action for Cases Created By Me -->
    <record id="action_cases_created_by_me" model="ir.actions.act_window">
        <field name="name">Cases Created By Me</field>
        <field name="res_model">case.management</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('user_id','=',uid)]</field>
    </record>

    <!-- Action for Cases Assigned To Me -->
    <record id="action_cases_assigned_to_me" model="ir.actions.act_window">
        <field name="name">Cases Assigned To Me</field>
        <field name="res_model">case.management</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('staff_id','=',uid)]</field>
    </record>

    <!-- Action for My Alerts -->
    <!-- <record id="action_my_alerts" model="ir.actions.act_window">
        <field name="name">My Alerts</field>
        <field name="res_model">alert</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('user_id','=',uid)]</field>
    </record> -->

    <record id="action_case_dashboard" model="ir.actions.act_window">
        <field name="name">Case Dashboard</field>
        <field name="res_model">case.statistics</field>
        <field name="view_mode">dashboard</field>
    </record>
    <!-- Action for Case By Status Chart -->
    <record id="action_case_by_status_chart" model="ir.actions.act_window">
        <field name="name">Case By Status Chart</field>
        <field name="res_model">case.management</field>
        <!-- <field name="view_id" ref="view_case_by_status_chart" /> -->
        <field name="view_mode">graph</field>
    </record>

    <!-- Action for Case By Severity Chart -->
    <record id="action_case_by_severity_chart" model="ir.actions.act_window">
        <field name="name">Case By Severity Chart</field>
        <field name="res_model">case.management</field>
        <!-- <field name="view_id" ref="view_case_by_severity_chart" /> -->
        <field name="view_mode">graph</field>
    </record>

    <!-- Action for Case By Category Chart -->
    <record id="action_case_by_category_chart" model="ir.actions.act_window">
        <field name="name">Case By Category Chart</field>
        <field name="res_model">case.management</field>
        <!-- <field name="view_id" ref="view_case_by_category_chart" /> -->
        <field name="view_mode">graph</field>
    </record>

    <!-- Action for Staff Open Cases Pivot Table -->
    <record id="action_staff_open_cases_pivot" model="ir.actions.act_window">
        <field name="name">Staff Open Cases Pivot</field>
        <field name="res_model">case.management</field>
        <!-- <field name="view_id" ref="view_staff_open_cases_pivot" /> -->
        <field name="view_mode">pivot</field>
    </record>

    <!-- Action for Staff Avg Resolution Time Pivot Table -->
    <record id="action_staff_avg_resolution_time_pivot" model="ir.actions.act_window">
        <field name="name">Staff Avg Resolution Time Pivot</field>
        <field name="res_model">case.management</field>
        <!-- <field name="view_id" ref="view_staff_avg_resolution_time_pivot" /> -->
        <field name="view_mode">pivot</field>
    </record>

    <!-- Action for Category Case Counts Pivot Table -->
    <record id="action_category_case_counts_pivot" model="ir.actions.act_window">
        <field name="name">Category Case Counts Pivot</field>
        <field name="res_model">case.management</field>
        <!-- <field name="view_id" ref="view_category_case_counts_pivot" /> -->
        <field name="view_mode">pivot</field>
    </record>

    <!-- Action for Top Overdue Cases Pivot Table -->
    <record id="action_top_overdue_cases_pivot" model="ir.actions.act_window">
        <field name="name">Top Overdue Cases Pivot</field>
        <field name="res_model">case.management</field>
        <!-- <field name="view_id" ref="view_top_overdue_cases_pivot" /> -->
        <field name="view_mode">pivot</field>
    </record>
</odoo>