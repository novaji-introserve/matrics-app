<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- COMMON TREE VIEWS -->
    
    <!-- Tree View for Open Cases -->
    <record id="view_cases_tree" model="ir.ui.view">
        <field name="name">cases.tree</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="name" invisible='1'/>
                <field name="transaction_id" invisible="1" />
                <!-- <field name="transaction_reference" invisible="1"/> -->
                <field name="customer_id" invisible="1"/>
                <field name="title" string="Severity" readonly="1" invisible="1" />
                <field name="title_html" string= "Severity" readonly="1" widget="html"/>
                <field name="created_at" readonly="1" invisible="1"/>
                <field name="created_at_formatted_datetime" string="Created Date" widget="text"/>
                <field name="user_id" string="Created By"/>
                <field name="staff_id" string="Staff Responsible"/>
                <field name="data_source" readonly="1" invisible="1"/>
                <field name="cases_action" string="Recommended Action" readonly="1"/>
                <field name="status_name" invisible="1"/>
                <field name="team_id" readonly='1'/>
                <field name="status_html" widget="html"/>
                <field name="severity_level" invisible="1"/>
                <field name="has_responses" invisible="1"/>
                <field name="is_creator" invisible="1"/>
                <field name="is_assigned_staff" invisible="1"/>
                <field name="is_supervisor" invisible="1"/>
            </tree>
        </field>
    </record>
    
    <!-- Tree View: Readonly for Cases Created by Me -->
    <record id="view_case_tree_readonly" model="ir.ui.view">
        <field name="name">case.tree.readonly</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="name" invisible='1'/>
                <field name="transaction_id" invisible='1'/>
                <!-- <field name="transaction_reference" invisible='1'/> -->
                <field name="customer_id" invisible="1"/>
                <field name="title" string="Severity" readonly="1" invisible="1" />
                <field name="title_html" string= "Severity" readonly="1" widget="html"/>
                <!-- <field name="created_at" string="Case Creation Date"/> -->
                <field name="created_at" readonly="1" invisible="1"/>
                <field name="created_at_formatted_datetime" string="Created Date" widget="text"/>
                <field name="user_id" string="Created By"/>
                <field name="staff_id" string="Staff Responsible"/>
                <field name="data_source" readonly="1" invisible="1"/>
                <field name="cases_action" string="Recommended Action" readonly="1"/>
                <field name="team_id"/>
                <field name="status_html" widget="html"/>
            </tree>
        </field>
    </record>
    
    <!-- Tree View for Cases Assigned to Me -->
    <record id="view_case_tree_assigned_to_me" model="ir.ui.view">
        <field name="name">case.tree.assigned.to.me</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="name" invisible='1'/>
                <!-- <field name="transaction_reference" invisible="1"/> -->
                <field name="transaction_id" invisible="1"/>
                <field name="customer_id" invisible="1"/>
                <field name="title" string="Severity" readonly="1" invisible="1" />
                <field name="title_html" string= "Severity" readonly="1" widget="html"/>
                <!-- <field name="created_at" string="Start Date"/> -->
                <field name="created_at" readonly="1" invisible="1"/>
                <field name="created_at_formatted_datetime" string="Created Date" widget="text"/>
                <field name="user_id" string="Created By"/>
                <field name="staff_id" string="Staff Responsible"/>
                <field name="data_source" readonly="1" invisible="1"/>
                <field name="cases_action" string="Recommended Action" readonly="1"/>
                <field name="team_id"/>
                <field name="status_html" widget="html"/>
            </tree>
        </field>
    </record>

    <!-- COMMON FORM VIEWS -->
    
    <!-- Base Form View for Cases -->
    <record id="view_case_form_base" model="ir.ui.view">
        <field name="name">case.form.base</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <form string="Case" create="false" delete="false">
                <header>
                    <field name="status_id" widget="statusbar" readonly="1"
                        decoration-danger="status_id == 'overdue'" 
                        decoration-success="status_id == 'closed'" />
                </header>
                <sheet>
                    <field name="is_supervisor" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group col="2">
                        <group>
                            <field name="created_at" readonly="1" invisible="1"/>
                            <field name="created_at_formatted_datetime" widget="text"/>
                            <field name="event_date" readonly="1" invisible="1"/>
                            <field name="event_date_formatted_datetime" widget="text"/>
                            <field name="branch_id" readonly="1"/>
                            <field name="team_id" readonly="1"/>
                            <!-- <field name="transaction_id" invisible='1'/> -->
                            <field name="transaction_id" attrs="{'invisible': [('transaction_id', '=', False)]}" readonly='1'/>
                            <field name="customer_id" attrs="{'invisible': [('customer_id', '=', False)]}" readonly="1"/>
                            <field name="data_source" readonly="1" invisible="1"/>
                            <field name="cases_action" string="Recommended Action" readonly="1"/>
                            <field name="title" string="Severity" invisible="1" readonly="1" />
                        </group>
                        <group>
                            <field name="staff_id" string="Staff Responsible" readonly="1"/>
                            <field name="supervisor_one_id" readonly="1"/>
                            
                            <!-- Supervisor 2 shown only for medium risk rating -->
                            <field name="supervisor_two_id" 
                                readonly="1"
                                attrs="{'invisible': [('title', '!=', '2')]}" />

                            <!-- Another Supervisor 2 instance shown only for high risk rating -->
                            <field name="supervisor_two_id" 
                                readonly="1"
                                attrs="{'invisible': [('title', '!=', '3')]}" />

                            <!-- Supervisor 3 shown only for high risk rating -->
                            <field name="supervisor_three_id" 
                                readonly="1"
                                attrs="{'invisible': [('title', '!=', '3')]}" />
                            
                            <field name="user_id" readonly="1"/>
                            <field name="severity_level" invisible="1"/>
                            <field name="is_creator" invisible="1"/>
                            <field name="is_assigned_staff" invisible="1"/>
                            <field name="has_responses" invisible="1"/>
                            <field name="new_process_category_id" string="Process Category" readonly="1"/>
                            <field name="status_name" invisible="1"/>
                            <field name="new_process_id" string="Process" readonly="1"/>
                            <!-- <field name="customer_id" attrs="{'invisible': [('customer_id', '=', False)]}" readonly="1"/> -->
                            <field name="quick_response" string="Respond to Case"
                            attrs="{'invisible': ['|',
                             ('is_assigned_staff', '=', False),
                             ('status_name', '=', 'closed')
                            ]}"/>

                            <!-- <field name="quick_response" string="Respond to Case" 
                                    attrs="{'readonly': ['|', '|', ('is_assigned_staff', '=', False), ('is_supervisor', '=', True), ('status_id', '=', 'Closed')], 
                                            'invisible': [('status_id', '=', 'Closed')]}"  /> -->
                            <!-- <field name="quick_response" string="Respond to Case" attrs="{'readonly': ['|', ('is_assigned_staff', '=', False), ('is_supervisor', '=', True)]}"  /> -->
                            <!-- <field name="quick_response" string='Respond to Case' placeholder="Enter your response here..." 
                            attrs="{'invisible': [('is_assigned_staff', '=', False)]}"/> -->
                        </group>
                    </group>
                        <!-- Add the new quick response field for assigned staff -->
                    <!-- <group attrs="{'invisible': [('is_assigned_staff', '=', False)]}">
                        <field name="quick_response" placeholder="Enter your response here..." 
                            attrs="{'required': [('is_assigned_staff', '=', True)]}"/>
                        <button name="action_submit_quick_response" string="Submit Response" 
                                type="object" class="btn-primary"
                                attrs="{'invisible': [('is_assigned_staff', '=', False)]}"/>
                    </group> -->

                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="cases_description" readonly="1" widget="html"/>
                                <field name="further_description" readonly="1" widget="html"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Form View for Open Cases with Staff Access -->
    <record id="view_case_form_staff_only" model="ir.ui.view">
        <field name="name">case.form.staff.only</field>
        <field name="model">case</field>
        <field name="inherit_id" ref="view_case_form_base"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <header position="replace">
                <header>
                    <!-- Close button only for creator and only if there are responses -->
                    <button name="action_close_case" 
                            string="Close Case" 
                            type="object" 
                            class="btn-primary" 
                            attrs="{'invisible': ['|', '|', ('is_creator', '=', False), ('has_responses', '=', False), ('is_supervisor', '=', True)]}"/>
                    <field name="status_id" widget="statusbar" readonly="1"/>
                </header>
            </header>
            <notebook position="replace">
                <notebook>
                    <page string="Description">
                        <group>
                            <field name="cases_description" readonly="1" widget="html"/>
                            <field name="further_description" readonly="1" widget="html"/>
                        </group>
                    </page>
                    <page string="Responses" attrs="{'invisible': []}">
                        <!-- Responses writable only for assigned staff and not supervisors -->
                        <!-- <field name="response_ids" context="{'default_case_id': id}" attrs="{'readonly': ['|', ('is_assigned_staff', '=', False), ('is_supervisor', '=', True)]}" nolabel="1"> -->
                        <field name="response_ids" context="{'default_case_id': id}" readonly="1" nolabel="1">
                            <tree>
                                <field name="create_date" readonly="1"/>
                                <field name="create_uid" string="Responder" options="{'no_open': True, 'no_create': True}"/>
                                <!-- <field name="quick_response" readonly="1" required="1"/> -->
                                <field name="response" required="1" />
                                <field name="case_id" invisible="1"/>
                            </tree>
                            <form>
                                <group>
                                    <field name="create_uid" readonly="1"/>
                                    <field name="create_date" readonly="1"/>
                                    <field name="response" invisible="1"/>
                                </group>
                            </form>
                        </field>
                    </page>
                    <page string="Attachments" attrs="{'invisible': [('is_supervisor', '=', True)]}">
                        <group>
                            <field name="attachment" widget="binary" filename="filename" attrs="{'readonly': ['|',('is_supervisor', '=', True),('attachment', '!=', False)]}" options="{'no_delete': True}" />
                            <field name="filename" invisible="1"/>
                        </group>
                    </page>
                </notebook>
            </notebook>
        </field>
    </record>
    
    <!-- Form View: Readonly for Cases Created by Me -->
    <record id="view_case_form_readonly" model="ir.ui.view">
        <field name="name">case.form.readonly</field>
        <field name="model">case</field>
        <field name="inherit_id" ref="view_case_form_base"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <header position="replace">
                <header>
                    <!-- Close button only for creator and only if there are responses -->
                    <button name="action_close_case" 
                            string="Close Case" 
                            type="object" 
                            class="btn-primary" 
                            attrs="{'invisible': ['|', '|', '|', ('is_creator', '=', False), ('has_responses', '=', False), ('is_supervisor', '=', True), ('status_name', '=', 'closed')]}"/>
                    <field name="status_id" widget="statusbar" readonly="1"/>
                </header>
            </header>
            <field name="is_supervisor" position="after">
                <field name="statuses" invisible="1"/>
            </field>
            <notebook position="replace">
                <notebook>
                    <page string="Description">
                        <group>
                            <field name="cases_description" readonly="1" widget="html"/>
                            <field name="further_description" readonly="1"/>
                        </group>
                    </page>
                    <page string="Responses">
                        <field name="response_ids" readonly="1" nolabel="1">
                            <tree>
                                <field name="create_uid" string="Responder"/>
                                <field name="create_date" string="Date" widget="datetime"/>
                                <field name="response" string="Response"/>
                            </tree>
                            <form>
                                <group>
                                    <field name="create_uid" readonly="1"/>
                                    <field name="create_date" readonly="1"/>
                                    <field name="response" invisible="1"/>
                                </group>
                            </form>
                        </field>
                    </page>
                    <page string="Attachments">
                        <field name="attachment"
                            filename="filename"
                            attrs="{'readonly': ['|',('is_creator', '=', False),('attachment', '!=', False)]}"
                            options="{'no_delete': True}"  />
                        <field name="filename" invisible="1"/>
                    </page>

                </notebook>
            </notebook>
            <div class="oe_chatter" position="replace">
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </div>
        </field>
    </record>

    <!-- Form View that works for response writing (Cases Assigned to Me) -->
    <record id="view_case_form_response_only" model="ir.ui.view">
        <field name="name">case.form.response.only</field>
        <field name="model">case</field>
        <field name="inherit_id" ref="view_case_form_base"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- Enhancing header with decorations -->
            <field name="status_id" position="attributes">
                <attribute name="decoration-danger">status_id == 'overdue'</attribute>
                <attribute name="decoration-success">status_id == 'closed'</attribute>
            </field>
            
            <!-- Replacing first group to match original structure -->
            <xpath expr="//sheet//group[1]" position="replace">
                <group>
                    <group>
                        <field name="created_at" readonly="1" invisible="1"/>
                        <field name="created_at_formatted_datetime" widget="text"/>
                        <field name="event_date" readonly="1" invisible="1"/>
                        <field name="event_date_formatted_datetime" widget="text"/>
                        <field name="title" string="Severity" readonly="1" invisible="1" />
                        <field name="branch_id" readonly="1"/>
                        <field name="team_id" readonly="1"/>
                        <field name="transaction_id" invisible='1'/>
                        <field name="transaction_id" attrs="{'invisible': [('transaction_id', '=', False)]}" readonly='1'/>
                        <field name="customer_id" attrs="{'invisible': [('customer_id', '=', False)]}" readonly="1"/>
                        <field name="data_source" readonly="1" invisible="1"/>
                        <field name="cases_action" string="Recommended Action" readonly="1" widget="html"/>
                    </group>
                    <group>
                        <field name="staff_id" string="Staff Responsible" readonly="1"/>
                        <field name="supervisor_one_id" readonly="1"/>
                        
                        <!-- Supervisor 2 shown only for medium risk rating -->
                        <field name="supervisor_two_id" 
                            readonly="1"
                            attrs="{'invisible': [('title', '!=', '2')]}" 
                            />

                        <!-- Another Supervisor 2 instance shown only for high risk rating -->
                        <field name="supervisor_two_id" 
                            readonly="1"
                            attrs="{'invisible': [('title', '!=', '3')]}" 
                            />

                        <!-- Supervisor 3 shown only for high risk rating -->
                        <field name="supervisor_three_id" 
                            readonly="1"
                            attrs="{'invisible': [('title', '!=', '3')]}" 
                            />

                        <field name="is_supervisor" invisible="1"/>
                        
                        <field name="user_id" readonly="1"/>
                        <field name="severity_level" invisible="1"/>
                        <field name="is_creator" invisible="1"/>
                        <field name="is_assigned_staff" invisible="1"/>
                        <field name="has_responses" invisible="1"/>
                        <field name="new_process_category_id" string="Process Category" readonly="1"/>
                        <field name="new_process_id" string="Process" readonly="1"/>
                        <field name="status_name" invisible="1"/>
                        <field name="quick_response" string="Respond to Case"
                        attrs="{'invisible': ['|',
                        ('is_assigned_staff', '=', False),
                        ('status_name', '=', 'closed')
                        ]}"/>
                    </group>
                </group>
            </xpath>
            
            <!-- Replacing notebook to match original implementation exactly -->
            <notebook position="replace">
                <notebook>
                    <page string="Description">
                        <group>
                            <field name="cases_description" readonly="1" widget="html"/>
                            <field name="further_description" readonly="1" widget="html"/>
                        </group>
                    </page>
                    <page string="Responses">
                        <field name="response_ids" context="{'default_case_id': id}" readonly="1" nolabel="1">
                            <tree string="Responses">
                                <field name="create_date" readonly="1"/>
                                <field name="create_uid" string="Responder" options="{'no_open': True, 'no_create': True}"/>
                                <field name="response" required="1"/>
                                <field name="case_id" invisible="1"/>
                            </tree>
                            <form>
                                <group>
                                    <field name="create_uid" readonly="1"/>
                                    <field name="create_date" readonly="1"/>
                                    <field name="response" readonly="1"/>
                                </group>
                            </form>
                        </field>
                    </page>
                    <page string="Attachments">
                        <field name="attachment"
                            filename="filename"
                            attrs="{'readonly': ['|', ('is_creator', '=', False),('attachment', '!=', False)]}" 
                            options="{'no_delete': True}"  />
                        <field name="filename" invisible="1"/>
                    </page>
                </notebook>
            </notebook>
            
            <!-- Making chatter match exactly -->
            <div class="oe_chatter" position="replace">
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </div>
        </field>
    </record>

    <!-- Readonly Form View for Closed Cases -->
    <record id="case_closed_form_view" model="ir.ui.view">
        <field name="name">case.closed.form</field>
        <field name="model">case</field>
        <field name="inherit_id" ref="view_case_form_base"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <field name="created_at" position="attributes">
                <attribute name="string">Start Date</attribute>
            </field>
            <field name="created_at_formatted_datetime" position="after">
                <field name="end_date" string="End Date" readonly="1" invisible="1"/>
            </field>
            <field name="branch_id" position="attributes">
                <attribute name="string">Branch</attribute>
            </field>
            <field name="transaction_id" position="attributes">
                <attribute name="string">Transaction Reference</attribute>
            </field>
            <notebook position="replace">
                <notebook>
                    <page string="Description">
                        <group>
                            <field name="cases_description" readonly="1" widget="html"/>
                            <field name="further_description" readonly="1" widget="html"/>
                        </group>
                    </page>
                    <page string="Responses">
                        <field name="response_ids" readonly="1" nolabel="1">
                            <tree>
                                <field name="create_uid" string="Responder"/>
                                <field name="create_date" string="Date" widget="datetime"/>
                                <field name="response" string="Response"/>
                            </tree>
                            <form>
                                <group>
                                    <field name="create_uid" readonly="1"/>
                                    <field name="create_date" readonly="1"/>
                                    <field name="response" readonly="1"/>
                                </group>
                            </form>
                        </field>
                    </page>
                    <page string="Attachments">
                        <field name="attachment"
                            filename="filename"
                            attrs="{'readonly': ['|',('is_creator', '=', False),('attachment', '!=', False)]}" 
                            options="{'no_delete': True}"  />
                        <field name="filename" invisible="1"/>
                    </page>

                </notebook>
            </notebook>
            <div class="oe_chatter" position="replace">
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </div>
        </field>
    </record>

    <!-- ACTIONS -->
    
    <!-- Action for Open Cases -->
    <record id="case_action" model="ir.actions.act_window">
        <field name="name">Open Cases</field>
        <field name="res_model">case</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">['|', '|', '|', 
                         ('status_id.name', '=', 'open'),
                         ('supervisor_one_id', '=', uid),
                         ('supervisor_two_id', '=', uid),
                         ('supervisor_three_id', '=', uid)]</field>
        <field name="view_ids" eval="[(5, 0, 0), 
                                      (0, 0, {'view_mode': 'tree', 'view_id': ref('view_cases_tree')}),
                                      (0, 0, {'view_mode': 'form', 'view_id': ref('view_case_form_staff_only')})]"/>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No open cases found
            </p>
            <p>
                All current open cases will appear here.
            </p>
        </field>
    </record>

    <!-- Action: All Closed Cases -->
    <record id="closed_case_action" model="ir.actions.act_window">
        <field name="name">All Closed Cases</field>
        <field name="res_model">case</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('status_id.name', '=', 'closed')]</field>
        <field name="context">{'create': False, 'search_default_order': 'create_date desc'}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
                                      (0, 0, {'view_mode': 'tree', 'view_id': ref('view_cases_tree')}),
                                      (0, 0, {'view_mode': 'form', 'view_id': ref('case_closed_form_view')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No closed cases found
            </p>
        </field>
    </record>

    <!-- Action: Overdue Cases -->
    <record id="overdue_case_action" model="ir.actions.act_window">
        <field name="name">Overdue Cases</field>
        <field name="res_model">case</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('status_id.name', '=', 'overdue')]</field>
        <field name="context">{'create': False}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
                                      (0, 0, {'view_mode': 'tree', 'view_id': ref('view_cases_tree')}),
                                      (0, 0, {'view_mode': 'form', 'view_id': ref('view_case_form_staff_only')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No overdue cases found
            </p>
            <p>
                Cases that have exceeded their SLA will appear here.
            </p>
        </field>
    </record>
    
    <!-- Action: Cases Created by Me -->
    <record id="action_case_created_by_me" model="ir.actions.act_window">
        <field name="name">Created by Me</field>
        <field name="res_model">case</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'create': False, 'search_default_order': 'create_date desc'}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
                                      (0, 0, {'view_mode': 'tree', 'view_id': ref('view_case_tree_readonly')}),
                                      (0, 0, {'view_mode': 'form', 'view_id': ref('view_case_form_readonly')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No case has been created by you yet.
            </p>
        </field>
    </record>
    
    <!-- Action: Cases Assigned to Me -->
    <record id="action_case_assigned_to_me" model="ir.actions.act_window">
        <field name="name">Cases Assigned to Me</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">case</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('staff_id', '=', uid)]</field>
        <field name="context">{}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
                                     (0, 0, {'view_mode': 'tree', 'view_id': ref('view_case_tree_assigned_to_me')}),
                                     (0, 0, {'view_mode': 'form', 'view_id': ref('view_case_form_response_only')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No case has been assigned to you yet.
            </p>
        </field>
    </record>

    <!-- SERVER ACTIONS -->
    
    <!-- Server Action for Open Cases -->
    <record id="action_open_cases_custom" model="ir.actions.server">
        <field name="name">Open Cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_cases()</field>
    </record>

    <!-- Server Action for Closed Cases -->
    <record id="action_closed_cases_custom" model="ir.actions.server">
        <field name="name">Closed Cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="state">code</field>
        <field name="code">action = model.action_view_closed_cases()</field>
    </record>

    <!-- Server Action for Overdue Cases -->
    <record id="action_overdue_cases_custom" model="ir.actions.server">
        <field name="name">Overdue Cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="state">code</field>
        <field name="code">action = model.action_view_overdue_cases()</field>
    </record>

    <!-- SECURITY RULES -->
    
    <record id="case_rule_supervisor" model="ir.rule">
        <field name="name">Case: supervisors see their cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="domain_force">[
        ('status_id.name', '=', 'open'),
        '|', '|',
            ('supervisor_one_id', '=', user.id),
            ('supervisor_two_id', '=', user.id),
            ('supervisor_three_id', '=', user.id)
    ]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>