<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Readonly Tree View -->
    <record id="case_list_closed_tree_view" model="ir.ui.view">
        <field name="name">case.list.closed.tree</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <!-- <tree></tree> -->
            <tree create="false" edit="false" delete="false">
                <field name="name" invisible='1'/>
                <field name="transaction_reference"/>
                <field name="title" string="Severity" readonly="1" invisible="1" />
                <field name="title_html" string= "Severity" readonly="1" widget="html"/>
                <field name="created_at" string="Case Creation Date"/>
                <field name="user_id" string="Created By"/>
                <field name="staff_id" string="Staff Responsible"/>
                <field name="data_source" readonly="1" invisible="1"/>
                <field name="cases_action" string="Recommended Action" readonly="1"/>
                <field name="team_id"/>
                <field name="status_html" widget="html"/>
                <field name="is_supervisor" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Readonly Form View -->
    <record id="case_closed_form_view" model="ir.ui.view">
        <field name="name">case.closed.form</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <form string="Case" create="false" delete="false">
                <header>
                    <!-- <field name="status_id" widget="statusbar" readonly="1"/> -->
                    <field name="status_id" widget="statusbar" readonly="1" 
                        decoration-danger="status_id == 'overdue'" 
                        decoration-success="status_id == 'closed'" />
                </header>
                <sheet>
                    <field name="is_supervisor" invisible="1"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="created_at" string="Start Date" readonly="1" invisible="1"/>
                            <field name="created_at_formatted_datetime" widget="text"/>
                            <field name="event_date" readonly="1" invisible="1"/>
                            <field name="event_date_formatted_datetime" widget="text"/>
                            <field name="end_date" string="End Date" readonly="1" invisible="1"/>
                            <field name="title" string="Severity" readonly="1" invisible="1" />
                            <field name="branch_id" string="Branch" readonly="1" />
                            <field name="team_id" readonly="1"/>
                            <field name="transaction_reference" string="Transaction Reference" readonly="1" />
                            <field name="data_source" readonly="1" invisible="1"/>
                            <field name="cases_action" string="Recommended Action" readonly="1"/>
                        </group>
                        <group>
                            <field name="staff_id" string="Staff Responsible" readonly="1"/>
                            <field name="supervisor_one_id" readonly="1"/>

                            <field name="supervisor_two_id" 
                                readonly="1"
                                attrs="{'invisible': [('title', 'not in', ['2', '3'])]}" 
                            />

                            <!-- <field name="supervisor_two_id" 
                                readonly="1"
                                attrs="{'invisible': ['|', ('title', '!=', '2'), ('title', '!=', '3')]}" 
                            /> -->

                            <!-- <field name="supervisor_two_id" 
                                readonly="1"
                                attrs="{'invisible': [('title', '!=', '2')]}" 
                                /> -->

                            <!-- Another Supervisor 2 instance shown only for high risk rating -->
                            <!-- <field name="supervisor_two_id" 
                                readonly="1"
                                attrs="{'invisible': [('title', '!=', '3')]}" 
                                /> -->

                            <!-- Supervisor 3 shown only for high risk rating -->
                            <field name="supervisor_three_id" 
                                readonly="1"
                                attrs="{'invisible': [('title', '!=', '3')]}" 
                                />

                            
                            <!-- Show supervisor_two only for medium or high severity -->
                            <!-- <field name="supervisor_two_id" readonly="1" 
                                   attrs="{'invisible': [('severity_level', '=', 'low')]}" groups="base.group_user" widget="no_label"/>
                             -->
                            <!-- Show supervisor_three only for high severity -->
                            <!-- <field name="supervisor_three_id" readonly="1"
                                    attrs="{'invisible': ['|', ('severity_level', '=', 'low'), ('severity_level', '=', 'medium')]}" groups="base.group_user" widget="no_label"/> -->

                            <field name="is_supervisor" invisible="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="severity_level" invisible="1"/>
                            <field name="is_creator" invisible="1"/>
                            <field name="is_assigned_staff" invisible="1"/>
                            <field name="has_responses" invisible="1"/>
                            <field name="process_category_id" string="Process Category" readonly="1"/>
                            <field name="process_id" string="Process" readonly="1"/>
                            <!-- <field name="process_category_id" readonly="1"/>
                            <field name="process_id" readonly="1"/> -->
                            <!-- <field name="cases_action" readonly="1"/> -->
                            <!-- <field name="root_category_id" readonly="1"/>
                            <field name="root_category_process_id" readonly="1"/> -->
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="cases_description" readonly="1"/>
                                <field name="further_description" readonly="1"/>
                            </group>
                        </page>
                        <page string="Responses">
                            <field name="response_ids" readonly="1" nolabel="1">
                                <tree>
                                    <field name="create_uid" string="Responder"/>
                                    <field name="create_date" string="Date" widget="datetime"/>
                                    <field name="response" string="Response"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="response" readonly="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Attachments">
                            <field name="attachment" filename="filename" readonly="1"/>
                            <field name="filename" invisible="1"/>
                            <!-- <field name="attachment_ids" widget="many2many_binary" readonly="1"/> -->
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action: All Closed Cases -->
    <record id="closed_case_action" model="ir.actions.act_window">
        <field name="name">All Closed Cases</field>
        <field name="res_model">case</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('status_id.name', '=', 'closed')]</field>
        <field name="context">{'create': False, 'search_default_order': 'create_date desc'}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
                                      (0, 0, {'view_mode': 'tree', 'view_id': ref('case_list_closed_tree_view')}),
                                      (0, 0, {'view_mode': 'form', 'view_id': ref('case_closed_form_view')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No closed cases found
            </p>
        </field>
    </record>


    <!-- Server Action for Closed Cases -->
    <record id="action_closed_cases_custom" model="ir.actions.server">
        <field name="name">Closed Cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="state">code</field>
        <field name="code">action = model.action_view_closed_cases()</field>
    </record>

</odoo>