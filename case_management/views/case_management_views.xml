<odoo>
    <!-- Tree View for Admin -->
    <record id="view_case_management_tree_admin" model="ir.ui.view">
        <field name="name">case.management.tree.admin</field>
        <field name="model">case.management</field>
        <field name="arch" type="xml">
            <tree>
                <field name="process_category" />
                <field name="process_status" />
                <field name="event_date" />
                <!-- <field name="customer_id" /> -->
                <field name="branch_staff_responsible_id" />
                <field name="severity_id" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_case_management_form" model="ir.ui.view">
        <field name="name">case.management.form</field>
        <field name="model">case.management</field>
        <field name="arch" type="xml">
            <form string="Case Management">
                <sheet>
                    <group>
                        <field name="process_category" />
                        <field name="process_status" />
                    </group>
                    <group>
                        <field name="event_date" />
                        <field name="narration" />
                        <field name="data_source" />
                    </group>
                    <group>
                        <!-- <field name="customer_id" /> -->
                        <field name="transaction_reference" />
                        <field name="recommended_action" />
                    </group>
                    <group>
                        <field name="severity_id" />
                        
                        <field name="risk_rating" />
                    </group>
                    <group>
                        <field name="branch_staff_responsible_id" />
                        <!-- <field name="responsible_department" /> -->
                        <field name="supervisor_one_id" />
                        <field name="supervisor_two_id" />
                        <field name="supervisor_three_id" />
                    </group>
                    <group>
                        <field name="further_description" />
                        <field name="attachment" widget="binary" />
                    </group>
                </sheet>
                <button name="action_reply_log" string="Reply Log" type="object" class="btn-primary" />
            </form>
        </field>
    </record>
</odoo>