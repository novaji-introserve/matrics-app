<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Define Overdue Status -->
    <record id="case_status_overdue" model="case.status">
        <field name="name">overdue</field>
    </record>

    <!-- Define Read-Only Tree View for Overdue Cases -->
    <record id="case_list_overdue_tree_view" model="ir.ui.view">
        <field name="name">case.list.overdue</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="name"/>
                <field name="transaction_reference"/>
                <field name="title" string="Severity" readonly="1" />
                <field name="created_at" string="Case Creation Date"/>
                <field name="user_id" string="Created By"/>
                <field name="staff_id" string="Staff Responsible"/>
                <field name="data_source" readonly="1"/>
                <field name="cases_action" string="Recommended Action" readonly="1"/>
                <field name="team_id"/>
                <field name="status_html" widget="html"/>
                <field name="severity_level" invisible="1"/>
                <field name="has_responses" invisible="1"/>
                <field name="is_creator" invisible="1"/>
                <field name="is_assigned_staff" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Enhanced Form View for Overdue Cases with Response and Close Features -->
    <record id="case_overdue_form_view" model="ir.ui.view">
        <field name="name">case.form.overdue</field>
        <field name="model">case</field>
        <field name="arch" type="xml">
            <form string="Case" create="false" delete="false">
                <header>
                    <!-- Close button only for creator and only if there are responses -->
                    <button name="action_close_case" 
                            string="Close Case" 
                            type="object" 
                            class="btn-primary" 
                            attrs="{'invisible': ['|', '|', 
                                                ('is_creator', '=', False), 
                                                ('has_responses', '=', False),
                                                ('statuses', '=', 'closed')]}"/>
                                                
                    <!-- <field name="status_id" widget="statusbar" readonly="1"/> -->
                    <!-- <field name="status_id" widget="statusbar" readonly="1" 
                        decoration-danger="status_id == 'overdue'" /> -->
                    <field name="status_id" widget="statusbar" readonly="1"/>            
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="created_at" string="Start Date" readonly="1"/>
                            <field name="end_date" readonly="1"/>
                            <field name="team_id" readonly="1"/>
                            <field name="branch_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="staff_id" readonly="1"/>
                            
                            <!-- Always show supervisor_one (for all severity levels) -->
                            <field name="supervisor_one_id" readonly="1"/>
                            
                            <!-- Show supervisor_two only for medium or high severity -->
                            <field name="supervisor_two_id" readonly="1" 
                                   attrs="{'invisible': [('severity_level', '=', 'low')]}"/>
                            
                            <!-- Show supervisor_three only for high severity -->
                           <field name="supervisor_three_id" readonly="1"
                                    attrs="{'invisible': ['|', ('severity_level', '=', 'low'), ('severity_level', '=', 'medium')]}"/>
                            
                            <field name="severity_level" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            
                            <!-- Required invisible fields for attrs -->
                            <field name="is_creator" invisible="1"/>
                            <field name="is_assigned_staff" invisible="1"/>
                            <field name="has_responses" invisible="1"/>
                            <field name="statuses" invisible="1"/>
                        </group>
                    </group>
                    
                    <!-- Tabbed sections for description, responses, and attachments -->
                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="cases_description" readonly="1"/>
                                <field name="further_description" readonly="1"/>
                            </group>
                        </page>
                        <page string="Responses">
                            <!-- Responses writable only for assigned staff -->
                            <field name="response_ids" attrs="{'readonly': [('is_assigned_staff', '=', False)]}" nolabel="1">
                                <tree editable="bottom">
                                    <field name="create_date" readonly="1"/>
                                    <field name="create_uid" readonly="1"/>
                                    <field name="response"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="response"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                
                <!-- Chatter for message tracking -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <!-- <field name="activity_ids" widget="mail_activity"/> -->
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Define Action with Enhanced Views -->
    <record id="overdue_case_action" model="ir.actions.act_window">
        <field name="name">All Overdue Cases</field>
        <field name="res_model">case</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('status_id.name', '=', 'overdue')]</field>
        <field name="context">{'create': False}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
                                     (0, 0, {'view_mode': 'tree', 'view_id': ref('case_list_overdue_tree_view')}),
                                     (0, 0, {'view_mode': 'form', 'view_id': ref('case_overdue_form_view')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No overdue cases found
            </p>
        </field>
    </record>
</odoo>