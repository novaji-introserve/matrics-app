<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Define the staff security group -->
    <record id="group_staff" model="res.groups">
        <field name="name">Case Management / Staff</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Users who can manage cases assigned to them</field>
    </record>
    
    <!-- Optional: Record rule to restrict cases to assigned staff -->
    <!-- <record id="rule_case_staff" model="ir.rule">
        <field name="name">Staff can only see their assigned cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="domain_force">[('staff_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('case_management.group_staff'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record> -->


    <!-- Add a more permissive rule for staff if needed -->
    <record id="rule_case_staff_enhanced" model="ir.rule">
        <field name="name">Staff can see their assigned cases and created cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="domain_force">['|', ('staff_id','=',user.id), ('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('case_management.group_staff'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>