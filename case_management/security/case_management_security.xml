<odoo>
    <!-- Admin Access -->
    <record id="case_management_rule_admin" model="ir.rule">
        <field name="name">Admin Case Management Access</field>
        <field name="model_id" ref="model_case_management" />
        <field name="groups" eval="[(4, ref('base.group_system'))]" />
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- User Access -->
    <record id="case_management_rule_user" model="ir.rule">
        <field name="name">User Case Management Access</field>
        <field name="model_id" ref="model_case_management" />
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
        <field name="domain_force">['|', ('create_uid', '=', user.id),
            ('branch_staff_responsible_id.user_id', '=', user.id)]</field>
    </record>
</odoo>