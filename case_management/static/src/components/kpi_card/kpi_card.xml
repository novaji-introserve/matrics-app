<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="owl.KpiCard" owl="1">
        <div t-att-class="cardClassName" t-on-click="handleClick">
            <div class="case-kpi-card__value"><span t-esc="props.value"/></div>
            <div class="case-kpi-card__label"><span t-esc="props.statName"/></div>
            <t t-if="props.summary">
                <div class="case-kpi-card__summary"><span t-esc="props.summary"/></div>
            </t>
            <div t-att-class="deltaClass">
                <span t-esc="percentageLabel"/>
            </div>
        </div>
    </t>
</templates>

