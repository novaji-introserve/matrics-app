<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Default Case Configuration -->
        <record id="default_case_configuration" model="case.configuration">
            <field name="name">Default Configuration</field>
            <field name="deadline_value">48</field>
            <field name="deadline_unit">hours</field>
            <field name="is_default">True</field>
            <field name="active">True</field>
            <field name="notify_before_overdue">False</field>
            <field name="notification_hours">24</field>
        </record>

        <!-- Additional sample configurations -->
        <record id="quick_response_configuration" model="case.configuration">
            <field name="name">Quick Response (24 Hours)</field>
            <field name="deadline_value">24</field>
            <field name="deadline_unit">hours</field>
            <field name="is_default">False</field>
            <field name="active">True</field>
            <field name="notify_before_overdue">True</field>
            <field name="notification_hours">6</field>
        </record>

        <record id="standard_configuration" model="case.configuration">
            <field name="name">Standard (3 Days)</field>
            <field name="deadline_value">3</field>
            <field name="deadline_unit">days</field>
            <field name="is_default">False</field>
            <field name="active">True</field>
            <field name="notify_before_overdue">True</field>
            <field name="notification_hours">24</field>
        </record>

        <record id="extended_configuration" model="case.configuration">
            <field name="name">Extended (1 Week)</field>
            <field name="deadline_value">1</field>
            <field name="deadline_unit">weeks</field>
            <field name="is_default">False</field>
            <field name="active">True</field>
            <field name="notify_before_overdue">True</field>
            <field name="notification_hours">48</field>
        </record>

    </data>
</odoo>