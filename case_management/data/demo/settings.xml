<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_case_settings_overdue" model="case.settings">
        <field name="name">Case Overdue Period</field>
        <field name="code">case_overdue_period</field>
        <field name="date_val">48</field>
        <field name="date_unit">hours</field>
        <field name="narration">Deteremines the Period when a case becomes overdue
        </field>
    </record>

    <record id="res_case_settings_archive" model="case.settings">
        <field name="name">Case Archive Period</field>
        <field name="code">case_archive_period</field>
        <field name="date_val">180</field>
        <field name="date_unit">days</field>
        <field name="narration">Deteremines the Period when a case is Archived
        </field>
    </record>

    <record id="res_settings_low_risk_threshold" model="case.settings">
        <field name="name">Low Risk Threshold</field>
        <field name="code">low_risk_threshold</field>
        <field name="val">3.9</field>
        <field name="narration">Low Risk Threshold</field>
    </record>
    <record id="res_settings_medium_risk_threshold" model="case.settings">
        <field name="name">Medium Risk Threshold</field>
        <field name="code">medium_risk_threshold</field>
        <field name="val">6.9</field>
        <field name="narration">Medium Risk Threshold</field>
    </record>
    <record id="res_settings_high_risk_threshold" model="case.settings">
        <field name="name">High Risk Threshold</field>
        <field name="code">high_risk_threshold</field>
        <field name="val">9</field>
        <field name="narration">High Risk Threshold</field>
    </record>
    <record id="res_settings_max_risk_score" model="case.settings">
        <field name="name">Maximum Risk Threshold</field>
        <field name="code">maximum_risk_threshold</field>
        <field name="val">9</field>
        <field name="narration">Maximum Risk Threshold</field>
    </record>

</odoo>
