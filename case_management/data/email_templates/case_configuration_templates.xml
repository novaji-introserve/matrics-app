<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Overdue Case Notification Email Template -->
        <record id="case_overdue_notification_template" model="mail.template">
            <field name="name">Case Overdue Notification</field>
            <field name="model_id" ref="model_case"/>
            <field name="subject">🚨 OVERDUE CASE REMINDER: ${ctx.get('case_ref') or 'Case'} - ${ctx.get('title') or 'No Title'}</field>
            <field name="email_from">${ctx.get('email_from')}</field>
            <field name="use_default_to">True</field>
            <field name="auto_delete" eval="True"/>
            <field name="lang">${ctx.get('user_lang') or object.user_id.lang}</field>
            <field name="body_html" type="html">
                <div style="padding: 15px; background-color: #FFFFFF; font-family: Arial, sans-serif; margin: 0; border: none; color: #000000;">
                    <div style="background-color: #FFFFFF; color: #000000; padding: 10px 15px;">
                    
                        <table width="100%" cellspacing="0" cellpadding="10">
                            <tr>
                                <td style="text-align: left; padding-left: 0; max-width:60px; object-fit:cover; padding-bottom: 15px;">
                                    <img src="/case_management/static/src/img/alt_bank_logo.png" alt="Bank Logo" style="max-height: 60px; max-width:60px; object-fit:cover;"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" style="border-bottom: 1px solid #eee; padding-bottom: 20px;word-wrap: break-word;">
                                    <i>🚨 <b>URGENT:</b> The case below is overdue by <t t-esc="ctx.get('overdue_duration', 'some time')"/> and requires immediate attention.</i><br/>
                                    <i>Please respond to this overdue case immediately, explaining the current status and your action plan.</i> <br/>
                                    <i><b>NOTE</b>: This case will remain overdue and escalate further unless resolved promptly.</i> <br/>
                                </td>
                            </tr>
                        </table>
                    </div>
                    
                    <div style="padding: 15px; background-color: white;">
                        
                        <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold; width: 35%;">Case Reference:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('case_ref', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Alert ID:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('alert_id', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Title:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('title', 'No title provided')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Severity Level:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('severity_level', 'Low')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Current Status:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('status_name', 'Open')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Department:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('staff_dept', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Process Type:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('process_type', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Process Category:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('process_category', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Expected Completion:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('expected_completion', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">SLA Deadline:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('deadline_config', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Overdue By:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; color: #dc3545; font-weight: bold;"><t t-esc="ctx.get('overdue_duration', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Event Date:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('event_date', 'N/A')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE; font-weight: bold;">Additional Details:</td>
                                <td style="padding: 8px; border-bottom: 1px solid #EEEEEE;"><t t-esc="ctx.get('description', 'No additional description provided.')"/></td>
                            </tr>
                        </table>
                        
                        <div style="margin-top: 20px;">
                            <h3 style="color: #000000; margin-bottom: 10px;"><b>Immediate Action Required</b></h3>
                            <p style="margin: 0 0 10px 0;"><i>Please take immediate action on this overdue case:</i></p>
                            <ul style="margin: 0; padding-left: 20px; color: #000000;">
                                <li>Review the case details and current status</li>
                                <li>Update the case with progress or resolution</li>
                                <li>Escalate if additional resources are needed</li>
                                <li>Communicate with stakeholders about the delay</li>
                            </ul>
                        </div>
                        
                        <div style="margin-top: 25px; text-align: left;">
                            <a t-att-href="ctx.get('response_link', '/web#model=case&amp;id=%s&amp;view_type=form' % object.id)" style="background-color: #dc3545; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px; display: inline-block;">🔗 Click To Review Case Now</a>
                        </div>
                    </div>
                    
                    <div style="padding: 10px 15px; background-color: #FFFFFF; font-size: 12px; color: #B78C00; text-align: left;">
                        <p>This is an automated overdue reminder from your Case Management System.</p>
                        <p style="margin: 5px 0 0 0;">Case Creator: <t t-esc="ctx.get('creator_user_name', 'N/A')"/> (<t t-esc="ctx.get('creator_user_email', 'N/A')"/>)</p>
                        <p style="margin: 5px 0 0 0;">Assigned to: <t t-esc="ctx.get('staff_user_name', 'N/A')"/></p>
                    </div>
                </div>
            </field>
        </record>
        
    </data>
</odoo>