<odoo>
    <record id="ir_cron_check_overdue_cases" model="ir.cron">
        <field name="name">Check Overdue Cases</field>
        <field name="model_id" ref="model_case"/>
        <field name="state">code</field>
        <field name="code">model.cron_check_overdue_cases()</field>
        <field name="interval_type">hours</field>
        <field name="interval_number">1</field> <!-- Check every 1 hour -->
        <field name="nextcall">2025-04-07 00:00:00</field> <!-- First run -->
    </record>
</odoo>
