<odoo noupdate="1">

    <record id="risk_plan_ussd" model="res.compliance.risk.assessment.plan">
        <field name="name">Risk Analysis For USSD Delivery Channel</field>
        <field name="code">USSD_DELIVERY_CHANNEL</field>
        <field name="sql_query">
            SELECT 1 
            FROM customer_channel_subscription ccs
            JOIN digital_delivery_channel ddc ON ccs.channel_id = ddc.id
            WHERE ccs.partner_id::integer = %s
            AND lower(ccs.value) IN ('yes', 'enrolled')
            AND ddc.code = 'ussd';
        </field>
        <field name="priority">1</field>
        <field name="state">active</field>
        <field name="narration">Analysis for customers using ussd channel</field>
        <field name="compute_score_from">risk_assessment</field>
        <field name="risk_assessment" ref="res_risk_assessment_regulatory_ussd"/>
        <field name="use_composite_calculation">True</field>
        <field name="universe_id" ref="compliance_management.compliance_inst_fc_risk_univ_23"/>
    </record>

