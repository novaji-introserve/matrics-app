#  storage path for odoo data and logs. should be an absolute path on the host machine. eg /home/ubuntu/storage
STORAGE_PATH=/path/to/storage
# should be name of project folder. eg matrics-app-odoo16-1
CONTAINER_NAME=matrics-app-odoo16-1
# should be name of database container in docker-compose.yml. eg matrics-app-db-1
DB_CONTAINER=matrics-app-db-1
DB_NAME=your_db_name
DB_HOST=pgbouncer
# pgbouncer port for database connection
DB_PORT=5433
# Database credentials from docker-compose.yml
DB_USER=your_db_user
DB_PASSWORD=your_db_password
FASTAPI_PORT=8001
ODOO_PORT=10016
ODOO_GEVENT_PORT=20016
REDIS_PORT=6379
# Odoo credentials from docker-compose.yml
ODOO_USER=your_odoo_user
ODOO_PASSWORD=your_odoo_password
# MySQL database configuration
MYSQL_USER='your_mysql_user'
MYSQL_PASSWORD='your_mysql_password'

# Adverse Media Screening (NewsAPI)
NewsApiKey=your_newsapi_key_here
NewsApiUrl=https://newsapi.org/v2/everything
EmailFrom=compliance@yourorg.com

# OpenAI configuration (used by openai_util module for PEP biography lookup)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=30
OPENAI_PROJECT=

# PostgreSQL sink configuration
PG_HOST='host.docker.internal'
PG_PORT='5433'
# PostgreSQL credentials from docker-compose.yml
PG_USER='your_pg_user'
PG_PASSWORD='your_pg_password'
# PostgreSQL database name for sink
PG_DATABASE='your_pg_database'
