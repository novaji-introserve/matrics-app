# =============================================================================
# STORAGE & HOST
# =============================================================================
# Absolute path on the host for persistent data (odoo, postgres, redis, etc.)
STORAGE_PATH=/path/to/storage
# Must match service/container naming in docker-compose.yml when overridden.
CONTAINER_NAME=matrics-app-odoo16-1
DB_CONTAINER=matrics-app-db-1
ODOO_SERVICE=odoo16
POSTGRES_SERVICE=db
POSTGRES_SERVICE_HOST=db
PGBOUNCER_DB_USER=your_db_user
PGBOUNCER_DB_PASSWORD=your_db_password
PGBOUNCER_ADMIN_USERS=your_admin_user

# =============================================================================
# PORTS (host-side)
# =============================================================================
POSTGRES_HOST_PORT=5432
POSTGRES_SERVICE_PORT=5432
DB_PORT=5433
ODOO_PORT=10016
ODOO_GEVENT_PORT=20016
ODOO_WEBSOCKET_PORT=8073
FASTAPI_PORT=8001
REDIS_PORT=6379
SEATUNNEL_HAZELCAST_PORT=5801
SEATUNNEL_API_PORT=9080

# =============================================================================
# DATABASE
# =============================================================================
DB_NAME=your_db_name
DB_HOST=pgbouncer
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ODOO_USER / ODOO_PASSWORD are consumed by docker-compose to configure the
# Odoo container and the PostgreSQL service.
ODOO_USER=your_odoo_user
ODOO_PASSWORD=your_odoo_password

# POSTGRES_* are consumed by FastAPI / pydantic-settings.
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=5433
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# PG_* are used by ETL / scripts that connect via host.docker.internal.
PG_HOST='host.docker.internal'
PG_PORT='5433'
PG_USER='your_pg_user'
PG_PASSWORD='your_pg_password'
PG_DATABASE='your_pg_database'

# MySQL (ETL source)
MYSQL_USER='your_mysql_user'
MYSQL_PASSWORD='your_mysql_password'

# =============================================================================
# ODOO APPLICATION
# =============================================================================
ODOO_BASE_URL=http://odoo16:8069
ODOO_DB=your_db_name
# Odoo web-UI login used by FastAPI for XML-RPC / JSON-RPC calls.
# Named ODOO_ADMIN_PASSWORD (not ODOO_PASSWORD) to avoid collision with the
# PostgreSQL system password above.
ODOO_USERNAME=admin
ODOO_ADMIN_PASSWORD=your_odoo_admin_password

# =============================================================================
# RQ JOB QUEUE
# =============================================================================
RQ_QUEUE_NAME=alerts
RQ_SCHEDULER_POLL_INTERVAL_SECONDS=1
RQ_SCHEDULER_CRON='*/5 * * * *'
RQ_SCHEDULER_JOB_ID=database-alert-email
ALERT_JOBS_SYNC_INTERVAL_SECONDS=60
ALERT_JOBS_FILE=config/alert_jobs.json

# =============================================================================
# ALERT EMAIL
# =============================================================================
ALERT_QUERY_SQL='SELECT id,name,email FROM res_partner WHERE active = true LIMIT 10'
ALERT_EMAIL_SUBJECT='Database alert records found'
ALERT_QUERY_ENABLED=true
ALERT_EMAIL_TO=alerts@example.com
ALERT_EMAIL_LOGO_URL=https://example.com/path/to/logo.png

# =============================================================================
# MAIL SERVER (outgoing SMTP)
# =============================================================================
MAIL_SERVER=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=alerts@example.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM=alerts@example.com
MAIL_FROM_NAME='Alert Manager'
MAIL_STARTTLS=false
MAIL_SSL_TLS=true
MAIL_VALIDATE_CERTS=true

# Outgoing-mail sender used by alert_management.
EmailFrom=alerts@example.com

# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY=sk-...
OPENAI_PROJECT=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=30

# =============================================================================
# ADVERSE MEDIA / NEWS API
# =============================================================================
NewsApiKey=your_newsapi_key_here
NewsApiUrl=https://newsapi.org/v2/everything

# =============================================================================
# FASTAPI / ML
# =============================================================================
TRAINING_DATA_PATH=/app/custom/training-data/transaction_training_data.csv
ODOO_CONNECT_MAX_ATTEMPTS=5
ODOO_CONNECT_RETRY_DELAY_SECONDS=3
ALERT_JOB_LOCK_TTL_SECONDS=240
ALERT_JOB_SEEN_TTL_SECONDS=604800
