<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">

    <t t-name="web_field_slider.SliderField" owl="1">
        <div class="d-flex">
            <input
                    t-ref="input"
                    type="range"
                    class="w-100"
                    t-att-name="props.name"
                    t-att-min="eval(props.min)"
                    t-att-max="eval(props.max)"
                    t-att-step="eval(props.step)"
                    t-att="{disabled: props.readonly}"
                    t-model="state.value"
            />
            <span t-esc="state.value"
                  class="mb-0 ms-3 text-nowrap"
            />
        </div>
    </t>

</template>
