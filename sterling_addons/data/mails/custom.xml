<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <!-- =====================================================
         Invitation Email — Due Diligence
         Overrides auth_signup.set_password_email
         ===================================================== -->
    <record id="auth_signup.set_password_email" model="mail.template">
      <field name="name">Due Diligence Invitation</field>
      <field name="model_id" ref="base.model_res_users"/>
      <field name="subject">{{ object.create_uid.name }} from {{ object.company_id.name }} invites you to Due Diligence</field>
      <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
      <field name="email_to">{{ object.email_formatted }}</field>
      <field name="description">Sent to new user after invitation</field>
      <field name="lang">{{ object.lang }}</field>
      <field name="auto_delete" eval="True"/>
      <field name="body_html" type="html">
<table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #f4f4f4; font-family:Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
<tr><td align="center">
<table border="0" cellpadding="0" cellspacing="0" width="600" style="padding: 0; background-color: #FFFFFF; color: #454748; border-collapse:separate;">
<tbody>
    <!-- HEADER -->
    <tr>
        <td align="center" style="min-width: 600px;">
            <table border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px; background: linear-gradient(135deg, #B78C01 0%, #8a6a01 100%); padding: 35px 30px; border-collapse:separate; border-radius:8px 8px 0 0;">
                <tr><td align="center">
                    <span style="font-size: 28px; font-weight: bold; color: #ffffff; letter-spacing:0.5px;">
                        Due Diligence
                    </span>
                </td></tr>
            </table>
        </td>
    </tr>

    <!-- CONTENT -->
    <tr>
        <td align="center" style="min-width: 600px;">
            <table border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px; background-color: white; padding: 45px 35px; border-collapse:separate;">
                <tr><td valign="top" style="font-size: 16px;">
                    <div>
                        <h2 style="color:#B78C01;margin:0 0 25px 0;font-size:24px;font-weight:600;">Welcome Aboard!</h2>

                        <p style="color:#333;line-height:1.7;margin:0 0 15px 0;">
                            Hello <strong style="color:#B78C01; text-transform: capitalize;"><t t-out="object.name or ''">User</t></strong>,
                        </p>

                        <p style="color:#555;line-height:1.7;margin:0 0 15px 0;">
                            You have been invited by <t t-out="object.create_uid.name or ''">Admin</t> to access the <strong style="color:#B78C01;">Due Diligence Compliance System</strong>.
                        </p>

                        <p style="color:#555;line-height:1.7;margin:0 0 35px 0;">
                            Your account has been set up. Click the button below to sign in using your corporate credentials.
                        </p>

                        <!-- CTA Button -->
                        <div style="margin:0 0 35px 0;text-align:center;">
                            <a href="/web/login"
                               style="background: linear-gradient(135deg, #B78C01 0%, #8a6a01 100%);padding:18px 45px;text-decoration:none;color:#fff;border-radius:8px;font-size:18px;font-weight:bold;display:inline-block;box-shadow:0 4px 12px rgba(183,140,1,0.3);letter-spacing:0.5px;">
                                Sign In to Due Diligence
                            </a>
                        </div>

                        <!-- Login Info Box -->
                        <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#fdf8e1;border-radius:8px;border-left:4px solid #B78C01;margin-bottom:30px;">
                            <tr><td style="padding:20px 25px;">
                                <p style="color:#B78C01;font-size:15px;line-height:1.6;margin:0 0 10px 0;font-weight:600;">
                                    Your Login Details:
                                </p>
                                <p style="color:#555;font-size:14px;line-height:1.6;margin:0;">
                                    <strong>Username/Email:</strong> <span style="color:#B78C01;font-weight:600;"><t t-out="object.login or ''">user@Due Diligence.ng</t></span>
                                </p>
                                <p style="color:#555;font-size:14px;line-height:1.6;margin:8px 0 0 0;">
                                    Use your corporate (AD) credentials to sign in.
                                </p>
                            </td></tr>
                        </table>

                        <!-- Important Info Box -->
                        <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#fffbf0;border-radius:8px;border-left:4px solid #B78C01;">
                            <tr><td style="padding:22px 25px;">
                                <p style="color:#333;font-size:14px;line-height:1.6;margin:0 0 12px 0;font-weight:600;">
                                    Important Information:
                                </p>
                                <ul style="color:#555;font-size:14px;line-height:1.8;margin:0;padding-left:20px;">
                                    <li>Sign in using your <strong>corporate Active Directory credentials</strong></li>
                                    <li>If you did not expect this invitation, please contact your administrator</li>
                                    <li>Do not share your login credentials with anyone</li>
                                </ul>
                            </td></tr>
                        </table>

                    </div>
                </td></tr>
            </table>
        </td>
    </tr>

    <!-- FOOTER -->
    <tr>
        <td align="center" style="min-width: 600px;">
            <table border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px; background-color: #fdf8e1; padding: 25px 30px; border-collapse:separate;border-radius:0 0 8px 8px;border-top:1px solid #e5d88a;">
                <tr><td align="center" style="font-size: 13px; color:#888;">
                    Need help? Contact your system administrator.
                </td></tr>
                <tr><td align="center" style="font-size: 12px; color:#999; padding-top:8px;">
                    © <t t-esc="datetime.datetime.now().year"/> Due Diligence. All rights reserved.
                </td></tr>
            </table>
        </td>
    </tr>
</tbody>
</table>
</td></tr>
</table>
      </field>
    </record>

    <!-- =====================================================
         Password Reset Template — Due Diligence
         Overrides auth_signup.reset_password_email
         ===================================================== -->
    <record id="auth_signup.reset_password_email" model="mail.template">
      <field name="name">Due Diligence: Password Reset</field>
      <field name="model_id" ref="base.model_res_users"/>
      <field name="subject">Account Access - Due Diligence Compliance System</field>
      <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
      <field name="email_to">{{ object.email_formatted }}</field>
      <field name="description">Sent to user who requested a password reset</field>
      <field name="lang">{{ object.lang }}</field>
      <field name="auto_delete" eval="True"/>
      <field name="body_html" type="html">
<table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #f4f4f4; font-family:Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
<tr><td align="center">
<table border="0" cellpadding="0" cellspacing="0" width="600" style="padding: 0; background-color: #FFFFFF; color: #454748; border-collapse:separate;">
<tbody>
    <!-- HEADER -->
    <tr>
        <td align="center" style="min-width: 600px;">
            <table border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px; background: linear-gradient(135deg, #B78C01 0%, #8a6a01 100%); padding: 35px 30px; border-collapse:separate; border-radius:8px 8px 0 0;">
                <tr><td align="center">
                    <span style="font-size: 26px; font-weight: bold; color: #ffffff;">
                        Due Diligence — Account Access
                    </span>
                </td></tr>
            </table>
        </td>
    </tr>

    <!-- CONTENT -->
    <tr>
        <td align="center" style="min-width: 600px;">
            <table border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px; background-color: white; padding: 40px 35px; border-collapse:separate;">
                <tr><td valign="top" style="font-size: 16px;">
                    <div>
                        <p style="color:#333;line-height:1.7;margin:0 0 15px 0;">
                            Hello <strong style="color:#B78C01; text-transform: capitalize;"><t t-out="object.name or ''">User</t></strong>,
                        </p>

                        <p style="color:#555;line-height:1.7;margin:0 0 15px 0;">
                            An account access request has been made for your account on <strong>Due Diligence Compliance System</strong>.
                        </p>

                        <p style="color:#555;line-height:1.7;margin:0 0 30px 0;">
                            Please sign in using your corporate credentials via the button below:
                        </p>

                        <!-- CTA Button -->
                        <div style="margin:0 0 30px 0;text-align:center;">
                            <a href="/web/login"
                               style="background: linear-gradient(135deg, #B78C01 0%, #8a6a01 100%);padding:16px 40px;text-decoration:none;color:#fff;border-radius:8px;font-size:18px;font-weight:bold;display:inline-block;box-shadow:0 4px 12px rgba(183,140,1,0.3);">
                                Sign In to Due Diligence
                            </a>
                        </div>

                        <!-- Warning Box -->
                        <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#fffbf0;border-radius:8px;border-left:4px solid #B78C01;">
                            <tr><td style="padding:20px;">
                                <p style="color:#555;font-size:14px;line-height:1.6;margin:0;">
                                    <strong>Didn't request this?</strong> You can safely ignore this email. Contact your administrator if you have concerns.
                                </p>
                            </td></tr>
                        </table>
                    </div>
                </td></tr>
            </table>
        </td>
    </tr>

    <!-- FOOTER -->
    <tr>
        <td align="center" style="min-width: 600px;">
            <table border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px; background-color: #fdf8e1; padding: 20px 30px; border-collapse:separate;border-radius:0 0 8px 8px;border-top:1px solid #e5d88a;">
                <tr><td align="center" style="font-size: 12px; color:#999; padding-top:8px;">
                    © <t t-esc="datetime.datetime.now().year"/> Due Diligence. All rights reserved.
                </td></tr>
            </table>
        </td>
    </tr>
</tbody>
</table>
</td></tr>
</table>
      </field>
    </record>

  </data>
</odoo>