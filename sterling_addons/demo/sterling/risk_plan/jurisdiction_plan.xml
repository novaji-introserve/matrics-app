<odoo>
       <data noupdate="1">
              <!-- Jurisdiction Plans -->

              <record id="risk_plan_south_w" model="res.compliance.risk.assessment.plan">
                     <field name="name">South West Region Analysis</field>
                     <field name="code">south_west_PLAN</field>
                     <field name="sql_query">SELECT 1 
FROM res_partner_account rpa
INNER JOIN res_branch rb ON rpa.branch_id = rb.id
WHERE rpa.customer_id = %s
AND rb.region = 'South West'
ORDER BY rpa.opening_date DESC
LIMIT 1;</field>
                     <field name="priority">40</field>
                     <field name="state">active</field>
                     <field name="narration">Analysis for customers in South West region</field>
                     <field name="risk_score">1</field>
                     <field name="compute_score_from">risk_assessment</field>
                     <field name="risk_assessment" ref="res_risk_assessment_south_W" />
                     <field name="use_composite_calculation">True</field>
                     <field name="universe_id" ref="compliance_management.compliance_inst_fc_risk_univ_21" />
              </record>

