                model="res.compliance.risk.assessment.plan">
            <field name="name">Abia Region Analysis</field>
            <field name="code">ABIA_PLAN</field>
            <field name="sql_query">SELECT 1 
FROM res_partner rp
INNER JOIN res_partner_region rpr ON rp.region_id = rpr.id
WHERE rp.id = %s
  AND LOWER(rpr.name) = 'abia'
LIMIT 1;
</field>
            <field name="priority">40</field>
            <field name="state">active</field>
            <field name="narration">Analysis for customers in Abia region</field>
            <field name="risk_score">4</field>
            <field name="compute_score_from">risk_assessment</field>
            <field name="risk_assessment"
                   ref="compliance_management.res_risk_assessment_abia" />
            <field name="use_composite_calculation">True</field>
