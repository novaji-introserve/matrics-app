<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl.IcomplyDashboard" owl="1">
        <div class="vh-100 p-4 overflow-auto bg-muted ">

            <div class="row g-5">
                <div class="col-12">
                    <div class="col-12 m-0 p-0 ">
                        <div
                            class="d-flex bg-white rounded shadow p-4 shadow-1 justify-content-between align-items-center">
                            <h3 class="lead fw-bold">DASHBOARD</h3>
                            <div>
                                <select name="" id="" class="form-select" t-model="state.datepicked"
                                    t-on-change="filterByDate">
                                    <option value="0" selected="selected">current</option>
                                    <option value="7">7 Days</option>
                                    <option value="14">last 14 Days</option>
                                    <option value="30">last month</option>
                                    <option value="60">2 months</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-2 mt-md-4">
                        <KpiCard onclick.bind="displayHighTransaction" name="'High Risk Tran.'" value="state.kpi.highrisk"
                            percentage="state.kpi.highriskbypercent" />

                        <KpiCard onclick.bind="displayMediumTransaction" name="'Medium Risk Tran.'"
                            value="state.kpi.mediumrisk" percentage="state.kpi.mediumriskbypercent" />

                        <KpiCard onclick.bind="displayLowTransaction" name="'Low Risk Tran.'" value="state.kpi.lowrisk"
                            percentage="state.kpi.lowriskpercentage" />

                        <KpiCard onclick.bind="displayScreenedTransaction" name="'Screened Transaction'"
                            value="state.kpi.totalScreenedTransactionCount" percentage="state.kpi.totalrulespercentage" />

                        <KpiCard onclick.bind="displayNothing" name="'High Risk(%)'"
                            value="state.kpi.highriskinRespectToTotalTransaction"
                            percentage="state.kpi.highriskiinRespectToTotalTransactionPercentage" />

                        <KpiCard onclick.bind="displayNothing" name="'Medium Risk(%)'"
                            value="state.kpi.mediumriskinRespectToTotalTransaction"
                            percentage="state.kpi.mediumriskiinRespectToTotalTransactionPercentage" />

                        <KpiCard onclick.bind="displayNothing" name="'Low Risk(%)'"
                            value="state.kpi.lowriskinRespectToTotalTransaction"
                            percentage="state.kpi.lowriskiinRespectToTotalTransactionPercent" />

                        <KpiCard onclick.bind="displayTotalProcess" name="'Total Processes'"
                            value="state.kpi.alertrulestotal"
                            percentage="" />
                    </div>

                    <div class="row mt-3">

                        <div class="col-md-4 ">
                            <div
                                class="d-flex bg-white shadow shadow-1  p-3 rounded justify-content-between align-items-center">
                                <h3 class="lead fw-bold text-primary">Transaction Risk Ratings </h3>
                                <button class="btn btn-primary">
                                    <i class="fa fa-angle-right"></i>
                                </button>
                            </div>

                            <div class="my-2 p-3 bg-white shadow shadow-2" style="height: 40vh;">
                                <ChartRenderer datepicked="state.datepicked"
                                    current_datepicked="state.current_datepicked" config="state.riskratingchart" type="'bar'"
                                    title="'Rating'" />
                            </div>
                        </div>

                        <div class="col-md-4 ">
                            <div
                                class="d-flex bg-white shadow shadow-1  p-3 rounded justify-content-between align-items-center">
                                <h3 class="lead fw-bold text-primary">Customers Risk Rating</h3>
                                <button class="btn btn-primary">
                                    <i class="fa fa-angle-right"></i>
                                </button>
                            </div>
                            <div class="mt-2 p-3 bg-white shadow shadow-2" style="height: 40vh;">
                                <ChartRenderer datepicked="state.datepicked"
                                    current_datepicked="state.current_datepicked" config="state.customerchart"
                                    type="'bar'" title="'Customer'" />
                            </div>
                        </div>
                        <div class="col-md-4 ">
                            <div
                                class="d-flex bg-white shadow shadow-1  p-3 rounded justify-content-between align-items-center">
                                <h3 class="lead fw-bold text-primary">Transaction State</h3>
                                <button class="btn btn-primary">
                                    <i class="fa fa-angle-right"></i>
                                </button>
                            </div>
                            <div class="mt-2 p-3 bg-white shadow shadow-2" style="height: 40vh;">
                                <ChartRenderer datepicked="state.datepicked"
                                    current_datepicked="state.current_datepicked" config="state.frequencychart"
                                    type="'pie'" title="'State'" />
                            </div>
                        </div>

                    </div>


                </div>


            </div>




        </div>
    </t>
</templates>