<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="owl.kpicard" owl="1">
        <div class="col-md-3 col-sm-6  mb-3 cursor-pointer" t-on-click="() => props.onClick">
            <div class="col m-0 p-0 ">
                <div class="bg-white  shadow p-1 py-1 shadow-1 text-center">
                    <h2 class="h1 fw-bold text-dark">
                        <span>
                            <t t-esc="props.value"/>
                        </span>
                    </h2>
                    <h6 class="text-muted h6">
                        <span>
                            <t t-esc="props.name" />
                        </span>
                    </h6>
                    <div class="h6 mt-3">
            
                            <span t-attf-class="text-#{props.percentage >= 100 ? 'success' : 'danger'}">
                                <span t-attf-class="me-1 fa fa-arrow-#{props.percentage >= 100 ? 'up' : 'down'}"></span>
                                <span>
                                    <t t-esc="props.percentage" />%
                                </span>
                                <span>since last period</span>
                            </span>
                         
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>