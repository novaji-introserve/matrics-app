<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_exception_form" model="ir.ui.view">
        <field name="name">exception.model.form</field>
        <field name="model">exception.model</field>
        <field name="arch" type="xml">
            <form string="Exception">
                <header>
                    <button name="action_generate_alert" type="object" string="Generate Alert"
                        class="btn-primary" />
                </header>
                <sheet>
                    <group>
                        <field name="process_name" />
                        <field name="sql_query" />
                        <field name="narration" />
                        <field name="frequency" />
                        <field name="exception_type" />
                        <field name="branch_id" />
                        <field name="alert_group_id" />
                        <field name="first_line_owner_id" />
                        <field name="second_line_owner_id" />
                        <field name="created_by" readonly="1" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_exception_tree" model="ir.ui.view">
        <field name="name">exception.model.tree</field>
        <field name="model">exception.model</field>
        <field name="arch" type="xml">
            <tree string="Exceptions">
                <field name="process_name" />
                <field name="exception_type" />
                <field name="frequency" />
                <field name="branch_id" />
                <field name="alert_group_id" />
                <field name="first_line_owner_id" />
                <field name="second_line_owner_id" />
                <field name="created_by" />
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_exception_model" model="ir.actions.act_window">
        <field name="name">Exceptions</field>
        <field name="res_model">exception.model</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Exception
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_exception_root" name="Exception Management" sequence="10" />
    <menuitem id="menu_exception" name="Exceptions" parent="menu_exception_root"
        action="action_exception_model" sequence="1" />
</odoo>