<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Log Profile Tree View -->
    <record id="view_icomply_log_profile_tree" model="ir.ui.view">
        <field name="name">icomply.log.profile.tree</field>
        <field name="model">icomply.log.profile</field>
        <field name="arch" type="xml">
            <tree string="Log Profiles">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="log_file_path"/>
                <field name="file_exists" widget="boolean_toggle"/>
                <field name="file_size"/>
                <field name="line_count"/>
                <field name="last_accessed"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Log Profile Kanban View -->
    <record id="view_icomply_log_profile_kanban" model="ir.ui.view">
        <field name="name">icomply.log.profile.kanban</field>
        <field name="model">icomply.log.profile</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="id"/>
                <field name="name"/>
                <field name="log_file_path"/>
                <field name="file_exists"/>
                <field name="file_size"/>
                <field name="line_count"/>
                <field name="color"/>
                <field name="last_accessed"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_color_#{kanban_getcolor(record.color.raw_value)} oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_top_right">
                                        <field name="active" widget="boolean_toggle"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div class="text-muted">
                                        <i class="fa fa-file-text-o"/> 
                                        <field name="log_file_path"/>
                                    </div>
                                    <div class="mt-2">
                                        <span t-if="record.file_exists.raw_value" class="badge badge-success">
                                            <i class="fa fa-check"/> Accessible
                                        </span>
                                        <span t-else="" class="badge badge-danger">
                                            <i class="fa fa-times"/> Not Found
                                        </span>
                                        <span class="badge badge-info ml-1">
                                            <field name="file_size"/>
                                        </span>
                                        <span class="badge badge-secondary ml-1">
                                            <field name="line_count"/> lines
                                        </span>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <button name="action_open_terminal" 
                                                type="object" 
                                                class="btn btn-primary btn-sm">
                                            <i class="fa fa-terminal"/> Open Terminal
                                        </button>
                                        <button name="action_test_log_file" 
                                                type="object" 
                                                class="btn btn-secondary btn-sm ml-1">
                                            <i class="fa fa-check-circle"/> Test
                                        </button>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <small class="text-muted">
                                            Last: <field name="last_accessed"/>
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Log Profile Form View -->
    <record id="view_icomply_log_profile_form" model="ir.ui.view">
        <field name="name">icomply.log.profile.form</field>
        <field name="model">icomply.log.profile</field>
        <field name="arch" type="xml">
            <form string="Log Profile">
                <header>
                    <button name="action_open_terminal" 
                            string="Open Terminal" 
                            type="object" 
                            class="oe_highlight"
                            icon="fa-terminal"/>
                    <button name="action_test_log_file" 
                            string="Test File Access" 
                            type="object"
                            icon="fa-check-circle"/>
                    <button name="action_refresh_info" 
                            string="Refresh Info" 
                            type="object"
                            icon="fa-refresh"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_terminal" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-terminal">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Open</span>
                                <span class="o_stat_text">Terminal</span>
                            </div>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" 
                            attrs="{'invisible': [('active', '=', True)]}"/>
                    
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Application Logs"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Basic Information">
                            <field name="log_file_path" placeholder="/var/log/odoo/odoo.log"/>
                            <field name="description" placeholder="Description of this log profile..."/>
                            <field name="active"/>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        
                        <group string="File Information">
                            <field name="file_exists" widget="boolean_toggle"/>
                            <field name="file_size"/>
                            <field name="line_count"/>
                            <field name="last_accessed"/>
                        </group>
                    </group>
                    
                    <group string="Display Settings">
                        <group>
                            <field name="auto_scroll"/>
                            <field name="show_timestamp"/>
                        </group>
                        <group>
                            <field name="show_level"/>
                            <field name="max_lines"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

