      "lookup_key": "code",
      "allow_null": true
    },
    "customer_id": {
      "source_field": "CUSTOMER_ID",
      "lookup_table": "res_partner",
      "lookup_key": "customer_id",
      "allow_null": true
    },
    "status": {
      "source_field": "TRANSACTION_STATUS",
      "lookup_table": "res_transaction_status",
      "lookup_key": "code",
      "allow_null": true
    }
