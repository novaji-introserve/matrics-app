    "TRANSACTION_MODE": "transaction_mode",
    "ACCOUNT_GROUP": "account_group",
    "REQUEST_ID": "request_id",
    "LCY_AMOUNT": "amount",
    "PARENT_LEDGER_ID": "parent_ledger_id",
    "SUB_GENERAL_LEDGER_CODE": "sub_general_ledger_code",
