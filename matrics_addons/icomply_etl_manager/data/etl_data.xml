<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Simplified ETL System Configuration Parameters -->
        
        <record id="etl_version" model="ir.config_parameter">
            <field name="key">etl.system_version</field>
            <field name="value">2.0.0-simplified</field>
        </record>
        
        <!-- Queue Job Integration -->
        <record id="etl_use_queue_job" model="ir.config_parameter">
            <field name="key">etl.use_queue_job</field>
            <field name="value">true</field>
        </record>
        
        <!-- Immediate Sync Threshold -->
        <record id="etl_immediate_sync_threshold" model="ir.config_parameter">
            <field name="key">etl.immediate_sync_threshold</field>
            <field name="value">1000</field>
        </record>
        
        <!-- Basic Configuration -->
        <record id="etl_default_batch_size" model="ir.config_parameter">
            <field name="key">etl.default_batch_size</field>
            <field name="value">2000</field>
        </record>
        
        <!-- Log Retention -->
        <record id="etl_log_retention_days" model="ir.config_parameter">
            <field name="key">etl.log_retention_days</field>
            <field name="value">30</field>
        </record>
        
    </data>
</odoo>