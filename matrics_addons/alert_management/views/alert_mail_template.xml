<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_alert_mail_template_tree" model="ir.ui.view">
        <field name="name">alert.mail.template.tree</field>
        <field name="model">alert.mail.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="code" />
            </tree>
        </field>
    </record>

    <record id="view_alert_mail_template_form" model="ir.ui.view">
        <field name="name">alert.mail.template.form</field>
        <field name="model">alert.mail.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe-edit-only" />
                        <h1>
                            <field name="name" placeholder="Template name" />
                        </h1>
                    </div>
                    <group>
                        <field name="code" />
                    </group>
                    <notebook>
                        <page string="Header">
                            <field name="html_header" widget="ace" options="{'style-inline': true}" />
                        </page>
                        <page string="Inline Style (CSS)">
                            <field name="inline_style" widget="ace" options="{'mode': 'css'}" />
                        </page>
                        <page string="Body">
                            <field name="html_body" widget="ace" options="{'style-inline': true}" />
                        </page>
                        <page string="Footer">
                            <field name="html_footer" widget="ace" options="{'style-inline': true}" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_alert_mail_template" model="ir.actions.act_window">
        <field name="name">Alert Templates</field>
        <field name="res_model">alert.mail.template</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new alert mail template.
            </p>
            <p>
                Templates define the HTML structure for alert notification emails.
            </p>
        </field>
    </record>

</odoo>
