<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default Database Types -->
        <record id="etl_db_type_mssql" model="etl.database.type">
            <field name="name">Microsoft SQL Server</field>
            <field name="code">mssql</field>
            <field name="driver_module">pyodbc</field>
            <field name="connection_template">Driver={[DRIVER]};Server={server};Database={database};UID={username};PWD={password};TrustServerCertificate=yes;</field>
            <field name="query_format">SELECT {columns} FROM [{table}]</field>
            <field name="requires_driver">True</field>
            <field name="connection_method">string</field>
            <field name="notes">Requires ODBC driver installation on server</field>
        </record>
        
        <record id="etl_db_type_postgresql" model="etl.database.type">
            <field name="name">PostgreSQL</field>
            <field name="code">postgresql</field>
            <field name="driver_module">psycopg2</field>
            <field name="connection_template">dbname={database} user={username} password={password} host={server} port={port}</field>
            <field name="query_format">SELECT {columns} FROM "{table}"</field>
            <field name="requires_driver">False</field>
            <field name="connection_method">string</field>
        </record>
        
        <record id="etl_db_type_mysql" model="etl.database.type">
            <field name="name">MySQL/MariaDB</field>
            <field name="code">mysql</field>
            <field name="driver_module">mysql.connector</field>
            <field name="connection_template">host={server},port={port},user={username},password={password},database={database}</field>
            <field name="query_format">SELECT {columns} FROM `{table}`</field>
            <field name="requires_driver">False</field>
            <field name="connection_method">params</field>
        </record>
        
        <record id="etl_db_type_oracle" model="etl.database.type">
            <field name="name">Oracle Database</field>
            <field name="code">oracle</field>
            <field name="driver_module">cx_Oracle</field>
            <field name="connection_template">{username}/{password}@{server}:{port}/{database}</field>
            <field name="query_format">SELECT {columns} FROM {table}</field>
            <field name="requires_driver">False</field>
            <field name="connection_method">string</field>
            <field name="notes">Requires Oracle client libraries installed on server</field>
        </record>
        
        <record id="etl_db_type_sqlite" model="etl.database.type">
            <field name="name">SQLite</field>
            <field name="code">sqlite</field>
            <field name="driver_module">sqlite3</field>
            <field name="connection_template">{database}</field>
            <field name="query_format">SELECT {columns} FROM {table}</field>
            <field name="requires_driver">False</field>
            <field name="connection_method">string</field>
        </record>
        
        <record id="etl_db_type_db2" model="etl.database.type">
            <field name="name">IBM DB2</field>
            <field name="code">db2</field>
            <field name="driver_module">ibm_db</field>
            <field name="connection_template">DATABASE={database};HOSTNAME={server};PORT={port};PROTOCOL=TCPIP;UID={username};PWD={password};</field>
            <field name="query_format">SELECT {columns} FROM {table}</field>
            <field name="requires_driver">False</field>
            <field name="connection_method">string</field>
            <field name="notes">Requires IBM DB2 driver installation on server</field>
        </record>
        
        <record id="etl_db_type_redshift" model="etl.database.type">
            <field name="name">Amazon Redshift</field>
            <field name="code">redshift</field>
            <field name="driver_module">psycopg2</field>
            <field name="connection_template">dbname={database} user={username} password={password} host={server} port={port}</field>
            <field name="query_format">SELECT {columns} FROM "{table}"</field>
            <field name="requires_driver">False</field>
            <field name="connection_method">string</field>
            <field name="notes">Uses PostgreSQL driver (psycopg2)</field>
        </record>
        
        <record id="etl_db_type_snowflake" model="etl.database.type">
            <field name="name">Snowflake</field>
            <field name="code">snowflake</field>
            <field name="driver_module">snowflake.connector</field>
            <field name="connection_template">account={server},user={username},password={password},database={database}</field>
            <field name="query_format">SELECT {columns} FROM {table}</field>
            <field name="requires_driver">False</field>
            <field name="connection_method">params</field>
        </record>
        
        <record id="etl_db_type_bigquery" model="etl.database.type">
            <field name="name">Google BigQuery</field>
            <field name="code">bigquery</field>
            <field name="driver_module">google.cloud.bigquery</field>
            <field name="connection_template">{database}</field>
            <field name="query_format">SELECT {columns} FROM `{table}`</field>
            <field name="requires_driver">False</field>
            <field name="connection_method">params</field>
            <field name="notes">Requires Google Cloud credentials in connection options</field>
        </record>
    </data>
</odoo>
