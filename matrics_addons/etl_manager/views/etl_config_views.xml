<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ETL Source Table Tree View -->
    <record id="view_etl_source_table_tree" model="ir.ui.view">
        <field name="name">etl.source.table.tree</field>
        <field name="model">etl.source.table</field>
        <field name="arch" type="xml">
            <tree string="ETL Tables">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="target_table"/>
                <field name="category_id"/>
                <field name="frequency_id"/>
                <field name="last_sync_time"/>
                <field name="last_sync_status"/>
                <field name="total_records_synced"/>
            </tree>
        </field>
    </record>

    <!-- ETL Source Table Form View -->
    <record id="view_etl_source_table_form" model="ir.ui.view">
        <field name="name">etl.source.table.form</field>
        <field name="model">etl.source.table</field>
        <field name="arch" type="xml">
            <form string="ETL Table Configuration">
                <header>
                    <button name="action_test_connection" 
                            string="Test Connection" 
                            type="object" 
                            class="btn-secondary"/>
                    <button name="action_sync_table" 
                            string="Sync Now" 
                            type="object" 
                            class="oe_highlight"
                            confirm="Are you sure you want to sync this table now?"/>
                    <button name="action_sync_table_csv" type="object" string="Sync with CSV Mode" class="oe_highlight" confirm="Are you sure you want to sync this table now?" attrs="{'invisible': [('use_csv_mode', '=', False)]}" />
                    <field name="last_sync_status" widget="statusbar"/>
                    <field name="progress_percentage" widget="progressbar" attrs="{'invisible': [('last_sync_status', '!=', 'running')]}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g., tbl_customer"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="target_table"/>
                            <field name="primary_key"/>
                            <field name="batch_size"/>
                            <field name="is_base_table"/>
                            <field name="sync_method" widget="radio"/>
                        </group>
                        <group>
                            <field name="category_id"/>
                            <field name="frequency_id"/>
                            <field name="last_sync_time"/>
                            <field name="total_records_synced"/>
                            <field name="use_csv_mode"/>
                        </group>
                    </group>
                    <!-- Add a new group for database connections -->
                    <group string="Database Connections">
                        <field name="source_db_connection_id" 
                            domain="[('active', '=', True)]"
                            options="{'no_create': True}"
                            required="1"/>
                        <field name="target_db_connection_id" 
                            domain="[('active', '=', True)]"
                            options="{'no_create': True}"
                            required="1"/>
                    </group>
                    <notebook>
                        <page string="Column Mappings">
                            <field name="mapping_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="source_column"/>
                                    <field name="target_column"/>
                                    <field name="mapping_type"/>
                                    <field name="lookup_table" 
                                        attrs="{'invisible': [('mapping_type', '!=', 'lookup')],
                                                'required': [('mapping_type', '=', 'lookup')]}"/>
                                    <field name="lookup_key" 
                                        attrs="{'invisible': [('mapping_type', '!=', 'lookup')],
                                                'required': [('mapping_type', '=', 'lookup')]}"/>
                                    <field name="lookup_value" 
                                        attrs="{'invisible': [('mapping_type', '!=', 'lookup')],
                                                'required': [('mapping_type', '=', 'lookup')]}"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Dependencies">
                            <field name="dependency_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Sync Logs">
                            <field name="sync_log_ids">
                                <tree>
                                    <field name="create_date"/>
                                    <field name="status"/>
                                    <field name="total_records"/>
                                    <field name="new_records"/>
                                    <field name="updated_records"/>
                                    <field name="error_message"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ETL Source Table Form View Extension for Queue Job -->
<record id="view_etl_source_table_form_job" model="ir.ui.view">
    <field name="name">etl.source.table.form.job</field>
    <field name="model">etl.source.table</field>
    <field name="inherit_id" ref="view_etl_source_table_form"/>
    <field name="arch" type="xml">
        <notebook position="inside">
            <page string="Job Information" attrs="{'invisible': [('job_uuid', '=', False)]}">
                <group>
                    <field name="job_uuid" readonly="1"/>
                    <field name="job_status" readonly="1"/>
                </group>
                <button name="action_view_jobs" string="View Jobs" type="object" class="oe_highlight" attrs="{'invisible': [('job_uuid', '=', False)]}"/>
            </page>
        </notebook>
    </field>
</record>

    <!-- ETL Source Table Search View -->
    <record id="view_etl_source_table_search" model="ir.ui.view">
        <field name="name">etl.source.table.search</field>
        <field name="model">etl.source.table</field>
        <field name="arch" type="xml">
            <search string="Search ETL Tables">
                <field name="name"/>
                <field name="target_table"/>
                <field name="category_id"/>
                <field name="frequency_id"/>
                <separator/>
                <filter string="Master Data" name="category_master" domain="[('category_id.code', '=', 'master')]"/>
                <filter string="Customer Data" name="category_customer" domain="[('category_id.code', '=', 'customer')]"/>
                <filter string="Account Data" name="category_account" domain="[('category_id.code', '=', 'account')]"/>
                <filter string="Transaction Data" name="category_transaction" domain="[('category_id.code', '=', 'transaction')]"/>
                <separator/>
                <filter string="Base Tables" name="base_tables" domain="[('is_base_table', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Frequency" name="group_frequency" context="{'group_by': 'frequency_id'}"/>
                    <filter string="Last Sync Status" name="group_status" context="{'group_by': 'last_sync_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_etl_source_table" model="ir.actions.act_window">
        <field name="name">ETL Tables</field>
        <field name="res_model">etl.source.table</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_etl_source_table_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first ETL table configuration!
            </p>
            <p>
                Define source tables and their mappings for ETL processes.
            </p>
        </field>
    </record>

        <!-- ETL Category Views -->
    <record id="view_etl_category_tree" model="ir.ui.view">
        <field name="name">etl.category.tree</field>
        <field name="model">etl.category</field>
        <field name="arch" type="xml">
            <tree string="ETL Categories">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_etl_category_form" model="ir.ui.view">
        <field name="name">etl.category.form</field>
        <field name="model">etl.category</field>
        <field name="arch" type="xml">
            <form string="ETL Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_etl_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">etl.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ETL Frequency Views -->
    <record id="view_etl_frequency_tree" model="ir.ui.view">
        <field name="name">etl.frequency.tree</field>
        <field name="model">etl.frequency</field>
        <field name="arch" type="xml">
            <tree string="ETL Frequencies">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="interval_number"/>
                <field name="interval_type"/>
            </tree>
        </field>
    </record>

    <record id="view_etl_frequency_form" model="ir.ui.view">
        <field name="name">etl.frequency.form</field>
        <field name="model">etl.frequency</field>
        <field name="arch" type="xml">
            <form string="ETL Frequency">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="interval_number"/>
                        <field name="interval_type"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ETL Frequency Action and Menu -->
    <record id="action_etl_frequency" model="ir.actions.act_window">
        <field name="name">Frequencies</field>
        <field name="res_model">etl.frequency</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>