<odoo noupdate="0">

<record model="ir.module.category" id="module_category_compliance">
  <field name="name">Compliance</field>
  <field name="sequence">50</field>
</record>

<record id="group_compliance_branch_compliance_officer" model="res.groups">
  <field name="name">Branch Compliance Officer</field>
  <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
  <field name="comment">Manage compliance for a Branch</field>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_compliance_branch_control_officer" model="res.groups">
  <field name="name">Branch Control Officer</field>
  <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
  <field name="comment">Manage internal control for a Branch</field>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_compliance_compliance_officer" model="res.groups">
  <field name="name">Compliance Officer</field>
  <field name="implied_ids" eval="[Command.link(ref('base.group_user')),Command.link(ref('group_compliance_branch_compliance_officer'))]"/>
  <field name="comment">Reports to CCO not limited to branch activities</field>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_compliance_compliance_risk_manager" model="res.groups">
  <field name="name">Compliance Risk Manager</field>
  <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_compliance_relationship_manager" model="res.groups">
  <field name="name">Compliance Relationship Manager</field>
  <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_compliance_transaction_monitoring_team" model="res.groups">
  <field name="name">Compliance Transaction Monitoring Team</field>
  <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_compliance_chief_compliance_officer" model="res.groups">
  <field name="name">Chief Compliance Officer</field>
  <field name="implied_ids" eval="[
  Command.link(ref('base.group_system')),
  Command.link(ref('base.group_erp_manager')),
  Command.link(ref('base.group_user')),
  Command.link(ref('group_compliance_compliance_officer'))]"/>
  <field name="comment">CCO oversees all branch compliance officers</field>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_no_access" model="res.groups">
    <field name="name">Restrict Access</field>
    <!-- This ensures the group starts with no users -->
    <field name="users" eval="[(5, 0, 0)]"/>
    <field name="comment">Hide Data From The UI</field>
    <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_adverse_media_analyst" model="res.groups">
  <field name="name">Adverse Media Analyst</field>
  <field name="implied_ids" eval="[Command.link(ref('group_compliance_branch_compliance_officer'))]"/>
  <field name="comment">View alerts; move to under_review; add notes; mark false positive</field>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_adverse_media_senior_analyst" model="res.groups">
  <field name="name">Adverse Media Senior Analyst</field>
  <field name="implied_ids" eval="[Command.link(ref('group_adverse_media_analyst')), Command.link(ref('group_compliance_compliance_officer'))]"/>
  <field name="comment">Confirm or close alerts; assign to others; all analyst permissions</field>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_adverse_media_manager" model="res.groups">
  <field name="name">Adverse Media Manager / MLRO</field>
  <field name="implied_ids" eval="[Command.link(ref('group_adverse_media_senior_analyst')), Command.link(ref('group_compliance_chief_compliance_officer'))]"/>
  <field name="comment">Override decisions; access all records; configure keywords; MLRO escalation target</field>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_adverse_media_auditor" model="res.groups">
  <field name="name">Adverse Media Auditor</field>
  <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
  <field name="comment">Read-only access to all adverse media records, scan logs, and audit trail</field>
  <field name="category_id" ref="module_category_compliance"/>
</record>

<record id="group_tech_support" model="res.groups">
  <field name="name">Tech Support</field>
  <field name="implied_ids" eval="[
    Command.link(ref('base.group_user')),
    Command.link(ref('group_compliance_chief_compliance_officer'))]"/>
  <field name="comment">Technical Support</field>
  <field name="users" eval="[(4, ref('base.user_admin'))]"/>
  <!-- <field name="category_id" ref="module_category_compliance"/> -->
</record>


</odoo>