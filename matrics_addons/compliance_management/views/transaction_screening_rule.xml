<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Screening Rules -->
    <record id="compliance_transaction_screening_rule_tree" model="ir.ui.view">
        <field name="name">compliance_transaction_screening_rule_tree</field>
        <field name="model">res.transaction.screening.rule</field>
        <field name="arch" type="xml">
            <tree string="RTransaction Screening Rule">
                <field name="name" />
                <field name="priority" />
                <field name="risk_level" widget="badge" decoration-danger="risk_level == 'high'"
                    decoration-warning="risk_level in ('medium')"
                    decoration-success="risk_level in ('low')" />
                <field name="likely_fraud" widget="boolean_toggle" />
                <field name="condition_select" />
                <field name="state" widget="badge" decoration-warning="state =='inactive'" decoration-success="state == 'active'" />
                <field name="create_uid" />
                <field name="create_date" />
            </tree>
        </field>
    </record>
    <record id="compliance_transaction_screening_rule_search" model="ir.ui.view">
        <field name="name">compliance_transaction_screening_rule_search</field>
        <field name="model">res.transaction.screening.rule</field>
        <field name="arch" type="xml">
            <search string="Transaction Screening Rule">
                <field name="name" />
                <field name="code" />
                <field name="risk_level" />
                <filter string="Active" name="filter_state_active" domain="[('state', '=', 'active')]" />
                <filter string="Inactive" name="filter_state_inactive" domain="[('state', '=', 'inactive')]" />
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                    <filter string="Risk Level" name="group_risk_level" context="{'group_by': 'risk_level'}" />
                </group>
            </search>
        </field>
    </record>
    <!-- Risk Assessment Form -->
    <record id="compliance_transaction_screening_rule_form" model="ir.ui.view">
        <field name="name">Transaction Screening Rule Form</field>
        <field name="model">res.transaction.screening.rule</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" class="oe_highlight" type="object"
                        string="Activate"
                        groups="compliance_management.group_compliance_compliance_risk_manager"
                        confirm="Activate this Rule. Are you sure?"
                        attrs="{'invisible': [('state', 'not in',['draft','inactive'])]}" />
                    <button name="action_deactivate" type="object"
                        string="Deactivate"
                        groups="compliance_management.group_compliance_branch_compliance_officer"
                        confirm="Deactivate this Rule. Are you sure?"
                        attrs="{'invisible': [('state','not in',['active','draft'])]}" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,inactive"
                        clickable="True" />
                </header>
                <sheet string="Transaction Screening Rule">

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" />
                        </group>
                        <group>
                            <field name="risk_level" />
                        </group>
                        <group>
                            <field name="priority" />
                        </group>
                        <group>
                            <field name="likely_fraud" widget="boolean_toggle" />
                        </group>
                        <group>
                            <field name="condition_select" />
                        </group>
                    </group>
                    <notebook colspan="4">
                        <page name='rule_query' string="Rule SQL Query" autofocus="autofocus">
                            <field name="sql_query"
                                placeholder="SQL Query returning a single value..."  widget="ace"/>
                            <div class="alert alert-info" role="alert" name="test_warning"> 
                                You can use the following placeholders in the SQL query: <ul>
                                    <li><code>#TRANSACTION_ID#</code> - (Internal) Transaction ID</li>
                                    <li><code>#AMOUNT#</code> - Transaction Amount</li>
                                    <li><code>#ACCOUNT_ID#</code> - Account ID</li>
                                    <li><code>#BRANCH_ID#</code> - Branch ID</li>
                                    <li><code>#TRAN_DATE#</code> - Transaction Date</li>
                                    <li><code>#CURRENCY_ID#</code> - Currency ID</li>
                                    <li><code>#CUSTOMER_ID#</code> - Customer ID</li>
                                </ul>
                            </div>
                        </page>
                        <page name='condition_python' string="Rule Python Code">
                            <field name="condition_python" widget="ace" />
                            <div class="alert alert-info" role="alert" name="test_warning"> 
                                You can use the following variables in the Python code:<br/>
                                
                                # transaction: object containing the transaction<br />
                                # customer: object containing the customer<br />
                                # branch: object containing the branch<br />
                                # account: object containing the account<br />
                                # currency: object containing the currency<br />
                                # env: environment  object<br />
                                #----------------------<br/>
                    
                                # Note: returned value have to be set in the variable 'result'<br />

                                result = transaction.amount > 1000<br />
                            </div>
                        </page>
                        <page name='internal_notes' string="Internal Notes">
                            <field name="narration" placeholder="Narration..." />
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

</odoo>
