<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_res_ledger_type_tree" model="ir.ui.view">
            <field name="name">res.ledger.type.tree</field>
            <field name="model">res.ledger.type</field>
            <field name="arch" type="xml">
                <tree string="Ledger Types">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="view_res_ledger_type_form" model="ir.ui.view">
            <field name="name">res.ledger.type.form</field>
            <field name="model">res.ledger.type</field>
            <field name="arch" type="xml">
                <form string="Ledger Type" class="o_form_document">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Ledger Type" style="width: 100%;"/>
                            </h1>
                        </div>
                        <group string="Audit Details" col="4">
                            <group colspan="4">
                                <field name="name"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_res_ledger_type" model="ir.actions.act_window">
            <field name="name">Ledger Types</field>
            <field name="res_model">res.ledger.type</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
