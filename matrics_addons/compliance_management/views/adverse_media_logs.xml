<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_adverse_media_alert_tree" model="ir.ui.view">
        <field name="name">adverse.media.alert.tree</field>
        <field name="model">adverse.media.alert</field>
        <field name="arch" type="xml">
            <tree string="Adverse Media Alerts">
                <field name="partner_id"/>
                <field name="partner_category"/>
                <field name="name"/>
                <field name="source_name"/>
                <field name="matched_keyword_ids" widget="many2many_tags"/>
                <field name="priority" widget="badge"
                    decoration-danger="priority == '0'"
                    decoration-warning="priority == '1'"
                    decoration-info="priority == '2'"
                    decoration-muted="priority in ('3', '4')"/>
                <field name="risk_score_decoration" invisible="1"/>
                <field name="risk_score"
                    decoration-danger="risk_score_decoration == 'danger'"
                    decoration-warning="risk_score_decoration == 'warning'"
                    decoration-success="risk_score_decoration == 'success'"/>
                <field name="assigned_officer_id" optional="show"/>
                <field name="review_deadline" optional="show"/>
                <field name="days_open" optional="show"/>
                <field name="status" widget="badge"
                    decoration-danger="status == 'new'"
                    decoration-warning="status == 'under_review'"
                    decoration-success="status == 'confirmed'"
                    decoration-muted="status == 'closed'"/>
                <field name="create_date" widget="date"/>
                <field name="source_date"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_adverse_media_alert_form" model="ir.ui.view">
        <field name="name">adverse.media.alert.form</field>
        <field name="model">adverse.media.alert</field>
        <field name="arch" type="xml">
            <form string="Adverse Media Alert">

                <header>
                    <button name="action_mark_false_positive" type="object"
                        string="Mark as False Positive"
                        attrs="{'invisible': [('status', 'in', ['confirmed', 'closed'])]}"
                        confirm="This will close the alert and create a suppression rule. Are you sure?"
                        groups="compliance_management.group_adverse_media_analyst"/>
                    <button name="action_open_case" type="object"
                        string="Open Case"
                        attrs="{'invisible': [('status', 'in', ['closed'])]}"/>
                    <button name="action_refer_to_str" type="object"
                        string="Refer to STR"
                        class="oe_highlight"
                        attrs="{'invisible': [('status', '!=', 'confirmed')]}"
                        confirm="This will open a new Suspicious Transaction Report pre-filled with alert details. Continue?"/>
                    <button name="action_reopen" type="object"
                        string="Reopen"
                        attrs="{'invisible': [('status', '!=', 'closed')]}"
                        groups="compliance_management.group_adverse_media_senior_analyst"/>
                    <field name="status" widget="statusbar"
                        options="{'clickable': '1'}"
                        statusbar_visible="new,under_review,confirmed,closed"/>
                </header>

                <sheet>

                    <!-- Alert heading — full width -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Alert Title" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Hidden decoration helpers -->
                    <field name="risk_score_decoration" invisible="1"/>

                    <!-- ── Section 1: Subject & Source ── -->
                    <group string="Subject &amp; Source">
                        <group>
                            <field name="partner_id"/>
                            <field name="partner_category" string="Entity Type"/>
                        </group>
                        <group>
                            <field name="source_name" readonly="1"/>
                            <field name="source_date" string="Published" readonly="1"/>
                            <field name="source_url" widget="url" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Section 2: Risk Assessment ── -->
                    <group string="Risk Assessment">
                        <group>
                            <field name="priority" widget="badge"
                                decoration-danger="priority == '0'"
                                decoration-warning="priority == '1'"
                                decoration-info="priority == '2'"
                                decoration-muted="priority in ('3', '4')"/>
                            <field name="base_risk_score" string="Base Score" readonly="1"/>
                            <field name="risk_score" string="Weighted Score"
                                widget="slider" step="0.1" min="0" max="9" readonly="1"
                                decoration-danger="risk_score_decoration == 'danger'"
                                decoration-warning="risk_score_decoration == 'warning'"
                                decoration-success="risk_score_decoration == 'success'"/>
                            <field name="matched_keyword_ids" widget="many2many_tags"
                                string="Matched Categories" readonly="1"/>
                        </group>
                        <group>
                            <field name="article_type" string="Article Type"/>
                            <field name="resolution_status" string="Resolution Status"/>
                        </group>
                    </group>

                    <!-- ── Section 3: Review &amp; Assignment ── -->
                    <group string="Review &amp; Assignment">
                        <group>
                            <field name="assigned_officer_id"
                                groups="compliance_management.group_adverse_media_senior_analyst"/>
                            <field name="review_deadline" readonly="1"/>
                            <field name="days_open" string="Days Open" readonly="1"/>
                        </group>
                        <group>
                            <field name="disposition"/>
                            <field name="recommendation"/>
                            <field name="scan_log_id" string="Scan Log" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Section 4: Review Notes — full width ── -->
                    <separator string="Review Notes"/>
                    <field name="review_notes" nolabel="1"
                        placeholder="Document your findings and rationale. Required before confirming or closing this alert."/>

                    <!-- ── Section 5: Article Evidence — full width ── -->
                    <separator string="Article Evidence"/>
                    <field name="description" string="Summary" nolabel="1" readonly="1"/>
                    <field name="content" nolabel="1" readonly="1"
                        attrs="{'invisible': [('content', '=', False)]}"/>

                </sheet>

                <div class="oe_chatter">
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>

            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_adverse_media_alert_search" model="ir.ui.view">
        <field name="name">adverse.media.alert.search</field>
        <field name="model">adverse.media.alert</field>
        <field name="arch" type="xml">
            <search string="Search Adverse Media Alerts">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="assigned_officer_id"/>
                <field name="description"/>
                <field name="content"/>
                <separator/>
                <filter string="New" name="new_alerts"
                    domain="[('status', '=', 'new')]"/>
                <filter string="Under Review" name="under_review"
                    domain="[('status', '=', 'under_review')]"/>
                <filter string="Confirmed" name="confirmed"
                    domain="[('status', '=', 'confirmed')]"/>
                <filter string="Closed" name="closed"
                    domain="[('status', '=', 'closed')]"/>
                <separator/>
                <filter string="Critical" name="critical"
                    domain="[('priority', '=', '0')]"/>
                <filter string="High" name="high_priority"
                    domain="[('priority', '=', '1')]"/>
                <filter string="Medium" name="medium_priority"
                    domain="[('priority', '=', '2')]"/>
                <separator/>
                <filter string="SLA Overdue" name="sla_overdue"
                    domain="[('review_deadline', '&lt;', datetime.datetime.now()), ('status', 'not in', ['confirmed', 'closed'])]"/>
                <filter string="Assigned to Me" name="assigned_to_me"
                    domain="[('assigned_officer_id', '=', uid)]"/>
                <separator/>
                <filter string="High Risk" name="high_risk"
                    domain="[('risk_score', '&gt;=', 20)]"/>
                <filter string="Medium Risk" name="medium_risk"
                    domain="[('risk_score', '&gt;=', 5), ('risk_score', '&lt;', 20)]"/>
                <filter string="Low Risk" name="low_risk"
                    domain="[('risk_score', '&lt;', 5)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status"
                        context="{'group_by': 'status'}"/>
                    <filter string="Priority" name="group_by_priority"
                        context="{'group_by': 'priority'}"/>
                    <filter string="Partner" name="group_by_partner"
                        context="{'group_by': 'partner_id'}"/>
                    <filter string="Assigned Officer" name="group_by_officer"
                        context="{'group_by': 'assigned_officer_id'}"/>
                    <filter string="Entity Type" name="group_by_category"
                        context="{'group_by': 'partner_category'}"/>
                    <filter string="Publication Date" name="group_by_date"
                        context="{'group_by': 'source_date'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
