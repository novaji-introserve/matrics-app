<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_res_ledger_tree" model="ir.ui.view">
            <field name="name">res.ledger.tree</field>
            <field name="model">res.ledger</field>
            <field name="arch" type="xml">
                <tree string="Ledgers">
                    <field name="name"/>
                    <field name="ledger_code"/>
                    <field name="ledger_type_id"/>
                </tree>
            </field>
        </record>

        <record id="view_res_ledger_form" model="ir.ui.view">
            <field name="name">res.ledger.form</field>
            <field name="model">res.ledger</field>
            <field name="arch" type="xml">
                <form string="Ledger" class="o_form_document">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Ledger Name" style="width: 100%;"/>
                            </h1>
                        </div>
                        <group string="Audit Details" col="4">
                            <group>
                                <field name="name"/>
                                <field name="ledger_code"/>
                            </group>
                            <group>
                                <field name="ledger_type_id"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_res_ledger_search" model="ir.ui.view">
            <field name="name">res.ledger.search</field>
            <field name="model">res.ledger</field>
            <field name="arch" type="xml">
                <search string="Search Ledgers">
                    <field name="name" filter_domain="['|', ('name', 'ilike', self), ('ledger_code', 'ilike', self)]"/>
                    <field name="ledger_code" filter_domain="[('ledger_code', 'ilike', self)]"/>
                    <field name="ledger_type_id"/>
                    <group expand="0" string="Group By">
                        <filter name="group_ledger_type" string="Ledger Type" context="{'group_by': 'ledger_type_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_res_ledger" model="ir.actions.act_window">
            <field name="name">Ledgers</field>
            <field name="res_model">res.ledger</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_res_ledger_search"/>
            <field name="context">{'search_default_group_ledger_type': 1}</field>
        </record>
    </data>
</odoo>
