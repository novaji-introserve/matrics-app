<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
       


        <!-- Actions for CSV Import -->
        <record id="action_csv_import" model="ir.actions.client">
            <field name="name">CSV Import</field>
            <field name="tag">compliance_management.csv_import_form</field>
            <field name="type">ir.actions.client</field>
        </record>


        <!-- Views for watchlist -->
        <!-- Tree View -->
        <record id="view_watchlist_tree" model="ir.ui.view">
            <field name="name">res.partner.watchlist.tree</field>
            <field name="model">res.partner.watchlist</field>
            <field name="arch" type="xml">
                <tree create="False" delete="False">
                    <!-- <field name="name"/> -->
                    <!-- <field name="watchlist_id"/> -->
                    <!-- <field name="first_name" readonly="1"/> -->
                    <field name="name"/>
                    <field name="middle_name" readonly="1"/>
                    <field name="surname" readonly="1"/>
                    <field name="bvn"/>
                    
                    <!-- <field name="nationality"/> -->
                    <!-- <field name="source"/> -->
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_watchlist_form" model="ir.ui.view">
            <field name="name">res.partner.watchlist.form</field>
            <field name="model">res.partner.watchlist</field>
            <field name="arch" type="xml">
                <form create="False" delete="False">
                    <sheet>

                        <group>
                            
                            <group>
                                <!-- <field name="first_name" readonly="1"/> -->
                                <field name="name" readonly="1"/>
                                <field name="middle_name" readonly="1"/>
                                <field name="surname" readonly="1"/>
                            </group>
                            
                            <group >
                                <!-- <field name="watchlist_id" readonly="1"/> -->
                                <field name="bvn" readonly="1"/>
                                <!-- <field name="nationality" readonly="1"/> -->
                                <!-- <field name="source" readonly="1"/> -->
                            </group>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>



        <!-- Views for blacklist -->
        <!-- Tree View -->
        <record id="view_blacklist_tree" model="ir.ui.view">
            <field name="name">res.partner.blacklist.tree</field>
            <field name="model">res.partner.blacklist</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="surname"/>
                    <field name="first_name"/>
                    <field name="middle_name"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_blacklist_form" model="ir.ui.view">
            <field name="name">res.partner.blacklist.form</field>
            <field name="model">res.partner.blacklist</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="surname"/>
                            <field name="first_name"/>
                            <field name="middle_name"/>
                            <field name= "bvn"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Views for sanction list -->
        <!-- Tree View -->
     
        <record id="view_sanction_list_tree" model="ir.ui.view">
            <field name="name">sanction_list.tree</field>
            <field name="model">sanction.list</field>
            <field name="arch" type="xml">
                <tree create="true" edit="true" delete="true">
                    <field name="list_type"/>
                    <field name="reference_number"/>
                    <field name="name"/>
                    <field name="entity_name"/>
                    <field name="surname"/>
                    <field name="first_name"/>
                    <field name="nationality"/>
                    <field name="sanction_date"/>
                    <field name="record_date_list"/>
                    <field name="source"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_sanction_list_form" model="ir.ui.view">
            <field name="name">sanction_list.form</field>
            <field name="model">sanction.list</field>
            <field name="arch" type="xml">
                <form create="true" edit="true" delete="true">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Name"/>
                            <h1>
                                <field name="name" placeholder="Sanction list name"/>
                            </h1>
                            <div class="text-muted">
                                <field name="reference_number" placeholder="Reference Number" class="oe_inline"/>
                                <span attrs="{'invisible': [('reference_number', '=', False), ('list_type', '=', False)]}"> | </span>
                                <field name="list_type" class="oe_inline"/>
                            </div>
                        </div>

                        <group>
                            <group>
                                <field name="entity_name"/>
                                <field name="first_name"/>
                                <field name="middle_name"/>
                                <field name="surname"/>
                            </group>
                            <group>
                                <field name="nationality"/>
                                <field name="birth_country"/>
                                <field name="gender"/>
                                <field name="title"/>
                                <field name="designation"/>
                                <field name="source"/>
                            </group>
                        </group>

                        <group string="Record Details">
                            <group>
                                <field name="date_of_birth"/>
                                <field name="place_of_birth"/>
                                <field name="national_id_number"/>
                                <field name="passport_details"/>
                            </group>
                            <group>
                                <field name="incorporation_number"/>
                                <field name="incorporation_date"/>
                                <field name="sanction_date"/>
                                <field name="record_date_list"/>
                                <field name="record_date_detail"/>
                            </group>
                        </group>

                        <group string="Location And Contact">
                            <field name="address"/>
                            <field name="aliases"/>
                            <field name="phone_numbers"/>
                        </group>

                        <group string="Narrative">
                            <field name="comments"/>
                            <field name="reason_for_designation"/>
                            <field name="press_release"/>
                            <field name="narrative_summary"/>
                        </group>

                        <group string="Source Link">
                            <field name="detail_url"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sanction_list_search" model="ir.ui.view">
            <field name="name">sanction_list.search</field>
            <field name="model">sanction.list</field>
            <field name="arch" type="xml">
                <search string="Search Sanction List">
                    <field name="name"/>
                    <field name="reference_number"/>
                    <field name="nationality"/>
                    <field name="source"/>
                    <field name="designation"/>
                    <filter string="Individuals" name="list_type_individual" domain="[('list_type', '=', 'individual')]"/>
                    <filter string="Entities" name="list_type_entity" domain="[('list_type', '=', 'entity')]"/>
                    <filter string="Has Nationality" name="has_nationality" domain="[('nationality', '!=', False)]"/>
                    <filter string="Has Source" name="has_source" domain="[('source', '!=', False)]"/>
                    <filter string="Has Designation" name="has_designation" domain="[('designation', '!=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="List Type" name="group_by_list_type" context="{'group_by': 'list_type'}"/>
                        <filter string="Nationality" name="group_by_nationality" context="{'group_by': 'nationality'}"/>
                        <filter string="Source" name="group_by_source" context="{'group_by': 'source'}"/>
                    </group>
                </search>
            </field>
        </record>



        <!-- Form Views for Global PEP -->

        <!-- Views for Global PEP List-->
        <record id="view_res_global_pep_tree" model="ir.ui.view">
            <field name="name">res.pep.tree</field>
            <field name="model">res.pep</field>
            <field name="arch" type="xml">
                <tree string="Global PEP List">
                    <field name="unique_identifier" />
                    <field name="name" />
                    <field name="surname" />
                    <field name="first_name" />
                    <field name="title" />
                    <field name="status" />
                    <field name="pep_classification" />
                    <field name="present_position" />
                    <field name="createdon" />
                    <field name="lastmodifiedon" />
                </tree>
            </field>
        </record>
        <record id="view_res_global_pep_form" model="ir.ui.view">
            <field name="name">res.pep.form</field>
            <field name="model">res.pep</field>
            <field name="arch" type="xml">
                <form string="Global PEP List">
                    <header>
                        <button name="action_find_person" class="oe_highlight" type="object" string="Find Biography" groups="compliance_management.group_compliance_compliance_risk_manager" attrs="{'invisible': [('job_status', '=', 'running')]}" />
                        <field name="job_status" widget="statusbar" statusbar_visible="pending,running,completed,failed"/>
                    </header>
                    <sheet>
                        <!-- Status messages for job -->
                        <div class="alert alert-info" role="alert" attrs="{'invisible': [('job_status', '!=', 'running')]}">
                            <p>
                                <i class="fa fa-spinner fa-spin"/>
 Biography lookup in progress...</p>
                        </div>
                        <div class="alert alert-success" role="alert" attrs="{'invisible': [('job_status', '!=', 'completed')]}">
                            <p>
                                <i class="fa fa-check"/>
 Biography lookup completed successfully.</p>
                        </div>
                        <div class="alert alert-danger" role="alert" attrs="{'invisible': [('job_status', '!=', 'failed')]}">
                            <p>
                                <i class="fa fa-exclamation-triangle"/>
 Error: <field name="import_message" readonly="1" class="oe_inline"/>
                            </p>
                        </div>

                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" placeholder="Name" />
                            </h1>
                        </div>

                        <div class="oe_title">
                            <label for="unique_identifier" class="oe_edit_only" />
                            <h1>
                                <field name="unique_identifier" placeholder="Name" />
                            </h1>
                        </div>
                        
                        <group>
                            <group string="Personal Information">
                                <field name="surname" />
                                <field name="first_name" />
                                <field name="middle_name" />
                                <field name="title" />
                                <field name="aka" />
                                <field name="sex" />
                                <field name="date_of_birth" />
                                <field name="age" />
                                <field name="email" />
                                <field name="place_of_birth" />
                                <field name="state_of_origin" />
                            </group>
                            <group>
                                <field name="citizenship" />
                                <field name="present_position" />
                                <field name="previous_position" />
                                <field name="pep_classification" />
                                <field name="profession" />
                                <field name="status" />
                                <field name="business_interest" />
                                <field name="last_fetch_date" />
                            </group>
                        </group>

                        <notebook>
                            <page name="info" string="Biography">
                                <field name="narration" />
                            </page>
                            <page name="family" string="Family and Contacts">
                                <group>
                                    <group string="Contact Information">
                                        <field name="official_address" />
                                        <field name="residential_address" />
                                    </group>
                                    <group string="Family Information">
                                        <field name="spouse" />
                                        <field name="children" />
                                        <field name="sibling" />
                                        <field name="parents" />
                                        <field name="mothers_maden_name" />
                                    </group>
                                </group>
                            </page>
                            <page name="education" string="Education">
                                <field name="education" />
                            </page>
                            <page name="career" string="Career">
                                <field name="career_history" />
                            </page>
                            <page string="Associates">
                                <group>
                                    <field name="associates__business_political_social_" />
                                    <field name="associate_business_politics" />
                                    <field name="bankers" />
                                    <field name="account_details" />
                                </group>
                            </page>
                            <page string="Reports &amp; Remarks">
                                <group>
                                    <field name="press_report" />
                                    <field name="date_report" />
                                    <field name="remarks" />
                                    <field name="additional_info" />
                                </group>
                            </page>
                            <page string="Audit Information">
                                <group>
                                    <field name="createdby" />
                                    <field name="createdon" />
                                    <field name="createdbyemail" />
                                    <field name="lastmodifiedby" />
                                    <field name="lastmodifiedon" />
                                    <field name="lastmodifiedbyemail" />
                                    <field name="source" />
                                    <!-- <field name="import_status" /> -->
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" />
                        <field name="activity_ids" />
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>

        <record id="view_global_pep_search" model="ir.ui.view">
            <field name="name">Global PEP Search</field>
            <field name="model">res.pep</field>
            <field name="priority" eval="10" />
            <field name="arch" type="xml">
                <search string="Search PEP">
                    <field name="first_name" />
                    <field name="surname" />
                </search>
            </field>
        </record>




        <record id="action_view_customer_pep" model="ir.actions.server">
            <field name="name">PEP List</field>
            <field name="model_id" ref="model_res_customer_pep" />
            <field name="type">ir.actions.server</field>
            <field name="state">code</field>
            <field name="code">action = model.action_view_customer_pep()</field>
        </record>

    </data>
</odoo>
