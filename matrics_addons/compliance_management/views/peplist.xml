<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Views for Peplist -->

        <!-- Tree View -->
        <record id="view_peplist_tree" model="ir.ui.view">
            <field name="name">pep.list.tree</field>
            <field name="model">pep.list</field>
            <field name="arch" type="xml">
                <tree>
                    <!-- <field name="name"/> -->
                    <field name="unique_id"/>
                    <field name="name"/>
                    <field name="firstname"/>
                    <field name="lastname"/>
                    <field name="position"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_peplist_form" model="ir.ui.view">
            <field name="name">pep.list.form</field>
            <field name="model">pep.list</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>

                            <group>
                                <field name="name" readonly="1"/>
                                <field name="firstname" readonly="1"/>
                                <field name="lastname" readonly="1"/>

                            </group>

                            <group >
                                <field name="unique_id" readonly="1" />
                                <field name="position" readonly="1" />
                            </group>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>

       

    </data>
</odoo>
