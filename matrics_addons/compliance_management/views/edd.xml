<odoo>

    <!-- Edd search view -->
    <record id="edd_search_view" model="ir.ui.view">
        <field name="name">Enhanced Due Diligence Search</field>
        <field name="model">res.partner.edd</field>
        <field name="arch" type="xml">
            <search>
                <!-- Regular search fields -->
                <field name="name"/>

                <!-- Filters -->
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>

                <!-- Group by -->
                <group expand="1" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Edd Tree View -->
    <record id="edd_tree_view" model="ir.ui.view">
        <field name="name">res.partner.edd.tree</field>
        <field name="model">res.partner.edd</field>
        <field name="arch" type="xml">
            <tree string="Enhanced Due Diligence " delete="false">
                <!-- <tree string="Enhanced Due Diligence "> -->
                <field name="customer_id" />
                <field name="responsible_id" string="Responsible" />
                <field name="user_id" string="Initiated By" />
                <field name="risk_score" />
                <field name="approved_by" string="Approved By" />
                <field name="date_approved" />
                <field name="status" decoration-primary="status == 'draft'" decoration-info="status == 'submitted'" decoration-warning="status == 'cancelled'" decoration-danger="status == 'rejected'" decoration-muted="status == 'completed'" decoration-success="status == 'approved'" widget="badge" />
                <field name="last_kyc_date" />
                <field name="create_date" string="Created On" />
            </tree>
        </field>
    </record>

    <!-- Edd Form View -->
    <record id="edd_form_view" model="ir.ui.view">
        <field name="name">res.partner.edd.form</field>
        <field name="model">res.partner.edd</field>
        <field name="arch" type="xml">
            <form string="Manage Enhanced Due Diligence" delete="false">
                <header>
                    <button name="action_notify_officer" type="object" string="Notify Officer" class="oe_highlight" 
                    attrs="{'invisible': [('show_notify_button', '=', False)]}"/>


                    <button name="action_submit_for_review" class="oe_highlight" type="object" string="Submit for Review" groups="compliance_management.group_compliance_branch_compliance_officer,compliance_management.group_compliance_relationship_manager" 
                    attrs="{'invisible': [('show_submit_for_review_button', '=', False)]}"/>


                    <button name="action_mark_review_completed" class="oe_highlight" type="object" string="Complete" 
                    attrs="{'invisible': [('show_completion_button', '=', False)]}"/>


                    <button name="action_approve" class="oe_highlight" type="object" string="Approve" groups="compliance_management.group_compliance_branch_compliance_officer,compliance_management.group_compliance_relationship_manager"
                     attrs="{'invisible': [('show_approval_button', '=', False)]}"/>

                    <button name="action_cancel" class="oe_highlight" type="object" string="Cancel" groups="compliance_management.group_compliance_branch_compliance_officer,compliance_management.group_compliance_relationship_manager"
                     attrs="{'invisible': [('show_cancel_button', '=',False)]}" />

                    <button name="action_archive" class="oe_highlight" type="object" string="Archive" groups="compliance_management.group_compliance_branch_compliance_officer,compliance_management.group_compliance_relationship_manager" 
                    attrs="{'invisible': [ ('show_archive_button', '=', False)]}" />

                    <button name="action_send_back" class="oe_highlight" type="object" string="Send Back" groups="compliance_management.group_compliance_branch_compliance_officer,compliance_management.group_compliance_relationship_manager" 
                    attrs="{'invisible': [('show_send_back_button', '=', False)]}"/>



                    <button name="open_reject_wizard" class="oe_highlight" type="object" string="Reject"                     
                    attrs="{'invisible': [('show_reject_button', '=', False)]}"/>



                    <button name="action_download_pdf" string="Download Document" type="object" class="oe_highlight" groups="compliance_management.group_compliance_branch_compliance_officer,compliance_management.group_compliance_relationship_manager" attrs="{'invisible': [('status', 'not in', ['approved', 'archived'])]}" />



                    <field name="status" widget="statusbar" statusbar_visible="draft,submitted,completed,approved,rejected,archived"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="is_cco" invisible="1"/>
                            <field name="is_editable_user" invisible="1"/>
                            <field name="is_relationship_manager" invisible="1"/>
                            <field name="is_diligence_officer" invisible="1"/>
                            <field name="is_officer_notified" invisible="1"/>
                            <field name="created_by_rm" invisible="1"/>
                            <field name="is_current_user_creator" invisible="1"/>
                            <field name="is_current_user_approver" invisible="1"/>

                            <field name="show_reject_button" invisible="1"/>
                            <field name="show_completion_button" invisible="1"/>
                            <field name="show_approval_button" invisible="1"/>
                            <field name="show_archive_button" invisible="1"/>
                            <field name="show_send_back_button" invisible="1"/>
                            <field name="show_submit_for_review_button" invisible="1"/>
                            <field name="show_cancel_button" invisible="1"/>
                            <field name="show_notify_button" invisible="1"/>
                            <field name="max_risk_score" invisible="1"/>


                            <field name="name" attrs="{'readonly': ['|', ('is_editable_user', '=', False), ('status', 'in', ['approved','archived','completed'])], 'required': [('is_editable_user', '=', True)]}"/>
                        </group>

                        <group>
                            <field name="customer_id" attrs="{'readonly': ['|', ('is_editable_user', '=', False), ('status', 'in', ['approved','archived','completed'])], 'required': [('is_editable_user', '=', True)]}"/>
                        </group>

                        <group>
                            <field name="description" placeholder="Reason Initiated" attrs="{'readonly': ['|', ('is_editable_user', '=', False), ('status', 'in', ['approved','archived','completed'])], 'required': [('is_editable_user', '=', True)]}"/>
                            <field name="status" invisible="1"/>
                        </group>
                        <group>
                            <field name="customer_type" attrs="{'readonly': ['|', ('is_editable_user', '=', False), ('status', 'in', ['approved','archived','completed'])], 'required': [('is_editable_user', '=', True)]}"/>
                            <field name="status" invisible="1"/>
                        </group>

                        <group>
                            <field name="approving_officer_id" attrs="{'readonly': ['|', ('is_editable_user', '=', False), ('status', 'in', ['approved','archived','completed'])], 'required': [('is_editable_user', '=', True)]}"/>
                            <field name="is_current_user_approving_officer" invisible="1"/>
                            <field name="reject_reason" invisible="1"/>
                        </group>

                        <group>
                            <field name="responsible_id" string="Officer in Charge" attrs="{'readonly': ['|', ('is_editable_user', '=', False), ('status', 'in', ['approved','archived','completed'])], 'required': [('is_editable_user', '=', True)]}"/>
                            <field name="is_current_user_responsible" invisible="1"/>
                            <field name="is_current_user_responsible" invisible="1"/>
                        </group>

                        <group>
                            <field name="approved_by" attrs="{'invisible': [('status', 'in', ['draft', 'cancelled', 'deleted','completed'])]}"/>
                            <field name="date_approved" attrs="{'invisible': [('status', 'in', ['draft', 'cancelled', 'deleted','completed'])]}"/>
                            <field name="is_current_user_approver" invisible="1"/>
                            <field name="is_current_user_approving_officer" invisible="1"/>
                        </group>

                        <group>
                            <field name="user_id" string="Initiated By" readonly="1"/>
                            <field name="reject_reason" readonly="1" attrs="{'invisible': [('status', '!=', 'rejected')]}"/>
                       
                        <field name="risk_score" widget="slider" step="0.1" min="1" max="max_risk_score"
                        attrs="{'readonly': ['|', ('is_editable_user', '=', False), ('status', 'in', ['approved','archived','completed'])]}"/>
                        </group>
 

                    </group>



                    <notebook>
                        <page string="Risk Assessment">
                            <group>
                                <group>
                                    <field name="has_initiated_new_kyc" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="was_kyc_comprehensive" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="last_kyc_date" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="account_status" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                                <group>
                                    <field name="documentation_status" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Customer Assessment">
                            <group>
                                <group colspan="2">
                                    <field name="visitation_observation" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="overall_kyc_outcome" placeholder="overall kyc outcome" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                                <group colspan="2">
                                    <field name="occupation" string="Occupation/Employment Profile" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>

                                <group>
                                    <field name="is_current_from_normal" string="Is Current Inflow From Normal Business" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>

                                <group>
                                    <field name="does_business_support_volume" string="Does Nature of Business Support Volume and Velocity Of Inflows" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Additional Information">
                            <group>
                                <group colspan="2">
                                    <field name="main_cash_purpose" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="main_inflow_purpose" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="main_fund_remitters" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="inflow_sources" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="other_related_accounts" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="supporting_document" widget="many2many_binary" attrs="{'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Due Diligence">
                            <!-- Corporate Customer Section -->
                            <group attrs="{'invisible': [('customer_type', '!=', 'corporate')]}">
                                <group string="Corporate Profile Information" name="corporate_profile_info">
                                    <field name="brief_customer_profile" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="nature_of_business" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="kycc_info" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="customer_address" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                                <group string="Company Registration and Legal Information" name="corporate_legal_info">
                                    <field name="company_registration_number" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="signatories_details" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="structured_ubo_count" readonly="1"/>
                                    <button name="action_load_customer_ubo_details" string="Load Structured UBOs" type="object" class="oe_highlight" attrs="{'invisible': [('customer_id', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="structured_ubo_summary" readonly="1" attrs="{'invisible': [('customer_id', '=', False)]}"/>
                                    <field name="beneficial_owner_details" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>

                                <group string="Corporate Citizenship Info" name="corporate_citizenship_info">
                                    <field name="dual_citizenship_info" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="citizenship_country_ids" widget="many2many_tags" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                            </group>

                            <group attrs="{'invisible': [('customer_type', '!=', 'corporate')]}">
                                <group string="Corporate Financial Details" name="corporate_financial_details">
                                    <field name="high_risk_industries" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="expected_monthly_income" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                    <field name="estimated_net_worth" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False)], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>

                                <group string="Corporate PEP Information" name="corporate_pep_info">
                                    <field name="pep_association" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="pep_relationship_details" attrs="{'invisible': [('pep_association', '=', False)],
                                            'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate'), ('pep_association', '=', True)], 'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="third_party_involvement" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate')], 
                                            'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="third_party_details" attrs="{'invisible': [('third_party_involvement', '=', False)],
                                            'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'corporate'), ('third_party_involvement', '=', True)], 
                                            'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}" />

                                    <field name="third_party_document" widget="many2many_binary" attrs="{'invisible': [('third_party_involvement', '=', False)], 
                                            'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                            </group>


                            <!-- Individual Customer Section -->
                            <group attrs="{'invisible': [('customer_type', '!=', 'individual')]}">
                                <group string="Individual Profile Information" name="individual_profile_info">
                                    <field name="brief_customer_profile" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="nature_of_business" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="employment_position" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="employer_name" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>

                                <group string="Residency Information" name="individual_residency_info">
                                    <field name="customer_address" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="residency_status" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="applicable_country_ids" widget="many2many_tags" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'individual')], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>
                            </group>

                            <group attrs="{'invisible': [('customer_type', '!=', 'individual')]}">
                                <group string="Individual Financial Details" name="individual_financial_details">
                                    <field name="expected_monthly_income" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>

                                    <field name="estimated_net_worth" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False)], 
                                                'readonly': ['|', ('status', 'in', ['approved', 'archived','rejected','completed']), '&amp;', ('is_current_user_responsible', '=', False), ('is_editable_user', '=', False)]}"/>
                                </group>

                                <group string="Individual PEP Information" name="individual_pep_info">
                                    <field name="is_customer_pep" attrs="{'required': [('is_current_user_responsible', '=', True), ('status', '=', 'draft'), ('is_editable_user', '=', False), ('customer_type', '=', 'individual')], 
