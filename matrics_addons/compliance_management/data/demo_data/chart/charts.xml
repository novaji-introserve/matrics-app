<odoo>
    <data noupdate="1">
        <record id="demo_chart_top10_branch_by_customer" model="res.dashboard.charts">
            <field name="name">Top 10 Branch by Accounts Opened</field>
            <field name="code">top_accounts</field>
            <field name="description">Top branches by account-opening volume.</field>
            <field name="display_summary">Branches with the highest account-opening volume in the selected period.</field>
            <field name="display_order">1</field>
            <field name="scope">compliance</field>
            <field name="is_visible" eval="True"/>
            <field name="refresh_mode">scheduled</field>
            <field name="cache_ttl_minutes">60</field>
            <field name="chart_type">bar</field>
            <field name="query">
                SELECT rb.id AS branch_id, rb.name, COUNT(rpa.id) AS account_count
                FROM res_branch rb
                JOIN res_partner_account rpa ON rb.id = rpa.branch_id
                GROUP BY rb.id, rb.name
                ORDER BY account_count DESC
                LIMIT 10;
            </field>
            <field name="color_scheme">brown</field>
            <field name="x_axis_field">name</field>
            <field name="y_axis_field">account_count</field>
            <field name="navigation_value_field">branch_id</field>
            <field name="branch_filter" eval="True"/>
            <field name="date_filter" eval="True"/>
            <field name="date_field">COALESCE(rpa.opening_date, rpa.date_created, rpa.create_date)</field>
            <field name="branch_field">rpa.branch_id</field>
            <field name="column">6</field>
            <field name="state">active</field>
            <field name="navigation_filter_field">branch_id</field>
            <field name="navigation_domain">[]</field>
            <field name="apply_dashboard_date_filter" eval="True"/>
            <field name="navigation_date_field">create_date</field>
            <field name="apply_dashboard_branch_filter" eval="True"/>
            <field name="navigation_branch_field">branch_id</field>
            <field name="target_model_id" ref="compliance_management.model_res_partner_account"/>
        </record>

        <record id="demo_chart_top10_high_risk_branch" model="res.dashboard.charts">
            <field name="name">Top 10 High Risk Branch by Accounts</field>
            <field name="code">top_high_risk_accounts</field>
            <field name="description">Branches with the largest number of high-risk accounts.</field>
            <field name="display_summary">Branches with the highest concentration of high-risk accounts in the selected period.</field>
            <field name="display_order">2</field>
            <field name="scope">compliance</field>
            <field name="is_visible" eval="True"/>
            <field name="refresh_mode">scheduled</field>
            <field name="cache_ttl_minutes">60</field>
            <field name="chart_type">bar</field>
            <field name="query">
                SELECT rb.id AS branch_id, rb.name AS name, COUNT(rpa.id) AS high_risk_accounts
                FROM res_branch rb
                JOIN res_partner_account rpa ON rb.id = rpa.branch_id
                JOIN res_partner rp ON rpa.customer_id = rp.id
                WHERE rp.risk_level = 'high'
                GROUP BY rb.id, rb.name
                ORDER BY high_risk_accounts DESC
                LIMIT 10;
            </field>
            <field name="color_scheme">brown</field>
            <field name="x_axis_field">name</field>
            <field name="y_axis_field">high_risk_accounts</field>
            <field name="navigation_value_field">branch_id</field>
            <field name="branch_filter" eval="True"/>
            <field name="date_filter" eval="True"/>
            <field name="date_field">COALESCE(rpa.opening_date, rpa.date_created, rpa.create_date)</field>
            <field name="branch_field">rpa.branch_id</field>
            <field name="column">6</field>
            <field name="state">active</field>
            <field name="navigation_filter_field">branch_id</field>
            <field name="navigation_domain">[('risk_level', '=', 'high')]</field>
            <field name="apply_dashboard_date_filter" eval="True"/>
            <field name="navigation_date_field">create_date</field>
            <field name="apply_dashboard_branch_filter" eval="True"/>
            <field name="navigation_branch_field">branch_id</field>
            <field name="target_model_id" ref="compliance_management.model_res_partner_account"/>
        </record>

        <record id="demo_chart_top_customer_risk_rules" model="res.dashboard.charts">
            <field name="name">Top 10 Customer Risk Rules</field>
            <field name="code">top_customer_risk_rules</field>
            <field name="description">Risk rules affecting the highest number of customers.</field>
            <field name="display_summary">Risk analysis rules affecting the highest number of partners in the selected period.</field>
            <field name="display_order">3</field>
            <field name="scope">compliance</field>
            <field name="is_visible" eval="True"/>
            <field name="refresh_mode">scheduled</field>
            <field name="cache_ttl_minutes">60</field>
            <field name="chart_type">line</field>
            <field name="query">
                SELECT rcap.id AS risk_rule_id, rcap.name AS name, COUNT(DISTINCT rppl.partner_id) AS partner_count
                FROM res_compliance_risk_assessment_plan rcap
                JOIN res_partner_risk_plan_line rppl ON rcap.id = rppl.plan_line_id
                JOIN res_partner rp ON rp.id = rppl.partner_id
                GROUP BY rcap.id, rcap.name
                ORDER BY partner_count DESC, rcap.name ASC
                LIMIT 10;
            </field>
            <field name="color_scheme">brown</field>
            <field name="x_axis_field">name</field>
            <field name="y_axis_field">partner_count</field>
            <field name="navigation_value_field">risk_rule_id</field>
            <field name="branch_filter" eval="True"/>
            <field name="date_filter" eval="True"/>
            <field name="date_field">rppl.create_date</field>
            <field name="branch_field">rp.branch_id</field>
            <field name="column">12</field>
            <field name="state">active</field>
            <field name="navigation_filter_field">plan_line_id</field>
            <field name="navigation_domain">[]</field>
            <field name="apply_dashboard_date_filter" eval="True"/>
            <field name="navigation_date_field">create_date</field>
            <field name="apply_dashboard_branch_filter" eval="True"/>
            <field name="navigation_branch_field">partner_id.branch_id</field>
            <field name="target_model_id" ref="compliance_management.model_res_partner_risk_plan_line"/>
        </record>

        <record id="demo_chart_top10_screened_transaction" model="res.dashboard.charts">
            <field name="name">Top Transaction Exception</field>
            <field name="code">top_transaction_exceptions</field>
            <field name="description">Most-triggered transaction screening rules.</field>
            <field name="display_summary">Most-triggered exception rules in the selected period.</field>
            <field name="display_order">4</field>
            <field name="scope">compliance</field>
            <field name="is_visible" eval="True"/>
            <field name="refresh_mode">scheduled</field>
            <field name="cache_ttl_minutes">60</field>
            <field name="chart_type">line</field>
            <field name="query">
                SELECT rtsr.id AS rule_id, rtsr.name AS name, COUNT(rct.id) AS hit_count
                FROM res_transaction_screening_rule rtsr
                JOIN res_customer_transaction rct ON rtsr.id = rct.rule_id
                GROUP BY rtsr.id, rtsr.name
                ORDER BY hit_count DESC
                LIMIT 10;
            </field>
            <field name="color_scheme">brown</field>
            <field name="x_axis_field">name</field>
            <field name="y_axis_field">hit_count</field>
            <field name="navigation_value_field">rule_id</field>
            <field name="branch_filter" eval="True"/>
            <field name="date_filter" eval="True"/>
            <field name="date_field">rct.date_created</field>
            <field name="branch_field">rct.branch_id</field>
            <field name="column">12</field>
            <field name="state">active</field>
            <field name="navigation_filter_field">rule_id</field>
            <field name="navigation_domain">[]</field>
            <field name="apply_dashboard_date_filter" eval="True"/>
            <field name="navigation_date_field">date_created</field>
            <field name="apply_dashboard_branch_filter" eval="True"/>
            <field name="navigation_branch_field">branch_id</field>
            <field name="target_model_id" ref="compliance_management.model_res_customer_transaction"/>
        </record>

        <record id="demo_chart_cases_by_status" model="res.dashboard.charts">
            <field name="name">Cases by Status</field>
            <field name="code">cases_by_status</field>
            <field name="description">Distribution of cases by lifecycle stage.</field>
            <field name="display_summary">Current case distribution by lifecycle stage for the selected period.</field>
            <field name="display_order">5</field>
            <field name="scope">compliance</field>
            <field name="is_visible" eval="True"/>
            <field name="refresh_mode">scheduled</field>
            <field name="cache_ttl_minutes">60</field>
            <field name="chart_type">pie</field>
            <field name="query">
                SELECT cm.case_status, COUNT(cm.id) AS case_count
                FROM case_manager cm
                GROUP BY cm.case_status
                ORDER BY case_count DESC, cm.case_status ASC
            </field>
            <field name="color_scheme">brown</field>
            <field name="x_axis_field">case_status</field>
            <field name="y_axis_field">case_count</field>
            <field name="navigation_value_field">case_status</field>
            <field name="branch_filter" eval="False"/>
            <field name="date_filter" eval="True"/>
            <field name="date_field">cm.create_date</field>
            <field name="column">6</field>
            <field name="state">active</field>
            <field name="navigation_filter_field">case_status</field>
            <field name="navigation_domain">[]</field>
            <field name="apply_dashboard_date_filter" eval="True"/>
            <field name="navigation_date_field">create_date</field>
            <field name="target_model_id" ref="case_management.model_case_manager"/>
        </record>

        <record id="demo_chart_cases_by_exceptions" model="res.dashboard.charts">
            <field name="name">Cases by Exceptions</field>
            <field name="code">cases_by_exceptions</field>
            <field name="description">Cases grouped by linked exception process.</field>
            <field name="display_summary">Cases grouped by linked exception process in the selected period.</field>
            <field name="display_order">6</field>
            <field name="scope">compliance</field>
            <field name="is_visible" eval="True"/>
            <field name="refresh_mode">scheduled</field>
            <field name="cache_ttl_minutes">60</field>
            <field name="chart_type">pie</field>
            <field name="query">
                SELECT ep.id AS process_id, ep.name AS name, COUNT(cm.id) AS case_count
                FROM case_manager cm
                JOIN exception_process_ ep ON ep.id = cm.process
                GROUP BY ep.id, ep.name
                ORDER BY case_count DESC, ep.name ASC
                LIMIT 10;
            </field>
            <field name="color_scheme">brown</field>
            <field name="x_axis_field">name</field>
            <field name="y_axis_field">case_count</field>
            <field name="navigation_value_field">process_id</field>
            <field name="branch_filter" eval="False"/>
            <field name="date_filter" eval="True"/>
            <field name="date_field">cm.create_date</field>
            <field name="column">6</field>
            <field name="state">active</field>
            <field name="navigation_filter_field">process</field>
            <field name="navigation_domain">[]</field>
            <field name="apply_dashboard_date_filter" eval="True"/>
            <field name="navigation_date_field">create_date</field>
            <field name="target_model_id" ref="case_management.model_case_manager"/>
        </record>
    </data>
</odoo>
