        <field name="code">permit_for_permanent_residence</field>
    </record>


    <record id="res_partner_iden_type_13" model="res.identification.type">
        <field name="name">Nysc Id/Call Up Letter</field>
        <field name="code">nysc_id/call_up_letter</field>
