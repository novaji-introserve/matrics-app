<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
        Customer Type Classification Configuration
        ===========================================

        This data file initializes the classification rules for determining
        whether a customer_status value represents an Individual or Corporate
        customer type.

        Business Rule (per client requirement):
            - Individual: "AltEvolve", "Internal Customer", "Laborer", "Individual"
            - Corporate: All other status values

        These rules can be modified via the UI without code changes, following
        the Open/Closed Principle.
        -->

        <!-- Individual Status Classifications -->
        <record id="customer_type_config_altevolve" model="customer.type.config">
            <field name="customer_status">AltEvolve</field>
            <field name="customer_type">individual</field>
            <field name="description">AltEvolve customers are classified as Individual accounts</field>
            <field name="active">True</field>
        </record>

        <record id="customer_type_config_internal_customer" model="customer.type.config">
            <field name="customer_status">Internal Customer</field>
            <field name="customer_type">individual</field>
            <field name="description">Internal bank customers are classified as Individual accounts</field>
            <field name="active">True</field>
        </record>

        <record id="customer_type_config_laborer" model="customer.type.config">
            <field name="customer_status">Laborer</field>
            <field name="customer_type">individual</field>
            <field name="description">Laborer customers are classified as Individual accounts</field>
            <field name="active">True</field>
        </record>

        <record id="customer_type_config_individual" model="customer.type.config">
            <field name="customer_status">Individual</field>
            <field name="customer_type">individual</field>
            <field name="description">Individual customers</field>
            <field name="active">True</field>
        </record>

