<odoo>
    <data noupdate="0">
        <record id="ir_cron_account_stat_refresh" model="ir.cron">
            <field name="name">Account Transaction Stats Refresh</field>
            <field name="model_id" ref="model_res_partner_account" />
            <field name="state">code</field>
            <field name="code">model.queue_account_stat_refresh(batch_size=2000)</field>
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False" />
            <field name="priority">20</field>
            <field name="active" eval="True" />
            <field name="nextcall" eval="((datetime.now().replace(hour=1, minute=0, second=0, microsecond=0)) if datetime.now().hour &lt; 1 else ((datetime.now() + timedelta(days=1)).replace(hour=1, minute=0, second=0, microsecond=0))).strftime('%Y-%m-%d %H:%M:%S')" />
        </record>
    </data>
</odoo>
