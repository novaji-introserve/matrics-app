<!-- <?xml version="1.0" encoding="utf-8"?> -->
<odoo>

    <data noupdate="0">

        <record id="ir_cron_adverse_media_scan" model="ir.cron">
            <field name="name">Scan Adverse Media</field>
            <field name="model_id" ref="model_adverse_media"/>
            <field name="state">code</field>
            <field name="code">model.scan_adverse_media()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False" />
        </record>

        <record id="ir_cron_adverse_media_sla_check" model="ir.cron">
            <field name="name">Adverse Media — SLA Breach Check</field>
            <field name="model_id" ref="model_adverse_media_alert"/>
            <field name="state">code</field>
            <field name="code">model.check_sla_breaches()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True" />
        </record>

        <record id="ir_cron_adverse_media_suppression_expiry" model="ir.cron">
            <field name="name">Adverse Media — Expire Suppression Rules</field>
            <field name="model_id" ref="model_adverse_media_suppression"/>
            <field name="state">code</field>
            <field name="code">model.expire_suppression_rules()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True" />
        </record>

        <record id="ir_cron_adverse_media_retention" model="ir.cron">
            <field name="name">Adverse Media — Archive Old Alerts</field>
            <field name="model_id" ref="model_adverse_media_alert"/>
            <field name="state">code</field>
            <field name="code">model.archive_old_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_adverse_media_weekly_digest" model="ir.cron">
            <field name="name">Adverse Media — Weekly Digest Email</field>
            <field name="model_id" ref="model_adverse_media_alert"/>
            <field name="state">code</field>
            <field name="code">model.send_weekly_digest()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>

    </data>

</odoo>
