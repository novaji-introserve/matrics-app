<odoo>
  <!--  Gender -->
    <record id="res_partner_gender_male" model="res.partner.gender">
        <field name="name">Male</field>
    </record>
    <record id="res_partner_gender_female" model="res.partner.gender">
        <field name="name">Female</field>
    </record>
    <record id="res_partner_gender_trans" model="res.partner.gender">
        <field name="name">Trans Gender</field>
    </record>
    <record id="res_partner_gender_other" model="res.partner.gender">
        <field name="name">Other</field>
    </record>
    <!-- Marital Status-->
    <record id="res_partner_marital_single" model="res.marital.status">
        <field name="name">Single</field>
    </record>
    <record id="res_partner_marital_married" model="res.marital.status">
        <field name="name">Married</field>
    </record>
    <record id="res_partner_marital_divorced" model="res.marital.status">
        <field name="name">Divorced</field>
    </record>
  

</odoo>