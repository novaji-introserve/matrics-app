<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Email Template Function -->
        <template id="adverse_media_alert_table">
            <table style="border-collapse: collapse; width: 100%; margin-top: 8px;">
                <tr style="background-color: #f2f2f2;">
                    <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Partner</th>
                    <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Title</th>
                    <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Risk Score</th>
                    <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Source</th>
                </tr>
                <t t-foreach="alert_records" t-as="alert">
                    <tr>
                        <td style="border: 1px solid #ddd; padding: 12px;">
                            <t t-esc="alert.partner_id.name"/>
                        </td>
                        <td style="border: 1px solid #ddd; padding: 12px;">
                            <t t-esc="alert.name"/>
                        </td>
                        <td style="border: 1px solid #ddd; padding: 12px;">
                            <t t-esc="alert.risk_score"/>
                        </td>
                        <td style="border: 1px solid #ddd; padding: 12px;">
                            <a t-att-href="alert.source_url" style="color: #3498db; text-decoration: none;">View Source</a>
                        </td>
                    </tr>
                </t>
            </table>
        </template>

        <!-- Main Email Template -->
        <record id="alert_notification_template" model="mail.template">
            <field name="name">Adverse Media Alert Notification</field>
            <field name="model_id" ref="model_adverse_media"/>
            <field name="subject">New Adverse Media Alerts Detected</field>
            <field name="email_from">${ctx.get('email_from')}</field>
            <field name="body_html" type="html">

                <!-- <div style="margin: 0px 12px; padding: 0px; font-family: Arial, sans-serif;"> -->
                <div style="margin: 10px 12px 0px 12px; padding: 0px; font-family: Arial, sans-serif;">

                    <!-- Header with Logo -->
                    <div style="padding: 8px; text-align: left; margin-bottom: 45px;">
                        <img t-att-src="ctx.get('company_logo')" alt="Company Logo" class="h-6"/>
                    </div>


                    <div style="padding: 20px;">
                        <p>Dear <b>
                            <i>
                                <t t-esc="ctx.get('officers_name')"/>
                            </i>
                        </b> ,
                    </p>

                    <p>New adverse media alerts have been detected.</p>

                    <!-- <h3 style="color: #2c3e50; margin-top: 20px;">Date and Time Entry: </h3> <span><t t-esc="ctx.get('datetime')"/></span> -->
                    <p style="line-height: 1.4;">
                        <strong style="color: #2c3e50;font-size: 1.17em;">Date and Time Entry:
                        </strong>
                        <t t-esc="ctx.get('datetime')"/>
                    </p>

                    <p>
                        <strong style="color: #2c3e50;font-size: 1.17em;">Alert Summary: </strong>
                    </p>
                    <!-- <h3 style="color: #2c3e50; margin-top: 20px;">Alert Summary:</h3> -->
                    <t t-call="compliance_management.adverse_media_alert_table">
                        <t t-set="alert_records" t-value="ctx.get('alerts')"/>
                    </t>

                    <p style="margin-top: 20px;">
                            Click <a t-att-href="ctx.get('action_url')" style="color: #3498db; text-decoration: none;">here</a> 
                            to view all new alerts in the system.
                    </p>

                    <p>Please review these alerts and take appropriate action.</p>

                    <div style="margin-top: 30px; color: #7f8c8d;">
                        <p>Best regards</p>
                    </div>
                </div>
            </div>
        </field>
        <field name="auto_delete" eval="False"/>
    </record>
</data>
</odoo>