<!-- views/sla_severity_views.xml -->
<odoo>
    <record id="view_sla_severity_tree" model="ir.ui.view">
        <field name="name">sla.severity.tree</field>
        <field name="model">sla.severity</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="noOfSupervisor" />
            </tree>
        </field>
    </record>

    <record id="view_sla_severity_form" model="ir.ui.view">
        <field name="name">sla.severity.form</field>
        <field name="model">sla.severity</field>
        <field name="arch" type="xml">
            <form string="SLA Severity">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="noOfSupervisor" />
                        <field name="description" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>