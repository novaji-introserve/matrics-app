<odoo>
  <data>
    <!-- Transaction Screening Rule Tree View -->
    <record id="transaction_screening_rule_tree" model="ir.ui.view">
      <field name="name">transaction_screening_rule_tree</field>
      <field name="model">res.transaction.screening.rule</field>
      <field name="inherit_id"
        ref="compliance_management.compliance_transaction_screening_rule_tree" />
      <field name="priority">20</field>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='transaction_flag']" position="after">
          <field name="blocked" />
        </xpath>
      </field>
    </record>
    <record id="transaction_screening_rule_form" model="ir.ui.view">
      <field name="name">transaction_screening_rule_form</field>
      <field name="model">res.transaction.screening.rule</field>
      <field name="inherit_id" ref="compliance_management.compliance_transaction_screening_rule_form" />
      <field name="priority">20</field>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='condition_select']" position="after">
          <field name="blocked" string="Block Transaction"  widget="boolean_toggle"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>