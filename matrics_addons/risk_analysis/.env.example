# ===================================================== #
# DATABASE CONFIGURATION - CONNECT TO EXISTING DATABASE #
# ===================================================== #

# PostgreSQL connection details
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_existing_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL_MODE=require                    # Options: disable, require, verify-ca, verify-full

# Connection pool settings
DB_POOL_MIN=10                         # Minimum connections to maintain
DB_POOL_MAX=50                         # Maximum connections allowed
DB_POOL_MAX_IDLE_TIME=300              # Seconds before idle connection is closed
DB_POOL_MAX_LIFETIME=3600              # Maximum seconds a connection can be reused
DB_CONNECT_TIMEOUT=10                  # Connection timeout in seconds
DB_QUERY_TIMEOUT=30                    # Query execution timeout in seconds

# ============================================
# PROCESSING CONFIGURATION
# ============================================

# Batch processing settings
BATCH_SIZE=1000                        # Number of customers per batch
WORKER_COUNT=20                        # Number of concurrent workers
CHUNK_SIZE=10000                       # Records to load into memory at once

# Performance tuning
ENABLE_BULK_OPERATIONS=true            # Use bulk inserts/updates
BULK_INSERT_BATCH_SIZE=500             # Records per bulk insert
PROGRESS_CHECKPOINT_INTERVAL=10000     # Save progress every N customers

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Logging settings
LOG_LEVEL=INFO                         # Options: DEBUG, INFO, WARN, ERROR
LOG_FORMAT=json                        # Options: json, text
LOG_OUTPUT=file                        # Options: stdout, file, both
LOG_FILE=/var/log/risk-processor.log   # Log file path (if file or both)
LOG_MAX_SIZE=100                       # Maximum log file size in MB
LOG_MAX_BACKUPS=5                      # Number of old log files to keep
LOG_MAX_AGE=30                         # Maximum days to retain old log files

# ============================================
# RETRY AND RESILIENCE
# ============================================

# Retry configuration
MAX_RETRIES=3                          # Maximum retry attempts for failed operations
RETRY_INITIAL_INTERVAL=1               # Initial retry delay in seconds
RETRY_MAX_INTERVAL=10                  # Maximum retry delay in seconds
RETRY_MULTIPLIER=2                     # Backoff multiplier

# ============================================
# OPERATIONAL SETTINGS
# ============================================

# Execution control
DRY_RUN=false                          # If true, don't write to database
RESUME_FROM_CHECKPOINT=false           # Resume from last saved checkpoint
CHECKPOINT_FILE=/tmp/risk-processor-checkpoint.json

# Customer filtering (optional)
# CUSTOMER_IDS=1,2,3,4,5               # Process only specific customers (comma-separated)
# CUSTOMER_ID_RANGE_START=1000         # Process customers from this ID
# CUSTOMER_ID_RANGE_END=2000           # Process customers up to this ID