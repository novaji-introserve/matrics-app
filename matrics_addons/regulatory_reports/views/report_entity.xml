<odoo>
    <data>
        <record id="view_report_entity_form" model="ir.ui.view">
            <field name="name">report.entity.form</field>
            <field name="model">res.regulatory.report.entity</field>
            <field name="arch" type="xml">
                <form string="Report Entity">
                    <sheet>
                       <div class="oe_title">
                            <label for="name" class="oe-edit-only" />
                            <h1>
                                <field name="name" placeholder="CBN" />
                            </h1>
                        </div>
                        <group>
                            <field name="code"/>
                        </group>
                        <notebook>
                          <page name="Description" string="Description">
                            <field name="description" widget="html" />
                          </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_report_entity_tree" model="ir.ui.view">
            <field name="name">report.entity.tree</field>
            <field name="model">res.regulatory.report.entity</field>
            <field name="arch" type="xml">
                <tree string="Report Entities">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="write_uid"/>
                    <field name="write_date"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>