<odoo>
    <record id="action_regulatory_report" model="ir.actions.act_window">
        <field name="name">Regulatory Reports</field>
        <field name="res_model">res.regulatory.report</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_regulatory_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first SQL-based regulatory report
            </p>
        </field>
    </record>

    <record id="action_regulatory_report_run" model="ir.actions.act_window">
        <field name="name">Regulatory Report Downloads</field>
        <field name="res_model">res.regulatory.report.run</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_regulatory_report"
        name="Regulatory"
        groups="compliance_management.group_compliance_chief_compliance_officer,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="compliance_management.menu_compliance_configuration"
        sequence="3000" />
    <menuitem
        id="menu_regulatory_report_entity"
        name="Report Entities"
        groups="compliance_management.group_compliance_chief_compliance_officer,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="menu_regulatory_report"
        action="action_regulatory_report_entity"
        sequence="5" />
    <menuitem
        id="menu_regulatory_report_template"
        name="Report Templates"
        groups="compliance_management.group_compliance_chief_compliance_officer,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="menu_regulatory_report"
        action="action_regulatory_report_template"
        sequence="10" />
    <menuitem
        id="menu_regulatory_report_item"
        name="Report Items"
        groups="compliance_management.group_compliance_chief_compliance_officer,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="menu_regulatory_report"
        action="action_regulatory_report_item"
        sequence="20" />
    <menuitem
        id="menu_regulatory_report_template_item"
        name="Report Template Items"
        groups="compliance_management.group_compliance_chief_compliance_officer,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="menu_regulatory_report"
        action="action_regulatory_report_template_item"
        sequence="25" />

    <menuitem
        id="menu_regulatory_report_root"
        name="Regulatory"
        groups="regulatory_reports.group_regulatory_report,compliance_management.group_compliance_chief_compliance_officer,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="compliance_management.menu_compliance_root"
        sequence="1000"/>
    <menuitem
        id="menu_regulatory_report_report"
        name="Reports"
        groups="regulatory_reports.group_regulatory_report,compliance_management.group_compliance_chief_compliance_officer,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="menu_regulatory_report_root"
        action="action_regulatory_report"
        sequence="10"/>
    <menuitem
        id="menu_regulatory_report_runs"
        name="Downloads"
        groups="regulatory_reports.group_regulatory_report,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="menu_regulatory_report_root"
        action="action_regulatory_report_run"
        sequence="20"/>
</odoo>
