<odoo>
    <record id="action_regulatory_report" model="ir.actions.act_window">
        <field name="name">Regulatory Reports</field>
        <field name="res_model">res.regulatory.report</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_regulatory_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first SQL-based regulatory report
            </p>
        </field>
    </record>

    <record id="action_regulatory_report_run" model="ir.actions.act_window">
        <field name="name">Regulatory Report Downloads</field>
        <field name="res_model">res.regulatory.report.run</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="menu_regulatory_report" model="ir.ui.menu">
        <field name="name">Legacy Regulatory Configuration</field>
        <field name="active" eval="False"/>
    </record>
    <record id="menu_regulatory_report_entity" model="ir.ui.menu">
        <field name="name">Legacy Report Entities</field>
        <field name="active" eval="False"/>
    </record>
    <record id="menu_regulatory_report_template" model="ir.ui.menu">
        <field name="name">Legacy Report Templates</field>
        <field name="active" eval="False"/>
    </record>
    <record id="menu_regulatory_report_item" model="ir.ui.menu">
        <field name="name">Legacy Report Items</field>
        <field name="active" eval="False"/>
    </record>
    <record id="menu_regulatory_report_template_item" model="ir.ui.menu">
        <field name="name">Legacy Report Template Items</field>
        <field name="active" eval="False"/>
    </record>

    <menuitem
        id="menu_regulatory_report_root"
        name="Regulatory"
        groups="regulatory_reports.group_regulatory_report,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="compliance_management.menu_compliance_root"
        sequence="1000"/>
    <menuitem
        id="menu_regulatory_report_report"
        name="Reports"
        groups="regulatory_reports.group_regulatory_report,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="menu_regulatory_report_root"
        action="action_regulatory_report"
        sequence="10"/>
    <menuitem
        id="menu_regulatory_report_runs"
        name="Downloads"
        groups="regulatory_reports.group_regulatory_report,compliance_management.group_compliance_compliance_officer,base.group_system"
        parent="menu_regulatory_report_root"
        action="action_regulatory_report_run"
        sequence="20"/>
</odoo>
