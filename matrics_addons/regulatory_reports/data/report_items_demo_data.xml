        <!-- ════════════════════════════════════════════════════════════════
             LARGE TRANSACTIONS — SQL Multi
             Returns 7 columns mapped to A3 on LargeTransactions sheet.
             Columns: S/N, Transaction Ref, Customer Name, Account Number,
                      Amount, Date, Branch
             ════════════════════════════════════════════════════════════════ -->

        <record id="item_large_transactions" model="res.regulatory.report.item">
            <field name="name">Large Transactions List</field>
            <field name="code">LARGE_TXN_LIST</field>
            <field name="source">sql_multi</field>
            <field name="source_sql">
                SELECT
                    ROW_NUMBER() OVER (ORDER BY t.date_created DESC)    AS sn,
                    COALESCE(t.transaction_number, t.name)               AS transaction_ref,
                    p.name                                               AS customer_name,
                    COALESCE(pa.name, '')                                AS account_number,
                    TO_CHAR(t.amount, 'FM999,999,999,990.00')           AS amount,
                    TO_CHAR(t.date_created, 'DD-Mon-YYYY')              AS transaction_date,
                    COALESCE(rb.name, t.branch_code, '')                AS branch
                FROM res_customer_transaction t
                JOIN res_partner p  ON p.id  = t.customer_id
                LEFT JOIN res_partner_account pa ON pa.id = t.account_id
                LEFT JOIN res_branch rb           ON rb.id = t.branch_id
                WHERE t.amount &gt;= 5000000
                AND t.date_created &gt;= DATE_TRUNC('month', NOW())
                AND t.date_created &lt;  DATE_TRUNC('month', NOW()) + INTERVAL '1 month'
                ORDER BY t.amount DESC
            </field>
            <field name="status">active</field>
            <field name="description">All transactions above NGN 5,000,000 this month. Returns 7 columns: S/N, Transaction Ref, Customer Name, Account Number, Amount, Date, Branch. Mapped to cell A3 on the LargeTransactions sheet.</field>
        </record>

