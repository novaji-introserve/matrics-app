        <!-- ════════════════════════════════════════════════════════════════
             SECTION A — BALANCE SHEET
             NOTE: items marked static require the Odoo accounting module
             (account_move_line) which is not installed. Update manually or
             switch source to sql_single once accounting is enabled.
             ════════════════════════════════════════════════════════════════ -->

        <record id="item_total_assets" model="res.regulatory.report.item">
            <field name="name">Total Assets</field>
            <field name="code">TOTAL_ASSETS</field>
            <field name="source">static</field>
            <field name="source_value">0.00</field>
            <field name="status">active</field>
            <field name="description">
                Sum of all asset accounts in millions (NGN). Update manually.
                Switch to sql_single with the query below once the accounting
                module (account_move_line) is installed:
                SELECT ROUND(SUM(debit - credit) / 1000000.0, 2)
                FROM account_move_line aml
                JOIN account_account aa ON aa.id = aml.account_id
                WHERE aa.account_type IN ('asset_current','asset_non_current','asset_fixed')
                AND aml.parent_state = 'posted'
            </field>
        </record>

        <record id="item_total_loans" model="res.regulatory.report.item">
            <field name="name">Total Loans and Advances</field>
            <field name="code">TOTAL_LOANS</field>
            <field name="source">sql_single</field>
            <field name="source_sql">
                SELECT COALESCE(ROUND(SUM(amount) / 1000000.0, 2), 0)
                FROM res_customer_transaction
                WHERE transaction_type = 'L'
                AND state = 'done'
                AND date_created &lt;= DATE_TRUNC('month', NOW()) + INTERVAL '1 month' - INTERVAL '1 day'
            </field>
            <field name="status">active</field>
            <field name="description">Total outstanding loan balances in millions (NGN). Requires transaction_type = 'L' in res_customer_transaction.</field>
        </record>

        <record id="item_total_deposits" model="res.regulatory.report.item">
            <field name="name">Total Deposits</field>
            <field name="code">TOTAL_DEPOSITS</field>
            <field name="source">sql_single</field>
            <field name="source_sql">
                SELECT COALESCE(ROUND(SUM(amount) / 1000000.0, 2), 0)
                FROM res_customer_transaction
                WHERE transaction_type = 'D'
                AND state = 'done'
                AND date_created &gt;= DATE_TRUNC('month', NOW())
                AND date_created &lt;  DATE_TRUNC('month', NOW()) + INTERVAL '1 month'
            </field>
            <field name="status">active</field>
            <field name="description">Total customer deposits this month in millions (NGN). Requires transaction_type = 'D' in res_customer_transaction.</field>
        </record>

