<odoo>
    <data noupdate="1">
        <record id="demo_chart_cases_by_status" model="res.dashboard.charts">
            <field name="name">Cases by Status</field>
            <field name="code">cases_by_status</field>
            <field name="description">Distribution of cases by lifecycle stage.</field>
            <field name="display_summary">Current case distribution by lifecycle stage for the selected period.</field>
            <field name="display_order">5</field>
            <field name="scope">compliance</field>
            <field name="is_visible" eval="True"/>
            <field name="refresh_mode">scheduled</field>
            <field name="cache_ttl_minutes">60</field>
            <field name="chart_type">pie</field>
            <field name="query">
                SELECT cm.case_status, COUNT(cm.id) AS case_count
                FROM case_manager cm
                GROUP BY cm.case_status
                ORDER BY case_count DESC, cm.case_status ASC
            </field>
            <field name="color_scheme">brown</field>
            <field name="x_axis_field">case_status</field>
            <field name="y_axis_field">case_count</field>
            <field name="navigation_value_field">case_status</field>
            <field name="branch_filter" eval="False"/>
            <field name="date_filter" eval="True"/>
            <field name="date_field">cm.create_date</field>
            <field name="column">6</field>
            <field name="state">active</field>
            <field name="navigation_filter_field">case_status</field>
            <field name="navigation_domain">[]</field>
            <field name="apply_dashboard_date_filter" eval="True"/>
            <field name="navigation_date_field">create_date</field>
            <field name="target_model_id" ref="case_management.model_case_manager"/>
        </record>

        <record id="demo_chart_cases_by_exceptions" model="res.dashboard.charts">
            <field name="name">Cases by Exceptions</field>
            <field name="code">cases_by_exceptions</field>
            <field name="description">Cases grouped by linked exception process.</field>
            <field name="display_summary">Cases grouped by linked exception process in the selected period.</field>
            <field name="display_order">6</field>
            <field name="scope">compliance</field>
            <field name="is_visible" eval="True"/>
            <field name="refresh_mode">scheduled</field>
            <field name="cache_ttl_minutes">60</field>
            <field name="chart_type">pie</field>
            <field name="query">
                SELECT ep.id AS process_id, ep.name AS name, COUNT(cm.id) AS case_count
                FROM case_manager cm
                JOIN exception_process_ ep ON ep.id = cm.process
                GROUP BY ep.id, ep.name
                ORDER BY case_count DESC, ep.name ASC
                LIMIT 10;
            </field>
            <field name="color_scheme">brown</field>
            <field name="x_axis_field">name</field>
            <field name="y_axis_field">case_count</field>
            <field name="navigation_value_field">process_id</field>
            <field name="branch_filter" eval="False"/>
            <field name="date_filter" eval="True"/>
            <field name="date_field">cm.create_date</field>
            <field name="column">6</field>
            <field name="state">active</field>
            <field name="navigation_filter_field">process</field>
            <field name="navigation_domain">[]</field>
            <field name="apply_dashboard_date_filter" eval="True"/>
            <field name="navigation_date_field">create_date</field>
            <field name="target_model_id" ref="case_management.model_case_manager"/>
        </record>
    </data>
</odoo>
