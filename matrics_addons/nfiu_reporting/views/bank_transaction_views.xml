<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- BANK TRANSACTION VIEWS -->

    <!-- Bank Transaction Tree View -->
    <record id="view_bank_transaction_tree" model="ir.ui.view">
        <field name="name">bank.transaction.tree</field>
        <field name="model">bank.transaction</field>
        <field name="arch" type="xml">
            <tree string="Bank Transactions" create="false" edit="false" delete="false">
                <field name="transaction_number" />
                <field name="date_transaction" />
                <field name="tran_type" />
                <field name="amount_local" />
                <field name="currency_code" />
                <field name="from_account_id" />
                <field name="to_account_id" />
                <field name="transaction_description" />
            </tree>
        </field>
    </record>

    <!-- Bank Transaction Form View -->
    <record id="view_bank_transaction_form" model="ir.ui.view">
        <field name="name">bank.transaction.form</field>
        <field name="model">bank.transaction</field>
        <field name="arch" type="xml">
            <form string="Bank Transaction" create="false" edit="false" delete="false">
                <header>
                    <button name="action_view_from_account" string="View From Account" type="object"
                        class="btn-primary" />
                    <button name="action_view_to_account" string="View To Account" type="object"
                        class="btn-primary" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="transaction_number" class="oe_edit_only" />
                        <h1>
                            <field name="transaction_number" readonly="1" />
                        </h1>
                    </div>
                    <group string="Transaction Overview" col="4">
                        <group>
                            <field name="transaction_number" />
                            <field name="internal_ref_number" />
                            <field name="transaction_location" />
                            <field name="date_transaction" />
                            <field name="value_date" />
                        </group>
                        <group>
                            <field name="amount_local" />
                            <field name="tran_type" />
                            <field name="currency_code" />
                            <field name="transmode_code" />
                            <field name="late_deposit" />
                        </group>
                    </group>
                    <group string="Operational Details" col="4">
                        <group>
                            <field name="teller" />
                            <field name="authorized" />
                        </group>
                        <group>
                            <field name="from_country" />
                            <field name="to_country" />
                            <field name="from_funds_code" />
                            <field name="to_funds_code" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Account Information">
                            <group string="Account Routing" col="4">
                                <group>
                                    <field name="from_account_id" />
                                </group>
                                <group>
                                    <field name="to_account_id" />
                                </group>
                            </group>
                        </page>
                        <page string="Description">
                            <group string="Transaction Narrative">
                                <field name="transaction_description" nolabel="1"
                                    style="max-width: 920px; width: 100%;" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Bank Transaction Search View -->
    <record id="view_bank_transaction_search" model="ir.ui.view">
        <field name="name">bank.transaction.search</field>
        <field name="model">bank.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Bank Transactions">
                <field name="transaction_number" />
                <field name="tran_type" />
                <field name="currency_code" />
                <filter
                    name="filter_today"
                    string="Today"
                    domain="[
                        ('date_transaction', '&gt;=', context_today().strftime('%%Y-%%m-%%d 00:00:00')),
                        ('date_transaction', '&lt;=', context_today().strftime('%%Y-%%m-%%d 23:59:59'))
                    ]"
                />
                <filter
                    name="filter_last_7_days"
                    string="Last 7 Days"
                    domain="[
                        ('date_transaction', '&gt;=', (context_today() - relativedelta(days=6)).strftime('%%Y-%%m-%%d 00:00:00')),
                        ('date_transaction', '&lt;=', context_today().strftime('%%Y-%%m-%%d 23:59:59'))
                    ]"
                />
                <filter
                    name="filter_last_1_month"
                    string="Last 1 Month"
                    domain="[
                        ('date_transaction', '&gt;=', (context_today() - relativedelta(months=1) + relativedelta(days=1)).strftime('%%Y-%%m-%%d 00:00:00')),
                        ('date_transaction', '&lt;=', context_today().strftime('%%Y-%%m-%%d 23:59:59'))
                    ]"
                />
                <filter
                    name="filter_credit"
                    string="Credit"
                    domain="[('tran_type', '=', 'credit')]"
                />
                <filter
                    name="filter_debit"
                    string="Debit"
                    domain="[('tran_type', '=', 'debit')]"
                />
                <group string="Group By">
                    <filter
                        name="group_by_currency_code"
                        string="Currency"
                        context="{'group_by': 'currency_code'}"
                    />
                    <filter
                        name="group_by_tran_type"
                        string="Transaction Type"
                        context="{'group_by': 'tran_type'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- BANK ACCOUNT VIEWS -->

    <!-- Bank Institution Tree View -->
    <record id="view_bank_institution_tree" model="ir.ui.view">
        <field name="name">bank.institution.tree</field>
        <field name="model">bank.institution</field>
        <field name="arch" type="xml">
            <tree string="Bank Institutions">
                <field name="name" />
                <field name="inst_code" />
                <field name="swift_code" />
                <field name="non_bank_institution" />
            </tree>
        </field>
    </record>

    <!-- Bank Institution Form View -->
    <record id="view_bank_institution_form" model="ir.ui.view">
        <field name="name">bank.institution.form</field>
        <field name="model">bank.institution</field>
        <field name="arch" type="xml">
            <form string="Bank Institution">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" placeholder="Institution Name" />
                        </h1>
                    </div>
                    <group string="Institution Details" col="4">
                        <group>
                            <field name="inst_code" />
                            <field name="swift_code" />
                        </group>
                        <group>
                            <field name="non_bank_institution" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Bank Account Type Tree View -->
    <record id="view_bank_account_type_tree" model="ir.ui.view">
        <field name="name">bank.account.type.tree</field>
        <field name="model">bank.account.type</field>
        <field name="arch" type="xml">
            <tree string="Bank Account Types">
                <field name="name" />
            </tree>
        </field>
    </record>

    <!-- Bank Account Type Form View -->
    <record id="view_bank_account_type_form" model="ir.ui.view">
        <field name="name">bank.account.type.form</field>
        <field name="model">bank.account.type</field>
        <field name="arch" type="xml">
            <form string="Bank Account Type">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" placeholder="Account Type" />
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Bank Account Tree View -->
    <record id="view_bank_account_tree" model="ir.ui.view">
        <field name="name">bank.account.tree</field>
        <field name="model">bank.account</field>
        <field name="arch" type="xml">
            <tree string="Bank Accounts" create="false" edit="false" delete="false">
                <field name="account_number" />
                <field name="account_name" />
                <field name="institution_id" />
                <field name="personal_account_type" />
                <field name="currency_id" />
                <field name="balance" />
                <field name="status_code" />
            </tree>
        </field>
    </record>

    <!-- Bank Account Form View -->
    <record id="view_bank_account_form" model="ir.ui.view">
        <field name="name">bank.account.form</field>
        <field name="model">bank.account</field>
        <field name="arch" type="xml">
            <form string="Bank Account" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <label for="account_name" class="oe_edit_only" />
                        <h1>
                            <field name="account_name" readonly="1" />
                        </h1>
                    </div>
                    <group string="Account Profile" col="4">
                        <group>
                            <field name="account_number" />
                            <field name="account_name" />
                            <field name="beneficiary" />
                            <field name="client_number" />
                            <field name="personal_account_type" />
                        </group>
                        <group>
                            <field name="balance" />
                            <field name="currency_id" />
                            <field name="currency_code" readonly="1" />
                            <field name="opened" />
                            <field name="status_code" />
                        </group>
                    </group>
                    <group string="Institution Details" col="4">
                        <group>
                            <field name="institution_id" />
                            <field name="institution_name" readonly="1" />
                            <field name="institution_code" readonly="1" />
                            <field name="swift_code" readonly="1" />
                        </group>
                        <group>
                            <field name="branch" />
                            <field name="non_bank_institution" readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Signatories">
                            <field name="signatory_ids">
                                <tree create="false" edit="false" delete="false">
                                    <field name="person_id" />
                                    <field name="is_primary" />
                                </tree>
                            </field>
                        </page>
                        <page string="Incoming Transactions">
                            <field name="incoming_transactions">
                                <tree create="false" edit="false" delete="false">
                                    <field name="transaction_number" />
                                    <field name="date_transaction" />
                                    <field name="amount_local" />
                                    <field name="from_account_id" />
                                </tree>
                            </field>
                        </page>
                        <page string="Outgoing Transactions">
                            <field name="outgoing_transactions">
                                <tree create="false" edit="false" delete="false">
                                    <field name="transaction_number" />
                                    <field name="date_transaction" />
                                    <field name="amount_local" />
                                    <field name="to_account_id" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Bank Account Search View -->
    <record id="view_bank_account_search" model="ir.ui.view">
        <field name="name">bank.account.search</field>
        <field name="model">bank.account</field>
        <field name="arch" type="xml">
            <search string="Search Bank Accounts">
                <field name="account_number" />
                <field name="institution_id" />
                <field name="personal_account_type" />
                <field name="currency_id" />
                <field name="status_code" />
                <group string="Group By">
                    <filter
                        name="group_by_institution_id"
                        string="Institution"
                        context="{'group_by': 'institution_id'}"
                    />
                    <filter
                        name="group_by_personal_account_type"
                        string="Account Type"
                        context="{'group_by': 'personal_account_type'}"
                    />
                    <filter
                        name="group_by_currency_id"
                        string="Currency"
                        context="{'group_by': 'currency_id'}"
                    />
                    <filter
                        name="group_by_status_code"
                        string="Status"
                        context="{'group_by': 'status_code'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- BANK PERSON VIEWS -->

    <!-- Bank Person Tree View -->
    <record id="view_bank_person_tree" model="ir.ui.view">
        <field name="name">bank.person.tree</field>
        <field name="model">bank.person</field>
        <field name="arch" type="xml">
            <tree string="Bank Persons" create="false" edit="false" delete="false">
                <field name="full_name" />
                <field name="title" />
                <field name="gender" />
                <field name="birthdate" />
                <field name="nationality1" />
                <field name="occupation" />
            </tree>
        </field>
    </record>

    <!-- Bank Person Form View -->
    <record id="view_bank_person_form" model="ir.ui.view">
        <field name="name">bank.person.form</field>
        <field name="model">bank.person</field>
        <field name="arch" type="xml">
            <form string="Bank Person" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <label for="full_name" class="oe_edit_only" />
                        <h1>
                            <field name="full_name" readonly="1" />
                        </h1>
                    </div>
                    <group string="Personal Profile" col="4">
                        <group>
                            <field name="title" />
                            <field name="first_name" />
                            <field name="last_name" />
                            <field name="full_name" />
                            <field name="gender" />
                            <field name="birthdate" />
                        </group>
                        <group>
                            <field name="nationality1" />
                            <field name="nationality2" />
                            <field name="residence" />
                        </group>
                    </group>
                    <group string="Professional and Tax Details" col="4">
                        <group>
                            <field name="occupation" />
                            <field name="source_of_wealth" />
                        </group>
                        <group>
                            <field name="tax_number" />
                            <field name="tax_reg_number" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Contact Information">
                            <group col="1">
                                    <field name="phone_ids" nolabel="1">
                                        <tree create="false" edit="false" delete="false">
                                            <field name="full_number" optional="hide" />
                                            <field name="phone_number" string="Phone Number" />
                                            <field name="country_prefix" string="Prefix" />
                                            <field name="contact_type" />
                                        </tree>
                                    </field>
                                    <field name="address_ids" nolabel="1" mode="tree,form">
                                        <tree create="false" edit="false" delete="false">
                                            <field name="city" />
                                            <field name="state" string="State / Province" />
                                            <field name="country_code" optional="hide" />
                                        </tree>
                                        <form string="Person Address" create="false" edit="false" delete="false">
                                            <sheet>
                                                <group col="4">
                                                    <group>
                                                        <field name="country_code" />
                                                        <field name="postal_code" />
                                                    </group>
                                                </group>
                                                <group col="1">
                                                    <field name="address" nolabel="1"
                                                        style="max-width: 960px; width: 100%;" />
                                                </group>
                                                <group col="4">
                                                    <group>
                                                        <field name="city" />
                                                    </group>
                                                    <group>
                                                        <field name="state" />
                                                    </group>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                            </group>
                        </page>
                        <page string="Identification">
                            <field name="identification_ids">
                                <tree create="false" edit="false" delete="false">
                                    <field name="identification_type" />
                                    <field name="number" />
                                    <field name="issue_date" />
                                    <field name="expiry_date" />
                                    <field name="issue_country" />
                                    <field name="issuing_authority" />
                                </tree>
                            </field>
                        </page>
                        <page string="Account Signatories">
                            <field name="signatory_ids">
                                <tree create="false" edit="false" delete="false">
                                    <field name="account_id" />
                                    <field name="is_primary" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
 
    <!-- ACTIONS -->

    <!-- Bank Transaction Action -->
    <record id="action_bank_transaction" model="ir.actions.act_window">
        <field name="name">Bank Transactions</field>
        <field name="res_model">bank.transaction</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_bank_transaction_tree" />
        <field name="search_view_id" ref="view_bank_transaction_search" />
        <field name="context">{'search_default_filter_today': 1, 'search_default_group_by_currency_code': 1, 'group_by': 'currency_code'}</field>
    </record>

    <!-- Bank Account Action -->
    <record id="action_bank_account" model="ir.actions.act_window">
        <field name="name">Bank Accounts</field>
        <field name="res_model">bank.account</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_bank_account_tree" />
        <field name="search_view_id" ref="view_bank_account_search" />
        <field name="context">{'search_default_group_by_personal_account_type': 1, 'group_by': 'personal_account_type'}</field>
        <field name="domain">[]</field>
    </record>

    <!-- Bank Institution Action -->
    <record id="action_bank_institution" model="ir.actions.act_window">
        <field name="name">Bank Institutions</field>
        <field name="res_model">bank.institution</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_bank_institution_tree" />
    </record>

    <!-- Bank Account Type Action -->
    <record id="action_bank_account_type" model="ir.actions.act_window">
        <field name="name">Bank Account Types</field>
        <field name="res_model">bank.account.type</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_bank_account_type_tree" />
    </record>

    <!-- Bank Person Action -->
    <record id="action_bank_person" model="ir.actions.act_window">
        <field name="name">Bank Persons</field>
        <field name="res_model">bank.person</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_bank_person_tree" />
        <field name="context">{}</field>
        <field name="domain">[]</field>
    </record>

    <!-- SECURITY RULES -->

    <!-- Bank Transaction Security -->
    <record id="access_bank_transaction_user" model="ir.model.access">
        <field name="name">bank.transaction.user</field>
        <field name="model_id" ref="model_bank_transaction" />
        <field name="group_id" ref="base.group_user" />
        <field name="perm_read" eval="1" />
        <field name="perm_write" eval="1" />
        <field name="perm_create" eval="1" />
        <field name="perm_unlink" eval="1" />
    </record>

    <!-- Bank Account Security -->
    <record id="access_bank_account_user" model="ir.model.access">
        <field name="name">bank.account.user</field>
        <field name="model_id" ref="model_bank_account" />
        <field name="group_id" ref="base.group_user" />
        <field name="perm_read" eval="1" />
        <field name="perm_write" eval="1" />
        <field name="perm_create" eval="1" />
        <field name="perm_unlink" eval="1" />
    </record>

    <!-- Bank Person Security -->
    <record id="access_bank_person_user" model="ir.model.access">
        <field name="name">bank.person.user</field>
        <field name="model_id" ref="model_bank_person" />
        <field name="group_id" ref="base.group_user" />
        <field name="perm_read" eval="1" />
        <field name="perm_write" eval="1" />
        <field name="perm_create" eval="1" />
        <field name="perm_unlink" eval="1" />
    </record>

    <!-- Additional model access rules would go here -->

</odoo>
