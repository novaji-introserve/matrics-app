<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- NFIU Report Tree View -->
        <record id="view_nfiu_indicator_tree" model="ir.ui.view">
            <field name="name">nfiu.indicator.tree</field>
            <field name="model">nfiu.indicator</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name" />
                    <field name="code" />
                    <field name="category" />
                    <field name="write_uid" />
                    <field name="write_date" />
                </tree>
            </field>
        </record>

        <!-- NFIU Report Form View -->
        <record id="view_nfiu_indicator_form" model="ir.ui.view">
            <field name="name">nfiu.indicator.form</field>
            <field name="model">nfiu.indicator</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" placeholder="Name" />
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="code" />
                                
                            </group>
                            <group>
                                <field name="category" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" />
                        <field name="activity_ids" widget="mail_activity" />
                        <field name="message_ids" widget="mail_thread" />
                    </div>
                </form>
            </field>
        </record>

        <!-- NFIU Report Search View -->
        <record id="view_nfiu_indicator_search" model="ir.ui.view">
            <field name="name">nfiu.indicator.search</field>
            <field name="model">nfiu.indicator</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" />
                    <field name="category" />
                    <group expand="0" string="Group By">
                        <filter string="Category" name="group_indicator_category"
                            context="{'group_by': 'category'}" />
                    </group>
                </search>
            </field>
        </record>

        <!-- Action for NFIU Reports -->
        <record id="action_nfiu_indicator" model="ir.actions.act_window">
            <field name="name">NFIU Threshold Indicators</field>
            <field name="res_model">nfiu.indicator</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new NFIU Reporting Indicator
                </p>
            </field>
        </record>
    </data>
</odoo>