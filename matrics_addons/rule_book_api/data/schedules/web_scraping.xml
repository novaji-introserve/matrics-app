        <record id="cron_delete_duplicate_source" model="ir.cron">
            <field name="name">Delete Duplicate regulatory Source or Source without file</field>
            <field name="model_id" ref="model_regulatory_document" />
            <field name="state">code</field>
            <field name="code">model.clean_duplicate_records()</field>
            <field name="active" eval="True" />
