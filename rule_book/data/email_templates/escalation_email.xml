<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="email_template_escalation" model="mail.template">
        <field name="name">Escalation Alert</field>
        <field name="model_id" ref="model_reply_log" />
        <field name="email_from">{{object.data()['email_from']}}</field>
        <field name="email_to">{{object.data()['email_to']}}</field>
        <field name="subject">New Report Submitted:{{object.data()['name']}}</field>
        <field name="body_html" type="html">
            <div>
                <p>Dear Escalation Officer,</p>
                <p>A new report has been submitted for the rulebook <strong>
                        <t
                            t-out="object.data()['name']"></t>
                    </strong>.</p>
                <p>
                    <strong>Description:</strong>
                    <t
                        t-out="object.data()['content']"></t>
                </p>
                <p>Please review the attached document.</p>
                <p>
                    <a
                        t-attf-href="#{object.data()['url_link']}">View Report</a>
                </p>

                <p>Best Regards,<br />Your Compliance Team</p>
            </div>
        </field>
        <field name="auto_delete" eval="False" />
    </record>

</odoo>