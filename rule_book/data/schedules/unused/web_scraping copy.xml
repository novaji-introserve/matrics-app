<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- Cron Job for checking rulebooks and updating due dates -->
        <record id="cron_web_scraping" model="ir.cron">
            <field name="name">Webscrapping For Regulatory document</field>
            <field name="model_id" ref="model_rulebook_title" />
            <field name="state">code</field>
            <field name="code">model.run_webscrapping()</field>
            <field name="active" eval="False" />
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="True" />
            <field name="nextcall"
                eval="(datetime.now().replace(hour=21, minute=0, second=0, microsecond=0))" />
        </record>
