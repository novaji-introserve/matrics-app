<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job for checking rulebooks and updating due dates -->
        <record id="cron_web_scraping" model="ir.cron">
            <field name="name">Webscrapping For Regulatory document</field>
            <field name="model_id" ref="model_external_resource" />
            <field name="state">code</field>
            <field name="code">model.run_webscrapping()</field>
            <field name="active" eval="True" />
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False" />
            <field name="nextcall"
                eval="(datetime.now().replace(hour=22, minute=0, second=0, microsecond=0))" />
        </record>
    </data>
</odoo>