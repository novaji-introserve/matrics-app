    <data>
        <!-- Cron Job for checking rulebook logs and updating due dates -->
        <record id="cron_check_rulebook_and_update_due_date" model="ir.cron">
            <field name="name">Check Rulebook Logs and Update Due Dates</field>
            <field name="model_id" ref="model_reply_log" />
            <field name="state">code</field>
            <field name="code">model.check_rulebook_and_update_due_date()</field>
            <field name="active" eval="True" />
            <field name="interval_type">minutes</field>
            <field name="interval_number">4</field>
            <field name="numbercall">-1</field>
            </record>
    </data>


    <data>
        <!-- Cron Job for checking rulebook logs and sending out emails that are due -->
        <record id="cron_check_rulebook_send_emails" model="ir.cron">
            <field name="name">Send rulebook Internal reminder, regulatory alerts and escalation emails </field>
            <field name="model_id" ref="model_reply_log" />
            <field name="state">code</field>
            <field name="code">model.send_reminder_email()</field>
            <field name="active" eval="True" />
            <field name="interval_type">minutes</field>
            <field name="interval_number">5</field>
            <field name="numbercall">-1</field>
        </record>
    </data>


    <data>
        <!-- Cron Job for Creating rulebook logs entry from rulebook -->
        <record id="_create_rulebook_logs_entry" model="ir.cron">
            <field name="name">Create rulebook logs entry from rulebook</field>
            <field name="model_id" ref="model_rulebook" />
            <field name="state">code</field>
            <field name="code">model._create_rulebook_logs_entry()</field>
            <field name="active" eval="True" />
            <field name="interval_type">days</field>
            <field name="interval_number">30</field>
            <field name="numbercall">-1</field>
        </record>
    </data>

    <data>
        <!-- Define a cron job to clean the 'type_of_return' field -->
        <record id="rulebook_clean_html_cron" model="ir.cron">
            <field name="name">Clean HTML in Type of Return</field>
            <field name="model_id" ref="rule_book.model_rulebook"/>
            <field name="state">code</field>
            <field name="code">model.clean_html_in_type_of_return()</field>         
            <field name="interval_number">5</field>            
            <field name="interval_type">months</field>           
            <field name="numbercall">-1</field>          
            <field name="active">False</field>      
        </record>
    </data>

    <data>
        <!-- Define a cron job to clean the mobile number from hr employee model -->
        <record id="clear_employee_mobile_phone" model="ir.cron">
            <field name="name">Clear Mobile Number From Employee Table</field>
            <field name="model_id" ref="rule_book.model_rulebook"/>
            <field name="state">code</field>
            <field name="code">model.clear_employee_mobile_phone()</field>         
            <field name="interval_number">1</field>            
            <field name="interval_type">days</field>           
            <field name="numbercall">-1</field>          
            <field name="active">False</field>      
        </record>
    </data>

    <data>
        <!-- cron job to update overdue rulebooks logs without reply-->
        <record id="_update_submission_timing" model="ir.cron">
            <field name="name">Update overdue rulebook logs without response</field>
            <field name="model_id" ref="model_reply_log"/>
            <field name="state">code</field>
           <field name="code">model._update_submission_timing()</field>
            <field name="active" eval="True" />
            <field name="interval_type">minutes</field>
            <field name="interval_number">5</field>
            <field name="numbercall">-1</field>
        </record>
    </data>


    <data>
        <!-- cron job to update timezone -->
        <record id="update_time_zone_for_all_users" model="ir.cron">
            <field name="name">Update Timezone for all Users</field>
            <field name="model_id" ref="model_rulebook"/>
            <field name="state">code</field>
            <field name="code">model.update_time_zone_for_all_users()</field>
            <field name="active" eval="False" />
            <field name="interval_type">months</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
        </record>
    </data>

    <data>
        <!-- cron job to clear last internal due date alert -->
        <record id="clear_last_internal_due_date_sent_" model="ir.cron">
            <field name="name">Clear last internal due date </field>
            <field name="model_id" ref="model_reply_log"/>
            <field name="state">code</field>
            <field name="code">model.clear_last_internal_due_date_sent()</field>
            <field name="active" eval="False" />
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
        </record>
    </data>


</odoo>