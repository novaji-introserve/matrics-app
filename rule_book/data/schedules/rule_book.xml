    <data>
        <!-- Cron Job for checking rulebooks and updating due dates -->
        <record id="cron_check_rulebook_and_update_due_date" model="ir.cron">
            <field name="name">Check Rulebooks and Update Due Dates</field>
            <field name="model_id" ref="model_rulebook" />
            <field name="state">code</field>
            <field name="code">model.check_rulebook_and_update_due_date()</field>
            <field name="active" eval="True" />
            <field name="interval_type">minutes</field>
            <field name="interval_number">5</field>
            <field name="numbercall">-1</field>
            <!-- <field name="doall" eval="False" />
            <field name="nextcall"
                eval="(datetime.now().replace(hour=19, minute=0, second=0, microsecond=0))" /> -->
        </record>
    </data>


    <data>
        <!-- Cron Job for checking rulebooks and updating due dates -->
        <record id="cron_check_rulebook_send_emails" model="ir.cron">
            <field name="name">Send Internal reminder, regulatory alerts and escalation emails </field>
            <field name="model_id" ref="model_rulebook" />
            <field name="state">code</field>
            <field name="code">model.send_reminder_email()</field>
            <field name="active" eval="False" />
            <field name="interval_type">minutes</field>
            <field name="interval_number">5</field>
            <field name="numbercall">-1</field>
            <!-- <field name="doall" eval="False" />
            <field name="nextcall" eval="(datetime.now().replace(hour=19, minute=0, second=0, microsecond=0))" /> -->
        </record>
    </data>
    
</odoo>