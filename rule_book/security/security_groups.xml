<?xml version="1.0" encoding="utf-8"?>
<!-- security/security_groups.xml -->
<odoo>
    <data noupdate="0">
        <!-- Create custom category for Rule Book -->
        <record id="module_category_rule_book" model="ir.module.category">
            <field name="name">Rule Book</field>
            <field name="description">Rule Book Access Rights</field>
            <field name="sequence">20</field>
        </record>

        <!-- Base Group for Department Users -->
        <record id="group_department_user" model="res.groups">
            <field name="name">Department User</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Compliance Group with Extended Access -->
        <record id="group_compliance" model="res.groups">
            <field name="name">Compliance</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('group_department_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Department-Specific Groups -->
        <record id="group_alm" model="res.groups">
            <field name="name">ALM</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('group_department_user'))]"/>
        </record>

        <record id="group_it" model="res.groups">
            <field name="name">IT</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('group_department_user'))]"/>
        </record>

        <record id="group_legal_adviser" model="res.groups">
            <field name="name">Legal Adviser</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('group_department_user'))]"/>
        </record>

        <record id="group_cyber_security" model="res.groups">
            <field name="name">Cyber Security</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('group_department_user'))]"/>
        </record>

        <record id="group_hr" model="res.groups">
            <field name="name">HR</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('group_department_user'))]"/>
        </record>

        <record id="group_operations" model="res.groups">
            <field name="name">Operations</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('group_department_user'))]"/>
        </record>

        <record id="group_customer_care" model="res.groups">
            <field name="name">Customer Care</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[(4, ref('group_department_user'))]"/>
        </record>
    </data>
</odoo>

