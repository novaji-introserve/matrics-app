<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Create custom category for Rule Book -->
        <record id="module_category_rule_book" model="ir.module.category">
            <field name="name">Rule Book</field>
            <field name="sequence">200</field>

        </record>

        <!-- Group Users -->
        <record id="group_department_user_" model="res.groups">
            <field name="name">Department User</field>
            <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]" />
            <!-- No implied groups -->
            <field name="category_id" ref="module_category_rule_book"/>
        </record>

        <record id="group_human_resource_" model="res.groups">
            <field name="name">HR Manager</field>
            <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]" />
            <field name="category_id" ref="module_category_rule_book"/>
        </record>

        <record id="group_compliance_manager_" model="res.groups">
            <field name="name">Compliance Manager</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin')),Command.link(ref('rule_book.group_human_resource_'))]"/>
        </record>

        <record id="group_chief_compliance_officer_" model="res.groups">
            <field name="name">Chief Compliance Officer</field>
            <field name="category_id" ref="module_category_rule_book"/>
            <field name="implied_ids" eval="[Command.link(ref('rule_book.group_compliance_manager_'))]"/>
        </record>



        <!-- Record rule for Users to view department members -->
        <record id="res_users_department_view_rule" model="ir.rule">
            <field name="name">Users: View Department Members</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="domain_force">[('employee_ids.department_id', '=', user.employee_ids.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('rule_book.group_department_user_'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record rule for Users to edit only their own record -->
        <record id="res_users_department_user_rule" model="ir.rule">
            <field name="name">Users: Read/Write Own User Record</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="domain_force">[('id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('rule_book.group_department_user_'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


        <!-- Employee Self-Edit Rule -->
        <record id="rule_hr_employee_self_edit" model="ir.rule">
            <field name="name">Employee: Edit Own Record</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('rule_book.group_department_user_'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


        <!-- Employee Read-Only Rule for Department Members -->
        <record id="rule_hr_employee_department_readonly" model="ir.rule">
            <field name="name">Employee: Read-Only Department Members</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[('department_id', '=', user.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('rule_book.group_department_user_'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>



        <!-- Record rule for reporters -->
        <record id="reply_log_reporter_rule" model="ir.rule">
            <field name="name">Reply Log Reporter Rule</field>
            <field name="model_id" ref="model_reply_log"/>
            <field name="domain_force">[('reporter', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('rule_book.group_department_user_'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record rule for department users (read-only access) -->
        <record id="reply_log_read_rule" model="ir.rule">
            <field name="name">Reply Log Read Rule</field>
            <field name="model_id" ref="model_reply_log"/>
            <field name="domain_force">[('department_id', '=', user.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('rule_book.group_department_user_'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>



        <record id="rule_user_full_access" model="ir.rule">
            <field name="name">HR Full Access to Users</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[Command.link(ref('rule_book.group_human_resource_'))]"/>
        </record>

        <record id="rule_employee_full_access" model="ir.rule">
            <field name="name">HR: Full Access to Employees</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[Command.link(ref('rule_book.group_human_resource_'))]"/>

        </record>

        <record id="rule_hr_department_access" model="ir.rule">
            <field name="name">HR: Full Access to Department</field>
            <field name="model_id" ref="hr.model_hr_department"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[Command.link(ref('rule_book.group_human_resource_'))]"/>
        </record>


        <record id="rule_rulebook_full_access" model="ir.rule">
            <field name="name">Compliance and COO: Full Rulebook Access</field>
            <field name="model_id" ref="rule_book.model_rulebook"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
        Command.link(ref('rule_book.group_compliance_manager_')) ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>

        </record>

        <record id="rule_rulebook_log_full_access" model="ir.rule">
            <field name="name">Compliance and COO: Full Rulebook Log Access</field>
            <field name="model_id" ref="rule_book.model_reply_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
        Command.link(ref('rule_book.group_compliance_manager_')) ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

      

     


    </data>
</odoo>