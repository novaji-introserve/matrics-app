<odoo>
    <record id="rulebook_record_rule" model="ir.rule">
        <field name="name">Rulebook Record Rule</field>
        <field name="model_id" ref="model_rulebook" />
        <field name="groups" eval="[(4, ref('rule_book.group_rulebook_viewer'))]" />
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!-- Rulebook Manager access -->
    <record id="action_rulebook" model="ir.actions.act_window">
        <field name="name">RuleBook</field>
        <field name="res_model">rulebook</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="groups_id" eval="[(6, 0, [ref('rule_book.group_rulebook_manager')])]" />
    </record>

    <!-- Rulebook Viewer access -->
    <record id="action_rulebook_view" model="ir.actions.act_window">
        <field name="name">RuleBook (View Only)</field>
        <field name="res_model">rulebook</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="groups_id" eval="[(6, 0, [ref('rule_book.group_rulebook_viewer')])]" />
    </record>

</odoo>