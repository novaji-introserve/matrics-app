<odoo>
  <data>
    <!-- rule book theme -->
    <record id="action_rulebook_theme" model="ir.actions.act_window">
      <field name="name">Rulebook Themes</field>
      <field name="res_model">rulebook.theme</field>
      <field name="view_mode">tree,form</field>
    </record>
    <!-- rule book source -->
    <record id="action_rulebook_sources" model="ir.actions.act_window">
      <field name="name">Rulebook Sources</field>
      <field name="res_model">rulebook.sources</field>
      <field name="view_mode">tree,form</field>
    </record>
    <record id="action_rulebook_title" model="ir.actions.act_window">
      <field name="name">Rulebook Titles</field>
      <field name="res_model">rulebook.title</field>
      <field name="view_mode">tree,form</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          Create your rule book title
        </p>
      </field>
    </record>

    <record id="action_rulebook_department" model="ir.actions.act_window">
      <field name="name">Departments</field>
      <field name="res_model">rulebook.department</field>
      <field name="view_mode">tree,form</field>
    </record>

    <!-- Risk Categories -->
    <record id="action_rulebook_risk_category" model="ir.actions.act_window">
      <field name="name">Risk Categories</field>
      <field name="res_model">rulebook.risk_category</field>
      <field name="view_mode">tree,form</field>
    </record>
    <!-- Exception Processes -->
    <record id="action_rulebook_exception_process" model="ir.actions.act_window">
      <field name="name">Exception Processes</field>
      <field name="res_model">rulebook.exception_process</field>
      <field name="view_mode">tree,form</field>

    </record>
    <!-- Responsible -->
    <record id="action_rulebook_responsible" model="ir.actions.act_window">
      <field name="name">Responsibles</field>
      <field name="res_model">rulebook.responsible</field>
      <field name="view_mode">tree,form</field>
    </record>


    <!-- rule book -->
    <record id="action_rulebook" model="ir.actions.act_window">
      <field name="name">RuleBook</field>
      <field name="res_model">rulebook</field>
      <field name="view_mode">tree,form,kanban</field>
      <field name="context">{"search_default_not_deleted":1}</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          Create your rule book
        </p>
      </field>
    </record>

    <!-- Exception Types -->
    <record id="action_rulebook_exception_type" model="ir.actions.act_window">
      <field name="name">Exception Types</field>
      <field name="res_model">rulebook.exception_type</field>
      <field name="view_mode">tree,form</field>

    </record>

    <!-- Reply log -->
    <record id="action_reply_log" model="ir.actions.act_window">
      <field name="name">Reply Log</field>
      <field name="res_model">reply.log</field>
      <field name="view_mode">tree,form</field>
      <field name="target">current</field>
      <field name="context">{}</field>
      <field name="domain">[]</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          View the Reply Log for your Rule book
        </p>
      </field>
    </record>

    <record id="action_pdf_chat" model="ir.actions.act_window">
      <field name="name">PDF Chat</field>
      <field name="res_model">pdf.chat</field>
      <field name="view_mode">tree,form</field>
    </record>


    <record id="action_cusotomer_details_js" model="ir.actions.client">
      <field name="name">Dashboard</field>
      <field name="tag">rule_book.action_cusotomer_details_js</field>
    </record>


    <!-- Menu Item -->


    <!-- Main Rulebook Menu -->
    <menuitem id="menu_rulebook_theme_root" name="Rulebook" sequence="1" />

    <!-- Submenu for Rulebook Details (Title, Theme, Rulebook, Reply Logs) -->
    <menuitem id="menu_rulebook_details" name="Rulebook" parent="menu_rulebook_theme_root"
      sequence="1" />
    <menuitem id="menu_rulebook_rulebook" name="Rulebook" parent="menu_rulebook_details"
      action="action_rulebook" sequence="1" />
    <menuitem id="menu_rulebook_title" name="Titles" parent="menu_rulebook_details"
      action="action_rulebook_title" sequence="2" />
    <menuitem id="menu_pdf_chat" name="AI Assistance" parent="menu_rulebook_details"
      action="action_pdf_chat" sequence="3" />
    <menuitem id="menu_rulebook_theme" name="Themes" parent="menu_rulebook_details"
      action="action_rulebook_theme" sequence="4" />
    <menuitem id="menu_reply_log" name="Reply Logs" parent="menu_rulebook_details"
      action="action_reply_log" sequence="5" />

    <!-- Submenu for Sources (Regulatory Source and Regulatory Records) -->
    <menuitem id="menu_rulebook_sources_root" name="Sources" parent="menu_rulebook_theme_root"
      sequence="2" />
    <!-- Submenu for Configuration (with Exception Management) -->
    <menuitem id="menu_rulebook_configuration" name="Configuration"
      parent="menu_rulebook_theme_root" sequence="3" />
    <menuitem id="menu_rulebook_responsible" name="Email Group" parent="menu_rulebook_configuration"
      action="action_rulebook_responsible" sequence="4" />
    <menuitem id="menu_rulebook_department" name="Departments" parent="menu_rulebook_configuration"
      action="action_rulebook_department" sequence="8" />
    <menuitem id="menu_rulebook_risk_category" name="Risk Categories"
      parent="menu_rulebook_configuration" action="action_rulebook_risk_category" sequence="7" />

    <!-- Exception Management under Configuration -->
    <menuitem id="menu_rulebook_exception" name="Exception Management"
      parent="menu_rulebook_configuration" sequence="5" />
    <menuitem id="menu_rulebook_exception_process" name="Exception Processes"
      parent="menu_rulebook_exception" action="action_rulebook_exception_process" sequence="6" />
    <menuitem id="menu_rulebook_exception_type" name="Exception Types"
      parent="menu_rulebook_exception" action="action_rulebook_exception_type" sequence="5" />
    <menuitem id="menu_regulatory_sources" name="Regulatory Sources"
      parent="menu_rulebook_configuration" action="action_rulebook_sources" />

    <menuitem
      id="helpdesk_rule_book_dashbaord"
      name="Dashboard"
      parent="menu_rulebook_theme_root"
      action="action_cusotomer_details_js"
      sequence="-1"
    />


    <!-- <record id="action_custom_tree" model="ir.actions.act_window">
      <field name="name">Custom Tree View</field>
      <field name="res_model">custom.tree.model</field>
      <field name="view_mode">tree,form</field>
      <field name="target">current</field>
    </record> -->

    <!-- <menuitem id="menu_custom_tree"
      name="Custom Tree"
      action="action_custom_tree"
      parent="menu_rulebook_theme_root" /> -->

  </data>


</odoo>