<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_branch_tree" model="ir.ui.view">
            <field name="name">rulebook.branch.tree</field>
            <field name="model">rulebook.branch</field>
            <field name="arch" type="xml">
                <tree string="Branches">
                    <field name="name"/>
                    <field name="location"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_branch_form" model="ir.ui.view">
            <field name="name">rulebook.branch.form</field>
            <field name="model">rulebook.branch</field>
            <field name="arch" type="xml">
                <form string="Branch">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="location"/>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_branch" model="ir.actions.act_window">
            <field name="name">Branches</field>
            <field name="res_model">rulebook.branch</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_branch_tree"/>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_branch" name="Branches" action="action_branch" parent="base.menu_custom"/>
    </data>
</odoo>