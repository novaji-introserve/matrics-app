<odoo>
    <!-- Tree view for User Import records -->
    <record id="view_user_import_tree" model="ir.ui.view">
        <field name="name">user.import.tree</field>
        <field name="model">user.import</field>
        <field name="arch" type="xml">
            <tree string="User Import Records">
                <field name="names"/>
                <field name="emails"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- Form view for User Import records -->
    <record id="view_user_import_form" model="ir.ui.view">
        <field name="name">user.import.form</field>
        <field name="model">user.import</field>
        <field name="arch" type="xml">
            <form string="User Import">
                <sheet>
                    <group>
                        <field name="names" widget="text"/>
                        <field name="emails" widget="text"/>
                    </group>
                    <footer>
                        <button string="Import Users" type="object" name="create_or_update_users" class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open the User Import views -->
    <record id="action_user_import" model="ir.actions.act_window">
        <field name="name">User Import</field>
        <field name="res_model">user.import</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <!-- Menu Item to access the User Import action -->
    <menuitem id="menu_user_import" name="User Import" parent="menu_rulebook_configuration" action="action_user_import" sequence="9"/>

</odoo>
