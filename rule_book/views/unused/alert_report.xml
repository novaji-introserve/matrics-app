<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View for the Alert Report -->
    <record id="view_alert_report_form" model="ir.ui.view">
        <field name="name">alert.report.form</field>
        <field name="model">alert.report</field>
        <field name="arch" type="xml">
            <form string="Response Timing Dashboard">
                <sheet>
                    <div class="oe_title">
                        <h1>Response Timing Dashboard</h1>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="chart_container"/>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for the Alert Report -->
    <record id="action_alert_report_window" model="ir.actions.act_window">
        <field name="name">Alert Report</field>
        <field name="res_model">alert.report</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_alert_report_form"/>
        <field name="target">main</field>
    </record>

    <!-- Menu Item for Alerts -->
    <menuitem id="menu_alert_report" name="Alerts" parent="menu_rulebook_details" action="action_alert_report_window" sequence="28"/>
</odoo>