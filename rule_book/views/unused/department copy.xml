<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Department View -->
    <record id="view_department_tree" model="ir.ui.view">
        <field name="name">department.tree</field>
        <field name="model">rulebook.department</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="user_ids" />

            </tree>
        </field>
    </record>

    <record id="view_department_form" model="ir.ui.view">
        <field name="name">department.form</field>
        <field name="model">rulebook.department</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name" />
                    <field name="user_ids" />
                </group>
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div> -->
            </form>
        </field>
    </record>

    <!-- addoimg department id to a new user -->
    <record id="view_users_form" model="ir.ui.view">
        <field name="name">res.users.form.inherit.department</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']" position="inside">
                <group>
                    <field name="department_ids" widget="many2many_tags"
                        options="{'no_create': True}" required="1"
                        help="Every user must be added to at least one department." />
                </group>
            </xpath>
        </field>
    </record>

</odoo>
