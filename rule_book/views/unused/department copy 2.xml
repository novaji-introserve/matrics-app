
<odoo>
    <!-- Branch Form View -->
    <record id="view_branch_form" model="ir.ui.view">
        <field name="name">rulebook.branch.form</field>
        <field name="model">rulebook.branch</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>

                        <group>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="location"/>
                        </group>
                    </group>

                    <!-- Departments Heading and Tree View -->
                    <!-- <h2 class="m-2">Departments</h2>
                    <field name="department_ids">
                        <tree>
                            <field name="name"/>
                            <field name="code"/>
                        </tree>
                    </field> -->
                </sheet>
            </form>
        </field>
    </record>

    <!-- Department Form View -->
    <record id="view_department_form" model="ir.ui.view">
        <field name="name">rulebook.department.form</field>
        <field name="model">rulebook.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="code"/>
                        </group>
                       
                    </group>

                    <!-- Users Heading and Tree View -->
                    <h2 class="m-2">Users</h2>
                    <field name="user_ids">
                        <tree>
                            <field name="name"/>
                            <field name="login"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
</odoo>

