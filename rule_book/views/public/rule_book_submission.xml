<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_submission_template" name="External Submission">
        <!-- <t t-call="website.layout"> -->
        <div class="container">
            <h2>Submit Your Report</h2>
            <form action="/submit_external_report" method="post" enctype="multipart/form-data">
                <input type="hidden" name="rulebook_id" t-att-value="rulebook_id" /> <!-- Hidden
                input for rulebook_id -->
                <div class="form-group">
                    <label for="reply_content">Description</label>
                    <textarea name="reply_content" class="form-control" required="True"></textarea>
                </div>
                <div class="form-group">
                    <label for="reporter">Inputer Name</label>
                    <input type="text" name="reporter" class="form-control" required="True" />
                </div>
                <div class="form-group">
                    <label for="document">Attach Document</label>
                    <input type="file" name="document" class="form-control" required="True" />
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
        <!-- </t> -->
    </template>
</odoo>