<odoo>
    <!-- Alert Log Tree View -->
    <record id="view_keyword_alert_log_tree" model="ir.ui.view">
        <field name="name">keyword.alert.log.tree</field>
        <field name="model">keyword.alert.log</field>
        <field name="arch" type="xml">
            <tree string="Keyword Alerts" create="false">
                <field name="name"/>
                <!-- <field name="create_date"/> -->
                <field name="formatted_alert_date"/>
                <field name="keyword_id"/>
                <!-- <field name="document_id"/> -->
                <!-- <field name="risk_level"/> -->
                <field name="risk_level" widget="badge" decoration-danger="risk_level == 'high'" decoration-warning="risk_level == 'medium'" decoration-info="risk_level == 'low'"/>

                <field name="status"/>
                <field name="officers_alerted" widget="many2many_tags"/>

            </tree>
        </field>
    </record>

    <!-- Alert Log Form View -->
    <record id="view_keyword_alert_log_form" model="ir.ui.view">
        <field name="name">keyword.alert.log.form</field>
        <field name="model">keyword.alert.log</field>
        <field name="arch" type="xml">
            <form string="Keyword Alert">
                <header>
                    <!-- <button name="action_mark_as_read" string="Acknowledge as Read" type="object" class="oe_highlight" attrs="{'invisible': [('status', 'in', ['read'])]}"/> -->
                    <!-- <button name="action_resend_alert" string="Resend Alert" type="object" attrs="{'invisible': [('status', 'not in', ['failed', 'pending'])]}"/> -->
                    <field name="status" widget="statusbar" statusbar_visible="sent,read" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <!-- <field name="keyword_id"/> -->
                            <field name="keyword_id" widget="many2many_tags" readonly="1"/>
                            <!-- <field name="risk_level"/> -->
                            <field name="risk_level" readonly="1" widget="badge"  decoration-danger="risk_level == 'high'" decoration-warning="risk_level == 'medium'" decoration-info="risk_level == 'low'"/>
                            <!-- <field name="create_date"/> -->
                            <field name="formatted_alert_date"/>

                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="document_id" readonly="1"/>
                            <field name="officers_alerted" widget="many2many_tags" readonly="1"/>
                        </group>
                    </group>
                    <!-- <group>
                            <field name="match_text" string="Matched Context"/>
                    </group> -->
                    <group>
                            <field name="ai_analysis" readonly="1" />
                            
                    </group>
                   
                </sheet>
                
                <div class="oe_chatter">
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Alert Log Search View -->
    <record id="view_keyword_alert_log_search" model="ir.ui.view">
        <field name="name">keyword.alert.log.search</field>
        <field name="model">keyword.alert.log</field>
        <field name="arch" type="xml">
            <search string="Search Keyword Alerts">
                <field name="name"/>
                <field name="keyword_id"/>
                <field name="document_id"/>
                <field name="officers_alerted"/>
                <filter string="High Risk" name="high_risk" domain="[('risk_level', '=', 'high')]"/>
                <filter string="Medium Risk" name="medium_risk" domain="[('risk_level', '=', 'medium')]"/>
                <filter string="Low Risk" name="low_risk" domain="[('risk_level', '=', 'low')]"/>
                <separator/>
                <filter string="Sent" name="status_sent" domain="[('status', '=', 'sent')]"/>
                <filter string="Read" name="status_read" domain="[('status', '=', 'read')]"/>
                <separator/>
                <filter string="My Alerts" name="my_alerts" domain="[('officers_alerted', 'in', uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Keyword" name="group_by_keyword" context="{'group_by': 'keyword_id'}"/>
                    <filter string="Document" name="group_by_document" context="{'group_by': 'document_id'}"/>
                    <filter string="Risk Level" name="group_by_risk" context="{'group_by': 'risk_level'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    <filter string="Alert Date" name="group_by_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Alert Log Calendar View -->
    <record id="view_keyword_alert_log_calendar" model="ir.ui.view">
        <field name="name">keyword.alert.log.calendar</field>
        <field name="model">keyword.alert.log</field>
        <field name="arch" type="xml">
            <calendar string="Keyword Alerts" date_start="create_date" color="risk_level" mode="month">
                <field name="name"/>
                <field name="keyword_id"/>
                <field name="document_id"/>
                <field name="status"/>
            </calendar>
        </field>
    </record>

    

    <!-- Alert Log Action Window -->
    <record id="action_keyword_alert_log" model="ir.actions.act_window">
        <field name="name">Keyword Alerts</field>
        <field name="res_model">keyword.alert.log</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="search_view_id" ref="view_keyword_alert_log_search"/>
        <field name="context">{'search_default_status_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No keyword alerts found
            </p>
            <p>
                Keyword alerts are created automatically when keywords are found in new regulatory documents.
            </p>
        </field>
    </record>

    <!-- Add menu item for Alert Log -->

    <menuitem id="menu_keyword_alert_log" name="Keyword Logs" parent="menu_rulebook_details" action="action_keyword_alert_log" sequence="50"/>
</odoo>