<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_rulebook_keyword_tree" model="ir.ui.view">
        <field name="name">regulatory.alert.tree</field>
        <field name="model">regulatory.alert</field>
        <field name="arch" type="xml">
            <tree string="Regulatory Alert">
                <field name="alert_officers" widget="many2many_tags" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_rulebook_keyword_form" model="ir.ui.view">
        <field name="name">regulatory.alert.form</field>
        <field name="model">regulatory.alert</field>
        <field name="arch" type="xml">
            <form string="Regulatory Alert Officers">
                <sheet>
                    
                    <group>
                        
                            <field name="alert_officers" widget="many2many_tags" help="Officer(s) to get alerted for new regulatory documents"/>
                    </group>
                    <group>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <!-- Action -->
    <record id="action_reg_alert" model="ir.actions.act_window">
        <field name="name">Regulatory Alert</field>
        <field name="res_model">regulatory.alert</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create regulatory alert officer(s)
            </p>
            <p>
                Define alert officers for regulatory documents.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_reg_alert" name="Regulatory Alert" parent="menu_rulebook_configuration" action="action_reg_alert" sequence="18"/>


</odoo>
    
