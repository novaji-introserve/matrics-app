<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_rulebook_keyword_tree" model="ir.ui.view">
        <field name="name">keyword.tracking.tree</field>
        <field name="model">keyword.tracking</field>
        <field name="arch" type="xml">
            <tree string="Tracking Keywords">
                <field name="name"/>
                <field name="code"/>
               <field name="risk_level" widget="badge" decoration-danger="risk_level=='high'" decoration-warning="risk_level=='medium'" decoration-success="risk_level=='low'"/>
                <field name="assigned_officers" widget="many2many_tags" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_rulebook_keyword_form" model="ir.ui.view">
        <field name="name">keyword.tracking.form</field>
        <field name="model">keyword.tracking</field>
        <field name="arch" type="xml">
            <form string="Tracking Keyword">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Keyword Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                           <field name="risk_level"/>
                        </group>
                        <group>
                            <field name="assigned_officers" widget="many2many_tags" help="Officer(s) to get alerted if keyword is found"/>
                        </group>
                    </group>
                    <group>
                    <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_rulebook_keyword_search" model="ir.ui.view">
        <field name="name">keyword.tracking.search</field>
        <field name="model">keyword.tracking</field>
        <field name="arch" type="xml">
            <search string="Search Tracking Keywords">
                <field name="name"/>
                <field name="code"/>
                <field name="assigned_officers"/>
                <filter string="High Risk" name="high_risk" domain="[('risk_level', '=', 'high')]"/>
                <filter string="Medium Risk" name="medium_risk" domain="[('risk_level', '=', 'medium')]"/>
                <filter string="Low Risk" name="low_risk" domain="[('risk_level', '=', 'low')]"/>
                <group expand="0" string="Group By">
                    <filter string="Risk Level" name="group_by_risk" context="{'group_by': 'risk_level'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_rulebook_keyword" model="ir.actions.act_window">
        <field name="name">Tracking Keywords</field>
        <field name="res_model">keyword.tracking</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first tracking keyword
            </p>
            <p>
                Define keywords for tracking deliverable with associated risk levels.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_keyword_tracking" name="Tracking Keywords" parent="menu_rulebook_configuration" action="action_rulebook_keyword" sequence="16"/>


</odoo>
    
