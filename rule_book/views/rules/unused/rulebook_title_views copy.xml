<odoo>
    <record id="view_rulebook_title_tree" model="ir.ui.view">
        <field name="name">rulebook.title.tree</field>
        <field name="model">rulebook.title</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="file_name" />
                <field name="released_date" />

                <field name="source_id" />
                <field name="created_on" optional="hide" />
                <field name="created_by" optional="hide" />
                <field name="input_type" widget='badge'
                    decoration-info="input_type=='ai'"
                    decoration-primary="input_type == 'manual'"
                />
                
                <field name="status" widget='badge'
                    decoration-success="status=='active'"
                    decoration-muted="status == 'inactive'"
                    decoration-danger="status == 'deleted'"
                />
            </tree>
        </field>
    </record>

    <record id="view_rulebook_title_form" model="ir.ui.view">
        <field name="name">rulebook.title.form</field>
        <field name="model">rulebook.title</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="row">
                        <div class="col-md-6">
                            <group>
                                <field name="name" />
                                <field name="ref_number" />
                                <field name="released_date" />

                                <field name="source_id" />
                                <field name="created_by" readonly="1" />
                                <field name="external_resource_url" readonly="1" />
                                <field name="input_type" widget='badge' readonly="1"
                                    decoration-info="input_type=='ai'"
                                    decoration-primary="input_type == 'manual'"
                                />

                            </group>
                            <group>
                                <field name="created_on" readonly="1" />
                                <field name="status" />
                            </group>
                        </div>
                        <div class="col-md-6">
                            <group>
                                <field name="file" filename="file_name" widget="pdf_viewer"
                                    options="{'preview_image': 'file'}" />
                            </group>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_rulebook_title_search_" model="ir.ui.view">
        <field name="name">rulebook.title.search</field>
        <field name="model">rulebook.title</field>
        <field name="arch" type="xml">
            <search string="Rulebook Source">
                <field name="name" />
                <field name="status" />
                <field name="source_id" />
                <group expand="1" string="Group By">
                    <filter string="Created By" name="created_by" />
                    <filter string="Source" name="source_id" />
                    <filter string="Status" name="status" />
                </group>
                <searchpanel>
                  
                    <field name="source_id" icon="fa-cog" enable_counters="1" string="Source" />
                    <field name="input_type" icon="fa-user-tie" enable_counters="1" string="Input Type" />
                    <field name="status" icon="fa-check" enable_counters="1" string="Status" />
                </searchpanel>
            </search>
        </field>
    </record>

</odoo>