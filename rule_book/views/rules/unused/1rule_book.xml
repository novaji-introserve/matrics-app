<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_rulebook_tree" model="ir.ui.view">
            <field name="name">rulebook.tree</field>
            <field name="model">rulebook</field>
            <field name="arch" type="xml">
                <tree string="Rulebooks" decoration-danger="status=='inactive'" decoration-muted="status=='deleted'">
                    <field name="name"/>
                    <field name="risk_rating" widget="badge" decoration-danger="risk_rating == 'critical'" decoration-warning="risk_rating == 'medium'" decoration-info="risk_rating == 'low'"/>
                    <field name="risk_category"/>
                    <field name="frequency_type"/>
                    <field name="start_date"/>
                    <field name="computed_date" string="Next Due Date"/>
                    <field name="responsible_id"/>
                    <field name="status" widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_rulebook_form" model="ir.ui.view">
            <field name="name">rulebook.form</field>
            <field name="model">rulebook</field>
            <field name="arch" type="xml">
                <form string="Rulebook">
                    <header>
                        <field name="status" widget="statusbar" options="{'clickable': '1'}" statusbar_visible="active,inactive,deleted"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <!-- Add action buttons here if needed -->
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Rulebook Title"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="theme_id"/>
                                <field name="risk_rating" widget="radio"/>
                                <field name="risk_category"/>
                                <field name="type_of_return"/>
                            </group>
                            <group>
                                <field name="regulatory_agency_id"/>
                                <field name="responsible_id"/>
                                <field name="section"/>
                            </group>
                        </group>

                        <notebook>
                            <!-- Frequency & Dates Tab -->
                            <page string="Schedule" name="schedule">
                                <group>
                                    <group string="Frequency Configuration">
                                        <field name="frequency_type" widget="radio"/>
                                        <field name="is_recurring" invisible="1"/>

                                        <!-- Custom Interval Fields -->
                                        <field name="custom_interval" attrs="{'invisible': [('frequency_type', '!=', 'custom')],
                                                      'required': [('frequency_type', '=', 'custom')]}"/>
                                        <field name="custom_interval_type" attrs="{'invisible': [('frequency_type', '!=', 'custom')],
                                                      'required': [('frequency_type', '=', 'custom')]}"/>
                                    </group>

                                    <group string="Date Configuration">
                                        <field name="start_date"/>
                                        <field name="end_date"/>
                                        <field name="exclude_holidays"/>
                                    </group>
                                </group>

                                <!-- Monthly Schedule Configuration -->
                                <group string="Monthly Schedule Details" attrs="{'invisible': [('frequency_type', 'not in', ['monthly', 'quarterly', 'semi_annual'])]}">
                                    <group>
                                        <field name="specific_day" attrs="{'invisible': [('specific_weekday', '!=', False)]}"/>
                                        <field name="specific_weekday"/>
                                        <field name="specific_week" attrs="{'invisible': [('specific_weekday', '=', False)],
                                                      'required': [('specific_weekday', '!=', False)]}"/>
                                    </group>
                                </group>

                                <!-- Computed Next Date -->
                                <group string="Next Occurrences" attrs="{'invisible': [('frequency_type', '=', 'once')]}">
                                    <field name="computed_date" readonly="1"/>
                                </group>
                            </page>

                            <!-- Escalation Tab -->
                            <page string="Escalation" name="escalation">
                                <group>
                                    <group string="Due Dates">
                                        <field name="internal_due_date_value"/>
                                        <field name="internal_due_date_unit"/>
                                        <field name="internal_due_date" readonly="1"/>
                                    </group>
                                    <group string="Escalation Configuration">
                                        <field name="escalation_date_value"/>
                                        <field name="escalation_date_unit"/>
                                        <field name="escalation_date" readonly="1"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Escalation Contacts">
                                        <field name="first_line_escalation"/>
                                        <field name="second_line_escalation"/>
                                    </group>
                                    <group string="Additional Contacts">
                                        <field name="officers_responsible" widget="many2many_tags"/>
                                    </group>
                                </group>
                            </page>

                            <!-- Details Tab -->
                            <page string="Details" name="details">
                                <group>
                                    <field name="description" nolabel="1" placeholder="Enter detailed description..."/>
                                </group>
                                <group string="Sanctions">
                                    <field name="sanction" nolabel="1" placeholder="Specify sanctions..."/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <!-- Chatter -->
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_rulebook_search" model="ir.ui.view">
            <field name="name">rulebook.search</field>
            <field name="model">rulebook</field>
            <field name="arch" type="xml">
                <search string="Search Rulebooks">
                    <field name="name"/>
                    <field name="risk_category"/>
                    <field name="responsible_id"/>
                    <field name="regulatory_agency_id"/>
                    <separator/>
                    <filter string="Active" name="active" domain="[('status', '=', 'active')]"/>
                    <filter string="Inactive" name="inactive" domain="[('status', '=', 'inactive')]"/>
                    <filter string="Critical Risk" name="critical_risk" domain="[('risk_rating', '=', 'critical')]"/>
                    <separator/>
                    <filter string="Due This Week" name="due_this_week" domain="[('computed_date', '&gt;=', context_today().strftime('%Y-%m-%d')),
                                    ('computed_date', '&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                    <filter string="Overdue" name="overdue" domain="[('computed_date', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                    <group expand="0" string="Group By">
                        <filter string="Risk Rating" name="group_risk_rating" context="{'group_by': 'risk_rating'}"/>
                        <filter string="Risk Category" name="group_risk_category" context="{'group_by': 'risk_category'}"/>
                        <filter string="Frequency" name="group_frequency" context="{'group_by': 'frequency_type'}"/>
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="Responsible" name="group_responsible" context="{'group_by': 'responsible_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Calendar View -->
        <record id="view_rulebook_calendar" model="ir.ui.view">
            <field name="name">rulebook.calendar</field>
            <field name="model">rulebook</field>
            <field name="arch" type="xml">
                <calendar string="Rulebook Calendar" date_start="computed_date" color="risk_rating" quick_add="0" mode="month">
                    <field name="name"/>
                    <field name="risk_rating"/>
                    <field name="responsible_id"/>
                </calendar>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_rulebook_kanban" model="ir.ui.view">
            <field name="name">rulebook.kanban</field>
            <field name="model">rulebook</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="risk_rating"/>
                    <field name="computed_date"/>
                    <field name="responsible_id"/>
                    <field name="status"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_record_subtitle">
                                        <field name="risk_rating" widget="label_selection" options="{'classes': {'low': 'success', 'medium': 'warning', 'critical': 'danger'}}"/>
                                    </div>
                                    <div>
                                        <strong>Next Due:</strong>
                                        <field name="computed_date"/>
                                    </div>
                                    <div>
                                        <strong>Responsible:</strong>
                                        <field name="responsible_id"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Action -->
        <record id="action_rulebook" model="ir.actions.act_window">
            <field name="name">Rulebooks</field>
            <field name="res_model">rulebook</field>
            <field name="view_mode">kanban,tree,form,calendar</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first rulebook
                </p>
                <p>
                    Create and manage your regulatory rulebooks with detailed scheduling and tracking.
                </p>
            </field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_rulebook_root" name="Rulebooks" sequence="10"/>

        <menuitem id="menu_rulebook_main" name="Rulebooks" parent="menu_rulebook_root" action="action_rulebook" sequence="1"/>
    </data>
</odoo>