<odoo>
    <!-- Tree View -->
    <record id="view_rulebook_sources_tree" model="ir.ui.view">
        <field name="name">rulebook.sources.tree</field>
        <field name="model">rulebook.sources</field>
        <field name="arch" type="xml">
            <tree string="Rulebook Sources">
                <field name="name" />
                <field name="url_link" />
                <field name="create_uid" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_rulebook_sources_form" model="ir.ui.view">
        <field name="name">rulebook.sources.form</field>
        <field name="model">rulebook.sources</field>
        <field name="arch" type="xml">
            <form string="Rulebook Source">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="description" />
                        <field name="url_link" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <!-- <record id="view_rulebook_sources_search" model="ir.ui.view">
