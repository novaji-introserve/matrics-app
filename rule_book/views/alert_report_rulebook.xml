<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_report_rulebook_tree" model="ir.ui.view">
            <field name="name">report.rulebook.tree</field>
            <field name="model">report.rulebook</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="user_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_report_rulebook_form" model="ir.ui.view">
            <field name="name">report.rulebook.form</field>
            <field name="model">report.rulebook</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_submit" string="Submit" type="object" states="draft" class="oe_highlight"/>
                        <button name="action_approve" string="Approve" type="object" states="submitted" groups="rule_book.group_compliance_officer" class="oe_highlight"/>
                        <button name="action_draft" string="Set to Draft" type="object" states="submitted,approved"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="user_id"/>
                            <field name="content"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <!-- <field name="message_follower_ids"/> -->
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_report_rulebook_search" model="ir.ui.view">
            <field name="name">report.rulebook.search</field>
            <field name="model">report.rulebook</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="user_id"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_report_rulebook" model="ir.actions.act_window">
            <field name="name">Reports</field>
            <field name="res_model">report.rulebook</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first report
                </p>
            </field>
        </record>
    </data>
</odoo>
