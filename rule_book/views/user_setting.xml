<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_access_rights_restricted" model="ir.ui.view">
        <field name="name">res.users.form.access.rights.restricted</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Method 1: Add groups attribute to the entire page -->

            <xpath expr="//div[@name='button_box']" position="attributes">
                <attribute name="groups">rule_book.group_chief_compliance_officer_</attribute>

            </xpath>
            <xpath expr="//page[@name='access_rights']" position="attributes">
                <attribute name="groups">rule_book.group_chief_compliance_officer_</attribute>
            </xpath>

        </field>
    </record>

    <!-- Inherit the hr.employee form and hide some page sections -->
    <record id="employee_custom_view_inherited" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">

            <!-- Hide the Work Information Section (Page "public") -->
            <xpath expr="//page[@name='public']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the Personal Information Section (Page "personal_information") -->
            <xpath expr="//page[@name='personal_information']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Hide job_id field -->
            <xpath expr="//field[@name='job_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide parent_id field -->
            <xpath expr="//field[@name='parent_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='coach_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='mobile_phone']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='work_phone']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//group[@name='identification_group']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//header//button[@name='149']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>


        </field>
    </record>


    <record id="your_custom_view_inherited" model="ir.ui.view">
        <field name="name">base.settings.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- Hide the 'Users' Section -->
            <xpath expr="//div[@id='invite_users']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'emails' Section -->
            <xpath expr="//div[@id='emails']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'user_default_rights' Section -->
            <xpath expr="//div[@id='user_default_rights']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'integration' Section -->
            <xpath expr="//div[@name='integration']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'performance' Section -->
            <xpath expr="//div[@name='performance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'companies' Section -->
            <xpath expr="//div[@id='companies']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'contact' Section -->
            <xpath expr="//div[@id='contacts_settings']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'active_user_setting' Section -->
            <xpath expr="//div[@id='active_user_setting']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'mail_templates_setting' Section -->
            <xpath expr="//div[@id='mail_templates_setting']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Hide the 'iap' portal Section -->
            <xpath expr="//div[@id='iap_portal']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'about' portal Section -->
            <xpath expr="//div[@id='about']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'product_get_pic_setting' portal Section -->
            <xpath expr="//div[@id='product_get_pic_setting']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'gmail_client_secret' portal Section -->
            <xpath expr="//div[@id='gmail_client_secret']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'res_config_dev_tool' widget -->
            <xpath expr="//widget[@name='res_config_dev_tool']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'res_config_edition' widget -->
            <xpath expr="//widget[@name='res_config_edition']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

        </field>
    </record>



</odoo>