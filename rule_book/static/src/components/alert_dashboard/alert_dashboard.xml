<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="AlertDashboard" owl="1">
        <div class="vh-100 overflow-auto bg-muted">
            <div class="row m-3">
                <div class="col-lg-12">
                    <div class="row">
                        <div class="col m-0 p-0">
                            <div class="shadow-sm border m-2 p-2 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h2 class="text-primary fw-bold">Alert Dashboard</h2>
                                    <div>
                                        <select class="form-select" t-model="state.period" t-on-change="OnChangePeriod">
                                            <option value="0">Select Period</option>
                                            <option value="7">Last 7 Days</option>
                                            <option value="30">Last 30 Days</option>
                                            <option value="90">Last 90 Days</option>
                                            <option value="365">Last 365 Days</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-2 m-0 p-0">
                            <div class="shadow-sm border m-2 p-2 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h6 class="text-primary fw-bold">Alert Responses</h6>

                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <KpiCard onClick.bind="viewEarlyReply" name="'Early Submission'" value="state.earlyReply.value" />
                        <!-- <KpiCard name="'Right on Time'" value="20" percentage="20"/> -->
                        <KpiCard onClick.bind="viewLateReply" name="'Late Submission'" value="state.lateReply.value" />
                        <KpiCard onClick.bind="viewNoReply" name="'Not Responded'" value="state.noReply.value"/>
                        <KpiCard onClick.bind="viewPendingReply" name="'Pending'" value="state.pendingReply.value"/>
                    </div>

                    <div class="row">
                        <div class="col-2 m-0 p-0">
                            <div class="shadow-sm border m-2 p-2 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h6 class="text-primary fw-bold">Alert Status</h6>
                                    
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <KpiCard onClick.bind="viewCompleted" name="'Completed '" value="state.completed.value" />
                        <!-- <KpiCard name="'Right on Time'" value="20" percentage="20"/> -->
                        <KpiCard onClick.bind="viewReviewed" name="'Reviewed'" value="state.reviewed.value" />
                        <KpiCard onClick.bind="viewSubmitted" name="'Submitted'" value="state.submitted.value"/>
                        <KpiCard onClick.bind="viewPending" name="'Pending'" value="state.pending.value" />
                    </div>

                    <div class="row">
                        <div class="col-lg-6 m-0 p-0">
                            <div class="shadow-sm border m-2 p-4 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h3 class="text-primary fw-bold">Rulebook Responses</h3>
                                    <div class="px-3 py-1 bg-primary cursor-pointer">
                                        <span class="fa fa-arrow-right text-white"/>
                                    </div>
                                </div>
                                <div style="width:100% !important; margin-top:10px !important;" >
                                    <ChartRenderer type="'line'" title="'Response Timing Report'" config="state.ResponseTiming"  />

                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 m-0 p-0">
                            <div class="shadow-sm border m-2 p-4 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h3 class="text-primary fw-bold mb-2">Rulebook Status</h3>
                                    <div class="px-3 py-1 bg-primary cursor-pointer">
                                        <span class="fa fa-arrow-right text-white"/>
                                    </div>
                                </div>
                                <div style="width:100% !important; margin-top:10px !important;">
                                    <ChartRenderer type="'bar'" title="'Status Report'" config="state.RulebookState" />

                                </div>
                            </div>
                        </div>

                    </div>
                </div>
