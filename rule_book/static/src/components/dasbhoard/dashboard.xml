									<t t-if="state.mostAskedQuestion.length === 0">
										<div class="alert alert-light">
                No questions have been asked yet.
										</div>
									</t>
									<t t-else="">
										<!-- Loop through the list of questions and their counts -->
										<div class="card-body pt-4" style="max-height: 300px; overflow-y: auto;">
											<ul class="p-0 m-0">
												<t t-foreach="state.mostAskedQuestion" t-as="question" t-key="question.question">
													<t t-set="index" t-value="state.mostAskedQuestion.indexOf(question)" />
													<li class="d-flex align-items-center mb-2">
														<!-- Circular container for the count -->
														<div class=" flex-shrink-0 me-3" t-att-style="'opacity: ' + (1 - (index / state.mostAskedQuestion.length))">
															<div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
																<span class="fw-bold">
																	<t t-esc="question.count" />
																</span>
															</div>
														</div>

														<!-- Display question -->
														<div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
															<div class="me-2">
																<div class="mb-1">
																	<small class="text-muted">
                                            Question:
																	</small>
																	<h6 class="fw-bold mb-0">
																		<t t-esc="question.question" />
																	</h6>
																</div>
															</div>
														</div>
													</li>
												</t>
											</ul>
										</div>
									</t>
								</div>
							</div>


						</div>



					</div>
				</div>
				<div class="layout-overlay layout-menu-toggle">
				</div>
			</div>
			<script src="rule_book/static/assets/vendor/js/bootstrap.js">
			</script>

			<!-- <script src="rule_book/static/assets/vendor/js/menu.js"></script> -->
			<!-- endbuild -->
