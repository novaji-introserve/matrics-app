<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl.AlertDashboard" owl="1">
        <div class="o_alert_dashboard vh-100 overflow-auto bg-muted">
            <!-- Header section (like Compliance, but with text) -->
            <div class="col-12">
                <div class="col-12 m-0 p-0">
                    <div class="o_alert_dashboard_header d-flex bg-white rounded shadow px-4 shadow-1 justify-content-between align-items-center">
                        <div class="flex-grow-1 me-3">
                            <h2 class="o_alert_dashboard_title m-0 fw-bold text-danger">Alert Management System</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="container-fluid o_alert_dashboard_content">
                <div class="row second-section mb-4 g-md-5 justify-content-between align-items-center">
                    <div class="position-relative card-container">
                        <!-- Loading: placeholder cards like Compliance -->
                        <t t-if="state.loading">
                            <div class="d-flex flex-nowrap overflow-auto">
                                <t t-foreach="[1,2,3,4,5,6,7,8]" t-as="placeholder" t-key="placeholder">
                                    <div class="px-4 py-2 mx-2 box shadow bg-white position-relative">
                                        <h2 class="my-3 fs-1 placeholder-glow">
                                            <span class="placeholder col-8"></span>
                                        </h2>
                                        <p class="text-muted text-capitalize fs-3 placeholder-glow">
                                            <span class="placeholder col-6"></span>
                                        </p>
                                        <div class="text-uppercase fw-bold text-center bg-dark text-white fs-6 position-absolute catbox">
                                            <p>--</p>
                                        </div> 
                                    </div>
                                </t>
                            </div>
                        </t>
                        <!-- Dynamic cards: one per statistic (like Compliance) -->
                        <t t-else="">
                            <t t-if="state.stats.length > 0">
                                <div class="d-flex flex-nowrap overflow-auto pb-2">
                                    <t t-foreach="state.stats" t-as="stat" t-key="stat.id">
                                        <div class="px-4 py-2 mx-2 box cursor-pointer shadow bg-white position-relative"
                                             t-on-click="() => this.openCardView(stat)" role="button">
                                            <h2 class="my-3 fs-1" t-out="stat.val"/>
                                            <p class="text-muted text-capitalize fs-3 mb-0" t-out="stat.name"/>
                                            <div class="text-uppercase fw-bold text-center bg-dark text-white fs-6 position-absolute catbox">
                                                <p t-out="this.scopeLabel(stat.scope)"/>
                                            </div>
                                        </div>                                        
                                    </t>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="bg-white rounded shadow-sm p-5 text-center">
                                    <h4 class="text-muted">No statistics yet</h4>
                                    <p class="small text-muted mb-3">Go to <strong>Alerts → Configurations → Statistics</strong>, create statistics and click <strong>Compute</strong> (or run the script) to see cards here.</p>
                                    <button class="btn btn-primary" t-on-click="() => this.openStatisticsList()">Open Statistics</button>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>

                <!-- Chart section (below cards, like Compliance dashboard) -->
                <div class="row mt-4 mb-4">
                    <div class="col-12">
                        <div class="o_alert_dashboard_chart_card bg-white rounded shadow-sm p-3">
                            <h6 class="fw-bold text-capitalize text-dark mb-3">Alert Statistics Overview</h6>
                            <div class="o_alert_dashboard_chart_wrap position-relative">
                                <t t-if="state.stats.length === 0">
                                    <div class="o_alert_dashboard_chart_empty d-flex align-items-center justify-content-center">
                                        <p class="text-muted mb-0">Add statistics above to see the chart.</p>
                                    </div>
                                </t>
                                <t t-else="">
                                    <canvas t-ref="chartCanvas" class="o_alert_dashboard_canvas"></canvas>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
