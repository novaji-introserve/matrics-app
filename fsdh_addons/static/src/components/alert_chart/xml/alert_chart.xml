<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl.AlertChart" owl="1">
        <div class="o_alert_chart_page vh-100 overflow-auto bg-light">
            <!-- Page header (own page title) -->
            <div class="o_alert_chart_header d-flex bg-white rounded shadow-sm px-4 py-3 mb-3 align-items-center">
                <h2 class="o_alert_chart_title m-0 fw-bold text-danger">Alert Statistics – Chart</h2>
            </div>

            <div class="container-fluid">
                <!-- Loading state -->
                <t t-if="state.loading">
                    <div class="o_alert_chart_loading d-flex justify-content-center align-items-center bg-white rounded shadow-sm p-5">
                        <div class="d-flex flex-column align-items-center">
                            <div class="spinner-border text-primary mb-2" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <span>Loading chart data...</span>
                        </div>
                    </div>
                </t>

                <!-- Error state -->
                <t t-elif="state.error">
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <span t-out="state.error"/>
                    </div>
                </t>

                <!-- Empty state: no statistics -->
                <t t-elif="state.stats.length === 0">
                    <div class="o_alert_chart_empty bg-white rounded shadow-sm p-5 text-center">
                        <p class="text-muted mb-3">No statistics yet. Add statistics under <strong>Alerts → Configurations → Statistics</strong> and run <strong>Compute</strong> (or the batch script) to see the chart.</p>
                        <button class="btn btn-primary" t-on-click="() => this.openStatisticsList()">Open Statistics</button>
                    </div>
                </t>

                <!-- Chart container (compliance-style: fixed height, loading overlay, canvas) -->
                <t t-else="">
                    <div class="o_alert_chart_card bg-white rounded shadow-sm p-3">
                        <h6 class="fw-bold text-capitalize text-dark mb-3">Alert Statistics Overview</h6>
                        <div class="o_alert_chart_container position-relative" style="width: 100%; height: 44vh;">
                            <!-- Initializing overlay (progressive load) -->
                            <div t-if="state.isInitializing" class="position-absolute top-0 start-0 end-0 bottom-0 d-flex justify-content-center align-items-center bg-white bg-opacity-75" style="z-index: 10;">
                                <div class="d-flex flex-column align-items-center">
                                    <div class="spinner-border text-primary mb-2" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <span>Initializing chart...</span>
                                </div>
                            </div>
                            <!-- Loading animation progress (progressive) -->
                            <div t-if="state.isAnimating" class="position-absolute bottom-0 start-0 end-0 p-2 bg-white bg-opacity-75" style="z-index: 10;">
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"
                                         t-attf-style="width: {{ state.totalElements > 0 ? (state.loadedElements / state.totalElements) * 100 : 0 }}%"/>
                                </div>
                            </div>
                            <canvas t-ref="alert_chart_canvas" class="o_alert_chart_canvas" style="width: 100%; height: 100%; display: block; margin: auto;"/>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
