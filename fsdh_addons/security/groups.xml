<odoo noupdate="0">
  

    <!-- Category – becomes the dropdown LABEL on the Users form -->
    <record model="ir.module.category" id="module_category_subsidiaries">
      <field name="name">Subsidiaries</field>
      <field name="sequence">55</field>
      <field name="visible" eval="False"/>
    </record>

    <!-- Level 1 (lowest): BUSINESS CONTROL -->
    <record id="group_subsidiary_fsdh_capital" model="res.groups">
      <field name="name">Business Control</field>
      <field name="active" eval="True"/>
      <field name="share" eval="False"/>
      <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
      <field name="category_id" ref="module_category_subsidiaries"/>
    </record>

    <!-- Level 2: IT CONTROL – implies BUSINESS CONTROL -->
    <record id="group_subsidiary_fsdh_asset_mgt" model="res.groups">
      <field name="name">IT Control</field>
      <field name="active" eval="True"/>
      <field name="share" eval="False"/>
      <field name="implied_ids" eval="[Command.link(ref('base.group_user')), Command.link(ref('group_subsidiary_fsdh_capital'))]"/>
      <field name="category_id" ref="module_category_subsidiaries"/>
    </record>

    <!-- Level 3: FSDH CAPITAL – implies IT CONTROL -->
    <record id="group_subsidiary_business_control" model="res.groups">
      <field name="name">Fsdh Capital</field>
      <field name="active" eval="True"/>
      <field name="share" eval="False"/>
      <field name="implied_ids" eval="[Command.link(ref('base.group_user')), Command.link(ref('group_subsidiary_fsdh_asset_mgt'))]"/>
      <field name="category_id" ref="module_category_subsidiaries"/>
    </record>

    <!-- Level 4 (highest): FSDH ASSET MGT – implies FSDH CAPITAL -->
    <record id="group_subsidiary_it_control" model="res.groups">
      <field name="name">Fsdh Asset Mgt</field>
      <field name="active" eval="True"/>
      <field name="share" eval="False"/>
      <field name="implied_ids" eval="[Command.link(ref('base.group_user')), Command.link(ref('group_subsidiary_business_control'))]"/>
      <field name="category_id" ref="module_category_subsidiaries"/>
    </record>
</odoo>
