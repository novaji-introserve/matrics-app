<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="email_template_escalation" model="mail.template">
        <field name="name">Alert Escalation Notification</field>
        <field name="model_id" ref="alert_management.model_alert_history"/>
        <field name="subject">[ESCALATION Level {{ ctx.get('step').sequence }}] UNRESOLVED: {{ object.name }}</field>
        <field name="email_to">{{ ctx.get('step').recipient_email }}</field>
        <field name="description">Template for escalated alerts</field>
        <field name="body_html" type="html">
            <div style="font-family: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #f4f7f6; padding: 2rem; color: #333333;">
                <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); overflow: hidden; border-top: 5px solid #dc2626;">
                    
                    <!-- Header -->
                    <div style="background-color: #fef2f2; padding: 1.5rem; text-align: center; border-bottom: 1px solid #fee2e2;">
                        <span style="font-size: 24px; font-weight: bold; color: #b91c1c;">Alert Escalation Notice</span>
                        <div style="margin-top: 0.5rem;">
                            <span style="background-color: #dc2626; color: white; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 14px; font-weight: 600; display: inline-block;">
                                Level <t t-esc="ctx.get('step').sequence"/> Escalation
                            </span>
                        </div>
                    </div>

                    <!-- Body -->
                    <div style="padding: 2rem;">
                        <p style="font-size: 16px; line-height: 1.5; color: #4b5563; margin-top: 0;">
                            <strong>Requires Immediate Review:</strong> The following alert has surpassed its Turnaround Time (TAT) and remains unresolved. It has been escalated to you for immediate action.
                        </p>

                        <!-- Alert Details Card -->
                        <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; padding: 1.5rem; margin-top: 1.5rem;">
                            <h3 style="margin-top: 0; color: #1e293b; font-size: 18px; border-bottom: 1px solid #cbd5e1; padding-bottom: 0.5rem;">Alert Summary</h3>
                            
                            <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
                                <tr>
                                    <td style="padding: 0.5rem 0; color: #64748b; width: 35%"><strong>Rule Name:</strong></td>
                                    <td style="padding: 0.5rem 0; color: #0f172a; font-weight: 500;" t-esc="object.name" />
                                </tr>
                                <tr>
                                    <td style="padding: 0.5rem 0; color: #64748b;"><strong>Alert ID:</strong></td>
                                    <td style="padding: 0.5rem 0; color: #0f172a; font-family: monospace; font-size: 13px;" t-esc="object.alert_id" />
                                </tr>
                                <tr>
                                    <td style="padding: 0.5rem 0; color: #64748b;"><strong>Priority:</strong></td>
                                    <td style="padding: 0.5rem 0;">
                                        <t t-set="priority_color" t-value="'#ca8a04'" />
                                        <t t-if="object.priority_level == 'critical'">
                                            <t t-set="priority_color" t-value="'#dc2626'" />
                                        </t>
                                        <span t-attf-style="color: {{priority_color}}; font-weight: bold; text-transform: capitalize;" t-esc="object.priority_level or 'Medium'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 0.5rem 0; color: #64748b;"><strong>Exception Process:</strong></td>
                                    <td style="padding: 0.5rem 0; color: #0f172a;" t-esc="object.process_id or 'N/A'" />
                                </tr>
                                <tr>
                                    <td style="padding: 0.5rem 0; color: #64748b;"><strong>Narration:</strong></td>
                                    <td style="padding: 0.5rem 0; color: #0f172a;" t-out="str(object.narration or '').replace('&amp;lt;p&amp;gt;', '').replace('&amp;lt;/p&amp;gt;', '').replace('&lt;p&gt;', '').replace('&lt;/p&gt;', '')" />
                                </tr>
                            </table>
                        </div>

                        <!-- Data Table Snippet if available -->
                        <t t-if="object.html_body">
                            <div style="margin-top: 1.5rem;">
                                <p style="font-size: 14px; font-weight: bold; color: #4b5563; margin-bottom: 0.5rem;">Target Data Preview:</p>
                                <div style="font-size: 12px; background: white; border: 1px solid #e2e8f0; border-radius: 4px; padding: 10px; overflow-x: auto;">
                                    <t t-raw="object.html_body" />
                                </div>
                            </div>
                        </t>

                        <!-- Action Button -->
                        <div style="text-align: center; margin-top: 2.5rem;">
                            <a t-attf-href="/web#id={{ object.id }}&amp;model=alert.history&amp;view_type=form" 
                               style="background-color: #0f172a; color: #ffffff; text-decoration: none; padding: 12px 24px; border-radius: 6px; font-weight: 600; font-size: 15px; display: inline-block;">
                                View Alert &amp; Take Action
                            </a>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div style="background-color: #f1f5f9; padding: 1.5rem; text-align: center; font-size: 12px; color: #64748b; border-top: 1px solid #e2e8f0;">
                        This is an automated escalation generated by the Compliance Escalation Matrix.
                        <br/>
                        Generated on <t t-esc="object.create_date"/>
                    </div>
                </div>
            </div>
        </field>
        <field name="lang">en_US</field>
        <field name="auto_delete" eval="False"/>
    </record>
</odoo>
