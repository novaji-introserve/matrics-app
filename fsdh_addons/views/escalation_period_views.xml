<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View (List View) -->
    <record id="view_escalation_period_tree" model="ir.ui.view">
        <field name="name">Escalation Period Tree</field>
        <field name="model">fsdh.escalation.period</field>
        <field name="arch" type="xml">
            <tree string="Escalation Period">
                 <field name="representation" string="Escalation Period" class="text-left" />
                <!-- <field name="name" string="Escalation Type" widget="selection" class="text-left" /> -->
                <!-- <field name="escalation_cycle" string="Escalation Period Cycle" colspan="2" class="text-left"/> -->
                <field name="create_uid" string="Created By" widget="many2one_avatar_user" colspan="2" class="text-left" />
                <field name="date_created" string="Date Created" widget="datetime" class="text-left" colspan="2"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_escalation_period_form" model="ir.ui.view">
        <field name="name">Escalation Period Form</field>
        <field name="model">fsdh.escalation.period</field>
        <field name="arch" type="xml">
            <form string="Escalation Period">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h3>
                            <field name="name" string="Escalation Type" class="col-12" />
                        </h3>
                    </div>
                    <group string="Interval" class="col-10" >
                        <field name="escalation_cycle"
                            string="Escalation Period Cycle"
                            attrs="{'invisible': [('name', '=', False)]}"  
                        />
                    </group>
                </sheet>

                <!-- Add the chatter here -->
                <div class="oe_chatter">
                    <field name="message_ids" widget="mail_thread" />
                    <field name="activity_ids" widget="mail_activity" />
                </div>
            </form>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_escalation_period" model="ir.actions.act_window">
        <field name="name">Escalation Period</field>
        <field name="res_model">fsdh.escalation.period</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_escalation_period_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new escalation period.
            </p>
            <p>
                Escalation periods determine the timeframe for alert escalation cycles.
            </p>
        </field>
    </record>
</odoo>
