<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_alert_stat_tree" model="ir.ui.view">
        <field name="name">alert.stat.tree</field>
        <field name="model">alert.stat</field>
        <field name="arch" type="xml">
            <tree string="Alert Statistics">
                <header>
                    <button name="compute_statistics" string="Compute" type="object" class="oe_highlight"/>
                </header>
                <field name="name" string="Name"/>
                <field name="code"/>
                <field name="scope" string="Branch"/>
                <field name="val" widget="badge" decoration-info="1"/>
                <field name="last_execution_status" optional="show" widget="badge"
                       decoration-success="last_execution_status == 'success'"
                       decoration-danger="last_execution_status == 'error'"/>
                <field name="create_date" string="Created on"/>
                <field name="write_date" string="Last Updated on"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_alert_stat_form" model="ir.ui.view">
        <field name="name">alert.stat.form</field>
        <field name="model">alert.stat</field>
        <field name="arch" type="xml">
            <form string="Alert Statistics">
                <header>
                    <button name="compute_statistics" string="Compute" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="scope" string="Branch"/>
                            <field name="val" readonly="1"/>
                            <field name="last_execution_status" widget="badge"
                                   decoration-success="last_execution_status == 'success'"
                                   decoration-danger="last_execution_status == 'error'"/>
                            <field name="last_error_message" attrs="{'invisible': [('last_execution_status', '!=', 'error')]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="sql_query" string="SQL Query">
                            <field name="sql_query" placeholder="Write SQL Query Here..."/>
                        </page>
                        <page name="internal_notes" string="Internal Notes">
                            <field name="narration" placeholder="Narration..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_alert_stat" model="ir.actions.act_window">
        <field name="name">Statistics</field>
        <field name="res_model">alert.stat</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_alert_stat_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a Statistic
            </p>
            <p>
                Define alert statistics with Name, Code, Scope, and SQL Query.
                Use the Compute button to update values when ready.
            </p>
        </field>
    </record>

</odoo>
