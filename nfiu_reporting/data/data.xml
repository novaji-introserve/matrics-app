        <!-- ============================================================
             NFIU CURRENCY THRESHOLDS
             Source: CBN/NFIU AML/CFT Regulations
             NGN: ₦5M individual / ₦10M corporate (ML Act 2022)
             Foreign: USD/GBP/EUR/CAD $10,000 equivalent; CNY ¥50,000
             ============================================================ -->

        <!-- NGN -->
        <record id="nfiu_threshold_ngn_individual" model="nfiu.currency.threshold">
            <field name="currency_id" ref="base.NGN"/>
            <field name="customer_type">individual</field>
            <field name="threshold">5000000.00</field>
            <field name="shortname">NG</field>
            <field name="description">CBN/NFIU mandated CTR threshold for individual customers in NGN (ML Prevention Act 2022)</field>
