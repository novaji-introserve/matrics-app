<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_compliance_settings_nfiu_ctr_currency" model="res.compliance.settings">
            <field name="name">Default Currency for Currency Transactions</field>
            <field name="code">nfiu_default_ctr_currency</field>
            <field name="val">NGN</field>
            <field name="narration">Default currency for foreign transaction</field>
        </record>
        <!-- Sequence for NFIU Reports -->
        <record id="seq_nfiu_report" model="ir.sequence">
            <field name="name">NFIU Report Sequence</field>
            <field name="code">nfiu.report</field>
            <field name="prefix">NFIU</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Sample Report Indicators -->
        <record id="indicator_threshold" model="nfiu.indicator">
            <field name="name">Threshold Report</field>
            <field name="code">THRESHOLDREPORT</field>
            <field name="category">THRESHOLDREPORT</field>
            <field name="description">Transaction exceeds reporting threshold</field>
        </record>

        <record id="indicator_cilpa1" model="nfiu.indicator">
            <field name="name">Customer refuses to provide identification</field>
            <field name="code">CILPA1</field>
            <field name="category">CILPA</field>
            <field name="description">Customer refuses to provide identification or provides
                suspicious identification</field>
        </record>

        <record id="indicator_ma1" model="nfiu.indicator">
            <field name="name">Frequent cash transactions</field>
            <field name="code">MA1</field>
            <field name="category">MA</field>
            <field name="description">Customer conducts frequent cash transactions</field>
        </record>

    </data>
</odoo>