<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- NFIU Report Tree View -->
        <record id="view_nfiu_entity_tree" model="ir.ui.view">
            <field name="name">nfiu.entity.tree</field>
            <field name="model">nfiu.entity</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name" />
                    <field name="commercial_name" />
                    <field name="branch_id" />
                    <field name="identification_id" />
                    <field name="entity_reference" />
                    <field name="fiu_reference" />
                    <field name="local_currency" />
                    <field name="incorporation_number" />
                    <field name="incorporation_legal_form" />
                    <field name="write_uid" optional="show" />
                    <field name="write_date" optional="show" />
                </tree>
            </field>
        </record>

        <!-- NFIU Report Form View -->
        <record id="view_nfiu_entity_form" model="ir.ui.view">
            <field name="name">nfiu.entity.form</field>
            <field name="model">nfiu.entity</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" placeholder="Name" />
                            </h1>
                        </div>
                        <div class="oe_title">
                            <label for="company_id" class="oe_edit_only" />
                            <h1>
                                <field name="company_id" placeholder="Related Company" />
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="commercial_name" />
                                <field name="incorporation_legal_form" />
                                <field name="identification_id" />
                                <field name="entity_reference" />
                                <field name="fiu_reference" />
                                <field name="branch_id" />
                                <field name="local_currency" />
                                <field name="incorporation_number" />
                                <field name="business" />
                                <field name="incorporation_country_code" />
                            </group>
                            <group>
                                <field name="email" />
                                <field name="url" />
                                <field name="phone" />
                                <field name="tax_number" />
                                <field name="tax_reg_number" />
                                <field name="incorporation_date" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Addresses">
                                <field name="address_ids" widget="many2many_tags" />
                            </page>
                            <page string="Directors">
                                <field name="director_ids" />
                            </page>
                            <page string="Comments">
                                <field name="comments" />
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" />
                        <field name="activity_ids" widget="mail_activity" />
                        <field name="message_ids" widget="mail_thread" />
                    </div>
                </form>
            </field>
        </record>

        <!-- NFIU Report Search View -->
        <record id="view_nfiu_entity_search" model="ir.ui.view">
            <field name="name">nfiu.entity.search</field>
            <field name="model">nfiu.entity</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" />
                    <field name="incorporation_legal_form" />
                    <group expand="0" string="Group By">
                        <filter string="Legal Form" name="group_incorporation_legal_form"
                            context="{'group_by': 'incorporation_legal_form'}" />
                    </group>
                </search>
            </field>
        </record>

        <!-- Action for NFIU Reports -->
        <record id="action_nfiu_entity" model="ir.actions.act_window">
            <field name="name">NFIU Entity</field>
            <field name="res_model">nfiu.entity</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new NFIU Reporting Entity
                </p>
            </field>
        </record>
    </data>
</odoo>