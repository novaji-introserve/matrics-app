<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="open_transactions" model="ir.actions.server">
      <field name="name">Open Local Currency Transactions</field>
      <field name="model_id" ref="model_res_customer_transaction" />
      <field name="type">ir.actions.server</field>
      <field name="state">code</field>
      <field name="code">action = model.open_local_transactions()</field>
    </record>
    <record id="other_transactions" model="ir.actions.server">
      <field name="name">Open Foreign Transactions</field>
      <field name="model_id" ref="model_res_customer_transaction" />
      <field name="type">ir.actions.server</field>
      <field name="state">code</field>
      <field name="code">action = model.open_foreign_transactions()</field>
    </record>
    <record id="suspicious_transactions" model="ir.actions.server">
      <field name="name">Suspicious Transaction Report</field>
      <field name="model_id" ref="model_res_customer_transaction" />
      <field name="type">ir.actions.server</field>
      <field name="state">code</field>
      <field name="code">action = model.open_suspicious_transactions()</field>
    </record>
    <record id="customer_transaction_view_inherited_form" model="ir.ui.view">
      <field name="name">compliance.transaction.form.inherit</field>
      <field name="model">res.customer.transaction</field>
      <field name="inherit_id" ref="compliance_management.compliance_transaction_form" />
      <field name="arch" type="xml">
        <xpath expr="//field[@name='likely_fraud']" position="after">
          <field name="suspicious_transaction" readonly="True" />
        </xpath>
        <!-- Add button to header area -->
        <xpath expr="//header" position="inside">
          <button name="action_mark_as_suspicious" string="Mark Suspicious Transaction"
            type="object" class="btn-warning"
            attrs="{'invisible': [('suspicious_transaction', '=', True)]}"
            groups="regulatory_reports.group_regulatory_report,base.group_system" />
          <button name="action_unmark_as_suspicious" string="Unmark Suspicious Transaction"
            type="object" class="btn-info"
            attrs="{'invisible': [('suspicious_transaction', '=', False)]}"
            groups="regulatory_reports.group_regulatory_report,base.group_system" />
        </xpath>
      </field>
    </record>
    <record id="customer_transaction_view_inherited_tree" model="ir.ui.view">
    <field name="name">compliance.transaction.tree.inherit</field>
    <field name="model">res.customer.transaction</field>
    <field name="inherit_id" ref="compliance_management.compliance_transaction_tree"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='likely_fraud']" position="after">
          <field name="suspicious_transaction" optional="show" />
        </xpath>
    </field>
</record>
  </data>

</odoo>