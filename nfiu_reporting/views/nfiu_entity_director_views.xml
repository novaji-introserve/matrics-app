<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- NFIU Report Tree View -->
        <record id="view_nfiu_entity_director_tree" model="ir.ui.view">
            <field name="name">nfiu.entity_director.tree</field>
            <field name="model">nfiu.entity.director</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name" />
                    <field name="person_id" />
                    <field name="entity_id" />
                    <field name="role" />
                    <field name="start_date" />
                    <field name="end_date" />
                    <field name="write_uid" />
                    <field name="write_date" />
                </tree>
            </field>
        </record>

        <!-- NFIU Report Form View -->
        <record id="view_nfiu_entity_director_form" model="ir.ui.view">
            <field name="name">nfiu.entity_director.form</field>
            <field name="model">nfiu.entity.director</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" placeholder="Name" />
                            </h1>
                        </div>

                        <group>
                            <group>

                                <field name="person_id" />
                                <field name="entity_id" />
                            </group>
                            <group>
                                <field name="role" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Tenure">
                                <group>
                                    <field name="start_date" />
                                    <field name="end_date" />
                                </group>

                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" />
                        <field name="activity_ids" widget="mail_activity" />
                        <field name="message_ids" widget="mail_thread" />
                    </div>
                </form>
            </field>
        </record>

        <!-- NFIU Report Search View -->
        <record id="view_nfiu_entity_director_search" model="ir.ui.view">
            <field name="name">nfiu.entity_director.search</field>
            <field name="model">nfiu.entity.director</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" />
                    <field name="role" />
                    <group expand="0" string="Group By">
                        <filter string="Role" name="group_entity_director_role"
                            context="{'group_by': 'role'}" />
                    </group>
                </search>
            </field>
        </record>

        <!-- Action for NFIU Reports -->
        <record id="action_nfiu_entity_director" model="ir.actions.act_window">
            <field name="name">NFIU Entity Directors</field>
            <field name="res_model">nfiu.entity.director</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new NFIU Reporting Entity Director
                </p>
            </field>
        </record>
    </data>
</odoo>