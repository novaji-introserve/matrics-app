<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_nfiu_reporting" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.nfiu.reporting</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Regulatory" string="Regulatory" data-key="nfiu_reporting" groups="base.group_system">
                    <h2>NFIU Reporting</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Validation Schema Attachment</span>
                                <div class="text-muted">
                                    Select the attachment used to validate NFIU XML submissions.
                                </div>
                                <div class="mt8">
                                    <field name="nfiu_xsd_attachment_id" options="{'no_create': False}"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Fallback Module Path</span>
                                <div class="text-muted">
                                    Used only when no schema attachment is configured or available.
                                </div>
                                <div class="mt8">
                                    <field name="nfiu_xsd_module_path" placeholder="data/NFIU_goAML_4_5_Schema.xsd"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
