<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Export Wizard Form View -->
        <record id="view_nfiu_export_wizard" model="ir.ui.view">
            <field name="name">nfiu.export.wizard.form</field>
            <field name="model">nfiu.export.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="report_type"/>
                            <field name="report_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_export" type="object" string="Export to XML" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Export Wizard Action -->
        <record id="action_nfiu_export_wizard" model="ir.actions.act_window">
            <field name="name">Export NFIU Reports</field>
            <field name="res_model">nfiu.export.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>