<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View for Case Manager -->
    <record id="view_case_manager_form" model="ir.ui.view">
        <field name="name">case.manager.form</field>
        <field name="model">case.manager</field>
        <field name="arch" type="xml">
            <form string="Case" duplicate="false">
                <header>
                    <button name="action_open_case" class="btn btn-success" string="Open Case" type="object" attrs="{'invisible': ['|', ('id', '=', False), ('case_status', '!=', 'draft')]}" confirm="Are you sure you want to open this case?"/>

                    <button name="action_close_case" class="btn btn-primary" string="Close Case" type="object" attrs="{'invisible': [('can_close_case', '=', False)]}" confirm="Are you sure you want to close this case?"/>


                    <button name="action_archive_case" class="btn btn-info" string="Archive Case" type="object" attrs="{'invisible': [('case_status', '!=', 'closed')]}" confirm="Are you sure you want to archive this case?" />

                    <field name="case_status" widget="statusbar" options="{'readonly': '1'}" statusbar_visible="draft,open,closed,overdue,archived"/>
                </header>
                
                <field name="overdue_alert_message" attrs="{'invisible': [('id', '!=', False)]}"/>

                
                
                <sheet>

                    <div class="oe_title" attrs="{'invisible': [('id', '=', False)]}">
                        <label for="case_ref" string="Case Reference"/>
                        <h1>
                            <field name="case_ref" readonly="1" class="oe_inline"/>
                        </h1>
                    </div>

                    <field name="is_responsible" invisible="1"/>
                    <field name="id" invisible="1"/>
                    <field name="can_close_case" invisible="1"/>

                    <group string="Case Classification" col="1">
                        <group col="1">
                            <label for="process_category" string="Exception Category"/>
                            <h1 class="mb-0">
                                <field name="process_category" string="Exception Category" options="{'no_open': False, 'no_create': False}" attrs="{'readonly': [('case_status', '!=', 'draft')]}" class="oe_inline" style="width: 100%;"/>
                            </h1>
                        </group>
                        <group col="1">
                            <label for="process" string="Exception Process"/>
                            <h1 class="mb-0">
                                <field name="process" string="Exception Process" options="{'no_open': False, 'no_create': False}" attrs="{'readonly': [('case_status', '!=', 'draft')]}" class="oe_inline" style="width: 100%;"/>
                            </h1>
                        </group>
                    </group>

                    <group string="Case Metadata">
                        <group>
                            <field name="event_date" attrs="{'readonly': [('case_status', '!=', 'draft')]}"/>
                            <field name="officer_responsible" options="{'no_open': True, 'no_create': True}" attrs="{'readonly': [('case_status', 'not in', ['draft', 'open', 'overdue'])]}"/>
                            <field name="department_id" options="{'no_open': True, 'no_create': True}" attrs="{'readonly': True}"/>
                            <field name="customer_id" options="{'no_open': True, 'no_create': True}" attrs="{'readonly': [ ('case_status', '!=', 'draft')]}"/>
                            <field name="transaction_id" options="{'no_open': True, 'no_create': True}" attrs="{'readonly': [ ('case_status', '!=', 'draft')]}"/>
                            <field name="case_rating" attrs="{'readonly': [ ('case_status', '!=', 'draft')]}" decoration-success="case_rating == 'low'" decoration-danger="case_rating == 'high'" decoration-warning="case_rating == 'medium'" />
                        </group>
                        <group>
                            <field name="supervisors" widget="many2many_tags" options="{'no_open': True, 'no_create': True}" attrs="{'readonly': [ ('case_status', '!=', 'draft')]}"/>
                            <!-- <field name="case_score" widget="risk_slider" options="{'step': 1, 'show_value': true, 'reverse_colors': false, 'readonly': True}"  attrs="{'invisible': ['|' ('transaction_id', '=', False),('customer_id', '=', False)]}"  /> -->
                            <field name="case_score" widget="risk_slider" options="{'step': 1, 'show_value': true, 'reverse_colors': false}" attrs="{'readonly': [('case_status', '!=', 'draft')]}"  />

                        </group>
                    </group>

                    <group string="Record Information" attrs="{'invisible': [('id', '=', False)]}">
                        <group>
                            <field name="create_uid" readonly="1" string="Created By"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1" string="Created On"/>
                        </group>
                    </group>

                    <group string="Respond" col="1" attrs="{'invisible': ['|', '|', ('is_responsible', '=', False), ('id', '=', False), ('case_status', '=', 'closed')]}">
                        <field name="new_response" placeholder="Add your response here..." nolabel="1"/>
                    </group>

                    <!-- <group string="Case Closure" attrs="{'invisible': [('show_closure_fields', '=', False)]}">
                        <field name="show_closure_fields" invisible="1"/>
                        <field name="close_remarks" string="Reason For Closure"/>
                    </group> -->
                    <group string="Case Closure" col="1" attrs="{'invisible': ['&amp;', ('show_closure_fields', '=', False), ('close_remarks', '=', False)]}">

                        <field name="show_closure_fields" invisible="1"/>

                        <field name="close_remarks" string="Reason For Closure" nolabel="1" placeholder="Provide remarks for closing this case..." attrs="{'readonly': ['|', ('case_status', '=', 'closed'), ('show_closure_fields', '=', False)]}"/>
                    </group>

                    <notebook>
                        <page string="Case Details">
                            <group string="Required Action" col="1">
                                <field name="cases_action" placeholder="Specify the required action..." attrs="{'readonly': [ ('case_status', '!=', 'draft')]}" nolabel="1"/>
                            </group>
                            <group string="Narration" col="1">
                                <field name="narration" placeholder="Enter brief narration about the case..." attrs="{'readonly': [ ('case_status', '!=', 'draft')]}" nolabel="1"/>
                            </group>
                            <group string="Detailed Description" col="1">
                                <field name="description" placeholder="Enter detailed description..." attrs="{'readonly': [ ('case_status', '!=', 'draft')]}" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Documentation" name="document_page">
                            <group string="Attachments" col="1">
                                <field name="document" filename="document_filename" attrs="{'readonly': [('case_status', '!=', 'draft')]}" nolabel="1"/>
                                <field name="document_filename" invisible="1"/>
                                <field name="document_url" invisible="1"/>
                                <div attrs="{'invisible': [('document', '=', False)]}">
                                    <button name="action_view_document" type="object" class="btn btn-link">
                                        <i class="fa fa-eye"/>
 View Document
                                    </button>
                                </div>
                            </group>
                        </page>
                        <page string="Responses" name="responses_page" attrs="{'invisible': ['|', ('id', '=', False), ('case_status', '=', 'draft')]}">
                            <!-- Display existing responses in read-only mode -->
                            <field name="response_ids" readonly="1">
                                <tree>
                                    <field name="create_uid" string="Responder"/>
                                    <field name="create_date" string="Response Date"/>
                                    <field name="response"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <group string="Response" col="1">
                                            <field name="response" readonly="1" nolabel="1"/>
                                        </group>
                                        <group string="Response Information">
                                            <group>
                                                <field name="create_uid" readonly="1" string="Responder" options="{'no_open': True, 'no_create': True}"/>
                                            </group>
                                            <group>
                                                <field name="create_date" readonly="1" string="Response Date"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <!-- <field name="message_follower_ids" widget="mail_followers"/> -->
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
                
            </form>
        </field>
    </record>




    <!-- Tree View for Case Manager -->
    <record id="view_case_manager_tree" model="ir.ui.view">
        <field name="name">case.manager.tree</field>
        <field name="model">case.manager</field>
        <field name="arch" type="xml">
            <tree string="Cases" create="true" duplicate="false">
                <field name="case_ref" />
                <field name="process"/>
                <field name="officer_responsible"/>
                <field name="case_rating" widget="badge" decoration-success="case_rating == 'low'" decoration-danger="case_rating == 'high'" decoration-warning="case_rating == 'medium'" />
                <field name="case_status" widget="badge" decoration-muted="case_status == 'draft'" decoration-success="case_status == 'closed'" decoration-danger="case_status == 'overdue'" decoration-info="case_status == 'open'" decoration-warning="case_status == 'archived'"/>
                <field name="event_date"/>
                <field name="create_date" string="Created On"/>
            </tree>
        </field>
    </record>

    <!-- Search View for Case Manager -->
    <record id="view_case_manager_search" model="ir.ui.view">
        <field name="name">case.manager.search</field>
        <field name="model">case.manager</field>
        <field name="arch" type="xml">
            <search string="Search Cases">
                <field name="case_ref"/>
                <field name="customer_id"/>
                <field name="process"/>
                <field name="process_category"/>
                <field name="officer_responsible"/>
                <field name="narration"/>
                <field name="cases_action"/>
                <separator/>
                <filter string="High Priority" name="high_priority" domain="[('case_rating', '=', 'high')]"/>
                <filter string="Medium Priority" name="medium_priority" domain="[('case_rating', '=', 'medium')]"/>
                <filter string="Low Priority" name="low_priority" domain="[('case_rating', '=', 'low')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by': 'case_status'}"/>
                    <filter string="Officer" name="group_by_officer" context="{'group_by': 'officer_responsible'}"/>
                    <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Customer" name="group_by_customer" context="{'group_by': 'customer_id'}"/>
                    <filter string="Process Category" name="group_by_category" context="{'group_by': 'process_category'}"/>
                    <filter string="Process" name="group_by_process" context="{'group_by': 'process'}"/>
                    <filter string="Event Date" name="group_by_date" context="{'group_by': 'event_date:month'}"/>
                </group>
            </search>
        </field>
    </record>




</odoo>
