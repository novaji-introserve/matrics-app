<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_alert_group_tree" model="ir.ui.view">
            <field name="name">alert.group.tree</field>
            <field name="model">alert.group</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name" />
                    <field name="email" />
                    <field name="email_cc" />
                    <field name="state" />
                    <field name="tag" />
                </tree>
            </field>
        </record>

        <record id="view_alert_group_form" model="ir.ui.view">
            <field name="name">alert.group.form</field>
            <field name="model">alert.group</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar" options="{'clickable':'1'}" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe-edit-only" />
                            <h1>
                                <field name="name" placeholder="enter Title for the alert group" />
                            </h1>
                        </div>
        
                        <group class="w-75">
                            <field name="email" widget="many2many_tags" />
                        </group>
                        <group class="w-75">
                            <field name="email_cc" widget="many2many_tags" />
                        </group>
        
                        <group class="w-75">
                            <field name="tag" />
                        </group>
                    </sheet>
        
                    <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread" />
                        <field name="activity_ids" widget="mail_activity" />
                    </div>
                </form>
            </field>
        </record>

        <record id="action_alert_group" model="ir.actions.act_window">
            <field name="name">Alert Group</field>
            <field name="res_model">alert.group</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new group for exception alert receiver.
            </p>
            <p>
                exception alert group system user for mail receiving process.
            </p>
        </field>
            
        </record>


</odoo>