<odoo>
  <!-- Action to open the list view of mail.mail -->
  <record id="action_mail_mail" model="ir.actions.act_window">
    <field name="name">Mails</field>
    <field name="res_model">mail.mail</field>
    <field name="view_mode">tree,form</field>
    <field name="view_id" ref="view_mail_mail_tree_inherit" />
    <field name="help" type="html">
      <p>
        Manage the Alerts.
      </p>
    </field>
  </record>

  <!-- Define a top-level menu (if necessary) -->
  <menuitem id="menu_custom_mail_root" name="Alert Managment" sequence="2" />

  <!-- Define a submenu for mail.mail -->
  <menuitem id="menu_mail_mail" name="Alerts"
    parent="menu_custom_mail_root"
    action="action_mail_mail"
    sequence="10" />
</odoo>