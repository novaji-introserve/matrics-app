<odoo>
    <!-- Tree View -->
    <record id="view_process_sql_tree" model="ir.ui.view">
        <field name="name">process.sql.tree</field>
        <field name="model">process.sql</field>
        <field name="arch" type="xml">
            <tree string="SQL Queries">
                <field name="name" />
                <field name="create_uid" />
                <field name="create_date" />
                <field name="write_uid" />
                <field name="write_date" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_process_sql_form" model="ir.ui.view">
        <field name="name">process.sql.form</field>
        <field name="model">process.sql</field>
        <field name="arch" type="xml">
            <form string="SQL Query" create="false">
                <header>
                    <button name="Validate" string="Validate Expression" class="btn btn-primary" type="object" />

                </header>
                <sheet>
        
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <div class="oe_title">
                        <field name="query" widget="ace" placeholder="SELECT column_1 as label, column_2 as value FROM table"/>
                             <div class="mt-3 text-muted">
                                 <p>Enter a valid SQL query </p>
                                 <p>Data fetched are to be partitioned by branch ensure there is branch column in your query</p>
                                 <p class="text-danger">Note: Only SELECT queries are allowed. DDL and DML operations are prohibited.</p>
                             </div>
                    </div>
                </sheet>

                <!-- Add the chatter here -->
                <div class="oe_chatter">
                    <field name="message_ids" widget="mail_thread" />
                    <field name="activity_ids" widget="mail_activity" />
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_process_sql" model="ir.actions.act_window">
        <field name="name">SQL Queries</field>
        <field name="res_model">process.sql</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_process_sql_tree" />
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new query for exception management.
            </p>
        </field>
    </record>

    

    
</odoo>