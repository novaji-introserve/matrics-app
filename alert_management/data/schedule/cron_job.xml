<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <!-- Cron Job for Alert Rules Processing -->
        <record id="ir_cron_alert_rules_processing" model="ir.cron">
            <field name="name">Process Alert Rules</field>
            <field name="model_id" ref="alert_management.model_alert_rules" />
            <field name="state">code</field>
            <field name="code">model.process_alert_rules()</field>
            <field name="active" eval="True" />
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <!-- <field name="doall" eval="True" /> -->
        </record>
    </data>
</odoo>
