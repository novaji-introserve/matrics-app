<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Exception Process View -->
    <record id="view_exception_process_tree" model="ir.ui.view">
        <field name="name">exception.process.tree</field>
        <field name="model">rulebook.exception_process</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="exception_type_id" />
                <field name="expectation" />
                <field name="sanction" />
            </tree>
        </field>
    </record>

    <record id="view_exception_process_form" model="ir.ui.view">
        <field name="name">exception.process.form</field>
        <field name="model">rulebook.exception_process</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name" />
                    <field name="exception_type_id" />
                    <field name="expectation" />
                    <field name="sanction" />
                </group>
            </form>
        </field>
    </record>


</odoo>
