    <record id="view_transaction_monitoring_tree" model="ir.ui.view">
        <field name="name">transaction.monitoring.tree</field>
        <field name="inherit_id" ref="compliance_management.compliance_transaction_tree" />
        <field name="model">res.customer.transaction</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_created']" position="after">
                <field name="valuedate" optional="show" />
                <field name="actualdate" optional="show" />
                <field name="userid" optional="show" />
                <field name="reversal" optional="show" />
                <field name="accountmodule" optional="show" />
                <field name="tellerno" optional="show" />
                <field name="deptcode" optional="show" />
                <field name="status" optional="show" />
                <field name="tran_channel" optional="show" />
                <field name="request_id" optional="show" />
                <field name="trans_id" optional="show" />
            </xpath>
        </field>
    </record>


