<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transaction_monitoring_form" model="ir.ui.view">
        <field name="name">transaction.monitoring.form</field>
        <field name="model">res.customer.transaction</field>
        <field name="inherit_id" ref="compliance_management.compliance_transaction_form" />
        <field name="arch" type="xml">
            <!-- <xpath expr="//button[@name='action_create']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath> -->
           <xpath expr="//div[@class='oe_title']//label[@for='name']" position="replace">
                    <label for="refno" class="oe_edit_only"/>
                </xpath>
                
                <!-- Replace the 'name' field with 'refno' field -->
                <xpath expr="//div[@class='oe_title']//field[@name='name']" position="replace">
                    <field name="refno" readonly="1"/>
                </xpath>
             
            <xpath expr="//page[@name='details']//group/group[last()]" position="after">
                <!-- Transaction Details -->
                <group string="Transaction Information">
                    <group string="Transaction Details">
                        <field name="accountmodule"/>
                        <field name="tran_channel"/>
                        <field name="tellerno"/>
                        <field name="reversal"/>
                    </group>
                    <group string="Date Information">
                        <field name="valuedate"/>
                        <field name="actualdate"/>
                        <field name="userid"/>
                    </group>
                </group>
                
                <!-- Processing Information -->
                <group string="Processing Information">
                    <group string="Status Details">
                        <field name="status"/>
                        <field name="deptcode"/>
                    </group>
                    <group string="Reference Information">
                        <field name="request_id"/>
                        <field name="trans_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Inherit Search View -->
    <record id="view_transaction_monitoring_search" model="ir.ui.view">
        <field name="name">transaction.monitoring.search</field>
        <field name="model">res.customer.transaction</field>
        <field name="inherit_id" ref="compliance_management.view_customer_trans_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='customer_id']" position="after">
                <field name="valuedate"/>
                <field name="userid"/>
                <field name="refno"/>
            </xpath>
            
            <xpath expr="//filter[@name='group_currency']" position="replace">
                        <filter name="group_currency" string="" domain="[]"
                        context="{'group_by': 'currency_id'}" />
            </xpath>

           
            
            <!-- <xpath expr="//filter[@name='group_state']" position="after">
                <filter string="Value Date" name="group_date" context="{'group_by': 'valuedate:day'}"/>
                <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
            </xpath> -->
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_transaction_monitoring_tree" model="ir.ui.view">
        <field name="name">transaction.monitoring.tree</field>
        <field name="inherit_id" ref="compliance_management.compliance_transaction_tree"/>
        <field name="model">res.customer.transaction</field>
        <field name="arch" type="xml">
            <!-- <xpath expr="//button[@name='action_create']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath> -->
           

            <xpath expr="//tree" position="attributes">
                <attribute name="default_order">valuedate desc</attribute>
                <!-- <attribute name="limit">80</attribute> -->
            </xpath>

            <xpath expr="//field[@name='name']" position="replace">
             <field name="refno" />
             </xpath>

            <xpath expr="//field[@name='date_created']" position="after">
                <field name="valuedate"/>
                <field name="actualdate"/>
                <field name="userid" optional="show"/>
                <field name="reversal" optional="hide"/>
                <field name="accountmodule" optional="hide"/>
                <field name="tellerno" optional="hide"/>
                <field name="deptcode" optional="hide"/>
                <field name="status"/>
                <field name="tran_channel" optional="hide"/>
                <field name="request_id" optional="hide"/>
                <field name="trans_id" optional="hide"/>
            </xpath>

        </field>
    </record> 

