    <record id="view_transaction_monitoring_form" model="ir.ui.view">
        <field name="name">transaction.monitoring.form</field>
        <field name="model">res.customer.transaction</field>
        <field name="inherit_id" ref="compliance_management.compliance_transaction_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='details']//group/group[last()]" position="after">
                <!-- Transaction Details -->
                <group string="Transaction Information">
                    <group string="Transaction Details">
                        <field name="accountmodule"/>
                        <field name="tran_channel"/>
                        <field name="tellerno"/>
                        <field name="reversal"/>
                    </group>
                    <group string="Date Information">
                        <field name="valuedate"/>
                        <field name="actualdate"/>
                        <field name="userid"/>
                    </group>
                </group>
                
                <!-- Processing Information -->
                <group string="Processing Information">
                    <group string="Status Details">
                        <field name="status"/>
                        <field name="deptcode"/>
                    </group>
                    <group string="Reference Information">
                        <field name="request_id"/>
                        <field name="trans_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

