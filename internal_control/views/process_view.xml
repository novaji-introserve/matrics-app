<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View for the process model -->
    <record id="view_process_tree" model="ir.ui.view">
        <field name="name">process.tree</field>
        <field name="model">process</field>
        <field name="arch" type="xml">
            <tree string="Process List">
                <field name="name" />
                <field name="description" />
                <field name="process_category_id" />
                <field name="branch_id" />
            </tree>
        </field>
    </record>

    <!-- Form View for the process model -->
    <record id="view_process_form" model="ir.ui.view">
        <field name="name">process.form</field>
        <field name="model">process</field>
        <field name="arch" type="xml">
            <form string="Process Form">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="description" />
                        <field name="process_category_id" />
                        <field name="branch_id" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open the tree view -->
    <record id="action_process" model="ir.actions.act_window">
        <field name="name">Process</field>
        <field name="res_model">process</field>
        <field name="view_mode">tree,form</field>
    </record>

   
</odoo>