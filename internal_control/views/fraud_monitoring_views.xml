<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_fraud_monitoring_tree" model="ir.ui.view">
        <field name="name">fraud.fraud.tree</field>
        <field name="model">res.internal.control.fraud.monitoring</field>
        <field name="arch" type="xml">
            <tree>
                <field name="fraud_reference"/>
                <field name="fraud_type"/>
                <field name="fraud_date"/>
                <field name="amount"/>
                <field name="status"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_fraud_monitoring_form" model="ir.ui.view">
        <field name="name">fraud.monitoring.form</field>
        <field name="model">res.internal.control.fraud.monitoring</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="fraud_reference"/>
                            <field name="fraud_type"/>
                            <field name="fraud_date"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="status"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>