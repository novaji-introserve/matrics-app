<odoo>
    <!-- Action Window -->
    <record id="action_customer_account" model="ir.actions.act_window">
        <field name="name">Customer Account</field>
        <field name="res_model">res.partner.account</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Customers account shows here
            </p>
        </field>
    </record>

    <!-- Add fields to the Tree View -->
    <record id="internal_control_customer_account_tree_inherit" model="ir.ui.view">
        <field name="name">res.customer.account.tree.inherit</field>
        <field name="model">res.partner.account</field>
        <field name="inherit_id" ref="compliance_management.compliance_customer_account_tree" />
        <field name="arch" type="xml">
            <field name="account_name" position="replace">
                <field name="accounttitle" string="Account Title" optional="show" />
                <field name="account_tier" string="Account Tier" optional="show" />
            </field>
            
            <field name="risk_level" position="replace">
            </field>
            
            <tree position="inside">
                <field name="lnbalance" string="Ln Balance" optional="show"/>
                <field name="bkbalance" string="Bk Balance" optional="show"/>
                <field name="unclearedbal" string="Uncleared Balance" optional="show"/>
                <field name="holdbal" string="Hold Balance" optional="show"/>
                <field name="totdebit" string="Total Debit" optional="show"/>
                <field name="totcredit" string="Total Credit" optional="show"/>
                <field name="last_month_balance" string="Last Month Balance" optional="show"/>
                <field name="lien" string="Lien" optional="show"/>
                <field name="source_account_id" string="Source Account ID" optional="show"/>
                <field name="Status" widget="boolean" string="Status" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- Add fields to the Form View -->
    <record id="customer_account_view_form_inherit" model="ir.ui.view">
        <field name="name">customer.account.view.form.inherit</field>
        <field name="model">res.partner.account</field>
        <field name="inherit_id" ref="compliance_management.customer_account_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Additional Details">
                    <group>
                        <field name="officercode" string="Account Officer"/>
                        <field name="sectorcode" string="Sector"/>
                        <field name="lnbalance" string="Ln Balance"/>
                        <field name="bkbalance" string="Bk Balance"/>
                        <field name="unclearedbal" string="Uncleared Balance"/>
                    </group>
                    <group>
                        <field name="holdbal" string="Hold Balance"/>
                        <field name="totdebit" string="Total Debit"/>
                        <field name="totcredit" string="Total Credit"/>
                        <field name="last_month_balance" string="Last Month Balance"/>
                        <field name="lien" string="Lien"/>
                    </group>
                </group>
                <group string="Other Details">
                    <field name="account_tier" string="Account Tier"/>
                    <field name="source_account_id" string="Source Account ID"/>
                    <field name="Status" widget="boolean" string="Status"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
