<odoo>
  <data>
    <record id="user_branch_menu" model="ir.ui.view">
      <field name="name">user_branch_menu</field>
      <field name="model">res.users</field>
      <field name="inherit_id" ref="base.view_users_form"/>
      <field name="priority">99</field>  <!-- High priority to load after other views -->
      <field name="arch" type="xml">
          <!-- Hide the Preferences page -->
          <xpath expr="//page[@name='preferences']" position="attributes">
              <attribute name="invisible">1</attribute>
          </xpath>

          <xpath expr="//page[@name='oauth']" position="attributes">
              <attribute name="invisible">1</attribute>
          </xpath>

          
      </field>
    </record>
  </data>
</odoo>