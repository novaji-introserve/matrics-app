<odoo>
  <data>
    <record id="user_branch_menu" model="ir.ui.view">
      <field name="name">user_branch_menu</field>
      <field name="model">res.users</field>
      <field name="inherit_id" ref="base.view_users_form"/>
      <field name="arch" type="xml">
          <!-- Hide the Preferences page instead of removing it -->
          <xpath expr="//page[@name='preferences']" position="attributes">
              <attribute name="invisible">1</attribute>
          </xpath>
          
          <!-- Hide the Security page instead of removing it -->
          <xpath expr="//page[@name='security']" position="attributes">
              <attribute name="invisible">1</attribute>
          </xpath>

                    <!-- Hide all buttons in the header -->
          <xpath expr="//header/button" position="attributes">
              <attribute name="invisible">1</attribute>
          </xpath>
          
          <!-- Hide the entire button box -->
          <xpath expr="//div[@name='button_box']" position="attributes">
              <attribute name="invisible">1</attribute>
          </xpath>

          

      </field>
    </record>


    
  </data>
</odoo>