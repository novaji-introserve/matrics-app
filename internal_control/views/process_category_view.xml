<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View for the process model -->
    <record id="view_process_category_tree" model="ir.ui.view">
        <field name="name">process.category.tree</field>
        <field name="model">process.category</field>
        <field name="arch" type="xml">
            <tree string="Process category List">
                <field name="name" />
                <field name="description" />
            </tree>
        </field>
    </record>

    <!-- Form View for the process model -->
    <record id="view_process_category_form" model="ir.ui.view">
        <field name="name">process.category.form</field>
        <field name="model">process.category</field>
        <field name="arch" type="xml">
            <form string="Process Category Form">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <div class="oe_title">
                        <label for="description" class="oe_edit_only" />
                        <h2><field name="description" string="Description" /></h2>
                    </div>
                </sheet>

                <!-- Add the chatter here -->
                <div class="oe_chatter">
                    <field name="message_ids" widget="mail_thread" />
                    <field name="activity_ids" widget="mail_activity" />
                </div>
            </form>
        </field>
    </record>

    <!-- Action to open the tree view -->
    <record id="action_process_category" model="ir.actions.act_window">
        <field name="name">Process Category</field>
        <field name="res_model">process.category</field>
        <field name="view_mode">tree,form</field>
    </record>

   
</odoo>