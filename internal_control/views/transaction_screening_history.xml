<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_transaction_screening_history_tree_inherit" model="ir.ui.view">
        <field name="name">transaction.screening.history.tree.inherit.internal.control</field>
        <field name="model">res.transaction.screening.history</field>
        <field name="inherit_id" ref="compliance_management.transaction_screening_history_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='branch_id']" position="after">
                <field name="transaction_date"/>
                <field name="currency_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_transaction_screening_history_search_inherit" model="ir.ui.view">
        <field name="name">transaction.screening.history.search.inherit.internal.control</field>
        <field name="model">res.transaction.screening.history</field>
        <field name="inherit_id" ref="compliance_management.transaction_screening_history_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='branch_id']" position="after">
                <field name="transaction_date"/>
                <field name="currency_id"/>
            </xpath>
            <xpath expr="//separator[1]" position="before">
                <filter
                    string="Today"
                    name="filter_today"
                    domain="[('transaction_date', '>=', context_today().strftime('%Y-%m-%d 00:00:00')), ('transaction_date', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"
                />
                <filter
                    string="Last 1 Week"
                    name="filter_last_week"
                    domain="[('transaction_date', '>=', (context_today() + relativedelta(days=-7)).strftime('%Y-%m-%d 00:00:00')), ('transaction_date', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"
                />
                <filter
                    string="Last 1 Month"
                    name="filter_last_month"
                    domain="[('transaction_date', '>=', (context_today() + relativedelta(days=-30)).strftime('%Y-%m-%d 00:00:00')), ('transaction_date', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"
                />
            </xpath>
            <xpath expr="//group[@name='group_by']" position="inside">
                <filter name="group_currency_id" string="Currency" domain="[]" context="{'group_by': 'currency_id'}" />
            </xpath>
        </field>
    </record>

    <record id="compliance_management.action_list_transaction_screening_history" model="ir.actions.act_window">
        <field name="context">{'search_default_filter_today': 1, 'search_default_group_branch_id': 1, 'search_default_group_currency_id': 1}</field>
    </record>
</odoo>
