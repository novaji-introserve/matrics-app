<odoo>
    <!-- Tree View -->
    <record id="view_alert_rules_tree" model="ir.ui.view">
        <field name="name">alert.rules.tree</field>
        <field name="model">alert.rules</field>
        <field name="arch" type="xml">
            <tree string="Alert Rules">
                <field name="name" />
                <field name="process_id" string="Process"/>
                <field name="process_category_id" string="Process Category" />
                <field name="frequency_id" string="Frequency" />
                <field name="status_id" string="Alert Status"/>
                <field name="alert_group_id" string="Alert Group" />
                <field name="branch_code" string="Branch" />
                <field name="risk_rating" />
                <field name="create_date" string="Created On" />
                <field name="create_uid" string="Created By" />

            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_alert_rules_form" model="ir.ui.view">
        <field name="name">alert.rules.form</field>
        <field name="model">alert.rules</field>
        <field name="arch" type="xml">
            <form string="Alert Rule">
                <sheet>
                <group>
                    <group colspan="2"> 
                        <field name="name" string="Alert Rule Name"/>
                    </group>
                    <group>
                        <field name="process_id" string="Process"/>
                    </group>
                    <group>
                        <field name="process_category_id" string="Process Category"/>
                    </group>
                    <group colspan="2">
                        <field name="narration"  widget="html" options="{'toolbar': true}" placeholder="Enter narration here..." />
                    </group>
                    <group>
                        <field name="frequency_id" string="Alert Frequency"/>
                    </group>
                    <group>
                        <field name="status_id" string="Alert Status"/>  
                    </group> 
                    <group colspan="2">    
                        <field name="sql_text" string="SQL Query" placeholder="Enter you SQL query here"/>
                    </group>
                    <group colspan="2">
                        <field name="alert_group_id" string="Alert Group" />
                    </group>
                    <group>
                        <field name="branch_code" />
                    </group>
                    <group>
                        <field name="risk_rating" />
                    </group>
                </group>
                   
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_alert_rules" model="ir.actions.act_window">
            <field name="name">Alert Rules</field>
            <field name="res_model">alert.rules</field>
            <field name="view_id" ref="view_alert_rules_tree"/>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Exception Alert Rules
                </p>
                <p>
                    Exception Alert Rule are Created Here
                </p>
            </field>
    </record>

</odoo>