<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<record id="view_alert_rules_status_tree" model="ir.ui.view">
    <field name="name">alert.rules.status.tree</field>
    <field name="model">alert.rules.status</field>
    <field name="arch" type="xml">
        <tree string="Alert Rules Status">
            <field name="name"/>
            <field name="code"/>
        </tree>
    </field>
</record>

<record id="view_alert_rules_status_form" model="ir.ui.view">
    <field name="name">alert.rules.status.form</field>
    <field name="model">alert.rules.status</field>
    <field name="arch" type="xml">
        <form string="Alert Rules Status">
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="code"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="action_alert_rules_status" model="ir.actions.act_window">
    <field name="name">Alert Status</field>
    <field name="res_model">alert.rules.status</field>
    <field name="view_mode">tree,form</field>
</record>


</odoo>