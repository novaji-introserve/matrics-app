<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Email template for new users -->
    <record id="alert_rules_mail_template" model="mail.template">
        <field name="name">Alert Mailing System</field>
        <field name="model_id" ref="internal_control.model_alert_rules"/>
        <field name="subject">Mail Report From Icomply</field>
        <field name="email_from">test@novajii.com</field>
        <field name="email_cc">{{ object.alert_group_id.email_cc }}</field>
        <field name="email_to">{{ object.alert_group_id.email_list }}</field>
        <field name="description">this is automation mail base on alert information in the database</field>
        <field name="body_html" type="html">

            <style>
                /* Reset body and table padding/margins */
                body,
                table {
                    margin: 0;
                    padding: 0;
                    width: 100%;
                    height: auto;
                }
            
                /* Set a maximum width for email content */
                .email-container {
                    width: 100%;
                    max-width: 600px;
                    /* standard width for email content */
                    margin: 0 auto;
                    background-color: #ffffff;
                }
            
                /* Break content into sections */
                .email-section {
                    padding: 16px;
                }
            
                .email-footer {
                    text-align: center;
                    font-size: 12px;
                    color: #666;
                    padding: 8px 0;
                }
            </style>


            <table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #FFFFFF; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
                <tr>
                    <td align="center">
                        <table border="0" cellpadding="0" cellspacing="0" width="590" style="padding: 16px; background-color: #FFFFFF; color: #454748; border-collapse:separate;">
                            <tbody>
                                <!-- HEADER -->
                                <tr>
                                    <td align="center">
                                        <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width: 590px; background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                            <tr>
                                                <td valign="middle">
                                                    <img src="https://covenantmfb.com.ng/wp-content/uploads/2019/05/CMFB-Logo.png" alt="logo" style="width: 12rem; object-fit:contain; height: 12rem; display:block; margin-bottom:1rem;"/>
                                                  
                                                    <div style="display: flex; align-items:center; gap:0.4rem">
                                                        <p>AlertId:</p>
                                                        <h6> <span t-esc="object.alert_id" /> </h6>
                                                   </div>
                                                   <hr />

                                                   <div style="display: flex; align-items:center; gap:0.4rem; margin: 0.5rem 0;">
                                                        <p>Narration:</p>
                                                        <p> <span t-esc="object.narration" /> </p>
                                                   </div>
                                                <hr />
                                                   <div style="display: flex; align-items:center; gap:0.4rem; margin: 0.5rem 0;">
                                                        <p>Date:</p>
                                                        <p> <span t-esc="object.date_created.strftime('%Y-%m-%d')" /> </p>
                                                   </div>
                                                   
                                                   <div style="margin: 0.5rem 0;">
                                                      <!-- <a href="'/web#action=%s&model=%s&view_type=list&menu_id=%s' % (7, 'ir.actions.act_window', 4)">Create New Alert</a> -->
                                                   </div>
                                                  
                                                    
                                                    
                                                </td>

                                            </tr>

                                            <tr>
                                                <t t-raw="object.table_html" />
                                            </tr>
                                            
                                            <tr>
                                                <td colspan="2" style="text-align:center;">
                                                    <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <!-- CONTENT -->
                                <tr>
                                    <td align="center" style="min-width: 590px;">
                                        <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width: 590px; background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                            <tr>
                                                <td valign="top" style="font-size: 13px;">
                                                    <div> </div>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="text-align:center;">
                                                    <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <!-- FOOTER -->
                                <tr>
                                    <td align="center" style="min-width: 590px;">
                                        <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width: 590px; background-color: white; font-size: 11px; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                            <tr>
                                                <td valign="middle" align="left">
                                                    <t>Novaji Introserve</t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td valign="middle" align="left" style="opacity: 0.7;">
                                                    <t>+1 650-123-4567</t>
                                                    <t>
                                                    | <a t-att-href="'mailto:%s' % ''" style="text-decoration:none; color: #454748;">info@yourcompany.com</a>
                                                    </t>
                                                    <t>
                                                    | <a t-att-href="'%s' % ''" style="text-decoration:none; color: #454748;" >http://www.example.com</a>
                                                    </t>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                <!-- POWERED BY -->
                 <!-- POWERED BY -->
                 <tr class='o_email_footer'>
                    
                </tr>
            </table>
        </field>
        <field name="lang">en_US</field>
        <field name="auto_delete" eval="False"/>
</record>
</odoo>