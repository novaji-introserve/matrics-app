<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job for Alert Rules Processing -->
        <record id="ir_cron_screen_rules_processing" model="ir.cron">
            <field name="name">Transaction screeninig Rules</field>
            <field name="model_id" ref="internal_control.model_res_customer_transaction" />
            <field name="state">code</field>
            <field name="code">for record in model.search([]): record.action_screen()</field>
            <field name="active" eval="False" />
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <!-- <field name="doall" eval="True" /> -->
        </record>
    </data>
</odoo>