<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit and Extend Tree View -->
    <record id="internal_control_screening_rule_tree" model="ir.ui.view">
        <field name="name">internal_control.screening.rule.tree</field>
        <field name="model">internal_control.screening.rule</field>
        <field name="inherit_id" ref="compliance_management.compliance_transaction_screening_rule_tree"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='create_uid']" position="before">
                <field name="state"/>
                <!-- <field name="department_id"/> -->
            </xpath>
        </field>
    </record>

    <record id="internal_control_screening_rule_form" model="ir.ui.view">
        <field name="name">internal_control.screening.rule.form</field>
        <field name="model">internal_control.screening.rule</field>
        <field name="inherit_id" ref="compliance_management.compliance_transaction_screening_rule_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">

            <xpath expr="//group[last()]" position="after">
                <group>
                    <!-- <field name="control_reference"/>
                    <field name="department_id"/> -->
                </group>
            </xpath>
        </field>
    </record>

    <!-- Action -->
    <record id="action_internal_control_screening_rule" model="ir.actions.act_window">
        <field name="name">Transaction Screening Rules</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">internal_control.screening.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="internal_control_screening_rule_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add transaction Screening Rules
            </p>
        </field>
    </record>
</odoo>