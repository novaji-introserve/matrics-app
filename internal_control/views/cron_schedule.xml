<odoo>
    <data>
        <!-- Inherit the base.ir_cron_view_tree view -->
        <record id="view_cron_tree_inherit" model="ir.ui.view">
            <field name="name">base.ir_cron.view.tree.inherit</field>
            <field name="model">ir.cron</field>
            <field name="inherit_id" ref="base.ir_cron_view_tree" />
            <field name="arch" type="xml">
                <xpath expr="//tree" position="attributes">
                    <!-- Disable the 'Create' button -->
                    <attribute name="create">False</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_cron_form_inherit" model="ir.ui.view">
            <field name="name">ir.cron.form.inherit</field>
            <field name="model">ir.cron</field>
            <field name="inherit_id" ref="base.ir_cron_view_form" />
            <field name="arch" type="xml">
                <!-- Hide the notebook -->
                <xpath expr="//notebook" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
        
                <!-- Optionally, you can also hide individual pages in the notebook -->
                <!-- Example for hiding a specific page within the notebook -->
              
            </field>
        </record>



        <record id="action_ir_cron" model="ir.actions.act_window">
            <field name="name">Scheduled Actions</field>
            <field name="res_model">ir.cron</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_filter_alert': 1, 'search_default_filter_transaction': 1}</field>
            <field name="view_id" ref="view_cron_tree_inherit" />
        </record>


