<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ENHANCED FORM VIEW -->
    <!-- ================================================================ -->
    <record id="view_bi_sql_view_form_enhanced" model="ir.ui.view">
        <field name="name">bi.sql.view.form.enhanced</field>
        <field name="model">bi.sql.view</field>
        <field name="inherit_id" ref="bi_sql_editor.view_bi_sql_view_form"/>
        <field name="arch" type="xml">
            
            <!-- Add Department field -->
            <field name="technical_name" position="after">
                <field name="department_id" 
                       options="{'no_create': True, 'no_edit': True}"
                       placeholder="Select department for this report"/>
            </field>
            
            <!-- Make technical name auto-populated -->
            <field name="technical_name" position="attributes">
                <attribute name="placeholder">Auto-generated from report name</attribute>
                <attribute name="help">Technical name for the SQL view. Auto-generated from report name, but you can customize it if needed.</attribute>
            </field>
            
            <!-- SECURITY CONTROL: Hide complex pages for non-CCO users -->
            <!-- Change group here if you want different users to see this -->
            <page name="page_security" position="attributes">
                <attribute name="groups">compliance_management.group_compliance_chief_compliance_officer</attribute>
            </page>
            
            <!-- SECURITY CONTROL: Hide complex fields for non-CCO users -->
            <!-- Change group here if you want different users to see this -->
            <field name="view_order" position="attributes">
                <attribute name="groups">compliance_management.group_compliance_chief_compliance_officer</attribute>
            </field>
            
            <!-- SECURITY CONTROL: Hide complex buttons for non-CCO users -->
            <!-- Change group here if you want different users to see these buttons -->
            <button name="button_reset_to_sql_valid" position="attributes">
                <attribute name="groups">compliance_management.group_compliance_chief_compliance_officer</attribute>
            </button>
            
            <button name="button_reset_to_model_valid" position="attributes">
                <attribute name="groups">compliance_management.group_compliance_chief_compliance_officer</attribute>
            </button>
            
            <button name="button_update_model_access" position="attributes">
                <attribute name="groups">compliance_management.group_compliance_chief_compliance_officer</attribute>
            </button>
            
        </field>
    </record>
    
    <!-- ================================================================ -->
    <!-- ENHANCED TREE VIEW - JavaScript handles security -->
    <!-- ================================================================ -->
    <record id="view_bi_sql_view_tree_enhanced" model="ir.ui.view">
        <field name="name">bi.sql.view.tree.enhanced</field>
        <field name="model">bi.sql.view</field>
        <field name="inherit_id" ref="bi_sql_editor.view_bi_sql_view_tree"/>
        <field name="arch" type="xml">
            
            <!-- No security attributes here - JavaScript handles everything -->
            
            <field name="name" position="attributes">
                <attribute name="widget">char</attribute>
            </field>
            
            <!-- Add Department column -->
            <field name="technical_name" position="after">
                <field name="department_id" optional="hide"/>
            </field>
            
            <!-- Make other columns optional -->
            <field name="size" position="attributes">
                <attribute name="optional">hide</attribute>
            </field>
            
            <!-- Add VIEW DATA button -->
            <field name="state" position="after">
                <button name="action_open_report_data" 
                        string="📊 View Data" 
                        type="object" 
                        class="btn-primary btn-sm"
                        attrs="{'invisible': [('state', '!=', 'ui_valid')]}"
                        help="Click to view report data directly"/>
            </field>
            
            <!-- SECURITY CONTROL: Hide technical name for regular users -->
            <!-- Change group here if you want different users to see technical names -->
            <field name="technical_name" position="attributes">
                <attribute name="groups">compliance_management.group_compliance_chief_compliance_officer</attribute>
                <attribute name="optional">hide</attribute>
            </field>
            
        </field>
    </record>
    
    <!-- ================================================================ -->
    <!-- ENHANCED ACTION -->
    <!-- ================================================================ -->
    <record id="action_bi_sql_view_enhanced" model="ir.actions.act_window">
        <field name="name">Exception Report by Department</field> 
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">bi.sql.view</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'group_by': 'department_id'}</field>
        <field name="view_id" ref="view_bi_sql_view_tree_enhanced"/>
    </record>
    
    <!-- ================================================================ -->
    <!-- UPDATE EXISTING MENU -->
    <!-- ================================================================ -->
    <record id="bi_sql_editor.menu_bi_sql_view" model="ir.ui.menu">
        <field name="action" ref="action_bi_sql_view_enhanced"/>
        <field name="name">Exception Reports</field>
    </record>

</odoo>