<odoo>
    <!-- Tree View -->
    <record id="view_process_sql_tree" model="ir.ui.view">
        <field name="name">process.sql.tree</field>
        <field name="model">process.sql</field>
        <field name="arch" type="xml">
            <tree string="SQL Queries">
                <field name="name" />
                <field name="query" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_process_sql_form" model="ir.ui.view">
        <field name="name">process.sql.form</field>
        <field name="model">process.sql</field>
        <field name="arch" type="xml">
            <form string="SQL Query" create="false" editable="false">
                <header>
                    <button name="Validate" string="Validate Expression" class="btn btn-primary" type="object" attrs="{'invisible': [('is_valid', '=', True)]}" />

                </header>
                <sheet>
                    <field name="is_valid" attrs="{'invisible': True}" />
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <div class="oe_title">
                        <label for="query" class="oe_edit_only" />
                        
                            <field name="query" class="col-12" />
                        
                    </div>
                </sheet>

                <!-- Add the chatter here -->
                <div class="oe_chatter">
                    <field name="message_ids" widget="mail_thread" />
                    <field name="activity_ids" widget="mail_activity" />
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_process_sql" model="ir.actions.act_window">
        <field name="name">SQL Queries</field>
        <field name="res_model">process.sql</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_process_sql_tree" />
        <field name="context">{}</field>
    </record>

    

    
</odoo>