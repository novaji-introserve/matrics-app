<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_alert_group_tree" model="ir.ui.view">
        <field name="name">alert.group.tree</field>
        <field name="model">alert.group</field>
        <field name="arch" type="xml">
            <tree string="Alert Groups">
                <field name="name"/>
                <field name="state"/>
                <field name="tag"/>
                <field name="create_date" string="created On"/>
                <field name="create_uid" string="created By"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_alert_group_form" model="ir.ui.view">
        <field name="name">alert.group.form</field>
        <field name="model">alert.group</field>
        <field name="arch" type="xml">
            <form string="Alert Group">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="state"/>
                        <field name="tag"/>
                    </group>
                    <group>
                         <field name="email" string="Select Email(s)"/>
                    </group>
                    <group>
                         <field name="email_cc" string="Email Copy"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
   
    <record id="action_alert_group" model="ir.actions.act_window">
        <field name="name">Alert Groups</field>
        <field name="res_model">alert.group</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_alert_group_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new alert groups for exception management.
            </p>
            <p>
                Alert groups help in managing exception notifications efficiently.
            </p>
        </field>
    </record>

</odoo>