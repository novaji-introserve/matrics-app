<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View (List View) -->
    <record id="view_exception_frequency_tree" model="ir.ui.view">
        <field name="name">Exception Frequency</field>
        <field name="model">exception.frequency</field>
        <field name="arch" type="xml">
            <tree string="Exception Frequency">
                <field name="name" string="Frequency" widget="selection" colspan="2" class="text-left" />
                <field name="period" string="Frequency Cycle" colspan="2" class="text-left"/>
                <field name="create_uid" string="Created By" widget="many2one_avatar_user" colspan="2" class="text-left" />
                <field name="date_created" string="Date Created" widget="datetime"  class="text-left" colspan="2"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_exception_frequency_form" model="ir.ui.view">
        <field name="name">Exception Frequency </field>
        <field name="model">exception.frequency</field>
        <field name="arch" type="xml">
            <form string="Exception Frequency">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h3>
                            <field name="name" string="Frequency Type" class="col-12" />
                        </h3>
                    </div>
                    <group string="Interval" class="col-10" >
                        <field name="period"
                            string="Frequency Cycle"
                            attrs="{'invisible': [('name', '=', False)]}"  
                        />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_alert_frequency" model="ir.actions.act_window">
        <field name="name">Exception Frequency</field>
        <field name="res_model">exception.frequency</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_exception_frequency_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new frequency for exception management.
            </p>
            <p>
                exception frequency help in managing how frequent the system check for exception.
            </p>
        </field>
    </record>
</odoo>
