<?xml version="1.0" encoding="utf-8"?>
    <odoo>
        <!-- Tree View (List View) -->
        <record id="view_exception_frequency_tree" model="ir.ui.view">
            <field name="name">exception.frequency.tree</field>
            <field name="model">exception.frequency</field>
            <field name="arch" type="xml">
                <tree string="Exception Frequency">
                    <field name="name" />
                    <field name="period" />
                    <field name="date_created" />
                    <field name="representation" />
                    <field name="period" />
                    <field name="create_date" string="Created On" />
                    <field name="create_uid" string="Created By" />
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_exception_frequency_form" model="ir.ui.view">
            <field name="name">exception.frequency.form</field>
            <field name="model">exception.frequency</field>
            <field name="arch" type="xml">
                <form string="Exception Frequency">
                    <sheet>
                        <group>
                            <field name="name" />
                            <field name="period" 
                                attrs="{'invisible': [('name', '=', False)]}" 
                            />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action Window -->
        <record id="action_alert_frequency" model="ir.actions.act_window">
            <field name="name">Exception Frequency</field>
            <field name="res_model">exception.frequency</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_exception_frequency_tree" />
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create new alert groups for exception management.
                </p>
                <p>
                    Alert groups help in managing exception notifications efficiently.
                </p>
            </field>
        </record>
    </odoo>
