<odoo>
    <!-- Tree View -->
    <record id="view_alert_group_tree" model="ir.ui.view">
        <field name="name">alert.group.tree</field>
        <field name="model">alert.group</field>
        <field name="arch" type="xml">
            <tree string="Alert group">
                <field name="name" />
                <field name="email_list"  />
                <field name="email_cc" />
                <field name="state" />
                <field name="tag" />
                <field name="date_created"  readonly="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_alert_group_form" model="ir.ui.view">
        <field name="name">alert.rules.group.form</field>
        <field name="model">alert.group</field>
        <field name="arch" type="xml">
            <form string="Alert Group">
                <sheet>
                
                    <group>
                   
                    <group class="col-md-6 col-12">
                       <field name="name" />
                       <field name="users_ids" widget="many2many_tags"/>
                       <field name="state" />
                    </group>
                    <group class="col-md-6 col-12">
                        <field name="tag" />
                        <field name="email_cc" />
                        <field name="date_created" readonly="1" />
                    </group>
                    </group>
                   
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_alert_group" model="ir.actions.act_window">
        <field name="name">Alert Group</field>
        <field name="res_model">alert.group</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

</odoo>