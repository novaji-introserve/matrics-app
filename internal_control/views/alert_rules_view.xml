<odoo>
    <!-- Tree View -->
    <record id="view_alert_rules_tree" model="ir.ui.view">
        <field name="name">alert.rules.tree</field>
        <field name="model">alert.rules</field>
        <field name="arch" type="xml">
            <tree string="Alert Rules">
                <field name="name" />
                <field name="alert_id" />
                <field name="frequency_id" />
                <field name="first_owner" />
                <field name="second_owner" />
                <field name="specific_email_recipients" />

                <field name="process_id" string="Process" />
                <field name="status" widget="selection" string="Status" />
                <field name="risk_rating" decoration-success="risk_rating == 'low'"
                    decoration-warning="risk_rating == 'medium'" decoration-danger="risk_rating == 'high'"
                    widget="badge" />
                <field name="last_checked" string="Last Checked" widget="datetime" />
                <field name="date_created" string="Date Created" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_alert_rules_form" model="ir.ui.view">
        <field name="name">alert.rules.form</field>
        <field name="model">alert.rules</field>
        <field name="arch" type="xml">
            <form string="Alert Rule" create="False">
                <header>
                   
                    <field name="status" widget="statusbar" options="{'clickable':'1'}" />
                </header>
                <sheet>
                    
                    <div class="oe_title">
                        <label for="name" class="oe-edit-only" />
                        <h1>
                            <field name="name" placeholder="enter Title for the exception rule" />
                        </h1>
                    </div>

                    <group string="PROCESS DETAILS">

                        <group colspan="2">
                            <field name="process_id" string="Process" />
                        </group>
                        <group>
                            <field name="frequency_id" />
                        </group>

                        <group>
                            <field name="risk_rating" string="Rating" />
                        </group>
        
                        <group string="SQL" colspan="2">
                            <field name="sql_text" />
                        </group>
      

                    </group>

                    <group>

                       
                    </group>
                    <group>

                        <group string="LAST CHECKED">
                            <field name="last_checked" string="Last Checked" widget="datetime" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Narration">
                            <field name="narration" string="Narration" style="padding: 2rem;"
                                placeholder="Enter narration here..." />
                        </page>
                        <page string="Receipients">
                            <group>
                                <group class="">
                                    <field name="specific_email_recipients" widget="many2many_tags" />
                                </group>
                                <group>
                                    <field name="alert_id" />
                                </group>
                            
                                <group class="">
                                    <field name="first_owner" />
                                </group>
                            
                                <group class="">
                                    <field name="second_owner" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <!-- Add the chatter here -->
                <div class="oe_chatter">
                    <field name="message_ids" widget="mail_thread" />
                    <field name="activity_ids" widget="mail_activity" />
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_alert_rules" model="ir.actions.act_window">
        <field name="name">Alert Rules</field>
        <field name="res_model">alert.rules</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

</odoo>