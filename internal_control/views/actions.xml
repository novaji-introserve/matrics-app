    <record id="action_date_vs_value_date_accounts" model="ir.actions.act_window">
        <field name="name">Trans Date &amp; Value Date Monitoring</field>
        <field name="res_model">res.customer.transaction</field>
        <field name="view_mode">tree,form</field>
        <!-- <field name="domain">[('TranDate', '!=', 'Valuedate')]</field> -->
        <field name="domain">[]</field>
        <field name="context">{
        'search_default_date_mismatch': 1
    }</field>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No date mismatch transactions found
            </p>
            <p>
                Transactions will appear here when they match monitoring criteria.
            </p>
        </field>
    </record>

    <!-- Server Action to fetch transactions with mismatched dates -->
    <record id="action_mismatched_transactions" model="ir.actions.server">
        <field name="name">Fetch Mismatched Transactions</field>
        <field name="model_id" ref="model_res_customer_transaction"/>
        <field name="state">code</field>
        <field name="code">
            action = model.get_date_mismatched_transactions()
        </field>
    </record>

