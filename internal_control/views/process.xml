<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_process_tree" model="ir.ui.view">
        <field name="name">process.tree</field>
        <field name="model">process</field>
        <field name="arch" type="xml">
            <tree string="Processes">
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_process_form" model="ir.ui.view">
        <field name="name">process.form</field>
        <field name="model">process</field>
        <field name="arch" type="xml">
            <form string="Process">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_process" model="ir.actions.act_window">
        <field name="name">Processes</field>
        <field name="res_model">process</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_process_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new exception process.
            </p>
            <p>
                Processes are managed here. Add the required details for exception management.
            </p>
        </field>
    </record>

</odoo>
