<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_res_transaction_channel_tree" model="ir.ui.view">
        <field name="name">res.transaction.channel.tree</field>
        <field name="model">res.transaction.channel</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_res_transaction_channel_form" model="ir.ui.view">
        <field name="name">res.transaction.channel.form</field>
        <field name="model">res.transaction.channel</field>
        <field name="arch" type="xml">
            <form string="Transaction Channel">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

        <!-- Action -->
    <record id="action_res_transaction_channel" model="ir.actions.act_window">
        <field name="name">Transaction Channels</field>
        <field name="res_model">res.transaction.channel</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>