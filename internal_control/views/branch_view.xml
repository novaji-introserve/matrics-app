<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<record id="view_tbl_branch_tree" model="ir.ui.view">
    <field name="name">res.branch.tree</field>
    <field name="model">res.branch</field>
    <field name="arch" type="xml">
        <tree string="Branch">
            <field name="code"/>
            <field name="name"/>
            <field name="users"/> 
        </tree>
    </field>
</record>

<record id="view_tbl_branch_form" model="ir.ui.view">
    <field name="name">res.branch.form</field>
    <field name="model">res.branch</field>
    <field name="arch" type="xml">
        <form string="Branch">
            <sheet>
                
                <group>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="users" widget="many2many_tags"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="action_res_branch" model="ir.actions.act_window">
    <field name="name">Branches</field>
    <field name="res_model">res.branch</field>
    <field name="view_mode">tree,form</field>
</record>


</odoo>