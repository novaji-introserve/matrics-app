<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_branch_tree_inherit" model="ir.ui.view">
        <field name="name">res.branch.tree.inherit</field>
        <field name="model">res.branch</field>
        <field name="inherit_id" ref="compliance_management.view_branch_tree" /> <!-- Reference to the existing view -->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="replace">
                <field name="branchcode" string="Branch Code" />
            </xpath>
            <xpath expr="//field[@name='name']" position="replace">
                <field name="branchname" string="Branch Name" />
            </xpath>
        </field>
    </record>

<record id="view_branch_form_inherit" model="ir.ui.view">
    <field name="name">res.branch.form.inherit</field>
    <field name="model">res.branch</field>
    <field name="inherit_id" ref="compliance_management.view_branch_form" /> <!-- Reference to the existing view -->
    <field name="arch" type="xml">
        <!-- Update the title section -->
        <xpath expr="//div[@class='oe_title']//label[@for='name']" position="attributes">
            <attribute name="for">branchname</attribute>
        </xpath>
        <xpath expr="//div[@class='oe_title']//h1//field[@name='name']" position="replace">
            <field name="branchname" string="Branch" />
        </xpath>
        <!-- Replace the existing code field if it exists -->
        <xpath expr="//field[@name='code']" position="replace">
            <field name="branchcode" string="Branch Code" />
        </xpath>
    </field>
</record>

