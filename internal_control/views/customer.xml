<?xml version="1.0" encoding="utf-8"?>
<odoo>    
    <!-- Internal Control Tree View -->
    <record id="internal_control_customer_tree" model="ir.ui.view">
        <field name="name">internal.control.customer.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree create="true">
                <field name="customer_id" optional="show"/>
                <field name="firstname" optional="show"/>
                <field name="lastname" optional="show"/>
                <field name="name"/>
                <field name="branch_id" optional="hide"/>
                <field name="state_id" optional="hide"/>
                <field name="date_opened" string="Date Opened" optional="show"/>
                <field name="nationality" string="Nationality" optional="hide"/>
                <field name="formatted_phone" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- Internal Control Form View -->
    <record id="internal_control_customer_form" model="ir.ui.view">
        <field name="name">internal.control.customer.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form readonly="1">
                <header>

                </header>
                <sheet>
                    <h1>
                        <label for="name">Name</label>
                        <field name="name" class="text-break"/>
                    </h1>
                    
                    <group>
                        <group string="Basic Information">
                            <field name="customer_id" readonly="1"/>
                            <field name="firstname" readonly="1"/>
                            <field name="lastname" readonly="1"/>
                            <field name="nin" string="NIN"/>
                            <field name="date_opened" string="Date Opened"/>
                            <field name="nationality"/>
                        </group>
                        <group string="Contact Information">
                            <field name="formatted_phone" readonly="1"/>
                            <field name="branch_id" readonly="1"/>
                            <field name="country_id" invisible="1"/>  <!-- Required for state_id domain -->
                            <field name="state_id"/>
                        </group>
                    </group>
                    
                    <notebook>

                        <page string="Additional Info" name="additional_info">
                            <group>
                                <field name="sector_id" readonly="1"/>
                                <field name="customer_industry_id" readonly="1"/>
                                <field name="employment_status"/>
                                <field name="state_residence"/>
                                <field name="first_risk_rating" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Internal Control Search View -->
    <record id="internal_control_customer_search" model="ir.ui.view">
        <field name="name">internal.control.customer.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Search Internal Control Customers">
                <field name="name" filter_domain="['|', '|', ('display_name', 'ilike', self), ('customer_id', 'ilike', self), ('formatted_phone', 'ilike', self)]"/>
                <field name="customer_id"/>
                <field name="firstname"/>
                <field name="lastname"/>
                <field name="formatted_phone"/>
                <field name="branch_id"/>
                <separator/>
                <filter string="Customers" name="type_customer" domain="[('internal_category', '=', 'customer')]"/>
                <filter string="Without NIN" name="no_nin" domain="[('nin', '=', False)]"/>
                <filter string="Today Opened" name="today_opened" domain="[('date_opened', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <group expand="0" name="group_by" string="Group By">
                    <filter name="group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state_id'}"/>
                    <filter name="group_nationality" string="Nationality" context="{'group_by': 'nationality'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Internal Control Action -->
    <record id="action_internal_control_customers" model="ir.actions.act_window">
        <field name="name">Internal Control Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('internal_control_customer_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('internal_control_customer_form')})]"/>
        <field name="search_view_id" ref="internal_control_customer_search"/>
        <field name="domain">[('internal_category', '=', 'customer')]</field>
        <field name="context">{}</field>
    </record>

    <!-- Your existing server actions - keep them -->
    <record id="action_open_customers_today" model="ir.actions.server">
        <field name="name">Today</field>
        <field name="model_id" ref="model_res_partner"/>
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = env['res.partner'].open_all_customers_today()</field>
    </record>
    
    <record id="action_open_customers_last_7days" model="ir.actions.server">
        <field name="name">Last 7 Days</field>
        <field name="model_id" ref="model_res_partner"/>
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = env['res.partner'].open_all_customers_last_7days()</field>
    </record>

</odoo>