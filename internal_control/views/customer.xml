<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_customer_tree_inherited" model="ir.ui.view">
        <field name="name">customer.tree</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="compliance_management.compl_cust_tree_inherit_res_partner" />
        <field name="arch" type="xml">
            <tree position="attributes">
                <attribute name="create">False</attribute>
            </tree>
            <xpath expr="//field[@name='risk_score']" position="replace" />
            <xpath expr="//field[@name='risk_level']" position="replace" />
            <xpath expr="//field[@name='email']" position="replace" />
            <xpath expr="//field[@name='state_id']" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
            <xpath expr="//field[@name='vat']" position="replace" />
            <xpath expr="//field[@name='category_id']" position="replace" />
            <!-- <xpath expr="//field[@name='branch_id']" position="replace" /> -->
            <!-- <xpath expr="//field[@name='phone']" position="attributes">
                <attribute name="invisible">show</attribute>
            </xpath> -->
            <xpath expr="//field[@name='tier_id']" position="replace" />
             <xpath expr="//field[@name='registration_date']" position="replace">
                <field name="date_opened" string="Date Opened" optional="show" />
            </xpath>
            <xpath expr="//field[@name='country_id']" position="replace">
                <field name="nationality" string="Nationality" optional="show" />
            </xpath>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_customer_form_inherited" model="ir.ui.view">
        <field name="name">customer.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="compliance_management.customer_actions_inherit_res_partner" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="replace">
                <header />
            </xpath>
            <xpath expr="//button[@name='get_risk_score']" position="replace" />
            <xpath expr="//button[@name='action_view_partner_invoices']" position="replace" />
            <xpath expr="//button[@name='action_view_sale_order']" position="replace" />
            <xpath expr="//page[@name='plans']" position="replace" />
            <xpath expr="//page[@name='accounts']" position="replace" />
            <xpath expr="//page[@name='risk_assessment']" position="replace" />
            <xpath expr="//page[@name='sanction_screening']" position="replace" />
            <xpath expr="//page[@name='edd_record']" position="replace" />
            <xpath expr="//page[@name='internal_notes']" position="replace" />
            <xpath expr="//form//field[@name='street']" position="attributes" >
               <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//field[@name='street2']" position="attributes" >
               <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//field[@name='company_id']" position="attributes" >
               <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//field[@name='website']" position="attributes" >
               <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//field[@name='parent_id']" position="attributes" >
               <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//field[@name='mobile']" position="attributes" >
               <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//field[@name='function']" position="attributes" >
               <attribute name="invisible">1</attribute>
            </xpath>
             <xpath expr="//form//field[@name='type']" position="attributes" >
               <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='bvn']" position="replace">
                <field name="nin" string="NIN" />
            </xpath>
            <xpath expr="//field[@name='registration_date']" position="replace">
                <field name="date_opened" string="Date Opened" />
            </xpath>
        </field>
    </record>

        <record id="action_open_customers" model="ir.actions.server">
        <field name="name">Open Customers</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">action = env['res.partner'].open_all_customers()</field>
    </record>
</odoo>
