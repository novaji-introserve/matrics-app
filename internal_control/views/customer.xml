<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_customer_form_inherited" model="ir.ui.view">
        <field name="name">customer.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="compliance_management.customer_actions_inherit_res_partner" />
        <field name="arch" type="xml">
           
            <xpath expr="//header" position="replace">
                <header />
            </xpath>
            <xpath expr="//page[@name='plans']" position="replace" />
             <xpath expr="//page[@name='accounts']" position="replace" /> 
            <xpath expr="//page[@name='risk_assessment']" position="replace" />
            <xpath expr="//page[@name='sanction_screening']" position="replace" />
            <xpath expr="//page[@name='edd_record']" position="replace" />
            <!-- <xpath expr="//page[@name='accounting']" position="replace" />  -->
          
        </field>
    </record>


    <!-- Tree View -->
    <record id="view_customer_tree_inherited" model="ir.ui.view">
        <field name="name">customer tree</field>
        <field name="inherit_id" ref="compliance_management.compl_cust_tree_inherit_res_partner" />
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            
          
                <xpath expr="//field[@name='risk_level']" position="replace" />
                <xpath expr="//field[@name='risk_score']" position="replace" />
           

        </field>
    </record>



   
</odoo>