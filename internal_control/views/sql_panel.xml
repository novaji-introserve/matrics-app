    <?xml version="1.0" encoding="utf-8"?>
    <odoo>
        <record id="my_psql_query_view_tree_inherit" model="ir.ui.view">
            <field name="name">SQL Panel</field>
            <field name="model">psql.query</field>
            <field name="inherit_id" ref="psql_query_execute.psql_query_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="inside">
                    <!-- <field name="your_new_field" string="Your New Field"/> -->
                </xpath>
            </field>
        </record>

        <record id="my_psql_query_view_form_inherit" model="ir.ui.view">
