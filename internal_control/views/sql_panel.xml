<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="my_psql_query_view_tree_inherit" model="ir.ui.view">
        <field name="name">SQL Panel</field>
        <field name="model">psql.query</field>
        <field name="inherit_id" ref="psql_query_execute.psql_query_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <!-- <field name="your_new_field" string="Your New Field"/> -->
            </xpath>
            <xpath expr="//tree" position="attributes">
                <attribute name="string">SQL Query</attribute>
            </xpath>
        </field>
    </record>

    <record id="my_psql_query_view_form_inherit" model="ir.ui.view">
        <field name="name">my.psql.query.view.form.inherit</field>
        <field name="model">psql.query</field>
        <field name="inherit_id" ref="psql_query_execute.psql_query_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']" position="after">
                <!-- <div class="">
                        <h2>My Custom Section</h2>
                        <p>This is my custom content added after the title.</p>
                    </div> -->
            </xpath>
            <xpath expr="//form" position="attributes">
                <attribute name="string">SQL Query</attribute>
            </xpath>
            <xpath expr="//button[@name='action_execute_query']" position="attributes">
                <attribute name="string">Run Query</attribute>
                <attribute name="class">btn btn-success</attribute>
            </xpath>
            <xpath expr="//button[@name='action_print_query_result_xlsx']" position="attributes">
                <attribute name="string">Export Excel</attribute>
                <attribute name="class">btn btn-success</attribute>
                <!-- Hide the print button until we fix it -->
                <attribute name="invisible">True</attribute>
            </xpath>
        </field>
    </record>
    <record id="psql_query_execute.action_psql_query" model="ir.actions.act_window">
        <field name="name">Database Query</field>
    </record>
</odoo>