<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_process_category_tree" model="ir.ui.view">
        <field name="name">process.category.tree</field>
        <field name="model">process.category</field>
        <field name="arch" type="xml">
            <tree string="Process Category">
                <field name="name"/>
                <field name="description"/>
                <field name="create_date" string="created On"/>
                <field name="create_uid" string="created By"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_process_category_form" model="ir.ui.view">
        <field name="name">process.category.form</field>
        <field name="model">process.category</field>
        <field name="arch" type="xml">
            <form string="Process">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group colspan="2">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_process_category" model="ir.actions.act_window">
        <field name="name">Processes Category</field>
        <field name="res_model">process.category</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_process_category_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new exception process category.
            </p>
            <p>
                Processes category are managed here. Add the required details for exception management.
            </p>
        </field>
    </record>

</odoo>
