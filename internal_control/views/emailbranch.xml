<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_alert_email_branch_tree" model="ir.ui.view">
        <field name="name">alert.email.branch.tree</field>
        <field name="model">email.branch</field>
        <field name="arch" type="xml">
            <tree string="Email Branch">
                <field name="branch_id" />
                <field name="email_list" />
                <field name="state" />
                <field name="date_created" readonly="1" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_alert_email_branch_form" model="ir.ui.view">
        <field name="name">alert.rules.email.branch.form</field>
        <field name="model">email.branch</field>
        <field name="arch" type="xml">
            <form string="Email Branch Form">
                <sheet>

                    <group class="col-md-6 col-12">
                        <field name="branch_id" />
                        <field name="users_ids" widget="many2many_tags" />
                        <field name="state" />
                    </group>
                       
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_alert_email_branch" model="ir.actions.act_window">
        <field name="name">Alert Email Branch Action</field>
        <field name="res_model">email.branch</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

</odoo>