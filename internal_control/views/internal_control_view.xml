<odoo>
    <record id="view_internal_control_tree" model="ir.ui.view">
        <field name="name">internal.control.tree</field>
        <field name="model">res.internal_control</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_internal_control_form" model="ir.ui.view">
        <field name="name">internal.control.form</field>
        <field name="model">res.internal_control</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Define the action -->
    <record id="action_internal_control" model="ir.actions.act_window">
        <field name="name">Internal Control</field>
        <field name="res_model">res.internal_control</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Add to a menu for visibility -->
    <menuitem id="menu_internal_control_main" name="Internal Control" sequence="10"/>
    <menuitem id="menu_internal_control" name="Records" parent="menu_internal_control_main" action="action_internal_control"/>
</odoo>
