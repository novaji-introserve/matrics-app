<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <!-- Cron Job for Alert Rules Processing -->
        <record id="ir_cron_transaction_screening_sync" model="ir.cron">
            <field name="name">sync transaction screening</field>
            <field name="model_id" ref="model_res_transaction_screening_rule" />
            <field name="state">code</field>
            <field name="code">model.screen_transactions()</field>
            <field name="active" eval="True" />
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
        </record>
    </data>
</odoo>