<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_resource_uri_account" model="res.resource.uri">
            <field name="name">Customer Account</field>
            <field name="model_uri">res.partner.account</field>
        </record>

        <record id="stat_total_transactions" model="res.compliance.stat">
            <field name="name">Total Transactions</field>
            <field name="code">tm_total_transactions</field>
            <field name="resource_id" ref="compliance_management.res_resource_uri_transaction"/>
            <field name="domain">[]</field>
            <field name="scope">interbank</field>
            <field name="scope_color">#2563eb</field>
            <field name="display_order">1</field>
            <field name="display_summary">Total transactions currently available for transaction monitoring review.</field>
            <field name="sql_query">SELECT COUNT(id) FROM res_customer_transaction</field>
        </record>

        <record id="stat_transaction_volume" model="res.compliance.stat">
            <field name="name">Transaction Volume</field>
            <field name="code">tm_transaction_volume</field>
            <field name="resource_id" ref="compliance_management.res_resource_uri_transaction"/>
            <field name="domain">[]</field>
            <field name="scope">interbank</field>
            <field name="scope_color">#0f766e</field>
            <field name="display_order">2</field>
            <field name="display_summary">Aggregate transaction value across all monitored transactions.</field>
            <field name="sql_query">SELECT COALESCE(ROUND(SUM(amount)::numeric, 2), 0) FROM res_customer_transaction</field>
        </record>

        <record id="stat_high_risk_transactions" model="res.compliance.stat">
            <field name="name">High-risk Transactions</field>
            <field name="code">tm_high_risk_transactions</field>
            <field name="resource_id" ref="compliance_management.res_resource_uri_transaction"/>
            <field name="domain">[('risk_level', '=', 'high')]</field>
            <field name="scope">interbank</field>
            <field name="scope_color">#dc2626</field>
            <field name="display_order">3</field>
            <field name="display_summary">Transactions currently rated high risk and requiring immediate attention.</field>
            <field name="sql_query">SELECT COUNT(id) FROM res_customer_transaction WHERE risk_level = 'high'</field>
        </record>

        <record id="stat_high_risk_accounts" model="res.compliance.stat">
            <field name="name">High-risk Accounts</field>
            <field name="code">tm_high_risk_accounts</field>
            <field name="resource_id" ref="internal_control.res_resource_uri_account"/>
            <field name="domain">[('risk_level', '=', 'high')]</field>
            <field name="scope">interbank</field>
            <field name="scope_color">#f97316</field>
            <field name="display_order">4</field>
            <field name="display_summary">Customer accounts linked to high-risk exposure in the monitoring estate.</field>
            <field name="sql_query">SELECT COUNT(rpa.id) FROM res_partner_account rpa INNER JOIN res_partner rp ON rp.id = rpa.customer_id WHERE rp.risk_level = 'high'</field>
        </record>
    </data>
</odoo>
