    <record id="view_grade_tree" model="ir.ui.view">
        <field name="name">hr.grade.tree</field>
        <field name="model">hr.grade</field>
        <field name="arch" type="xml">
            <tree string="Grade">
                <field name="name" />
            </tree>
        </field>
    </record>
